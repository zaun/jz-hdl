{
    "comments": {
        "lineComment": "//"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"", "notIn": ["string"] }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*@(module|project|global|testbench|simulation|template|feature)\\b",
            "end": "^\\s*@(endmod|endproj|endglob|endtb|endsim|endtemplate|endfeat)\\b"
        }
    },
    "wordPattern": "@?[a-zA-Z_][a-zA-Z0-9_]*"
}
