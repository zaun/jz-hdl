{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "JZ-HDL",
    "scopeName": "source.jz-hdl",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#sized-literals" },
        { "include": "#numbers" },
        { "include": "#directives" },
        { "include": "#block-keywords" },
        { "include": "#control-keywords" },
        { "include": "#direction-keywords" },
        { "include": "#special-values" },
        { "include": "#operators" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.jz-hdl",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.jz-hdl",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.jz-hdl",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "sized-literals": {
            "patterns": [
                {
                    "name": "constant.numeric.sized.jz-hdl",
                    "match": "\\b[0-9]+'[bBdDhH][0-9a-fA-F_]+\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.integer.jz-hdl",
                    "match": "\\b[0-9][0-9_]*\\b"
                }
            ]
        },
        "directives": {
            "patterns": [
                {
                    "name": "keyword.control.directive.jz-hdl",
                    "match": "@(module|endmod|project|endproj|blackbox|new|top|import|global|endglob|feature|endfeat|else|check|template|endtemplate|apply|scratch|testbench|endtb|simulation|endsim|setup|update|clock|run|run_until|run_while|print|print_if|trace|mark|mark_if|alert|alert_if|expect_equal|expect_not_equal|expect_tristate|repeat|end)\\b"
                }
            ]
        },
        "block-keywords": {
            "patterns": [
                {
                    "name": "keyword.other.block.jz-hdl",
                    "match": "\\b(CONST|PORT|WIRE|REGISTER|LATCH|MEM|ASYNCHRONOUS|SYNCHRONOUS|MUX|CDC|CONFIG|CLOCKS|IN_PINS|OUT_PINS|INOUT_PINS|MAP|CLOCK_GEN|TEST|TAP|MONITOR)\\b"
                }
            ]
        },
        "control-keywords": {
            "patterns": [
                {
                    "name": "keyword.control.jz-hdl",
                    "match": "\\b(IF|ELIF|ELSE|SELECT|CASE|DEFAULT|OVERRIDE)\\b"
                }
            ]
        },
        "direction-keywords": {
            "patterns": [
                {
                    "name": "storage.type.direction.jz-hdl",
                    "match": "\\b(IN|OUT|INOUT)\\b"
                }
            ]
        },
        "special-values": {
            "patterns": [
                {
                    "name": "constant.language.jz-hdl",
                    "match": "\\b(GND|VCC|DISCONNECT)\\b"
                },
                {
                    "name": "variable.language.no-connect.jz-hdl",
                    "match": "\\b_\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.jz-hdl",
                    "match": "(=>z|=>s|=>|=z|=s|<=z|<=s|<=|=)"
                },
                {
                    "name": "keyword.operator.comparison.jz-hdl",
                    "match": "(==|!=|>=|>>>|>>|<<)"
                },
                {
                    "name": "keyword.operator.logical.jz-hdl",
                    "match": "(&&|\\|\\||!)"
                },
                {
                    "name": "keyword.operator.bitwise.jz-hdl",
                    "match": "(&|\\||\\^|~)"
                },
                {
                    "name": "keyword.operator.arithmetic.jz-hdl",
                    "match": "(\\+|-|\\*|/|%)"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.jz-hdl",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}
