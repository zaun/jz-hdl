  "clock_gen": [
    {
      "type": "pll",
      "source": "DS180 v2.6.1, Section: Clock Management; DS181 v1.27.1, Table: MMCM Switching Characteristics; UG472 v1.13, Chapter 3: Clock Management Tile",
      "description": "Mixed-Mode Clock Manager (MMCME2_BASE). Primary clock synthesizer with 7 outputs (CLKOUT0-CLKOUT6), feedback output (CLKFBOUT), and fractional divide on CLKOUT0.",

      "count": 5,
      "chaining": true,

      "map": {
        "verilog-2005": [
          "MMCME2_BASE #(\n",
          "    .BANDWIDTH(\"OPTIMIZED\"),\n",
          "    .CLKFBOUT_MULT_F(%%CLKFBOUT_MULT_F%%),\n",
          "    .CLKFBOUT_PHASE(0.0),\n",
          "    .CLKIN1_PERIOD(%%REF_CLK_period_ns%%),\n",
          "    .CLKOUT0_DIVIDE_F(%%CLKOUT0_DIVIDE_F%%),\n",
          "    .CLKOUT0_PHASE(0.0),\n",
          "    .CLKOUT0_DUTY_CYCLE(0.5),\n",
          "    .CLKOUT1_DIVIDE(%%CLKOUT1_DIVIDE%%),\n",
          "    .CLKOUT1_PHASE(0.0),\n",
          "    .CLKOUT1_DUTY_CYCLE(0.5),\n",
          "    .CLKOUT2_DIVIDE(%%CLKOUT2_DIVIDE%%),\n",
          "    .CLKOUT2_PHASE(0.0),\n",
          "    .CLKOUT2_DUTY_CYCLE(0.5),\n",
          "    .CLKOUT3_DIVIDE(%%CLKOUT3_DIVIDE%%),\n",
          "    .CLKOUT3_PHASE(0.0),\n",
          "    .CLKOUT3_DUTY_CYCLE(0.5),\n",
          "    .CLKOUT4_DIVIDE(%%CLKOUT4_DIVIDE%%),\n",
          "    .CLKOUT4_PHASE(0.0),\n",
          "    .CLKOUT4_DUTY_CYCLE(0.5),\n",
          "    .CLKOUT5_DIVIDE(%%CLKOUT5_DIVIDE%%),\n",
          "    .CLKOUT5_PHASE(0.0),\n",
          "    .CLKOUT5_DUTY_CYCLE(0.5),\n",
          "    .CLKOUT6_DIVIDE(%%CLKOUT6_DIVIDE%%),\n",
          "    .CLKOUT6_PHASE(0.0),\n",
          "    .CLKOUT6_DUTY_CYCLE(0.5),\n",
          "    .DIVCLK_DIVIDE(%%DIVCLK_DIVIDE%%),\n",
          "    .STARTUP_WAIT(\"FALSE\")\n",
          ") u_mmcm_%%instance_idx%% (\n",
          "    .CLKIN1(%%REF_CLK%%),\n",
          "    .CLKFBIN(%%CLKFBOUT%%),\n",
          "    .CLKFBOUT(%%CLKFBOUT%%),\n",
          "    .CLKOUT0(%%BASE%%),\n",
          "    .CLKOUT1(%%CLKOUT1%%),\n",
          "    .CLKOUT2(%%CLKOUT2%%),\n",
          "    .CLKOUT3(%%CLKOUT3%%),\n",
          "    .CLKOUT4(%%CLKOUT4%%),\n",
          "    .CLKOUT5(%%CLKOUT5%%),\n",
          "    .CLKOUT6(%%CLKOUT6%%),\n",
          "    .LOCKED(%%LOCK%%),\n",
          "    .RST(1'b0),\n",
          "    .PWRDWN(1'b0)\n",
          ");\n"
        ],
        "rtlil": [
          "cell \\MMCME2_BASE $auto$%%instance_idx%%\n",
          "  parameter \\BANDWIDTH \"OPTIMIZED\"\n",
          "  parameter \\CLKFBOUT_MULT_F %%CLKFBOUT_MULT_F%%\n",
          "  parameter \\CLKFBOUT_PHASE 0.0\n",
          "  parameter \\CLKIN1_PERIOD %%REF_CLK_period_ns%%\n",
          "  parameter \\CLKOUT0_DIVIDE_F %%CLKOUT0_DIVIDE_F%%\n",
          "  parameter \\CLKOUT0_PHASE 0.0\n",
          "  parameter \\CLKOUT0_DUTY_CYCLE 0.5\n",
          "  parameter \\CLKOUT1_DIVIDE %%CLKOUT1_DIVIDE%%\n",
          "  parameter \\CLKOUT1_PHASE 0.0\n",
          "  parameter \\CLKOUT1_DUTY_CYCLE 0.5\n",
          "  parameter \\CLKOUT2_DIVIDE %%CLKOUT2_DIVIDE%%\n",
          "  parameter \\CLKOUT2_PHASE 0.0\n",
          "  parameter \\CLKOUT2_DUTY_CYCLE 0.5\n",
          "  parameter \\CLKOUT3_DIVIDE %%CLKOUT3_DIVIDE%%\n",
          "  parameter \\CLKOUT3_PHASE 0.0\n",
          "  parameter \\CLKOUT3_DUTY_CYCLE 0.5\n",
          "  parameter \\CLKOUT4_DIVIDE %%CLKOUT4_DIVIDE%%\n",
          "  parameter \\CLKOUT4_PHASE 0.0\n",
          "  parameter \\CLKOUT4_DUTY_CYCLE 0.5\n",
          "  parameter \\CLKOUT5_DIVIDE %%CLKOUT5_DIVIDE%%\n",
          "  parameter \\CLKOUT5_PHASE 0.0\n",
          "  parameter \\CLKOUT5_DUTY_CYCLE 0.5\n",
          "  parameter \\CLKOUT6_DIVIDE %%CLKOUT6_DIVIDE%%\n",
          "  parameter \\CLKOUT6_PHASE 0.0\n",
          "  parameter \\CLKOUT6_DUTY_CYCLE 0.5\n",
          "  parameter \\DIVCLK_DIVIDE %%DIVCLK_DIVIDE%%\n",
          "  parameter \\STARTUP_WAIT \"FALSE\"\n",
          "  connect \\CLKIN1 \\%%REF_CLK%%\n",
          "  connect \\CLKFBIN \\%%CLKFBOUT%%\n",
          "  connect \\CLKFBOUT \\%%CLKFBOUT%%\n",
          "  connect \\CLKOUT0 \\%%BASE%%\n",
          "  connect \\CLKOUT1 \\%%CLKOUT1%%\n",
          "  connect \\CLKOUT2 \\%%CLKOUT2%%\n",
          "  connect \\CLKOUT3 \\%%CLKOUT3%%\n",
          "  connect \\CLKOUT4 \\%%CLKOUT4%%\n",
          "  connect \\CLKOUT5 \\%%CLKOUT5%%\n",
          "  connect \\CLKOUT6 \\%%CLKOUT6%%\n",
          "  connect \\LOCKED \\%%LOCK%%\n",
          "  connect \\RST 1'0\n",
          "  connect \\PWRDWN 1'0\n",
          "end\n"
