            "    .OQ(%%output%%),\n",
            "    .SHIFTOUT1(),\n",
            "    .SHIFTOUT2(),\n",
            "    .TBYTEOUT(),\n",
            "    .TFB(),\n",
            "    .TQ(),\n",
            "    .CLK(%%fclk%%),\n",
            "    .CLKDIV(%%pclk%%),\n",
            "    .D1(%%D0%%),\n",
            "    .D2(%%D1%%),\n",
            "    .D3(%%D2%%),\n",
            "    .D4(%%D3%%),\n",
            "    .D5(%%D4%%),\n",
            "    .D6(%%D5%%),\n",
            "    .D7(%%D6%%),\n",
            "    .D8(%%D7%%),\n",
            "    .OCE(1'b1),\n",
            "    .RST(%%reset%%),\n",
            "    .SHIFTIN1(1'b0),\n",
            "    .SHIFTIN2(1'b0),\n",
            "    .T1(1'b0),\n",
            "    .T2(1'b0),\n",
            "    .T3(1'b0),\n",
            "    .T4(1'b0),\n",
            "    .TBYTEIN(1'b0),\n",
            "    .TCE(1'b0)\n",
            ");\n"
          ],
          "rtlil": [
            "cell \\OSERDESE2 $auto$%%instance%%\n",
            "  parameter \\DATA_RATE_OQ \"DDR\"\n",
            "  parameter \\DATA_RATE_TQ \"SDR\"\n",
            "  parameter \\DATA_WIDTH 8\n",
            "  parameter \\SERDES_MODE \"MASTER\"\n",
            "  parameter \\TRISTATE_WIDTH 1\n",
            "  connect \\OQ \\%%output%%\n",
            "  connect \\CLK \\%%fclk%%\n",
            "  connect \\CLKDIV \\%%pclk%%\n",
            "  connect \\D1 \\%%D0%%\n",
            "  connect \\D2 \\%%D1%%\n",
            "  connect \\D3 \\%%D2%%\n",
            "  connect \\D4 \\%%D3%%\n",
            "  connect \\D5 \\%%D4%%\n",
            "  connect \\D6 \\%%D5%%\n",
            "  connect \\D7 \\%%D6%%\n",
            "  connect \\D8 \\%%D7%%\n",
            "  connect \\OCE 1'1\n",
            "  connect \\RST \\%%reset%%\n",
            "  connect \\TCE 1'0\n",
            "end\n"
          ]
        }
      }
    },
    "input": {
