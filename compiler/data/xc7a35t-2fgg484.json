          "expr": "(1000.0 / REF_CLK_period_ns) * CLKFBOUT_MULT / DIVCLK_DIVIDE",
          "min": 800,
          "max": 1600
        }
      },

      "outputs": {
        "BASE": {
          "description": "Primary PLL output (CLKOUT0)",
          "port": "CLKOUT0",
          "frequency_mhz": {
            "description": "Primary output frequency: FVCO / CLKOUT0_DIVIDE",
            "expr": "FVCO / CLKOUT0_DIVIDE"
          }
        },

        "CLKOUT1": {
          "description": "Secondary PLL output",
          "port": "CLKOUT1",
          "frequency_mhz": {
            "description": "Secondary output frequency: FVCO / CLKOUT1_DIVIDE",
            "expr": "FVCO / CLKOUT1_DIVIDE"
          }
        },

        "CLKOUT2": {
          "description": "Tertiary PLL output",
          "port": "CLKOUT2",
          "frequency_mhz": {
            "description": "Tertiary output frequency: FVCO / CLKOUT2_DIVIDE",
            "expr": "FVCO / CLKOUT2_DIVIDE"
          }
        },

        "CLKOUT3": {
          "description": "Quaternary PLL output",
          "port": "CLKOUT3",
          "frequency_mhz": {
            "description": "Quaternary output frequency: FVCO / CLKOUT3_DIVIDE",
            "expr": "FVCO / CLKOUT3_DIVIDE"
          }
        },

        "CLKOUT4": {
          "description": "PLL output 4",
          "port": "CLKOUT4",
          "frequency_mhz": {
            "description": "Output 4 frequency: FVCO / CLKOUT4_DIVIDE",
            "expr": "FVCO / CLKOUT4_DIVIDE"
          }
        },

        "CLKOUT5": {
          "description": "PLL output 5",
          "port": "CLKOUT5",
          "frequency_mhz": {
            "description": "Output 5 frequency: FVCO / CLKOUT5_DIVIDE",
            "expr": "FVCO / CLKOUT5_DIVIDE"
          }
        },

        "CLKFBOUT": {
          "description": "Feedback output, must be connected to CLKFBIN for internal feedback",
          "port": "CLKFBOUT"
        },

        "LOCK": {
          "description": "PLL lock indicator, high when PLL is locked",
          "port": "LOCKED"
        }
      },

      "constraints": [
        {
          "description": "VCO frequency must be within 800-1600 MHz range for -2 speed grade.",
          "rule": "FVCO range check"
        },
        {
          "description": "Output frequency must not exceed 800 MHz.",
          "rule": "output frequency range check"
        }
      ]
    }
