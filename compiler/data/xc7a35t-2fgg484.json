  "differential": {
    "source": "DS181 v1.27.1, Table 9 (Differential SelectIO), Table 11 (LVDS_25 DC Specs); UG471 v1.10, Section: Differential I/O Standards",
    "type": "true",
    "io_type": "LVDS_25",
    "output": {
      "buffer": {
        "description": "LVDS_25 differential output buffer (OBUFDS)",
        "map": {
          "verilog-2005": [
            "OBUFDS u_%%instance%% (\n",
            "    .I(%%input%%),\n",
            "    .O(%%pin_p%%),\n",
            "    .OB(%%pin_n%%)\n",
            ");\n"
          ],
          "rtlil": [
            "cell \\OBUFDS $auto$%%instance%%\n",
            "  connect \\I \\%%input%%\n",
            "  connect \\O \\%%pin_p%%\n",
            "  connect \\OB \\%%pin_n%%\n",
            "end\n"
          ]
        }
      },
      "serializer": {
        "description": "8:1 output serializer (OSERDESE2) for LVDS/TMDS output",
        "ratio": 8,
        "map": {
          "verilog-2005": [
            "OSERDESE2 #(\n",
            "    .DATA_RATE_OQ(\"DDR\"),\n",
