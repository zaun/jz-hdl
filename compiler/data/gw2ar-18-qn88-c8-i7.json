            100,
            102,
            104,
            106,
            108,
            110,
            112,
            114,
            116,
            118,
            120,
            122,
            124,
            126,
            128
          ]
        }
      },
      "outputs": {
        "BASE": {
          "port": "OSCOUT",
          "is_clock": true,
          "frequency_mhz": {
            "expr": "250.0 / DIV"
          }
        }
      }
    },
    {
      "type": "pll",
      "source": "DS226-2.6E, Section 2.7 (Clocks); UG286 Gowin Clock User Guide (PLL timing parameters)",
      "description": "Phase-Locked Loop block with one reference input, a single VCO, and four physically distinct clock outputs.",
      "count": 2,
      "chaining": false,
      "map": {
        "verilog-2005": [
          "rPLL #(\n",
          "    .DEVICE(\"GW2AR-18\"),         // Specify your device\n",
          "    .FCLKIN(%%REF_CLK_mhz%%),       // Input frequency in MHz\n",
          "    .IDIV_SEL(%%IDIV%%),           // IDIV: Input divider\n",
          "    .FBDIV_SEL(%%FBDIV%%),         // FBDIV: Feedback divider\n",
          "    .ODIV_SEL(%%ODIV%%),           // ODIV: Output divider\n",
          "    .PSDA_SEL(\"%%PSDA_SEL%%\"),\n",
          "    .DUTYDA_SEL(\"1000\"),\n",
          "    .DYN_IDIV_SEL(\"FALSE\"),\n",
          "    .DYN_FBDIV_SEL(\"FALSE\"),\n",
          "    .DYN_ODIV_SEL(\"FALSE\"),\n",
          "    .DYN_DA_EN(\"FALSE\"),\n",
          "    .DYN_SDIV_SEL(%%CLKOUTD_DIV%%),\n",
          "    .CLKOUT_FT_DIR(1'b1),\n",
          "    .CLKOUTP_FT_DIR(1'b1),\n",
          "    .CLKOUT_DLY_STEP(0),\n",
          "    .CLKOUTP_DLY_STEP(0),\n",
          "    .CLKFB_SEL(\"internal\"),\n",
          "    .CLKOUT_BYPASS(\"FALSE\"),\n",
          "    .CLKOUTP_BYPASS(\"FALSE\"),\n",
          "    .CLKOUTD_BYPASS(\"FALSE\"),\n",
          "    .CLKOUTD_SRC(\"CLKOUT\"),\n",
          "    .CLKOUTD3_SRC(\"CLKOUT\")\n",
          ") u_pll_%%instance_idx%% (\n",
          "    .CLKOUT(%%BASE%%),   // Primary output\n",
          "    .LOCK(%%LOCK%%),     // High when stable\n",
          "    .CLKOUTP(%%PHASE%%), // Phase shifted output\n",
          "    .CLKOUTD(%%DIV%%),   // Divided output\n",
          "    .CLKOUTD3(%%DIV3%%), // Divided by 3 output\n",
          "    .RESET(1'b0),        // Reset signal\n",
          "    .RESET_P(1'b0),      // PLL power down\n",
          "    .CLKIN(%%REF_CLK%%),  // Reference clock input\n",
          "    .CLKFB(1'b0)         // External feedback\n",
          ");\n"
        ],
        "rtlil": [
          "cell \\rPLL $auto$%%instance_idx%%\n",
          "  parameter \\DEVICE \"GW2AR-18\"\n",
          "  parameter \\FCLKIN %%REF_CLK_mhz%%\n",
          "  parameter \\IDIV_SEL %%IDIV%%\n",
          "  parameter \\FBDIV_SEL %%FBDIV%%\n",
          "  parameter \\ODIV_SEL %%ODIV%%\n",
          "  parameter \\PSDA_SEL \"%%PSDA_SEL%%\"\n",
          "  parameter \\DUTYDA_SEL \"1000\"\n",
          "  parameter \\DYN_IDIV_SEL \"FALSE\"\n",
          "  parameter \\DYN_FBDIV_SEL \"FALSE\"\n",
          "  parameter \\DYN_ODIV_SEL \"FALSE\"\n",
          "  parameter \\DYN_DA_EN \"FALSE\"\n",
          "  parameter \\DYN_SDIV_SEL %%CLKOUTD_DIV%%\n",
          "  parameter \\CLKOUT_FT_DIR 1\n",
          "  parameter \\CLKOUTP_FT_DIR 1\n",
          "  parameter \\CLKOUT_DLY_STEP 0\n",
          "  parameter \\CLKOUTP_DLY_STEP 0\n",
          "  parameter \\CLKFB_SEL \"internal\"\n",
          "  parameter \\CLKOUT_BYPASS \"FALSE\"\n",
          "  parameter \\CLKOUTP_BYPASS \"FALSE\"\n",
          "  parameter \\CLKOUTD_BYPASS \"FALSE\"\n",
          "  parameter \\CLKOUTD_SRC \"CLKOUT\"\n",
          "  parameter \\CLKOUTD3_SRC \"CLKOUT\"\n",
          "  connect \\CLKIN \\%%REF_CLK%%\n",
          "  connect \\CLKOUT \\%%BASE%%\n",
          "  connect \\LOCK \\%%LOCK%%\n",
          "  connect \\CLKOUTP \\%%PHASE%%\n",
          "  connect \\CLKOUTD \\%%DIV%%\n",
          "  connect \\CLKOUTD3 \\%%DIV3%%\n",
          "  connect \\RESET 1'0\n",
          "  connect \\RESET_P 1'0\n",
          "  connect \\CLKFB 1'0\n",
          "end\n"
        ]
      },
      "inputs": {
        "REF_CLK": {
          "description": "Reference clock input to the PLL",
          "required": true,
          "width": 1,
          "requires_period": true,
          "min_mhz": 3,
          "max_mhz": 500
        }
      },
      "parameters": {
        "IDIV": {
          "description": "Input clock divider select (actual divider = IDIV + 1)",
          "type": "int",
          "default": 0,
          "min": 0,
          "max": 63
        },
        "FBDIV": {
          "description": "Feedback divider select (actual multiplier = FBDIV + 1)",
          "type": "int",
          "default": 0,
          "min": 0,
          "max": 63
        },
        "ODIV": {
          "description": "Output divider select (used directly)",
          "type": "int",
          "default": 8,
          "valid": [
            2,
            4,
            8,
            16,
            32,
            48,
            64,
            80,
            96,
            112,
            128
          ]
        },
        "PHASESEL": {
          "description": "Phase tap (0-315\u00b0 in 45\u00b0 steps)",
          "type": "int",
          "default": 0,
          "min": 0,
          "max": 7
        },
        "CLKOUTD_DIV": {
          "description": "Post-divider for DIV output",
          "type": "int",
          "default": 2,
          "min": 2,
          "max": 128
        }
      },
      "derived": {
        "FVCO": {
          "description": "Internal Voltage-Controlled Oscillator Frequency",
          "expr": "(1000.0 / REF_CLK_period_ns) * (FBDIV + 1) * ODIV / (IDIV + 1)",
          "min": 500,
          "max": 1250
        },
        "PSDA_SEL": {
          "description": "String representation of the binary number for PHASESEL ex: \"0001\", \"1100\".",
          "expr": "toString(PHASESEL * 2, BIN, 4)"
        }
      },
      "outputs": {
        "BASE": {
          "description": "Primary output",
          "port": "CLKOUT",
          "is_clock": true,
          "frequency_mhz": {
            "description": "Frequency of the base output clock derived directly from the FVCO.",
            "expr": "FVCO / ODIV"
          }
        },
        "PHASE": {
          "description": "Primary output, Phase shifted. Requires PHASESEL",
          "port": "CLKOUTP",
          "is_clock": true,
          "frequency_mhz": {
            "description": "Frequency of the phased output clock. Identical to the base output frequency.",
            "expr": "FVCO / ODIV"
          },
          "phase_deg": {
            "description": "Phase offset applied to the phased output, expressed in degrees relative to the base output.",
            "expr": "PHASESEL * 45"
          }
        },
        "DIV": {
          "description": "Divided PLL output, Requires CLKOUTD_DIV",
          "port": "CLKOUTD",
          "is_clock": true,
          "frequency_mhz": {
            "description": "Frequency of the divided output clock after applying the post-divider.",
            "expr": "(FVCO / ODIV) / CLKOUTD_DIV"
          }
        },
        "DIV3": {
          "description": "Fixed divide-by-3 PLL output",
          "port": "CLKOUT3",
          "is_clock": true,
          "frequency_mhz": {
            "description": "Frequency of the fixed divide-by-3 output derived from the base output.",
            "expr": "(FVCO / ODIV) / 3"
          }
        },
        "LOCK": {
          "description": "PLL lock indicator, high when PLL is locked",
          "port": "LOCK",
          "is_clock": false
        }
      },
      "constraints": [
        {
          "description": "The phased output may only be used if a valid PHASESEL value is provided.",
          "rule": "PHASE output requires PHASESEL"
        },
        {
          "description": "The divided output may only be used if a valid CLKOUTD_DIV value is provided.",
          "rule": "DIV output requires CLKOUTD_DIV"
        }
      ]
    },
    {
      "type": "clkdiv",
      "source": "DS226-2.6E, Section 2.7.3 (High-speed Clocks); UG286 Gowin Clock User Guide",
      "mode": "local",
      "description": "Local clock divider (CLKDIV) for IO logic. Divides an input clock by a fixed ratio.",
      "count": 8,
      "map": {
        "verilog-2005": [
          "CLKDIV #(\n",
          "    .DIV_MODE(\"%%DIV_MODE%%\"),\n",
          "    .GSREN(\"false\")\n",
          ") u_clkdiv_%%instance_idx%% (\n",
          "    .HCLKIN(%%REF_CLK%%),\n",
          "    .RESETN(1'b1),\n",
          "    .CALIB(1'b0),\n",
          "    .CLKOUT(%%BASE%%)\n",
          ");\n"
        ],
        "rtlil": [
          "cell \\CLKDIV $auto$%%instance_idx%%\n",
          "  parameter \\DIV_MODE \"%%DIV_MODE%%\"\n",
          "  parameter \\GSREN \"false\"\n",
          "  connect \\HCLKIN \\%%REF_CLK%%\n",
          "  connect \\RESETN 1'1\n",
          "  connect \\CALIB 1'0\n",
          "  connect \\CLKOUT \\%%BASE%%\n",
          "end\n"
        ]
      },
      "inputs": {
        "REF_CLK": {
          "description": "Reference clock input to the clock divider",
          "required": true,
          "width": 1,
          "requires_period": true
        }
      },
      "parameters": {
        "DIV_MODE": {
          "description": "Clock division ratio",
          "type": "string",
          "default": "2",
          "valid": [
            "2",
            "3.5",
            "4",
            "5"
          ]
        }
      },
      "outputs": {
        "BASE": {
          "description": "Divided clock output",
          "port": "CLKOUT",
          "is_clock": true,
          "frequency_mhz": {
            "description": "Frequency of the divided output clock.",
            "expr": "(1000.0 / REF_CLK_period_ns) / DIV_MODE"
          }
        }
      }
    },
    {
      "type": "clkdiv2",
      "source": "DS226-2.6E, Section 2.7 (Clocks); UG286 Gowin Clock User Guide",
      "mode": "local",
      "description": "HCLK divide-by-2 clock divider (CLKDIV2). Simple /2 divider with no configurable parameters.",
      "count": 16,
      "map": {
        "verilog-2005": [
          "CLKDIV2 u_clkdiv2_%%instance_idx%% (\n",
          "    .HCLKIN(%%REF_CLK%%),\n",
          "    .RESETN(1'b1),\n",
          "    .CLKOUT(%%BASE%%)\n",
          ");\n"
        ],
        "rtlil": [
          "cell \\CLKDIV2 $auto$%%instance_idx%%\n",
          "  connect \\HCLKIN \\%%REF_CLK%%\n",
          "  connect \\RESETN 1'1\n",
          "  connect \\CLKOUT \\%%BASE%%\n",
          "end\n"
        ]
      },
      "inputs": {
        "REF_CLK": {
          "description": "Reference clock input to the clock divider",
          "required": true,
          "width": 1,
          "requires_period": true
        }
      },
      "outputs": {
        "BASE": {
          "description": "Divided-by-2 clock output",
          "port": "CLKOUT",
          "is_clock": true,
          "frequency_mhz": {
            "description": "Frequency of the fixed divide-by-2 output clock.",
            "expr": "(1000.0 / REF_CLK_period_ns) / 2"
          }
        }
      }
    },
    {
      "type": "buf",
      "source": "DS226-2.6E, Section 2.7 (Clocks); UG286 Gowin Clock User Guide, Section 2.4 (DQCE)",
      "mode": "global",
      "description": "Global clock buffer (DQCE). Promotes a clock onto the global GCLK network with dynamic clock enable.",
      "count": 24,
      "map": {
        "verilog-2005": [
          "DQCE u_dqce_%%instance_idx%% (\n",
          "    .CLKIN(%%REF_CLK%%),\n",
          "    .CE(%%CE%%),\n",
          "    .CLKOUT(%%BASE%%)\n",
          ");\n"
        ],
        "rtlil": [
          "cell \\DQCE $auto$%%instance_idx%%\n",
          "  connect \\CLKIN \\%%REF_CLK%%\n",
          "  connect \\CE 1'1\n",
          "  connect \\CLKOUT \\%%BASE%%\n",
          "end\n"
        ]
      },
      "inputs": {
        "REF_CLK": {
          "description": "Reference clock input to the buffer",
          "required": true,
          "width": 1,
          "requires_period": true
        },
        "CE": {
          "description": "Clock enable (active-high). When deasserted, output is held low.",
          "required": false,
          "default": "1'b1",
          "width": 1
        }
      },
      "outputs": {
        "BASE": {
          "description": "Buffered clock output on global network",
          "port": "CLKOUT",
          "is_clock": true,
          "frequency_mhz": {
            "description": "Same frequency as input (buffer, no division).",
            "expr": "(1000.0 / REF_CLK_period_ns)"
          }
        }
      }
    },
    {
      "type": "buf2",
      "source": "DS226-2.6E, Section 2.7.3 (High-speed Clocks); UG286 Gowin Clock User Guide, Section 4.1 (DHCEN)",
      "mode": "local",
      "description": "HCLK clock buffer (DHCEN). Promotes a clock onto the regional HCLK network with dynamic clock enable (active-low CE).",
      "count": 8,
      "map": {
        "verilog-2005": [
          "DHCEN u_dhcen_%%instance_idx%% (\n",
          "    .CLKIN(%%REF_CLK%%),\n",
          "    .CE(%%CE%%),\n",
          "    .CLKOUT(%%BASE%%)\n",
          ");\n"
        ],
        "rtlil": [
          "cell \\DHCEN $auto$%%instance_idx%%\n",
          "  connect \\CLKIN \\%%REF_CLK%%\n",
          "  connect \\CE 1'0\n",
          "  connect \\CLKOUT \\%%BASE%%\n",
          "end\n"
        ]
      },
      "inputs": {
        "REF_CLK": {
          "description": "Reference clock input to the buffer",
          "required": true,
          "width": 1,
          "requires_period": true
        },
        "CE": {
          "description": "Clock enable (active-low). When asserted low, output is enabled.",
          "required": false,
          "default": "1'b0",
          "width": 1
        }
      },
      "outputs": {
        "BASE": {
          "description": "Buffered clock output on HCLK network",
          "port": "CLKOUT",
          "is_clock": true,
          "frequency_mhz": {
            "description": "Same frequency as input (buffer, no division).",
            "expr": "(1000.0 / REF_CLK_period_ns)"
          }
        }
      }
    }
