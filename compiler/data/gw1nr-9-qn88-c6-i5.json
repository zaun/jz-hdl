  "latches": {
    "source": "DS117-3.2.3E, Table 1-1 p.3 (GW1NR-2: FF+Latch=2304, FF=2016); SUG283-3.5E (Placement rule of FF, LATCH)",
    "FAB": {
      "description": "Configurable Function Unit (General Logic)",
      "D": true,
      "SR": false,
      "note": "CFU REG elements can be configured as D latches. GW1NR-2 Table 1-1 explicitly lists 288 latches (2304 total - 2016 FF). Same CFU architecture (LUT+REG/SREG) across GW1NR family. See UG288 Gowin CFU User Guide for details."
    },
    "IOB": {
      "description": "I/O Blocks (Input/Output Pins)",
      "D": true,
      "SR": false,
      "modes": ["Transparent", "Gated"],
      "note": "Registers in I/O logic can be programmed as latches."
    }
  },

