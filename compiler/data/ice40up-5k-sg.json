        },
        "DIVQ": {
          "description": "Output divider (divides VCO by 2^DIVQ)",
          "type": "int",
          "default": 0,
          "min": 0,
          "max": 7
        },
        "FILTER_RANGE": {
          "description": "PLL filter range for loop stability",
          "type": "int",
          "default": 1,
          "min": 0,
          "max": 7
        },
        "PLLOUT_SELECT_A": {
          "description": "Port A output mux: GENCLK (full VCO/2^DIVQ), GENCLK_HALF (half), SHIFTREG_0deg, or SHIFTREG_90deg",
          "type": "string",
          "default": "GENCLK",
          "valid": [
            "GENCLK",
            "GENCLK_HALF",
            "SHIFTREG_0deg",
            "SHIFTREG_90deg"
          ]
        },
        "PLLOUT_SELECT_B": {
          "description": "Port B output mux: GENCLK (full VCO/2^DIVQ), GENCLK_HALF (half), SHIFTREG_0deg, or SHIFTREG_90deg",
          "type": "string",
          "default": "GENCLK",
          "valid": [
            "GENCLK",
            "GENCLK_HALF",
            "SHIFTREG_0deg",
            "SHIFTREG_90deg"
          ]
        }
      },
      "derived": {
        "FVCO": {
          "description": "Internal VCO frequency",
          "expr": "(1000.0 / REF_CLK_period_ns) * (DIVF + 1) / (DIVR + 1)",
          "min": 533,
          "max": 1066
        }
      },
      "outputs": {
        "BASE_A": {
          "description": "Port A PLL output (PLLOUTGLOBALA). Frequency depends on PLLOUT_SELECT_A: GENCLK = FVCO/2^DIVQ, GENCLK_HALF = FVCO/2^(DIVQ+1).",
          "port": "PLLOUTGLOBALA",
          "is_clock": true,
          "frequency_mhz": {
            "description": "Port A output frequency assuming PLLOUT_SELECT_A=GENCLK: F_VCO / 2^DIVQ",
            "expr": "FVCO / (1 << DIVQ)"
          }
        },
        "BASE_B": {
          "description": "Port B PLL output (PLLOUTGLOBALB). Frequency depends on PLLOUT_SELECT_B: GENCLK = FVCO/2^DIVQ, GENCLK_HALF = FVCO/2^(DIVQ+1).",
          "port": "PLLOUTGLOBALB",
          "is_clock": true,
          "frequency_mhz": {
            "description": "Port B output frequency assuming PLLOUT_SELECT_B=GENCLK_HALF: F_VCO / 2^(DIVQ+1)",
            "expr": "FVCO / (2 * (1 << DIVQ))"
          }
        },
        "LOCK": {
          "description": "PLL lock indicator, high when PLL is locked",
          "port": "LOCK",
          "is_clock": false
        }
      },
      "constraints": [
        {
          "description": "VCO frequency must be within 533-1066 MHz range.",
          "rule": "FVCO range check"
        }
      ]
    },
    {
      "type": "buf",
      "source": "TN1260 iCE40 Technology Library; DS-ICE40-UltraPlus, Section 4.6 (Global Buffers)",
      "mode": "global",
      "description": "Global clock buffer (SB_GB). Promotes an internal signal onto the global clock network.",
      "count": 8,
      "map": {
        "verilog-2005": [
          "SB_GB u_gb_%%instance_idx%% (\n",
          "    .USER_SIGNAL_TO_GLOBAL_BUFFER(%%REF_CLK%%),\n",
          "    .GLOBAL_BUFFER_OUTPUT(%%BASE%%)\n",
          ");\n"
        ],
        "rtlil": [
          "cell \\SB_GB $auto$%%instance_idx%%\n",
          "  connect \\USER_SIGNAL_TO_GLOBAL_BUFFER \\%%REF_CLK%%\n",
          "  connect \\GLOBAL_BUFFER_OUTPUT \\%%BASE%%\n",
          "end\n"
        ]
      },
      "inputs": {
        "REF_CLK": {
          "description": "Reference clock input to the buffer",
          "required": true,
          "width": 1,
          "requires_period": true
        }
      },
      "outputs": {
        "BASE": {
          "description": "Buffered clock output on global network",
          "port": "GLOBAL_BUFFER_OUTPUT",
          "is_clock": true,
          "frequency_mhz": {
            "description": "Same frequency as input (buffer, no division).",
            "expr": "(1000.0 / REF_CLK_period_ns)"
          }
        }
      }
    }
  ],
  "differential": {
    "source": "iCE40 Technology Library, SB_IO; DS-ICE40-UltraPlus Section 4 (I/O)",
    "type": "pseudo",
    "io_type": "SB_LVCMOS",
    "output": {
      "serializer": [
        {
          "description": "2:1 DDR output using dual SB_IO (pseudo-differential LVDS)",
          "ratio": 2,
          "required_clocks": [
            "fclk"
          ],
          "map": {
            "verilog-2005": [
              "SB_IO #(\n",
              "    .PIN_TYPE(6'b010000)\n",
              ") u_%%instance%%_p (\n",
              "    .PACKAGE_PIN(%%pin_p%%),\n",
              "    .OUTPUT_CLK(%%fclk%%),\n",
              "    .D_OUT_0(%%D0%%),\n",
              "    .D_OUT_1(%%D1%%)\n",
              ");\n",
              "SB_IO #(\n",
              "    .PIN_TYPE(6'b010000)\n",
              ") u_%%instance%%_n (\n",
              "    .PACKAGE_PIN(%%pin_n%%),\n",
              "    .OUTPUT_CLK(%%fclk%%),\n",
              "    .D_OUT_0(~%%D0%%),\n",
              "    .D_OUT_1(~%%D1%%)\n",
              ");\n"
            ],
            "rtlil": [
              "cell \\SB_IO $auto$%%instance%%_p\n",
              "  parameter \\PIN_TYPE 6'010000\n",
              "  connect \\PACKAGE_PIN \\%%pin_p%%\n",
              "  connect \\OUTPUT_CLK \\%%fclk%%\n",
              "  connect \\D_OUT_0 \\%%D0%%\n",
              "  connect \\D_OUT_1 \\%%D1%%\n",
              "end\n",
              "wire width 1 \\jz_inv_d0_%%instance%%\n",
              "wire width 1 \\jz_inv_d1_%%instance%%\n",
              "cell $not $auto$inv_d0_%%instance%%\n",
              "  parameter \\A_SIGNED 0\n",
              "  parameter \\A_WIDTH 1\n",
              "  parameter \\Y_WIDTH 1\n",
              "  connect \\A \\%%D0%%\n",
              "  connect \\Y \\jz_inv_d0_%%instance%%\n",
              "end\n",
              "cell $not $auto$inv_d1_%%instance%%\n",
              "  parameter \\A_SIGNED 0\n",
              "  parameter \\A_WIDTH 1\n",
              "  parameter \\Y_WIDTH 1\n",
              "  connect \\A \\%%D1%%\n",
              "  connect \\Y \\jz_inv_d1_%%instance%%\n",
              "end\n",
              "cell \\SB_IO $auto$%%instance%%_n\n",
              "  parameter \\PIN_TYPE 6'010000\n",
              "  connect \\PACKAGE_PIN \\%%pin_n%%\n",
              "  connect \\OUTPUT_CLK \\%%fclk%%\n",
              "  connect \\D_OUT_0 \\jz_inv_d0_%%instance%%\n",
              "  connect \\D_OUT_1 \\jz_inv_d1_%%instance%%\n",
              "end\n"
            ]
          }
        }
      ]
    }
