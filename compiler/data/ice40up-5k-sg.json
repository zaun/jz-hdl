  "clock_gen": [
    {
      "type": "osc",
      "source": "DS-ICE40-UltraPlus, Section: Internal Oscillator (SB_HFOSC)",
      "description": "High-Frequency Internal Oscillator (HFOSC). Base frequency 48 MHz with programmable divider.",
      "count": 1,
      "map": {
        "verilog-2005": [
          "SB_HFOSC #(\n",
          "    .CLKHF_DIV(\"%%CLKHF_DIV%%\")\n",
          ") u_hfosc (\n",
          "    .CLKHFEN(1'b1),\n",
          "    .CLKHFPU(1'b1),\n",
          "    .CLKHF(%%BASE%%)\n",
          ");\n"
        ],
        "rtlil": [
          "cell \\SB_HFOSC $auto$hfosc\n",
          "  parameter \\CLKHF_DIV \"%%CLKHF_DIV%%\"\n",
          "  connect \\CLKHFEN 1'1\n",
          "  connect \\CLKHFPU 1'1\n",
          "  connect \\CLKHF \\%%BASE%%\n",
          "end\n"
        ]
      },
      "inputs": {
        "REF_CLK": {
          "required": false,
          "description": "OSC has no external clock input"
        }
      },
      "parameters": {
        "CLKHF_DIV": {
          "description": "Clock divider: 0b00=48MHz, 0b01=24MHz, 0b10=12MHz, 0b11=6MHz",
          "type": "string",
          "default": "0b00",
          "valid": [
            "0b00",
            "0b01",
            "0b10",
            "0b11"
          ]
        }
      },
      "outputs": {
        "BASE": {
          "description": "High-frequency oscillator output",
          "port": "CLKHF",
          "is_clock": true,
          "frequency_mhz": {
            "expr": "48.0 / (1 << CLKHF_DIV)"
          }
        }
      }
    },
    {
