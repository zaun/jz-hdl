      "inputs": {
        "REF_CLK": {
          "description": "Reference clock input to the PLL",
          "required": true,
          "width": 1,
          "requires_period": true,
          "min_mhz": 19,
          "max_mhz": 800
        }
      },
      "parameters": {
        "IDIV": {
          "description": "Input clock divider (IDIV_SEL). Divides CLKIN before phase detector. Actual division = IDIV_SEL.",
          "type": "int",
          "default": 1,
          "min": 1,
          "max": 64
        },
        "FBDIV": {
          "description": "Feedback divider (FBDIV_SEL). Controls feedback path division. Actual division = FBDIV_SEL.",
          "type": "int",
          "default": 1,
          "min": 1,
          "max": 64
        },
        "MDIV": {
          "description": "VCO multiplier (MDIV_SEL). FVCO = FCLKIN * MDIV / IDIV. Actual value = MDIV_SEL.",
          "type": "int",
          "default": 8,
          "min": 2,
          "max": 128
        },
        "ODIV0": {
          "description": "Channel 0 output divider (ODIV0_SEL). FOUT0 = FVCO / ODIV0.",
          "type": "int",
          "default": 8,
          "min": 1,
          "max": 128
        },
        "ODIV1": {
          "description": "Channel 1 output divider (ODIV1_SEL). FOUT1 = FVCO / ODIV1.",
          "type": "int",
          "default": 8,
          "min": 1,
          "max": 128
        },
        "ODIV2": {
          "description": "Channel 2 output divider (ODIV2_SEL).",
          "type": "int",
          "default": 8,
          "min": 1,
          "max": 128
        },
        "ODIV3": {
          "description": "Channel 3 output divider (ODIV3_SEL).",
          "type": "int",
          "default": 8,
          "min": 1,
          "max": 128
        },
        "ODIV4": {
          "description": "Channel 4 output divider (ODIV4_SEL).",
          "type": "int",
          "default": 8,
          "min": 1,
          "max": 128
        },
        "ODIV5": {
          "description": "Channel 5 output divider (ODIV5_SEL).",
          "type": "int",
          "default": 8,
          "min": 1,
          "max": 128
        },
        "ODIV6": {
          "description": "Channel 6 output divider (ODIV6_SEL).",
          "type": "int",
          "default": 8,
          "min": 1,
          "max": 128
        }
      },
      "derived": {
        "FVCO": {
          "description": "Internal VCO frequency",
          "expr": "(1000.0 / REF_CLK_period_ns) * MDIV / IDIV",
          "min": 700,
          "max": 1400
        }
      },
      "outputs": {
        "BASE": {
          "description": "Primary PLL output (CLKOUT0)",
          "port": "CLKOUT0",
          "is_clock": true,
          "frequency_mhz": {
            "expr": "FVCO / ODIV0"
          }
        },
        "LOCK": {
          "description": "PLL lock indicator (1 = locked)",
          "port": "LOCK",
          "is_clock": false
        }
      },
      "constraints": [
        {
          "description": "VCO frequency must be within range (DS1103 Table 3-37)",
          "check": "FVCO >= 700 && FVCO <= 1400"
        },
        {
          "description": "Output frequency must be within range (DS1103 Table 3-37)",
          "check": "FVCO / ODIV0 >= 6.25 && FVCO / ODIV0 <= 800"
        }
      ]
    },
    {
      "type": "clkdiv",
      "source": "UG306-1.0.8E, Section 4.3 (CLKDIV Primitive), Table 4-3, Table 4-4",
      "mode": "local",
      "description": "Local clock divider (CLKDIV) for IO logic. Divides an input clock by a configurable ratio.",
      "count": 8,
      "map": {
        "verilog-2005": [
          "CLKDIV #(\n",
          "    .DIV_MODE(\"%%DIV_MODE%%\")\n",
          ") u_clkdiv_%%instance_idx%% (\n",
          "    .HCLKIN(%%REF_CLK%%),\n",
          "    .RESETN(1'b1),\n",
          "    .CALIB(1'b0),\n",
          "    .CLKOUT(%%BASE%%)\n",
          ");\n"
        ],
        "rtlil": [
          "cell \\CLKDIV $auto$%%instance_idx%%\n",
          "  parameter \\DIV_MODE \"%%DIV_MODE%%\"\n",
          "  connect \\HCLKIN \\%%REF_CLK%%\n",
          "  connect \\RESETN 1'1\n",
          "  connect \\CALIB 1'0\n",
          "  connect \\CLKOUT \\%%BASE%%\n",
          "end\n"
        ]
      },
      "inputs": {
        "REF_CLK": {
          "description": "High-speed clock input to the divider",
          "required": true,
          "width": 1,
          "requires_period": true
        }
      },
      "parameters": {
        "DIV_MODE": {
          "description": "Clock division ratio",
          "type": "string",
          "default": "2",
          "valid": [
            "1",
            "2",
            "3",
            "3.5",
            "4",
            "5",
            "6",
            "7",
            "8"
          ]
        }
      },
      "outputs": {
        "BASE": {
          "description": "Divided clock output",
          "port": "CLKOUT",
          "is_clock": true,
          "frequency_mhz": {
            "description": "Input frequency divided by DIV_MODE",
            "expr": "(1000.0 / REF_CLK_period_ns) / DIV_MODE"
          }
        }
      }
    },
