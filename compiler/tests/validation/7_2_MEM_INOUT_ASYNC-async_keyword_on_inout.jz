// MEM_INOUT_ASYNC: INOUT ports are always synchronous; ASYNC/SYNC keyword not permitted.
// Plain INOUT without keyword included for no false positives.

@project MEM_INOUT_ASYNC_async_keyword_on_inout
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: INOUT with ASYNC keyword in helper
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 1: INOUT with ASYNC keyword
    MEM {
        mem_a [8] [16] = 8'h00 {
            INOUT rw ASYNC;
        };
    }

    // Valid: plain INOUT (no keyword)
    MEM {
        mem_ok [8] [16] = 8'h00 {
            INOUT rw_ok;
        };
    }

    ASYNCHRONOUS {
        data = mem_ok.rw_ok.data;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_ok.rw_ok.addr <= addr;
        mem_ok.rw_ok.wdata <= wdata;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 2: INOUT with SYNC keyword
    MEM {
        mem_b [8] [16] = 8'h00 {
            INOUT rw SYNC;
        };
    }

    // Valid: plain INOUT (no keyword)
    MEM {
        mem_ok2 [8] [16] = 8'h00 {
            INOUT rw_ok2;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_ok2.rw_ok2.data;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_ok2.rw_ok2.addr <= addr;
        mem_ok2.rw_ok2.wdata <= wdata;
    }
@endmod
