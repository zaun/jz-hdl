// INSTANCE_NAME_DUP_IN_MODULE: two instances with the same name in one module.
// Verified

@project INSTANCE_NAME_DUP_IN_MODULE_EXAMPLES
  CONFIG {
    WIDTH = 8;
  }

  @top Project {
    IN  [1] in = _;
    OUT [1] out = _;
  }
@endproj

@module Child
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod

@module Project
  PORT {
    IN  [1] in;
    OUT [1] out;
  }
  
  @new u Child {
    IN  [1] in = _;
    OUT [1] out = _;
  }
  
  @new u Child {
    IN  [1] in = _;
    OUT [1] out = _;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod
