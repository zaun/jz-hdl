// PROJECT_NAME_NOT_UNIQUE: project name conflicts with a module name.
// Verified

@project CONFLICT
  @top NO_CONFLICT {
    IN  [1] clk = _;
    OUT [1] dout = _;
  }
@endproj

@module NO_CONFLICT
  PORT {
    IN  [1] clk;
    OUT [1] dout;
  }

  @new m CONFLICT {
    IN  [1] clk = clk;
    OUT [1] dout = dout;
  }
@endmod

@module CONFLICT
  PORT {
    IN  [1] clk;
    OUT [1] dout;
  }

  ASYNCHRONOUS {
    dout = clk;
  }
@endmod
