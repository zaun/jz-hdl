// ASSIGN_SLICE_OVERLAP: overlapping part-select assignments to same register bits in a single path.
// Verified

@project ASSIGN_SLICE_OVERLAP_PROJECT
  @top ASSIGN_SLICE_OVERLAP_EXAMPLE {
    IN  [1] clk = _;
    OUT [8] out = _;
  }
@endproj

@module ASSIGN_SLICE_OVERLAP_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [8] out;
  }

  REGISTER {
    a [8] = 8'h00;
    b [8] = 8'h00;
  }

  ASYNCHRONOUS {
    out <= a & b;
  }

  SYNCHRONOUS(CLK=clk) {
    // Overlapping slices on the same register bits.
    a[3:0] <= 4'hA;
    a[5:2] <= 4'hB;
    b[3:0] <= 4'hB;
    b[7:4] <= 4'hB;
    b[4:3] <= 2'b01;
  }
@endmod
