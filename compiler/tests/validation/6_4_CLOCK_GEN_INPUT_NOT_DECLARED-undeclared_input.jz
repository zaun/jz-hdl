// CLOCK_GEN_INPUT_NOT_DECLARED: CLOCK_GEN input clock not declared in CLOCKS block.
// Tests a PLL whose IN references a clock not in CLOCKS.
// Valid PLL with declared input included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_INPUT_NOT_DECLARED_undeclared_input
    CLOCKS {
        ref_clk = { period=10 };
        gen_out;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        // Trigger: phantom_clk is not declared in CLOCKS
        PLL {
            IN REF_CLK phantom_clk;
            OUT BASE gen_out;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
