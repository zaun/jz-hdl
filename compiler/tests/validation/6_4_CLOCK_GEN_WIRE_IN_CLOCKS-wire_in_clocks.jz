// CLOCK_GEN_WIRE_IN_CLOCKS: CLOCK_GEN WIRE output must not be declared in CLOCKS block.
// Tests WIRE output that is also listed in the CLOCKS block.
// Valid WIRE (not in CLOCKS) included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_WIRE_IN_CLOCKS_wire_in_clocks
    CLOCKS {
        ref_clk = { period=10 };
        valid_out;
        // Trigger: WIRE output listed in CLOCKS
        lock_clk;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        PLL {
            IN REF_CLK ref_clk;
            OUT BASE valid_out;
            // Trigger 1: WIRE output declared in CLOCKS block
            WIRE LOCK lock_clk;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
