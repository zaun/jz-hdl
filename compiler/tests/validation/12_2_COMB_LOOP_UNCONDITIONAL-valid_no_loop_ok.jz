// COMB_LOOP_UNCONDITIONAL: Valid programs with no combinational loops.
// Exercises linear chains, fan-out/reconvergence, long chains (10+ signals),
// and register-based path breaks to verify no false positives.

@project COMB_LOOP_UNCONDITIONAL_valid_no_loop_ok
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [1] din = _;
        OUT [1] out_a = _;
        OUT [1] out_b = _;
        OUT [1] out_c = _;
    }
@endproj

// Helper: linear chain through multiple wires (no cycle)
@module HelperLinear
    PORT {
        IN  [1] din;
        OUT [1] dout;
    }

    WIRE {
        w1 [1];
        w2 [1];
        w3 [1];
    }

    ASYNCHRONOUS {
        // Valid: linear chain din -> w1 -> w2 -> w3 -> dout
        w1 = din;
        w2 = w1;
        w3 = w2;
        dout = w3;
    }
@endmod

// Helper: fan-out and reconvergence (no cycle)
@module HelperFanout
    PORT {
        IN  [1] din;
        OUT [1] dout;
    }

    WIRE {
        a [1];
        b [1];
    }

    ASYNCHRONOUS {
        // Valid: fan-out from din to a and b, then reconverge at dout
        a = din;
        b = din;
        dout = a & b;
    }
@endmod

// Helper: long chain of 10+ signals (no cycle)
@module HelperLong
    PORT {
        IN  [1] din;
        OUT [1] dout;
    }

    WIRE {
        s1  [1];
        s2  [1];
        s3  [1];
        s4  [1];
        s5  [1];
        s6  [1];
        s7  [1];
        s8  [1];
        s9  [1];
        s10 [1];
    }

    ASYNCHRONOUS {
        // Valid: long linear chain (10 signals, no cycle)
        s1  = din;
        s2  = s1;
        s3  = s2;
        s4  = s3;
        s5  = s4;
        s6  = s5;
        s7  = s6;
        s8  = s7;
        s9  = s8;
        s10 = s9;
        dout = s10;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] din;
        OUT [1] out_a;
        OUT [1] out_b;
        OUT [1] out_c;
    }

    WIRE {
        x [1];
        y [1];
        z [1];
    }

    @new inst_linear HelperLinear {
        IN  [1] din = din;
        OUT [1] dout = out_a;
    };

    @new inst_fanout HelperFanout {
        IN  [1] din = din;
        OUT [1] dout = _;
    };

    @new inst_long HelperLong {
        IN  [1] din = din;
        OUT [1] dout = out_c;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        // Valid: linear feed-forward din -> x -> y -> z (no cycle)
        x = din;
        y = x;
        z = y;
        // Valid: register breaks combinational path
        out_b = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= din;
    }
@endmod
