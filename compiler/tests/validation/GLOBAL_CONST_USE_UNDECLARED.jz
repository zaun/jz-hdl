// GLOBAL_CONST_USE_UNDECLARED: use of GLOBAL.<name> where the namespace or constant is not declared.
// Verified

@global OPCODES
  NOP = 1'b0;
  LOAD = 1'b1;
@endglob

@project GLOBAL_CONST_USE_UNDECLARED_EXAMPLE
  @top top {
    OUT [1] out = _;
  }
@endproj

@module top
  PORT {
    OUT [1] out;
  }

  ASYNCHRONOUS {
    // OPCODES namespace exists, but UNDECLARED constant does not.
    out <= OPCODES.UNDECLARED;
  }
@endmod
