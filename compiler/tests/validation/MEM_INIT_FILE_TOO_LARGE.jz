// MEM_INIT_FILE_TOO_LARGE: @file payload larger than MEM depth * word_width.
// Verfied

@project MEM_INIT_FILE_TOO_LARGE_PROJECT
  @top MEM_INIT_FILE_TOO_LARGE_EXAMPLE {
    OUT [8] data = _;
  }
@endproj

@module MEM_INIT_FILE_TOO_LARGE_EXAMPLE
  PORT {
    OUT [8] data;
  }

  MEM {
    // Capacity: depth=2, word_width=8 -> 16 bits.
    // The test harness should provide 'mem_big.bin' with >2 bytes of data.
    rom_big [8] [2] = @file("mem_big.bin") {
      OUT rd ASYNC;
    };
  }

  ASYNCHRONOUS {
    data <= rom_big.rd[1];
  }
@endmod