// REG_MULTI_DIMENSIONAL: Register declared with multi-dimensional syntax.
// Each trigger tests multi-dimensional register declaration in a different module.
// Valid single-dimensional registers included for no false positives.

@project REG_MULTI_DIMENSIONAL_multi_dim_register
    @top TopMod {
        IN  [1] clk = _;
        OUT [8] dout = _;
        OUT [8] dout_h = _;
    }
@endproj

// Helper module: multi-dimensional register
@module HelperMod
    PORT {
        IN  [1] clk;
        OUT [8] data_out;
    }

    REGISTER {
        // Trigger 1: multi-dimensional register in helper module
        r_bad [8] [4];
        // Valid: single-dimensional register
        r_ok [8] = 8'h00;
    }

    ASYNCHRONOUS {
        data_out = r_ok;
    }

    SYNCHRONOUS(CLK=clk) {
        r_ok <= ~r_ok;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [8] dout;
        OUT [8] dout_h;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        OUT [8] data_out = dout_h;
    };

    REGISTER {
        // Trigger 2: multi-dimensional register in top module
        r_bad_top [16] [2];
        // Valid: single-dimensional register
        r_ok [8] = 8'hAA;
    }

    ASYNCHRONOUS {
        dout = r_ok;
    }

    SYNCHRONOUS(CLK=clk) {
        r_ok <= ~r_ok;
    }
@endmod
