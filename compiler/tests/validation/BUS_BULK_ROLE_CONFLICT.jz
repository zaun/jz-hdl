// BUS_BULK_ROLE_CONFLICT: bulk BUS assignment between instances with same BUS role.
// Verified

@project BUS_BULK_ROLE_CONFLICT_EXAMPLE
  BUS FABRIC {
    IN  [8] data;
  }

  @top top {
    IN [1] clk = _;
  }
@endproj

@module endpoint_src_a
  PORT {
    BUS FABRIC SOURCE [1] link;
  }

  ASYNCHRONOUS {
    // placeholder logic
  }
@endmod

@module endpoint_src_b
  PORT {
    BUS FABRIC SOURCE [1] link;
  }

  ASYNCHRONOUS {
    // placeholder logic
  }
@endmod

@module top
  PORT {
    IN [1] clk;
  }

  // Bulk BUS assignment between two SOURCE roles
  ASYNCHRONOUS {
    src_a.link = src_b.link;
  }

  @new src_a endpoint_src_a {
    IN [1] clk = clk;
  }

  @new src_b endpoint_src_b {
    IN [1] clk = clk;
  }
@endmod
