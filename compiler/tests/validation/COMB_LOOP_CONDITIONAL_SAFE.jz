// COMB_LOOP_CONDITIONAL_SAFE: cycles only within mutually exclusive branches
// considered safe (no error). The flow-insensitive union of edges
// a <-> b forms a cycle, but along any single execution path only one
// direction is present.
// Verified

@project COMB_LOOP_CONDITIONAL_SAFE_PROJECT
  @top COMB_LOOP_CONDITIONAL_SAFE_EXAMPLE {
    IN  [1] sel = _;
    OUT [1] y = _;
  }
@endproj

@module COMB_LOOP_CONDITIONAL_SAFE_EXAMPLE
  PORT {
    IN  [1] sel;
    OUT [1] y;
  }

  WIRE {
    a [1];
    b [1];
  }

  ASYNCHRONOUS {
    
    IF (sel) {
      b <= sel;
      a <= b;
    } ELSE {
      a <= sel;
      b <= a;
    }

    y = a;
  }
@endmod
