// TEMPLATE_FORBIDDEN_DIRECTIVE: @new directive in module-scoped template.
// Realistic syntax with full instantiation. Parser does not recover after
// the error, producing cascading PARSE000.

@project TEMPLATE_FORBIDDEN_DIRECTIVE_new_in_mod_template
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module HelperMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    ASYNCHRONOUS {
        data = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    // Trigger: @new directive inside module-scoped template
    @template new_mod_tmpl(a, b)
        @new inst_inner HelperMod {
            IN  [1] din = a;
            OUT [1] data = b;
        };
    @endtemplate

    @new inst_a HelperMod {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
