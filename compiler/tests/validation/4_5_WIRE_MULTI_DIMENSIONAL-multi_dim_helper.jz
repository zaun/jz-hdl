// WIRE_MULTI_DIMENSIONAL: Wire declared with multi-dimensional syntax.
// Trigger: multi-dimensional wire in helper module.
// Valid single-dimensional wire included to verify no false positives.

@project WIRE_MULTI_DIMENSIONAL_multi_dim_helper
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [8] din = _;
        OUT [8] dout = _;
    }
@endproj

// Helper module: multi-dimensional wire trigger
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] data_in;
        OUT [8] data_out;
    }

    WIRE {
        // Valid: single-dimensional wire
        w_ok [8];
        // Trigger 1: multi-dimensional wire in helper module
        w_bad [8] [4];
    }

    REGISTER {
        r [8] = 8'h00;
    }

    ASYNCHRONOUS {
        w_ok <= data_in;
        data_out <= w_ok | r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= w_ok;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] din;
        OUT [8] dout;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [8] data_in = din;
        OUT [8] data_out = dout;
    };

    ASYNCHRONOUS {
        dout <= r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= din;
    }
@endmod
