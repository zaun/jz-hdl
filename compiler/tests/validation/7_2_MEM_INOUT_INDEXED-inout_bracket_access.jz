// MEM_INOUT_INDEXED: INOUT port may not be indexed with brackets.
// Valid .addr/.data/.wdata access included for no false positives.

@project MEM_INOUT_INDEXED_inout_bracket_access
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: INOUT indexed in helper module
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    ASYNCHRONOUS {
        data = mem_a.rw.data;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_a.rw.addr <= addr;
        mem_a.rw.wdata <= wdata;
        // Trigger 1: bracket index on INOUT port (write)
        mem_a.rw[addr] <= wdata;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        // Trigger 2: bracket index on INOUT port (read)
        data = mem_b.rw[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_b.rw.addr <= addr;
        mem_b.rw.wdata <= wdata;
    }
@endmod
