// MEM_INVALID_PORT_TYPE: invalid MEM port direction/qualifier combination.
// Verfied

@project MEM_INVALID_PORT_TYPE_PROJECT
  @top MEM_INVALID_PORT_TYPE_EXAMPLE {
    IN  [1] clk = _;
    IN  [8] din = _;
    OUT [8] dout = _;
  }
@endproj

@module MEM_INVALID_PORT_TYPE_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [8] din;
    OUT [8] dout;
  }

  MEM {
    // IN port wrongly declared ASYNC instead of using a WRITE_MODE.
    mem [8] [4] = 8'h00 {
      OUT rd ASYNC;
      IN  wr ASYNC;
    };
  }

  ASYNCHRONOUS {
    dout <= mem.rd[1];
  }

  SYNCHRONOUS(CLK=clk) {
    mem.wr[1] <= din;
  }
@endmod
