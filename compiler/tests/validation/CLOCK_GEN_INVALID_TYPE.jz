// CLOCK_GEN_INVALID_TYPE: CLOCK_GEN generator must be PLL, DLL, CLKDIV, OSC, or BUF.

@project CLOCK_GEN_INVALID_TYPE_TEST
  CLOCKS {
    sys_clk = { period=10 };
    fast_clk;
  }

  IN_PINS {
    sys_clk = { standard=LVCMOS33 };
    btn = { standard=LVCMOS33 };
  }

  OUT_PINS {
    led = { standard=LVCMOS33, drive=8 };
  }

  CLOCK_GEN {
    FOOBAR {
      IN REF_CLK sys_clk;
      OUT BASE fast_clk;
    };
  }

  MAP {
    sys_clk = 1;
    btn = 2;
    led = 3;
  }

  @top top {
    IN  [1] a = btn;
    OUT [1] out = led;
  }
@endproj

@module top
  PORT {
    IN  [1] a;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = a;
  }
@endmod
