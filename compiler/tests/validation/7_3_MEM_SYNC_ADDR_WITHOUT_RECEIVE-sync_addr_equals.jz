// MEM_SYNC_ADDR_WITHOUT_RECEIVE: Assign sync port .addr using = instead of <=.
// Valid <= assignment included for no false positives.

@project MEM_SYNC_ADDR_WITHOUT_RECEIVE_sync_addr_equals
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        OUT [8] data = _;
    }
@endproj

// Helper: = instead of <= for .addr
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd SYNC;
        };
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= mem_a.rd.data;
        // Trigger 1: = instead of <=
        mem_a.rd.addr = addr;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd SYNC;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= mem_b.rd.data;
        // Trigger 2: = instead of <= in top module
        mem_b.rd.addr = addr;
    }
@endmod
