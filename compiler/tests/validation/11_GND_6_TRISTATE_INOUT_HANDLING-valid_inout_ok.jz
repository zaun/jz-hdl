// TRISTATE_INOUT_HANDLING: Happy path — INOUT ports with clean z patterns.
// Two instances with INOUT ports share the same parent wire.
// Both use ternary z patterns with explicit comparison guards.
// The tristate proof engine verifies mutual exclusion; OE extraction succeeds.
// Valid: top-level INOUT port is preserved (not transformed).

@project TRISTATE_INOUT_HANDLING_valid_inout_ok
    @top TopMod {
        IN    [1] en = _;
        IN    [8] din = _;
        OUT   [8] result = _;
        INOUT [8] bidir = _;
    }
@endproj

// DriverA: drives INOUT when en == 1'b1
@module DriverA
    PORT {
        IN    [1] en;
        IN    [8] din;
        INOUT [8] data;
    }

    ASYNCHRONOUS {
        data <= (en == 1'b1) ? din : 8'bzzzz_zzzz;
    }
@endmod

// DriverB: drives INOUT when en == 1'b0
@module DriverB
    PORT {
        IN    [1] en;
        IN    [8] din;
        INOUT [8] data;
    }

    ASYNCHRONOUS {
        data <= (en == 1'b0) ? din : 8'bzzzz_zzzz;
    }
@endmod

// Top module: shared bus via INOUT, plus top-level INOUT preserved
@module TopMod
    PORT {
        IN    [1] en;
        IN    [8] din;
        OUT   [8] result;
        INOUT [8] bidir;
    }

    REGISTER {
        r [8] = 8'b0000_0000;
    }

    WIRE {
        bus [8];
    }

    @new inst_a DriverA {
        IN    [1] en = en;
        IN    [8] din = din;
        INOUT [8] data = bus;
    };

    @new inst_b DriverB {
        IN    [1] en = en;
        IN    [8] din = din;
        INOUT [8] data = bus;
    };

    ASYNCHRONOUS {
        result <= bus;

        // Top-level INOUT with z — preserved, not transformed
        IF (en) {
            bidir <= r;
        } ELSE {
            bidir <= 8'bzzzz_zzzz;
        }
    }

    SYNCHRONOUS(CLK=en) {
        r <= din;
    }
@endmod
