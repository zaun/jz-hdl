// MEM_MULTIPLE_ADDR_ASSIGNS: Multiple .addr assignments on INOUT port.
// Single .addr assignment included for no false positives.

@project MEM_MULTIPLE_ADDR_ASSIGNS_inout_multi_addr
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Helper: multiple .addr in helper
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    ASYNCHRONOUS {
        data = mem_a.rw.data;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_a.rw.wdata <= wdata;
        // First .addr assignment
        mem_a.rw.addr <= addr;
        // Trigger 1: second .addr assignment
        mem_a.rw.addr <= 4'h0;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_b.rw.data;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_b.rw.addr <= addr;
        // First .addr assignment
        mem_b.rw.addr <= addr;
        // Trigger 2: second .addr in top module
        mem_b.rw.addr <= 4'h0;
    }
@endmod
