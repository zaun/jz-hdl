// MEM_INOUT_ADDR_IN_ASYNC: INOUT port .addr may only be assigned in SYNCHRONOUS blocks.
// Verified

@project MEM_INOUT_ADDR_IN_ASYNC_PROJECT
  @top MEM_INOUT_ADDR_IN_ASYNC_EXAMPLE {
    IN  [4] address = _;
    OUT [1] data = _;
  }
@endproj

@module MEM_INOUT_ADDR_IN_ASYNC_EXAMPLE
  PORT {
    IN  [4] address;
    OUT [1] data;
  }

  MEM {
    single_port [8] [16] = 8'h00 {
      INOUT rw;
    };
  }

  ASYNCHRONOUS {
    // ERROR: .addr can only be assigned in SYNCHRONOUS blocks
    single_port.rw.addr <= address;
    data <= 1'b0;
  }
@endmod
