// TEMPLATE_FORBIDDEN_BLOCK_HEADER: SYNCHRONOUS block header in file-scoped template.
// Realistic syntax with CLK parameter and block body. Parser does not recover after
// the error, producing cascading PARSE000.

@project TEMPLATE_FORBIDDEN_BLOCK_HEADER_sync_file_scoped
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Trigger: SYNCHRONOUS block header inside file-scoped template
@template sync_tmpl(a, b)
    SYNCHRONOUS(CLK=a) {
        b <= a;
    }
@endtemplate

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
