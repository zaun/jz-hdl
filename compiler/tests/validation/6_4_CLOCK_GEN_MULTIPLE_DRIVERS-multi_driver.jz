// CLOCK_GEN_MULTIPLE_DRIVERS: Clock is driven by multiple CLOCK_GEN outputs.
// Tests a clock that is an OUT of two different CLOCK_GEN units.
// Valid single-driven clock included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_MULTIPLE_DRIVERS_multi_driver
    CLOCKS {
        ref_clk = { period=10 };
        // Trigger: driven by two PLLs
        multi_clk;
        // Valid: driven by one PLL only
        single_clk;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        // First PLL drives multi_clk
        PLL {
            IN REF_CLK ref_clk;
            OUT BASE multi_clk;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };

        // Second PLL also drives multi_clk (trigger)
        PLL {
            IN REF_CLK ref_clk;
            OUT BASE multi_clk;
            OUT PHASE single_clk;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
