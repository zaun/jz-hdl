@module leaf
  PORT {
    OUT [8] data;
  }

  MEM(TYPE=DISTRIBUTED) {
    ram [16] [1024] = 16'h0000 {
      OUT rd ASYNC;
    };
  }

  ASYNCHRONOUS {
    data <= ram.rd[7:0];
  }
@endmod

@module top
  PORT {
    OUT [8] data;
  }

  @new a1 leaf {
    OUT [8] data = _;
  }

  @new a2 leaf {
    OUT [8] data = _;
  }

  @new a3 leaf {
    OUT [8] data = _;
  }

  ASYNCHRONOUS {
    data <= a1.data;
  }
@endmod

@project(CHIP="GW2AR-18-QN88-C8-I7") demo
  @top top {
    OUT [8] data = _;
  }
@endproj
