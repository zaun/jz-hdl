// HAPPY_PATH: iCE40 differential output with width=2 only requires fclk.
// The chip data's required_clocks for ratio=2 is ["fclk"] — no pclk or reset needed.

@project(CHIP="ICE40UP-5K-SG48") HAPPY_PATH_diff_out_ice40_fclk_only
    CLOCKS {
        SCLK = { period=83.33 };
        serial_clk;
    }

    IN_PINS {
        SCLK = { standard=LVCMOS33 };
    }

    OUT_PINS {
        // Valid: width=2 on iCE40 only needs fclk (no pclk, no reset)
        TMDS_CLK = { mode=DIFFERENTIAL, standard=LVDS25, drive=3.5, fclk=serial_clk, width=2 };
    }

    MAP {
        SCLK = 35;
        TMDS_CLK = { P=47, N=48 };
    }

    CLOCK_GEN {
        PLL3 {
            IN REF_CLK SCLK;
            OUT BASE serial_clk;
            WIRE LOCK pll_lock;
            CONFIG {
                DIVR = 0;
                DIVF = 83;
                DIVQ = 4;
                FILTER_RANGE = 1;
                PLLOUT_SELECT = GENCLK;
            };
        };
    }

    @top TopMod {
        IN  [1] clk  = serial_clk;
        OUT [2] data = TMDS_CLK;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [2] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data <= { r, ~r };
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
