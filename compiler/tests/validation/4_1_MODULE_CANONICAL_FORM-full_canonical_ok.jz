// MODULE_CANONICAL_FORM: Happy path for Section 4.1 module canonical form.
// Exercises full canonical form with all sections, minimal module, modules
// without CONST/REGISTER/WIRE, multiple SYNCHRONOUS blocks with different
// clocks, and SYNCHRONOUS header variants (EDGE, RESET, RESET_ACTIVE, RESET_TYPE).

@project MODULE_CANONICAL_FORM_full_canonical_ok
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk_a = _;
        IN  [1] clk_b = _;
        IN  [1] rst = _;
        IN  [1] din = _;
        OUT [1] data = _;
    }
@endproj

// Full canonical form: CONST, PORT, WIRE, REGISTER, ASYNCHRONOUS, SYNCHRONOUS
@module FullCanonical
    CONST {
        SIZE = 4;
    }

    PORT {
        IN  [1] clk;
        IN  [1] din;
        OUT [1] data;
    }

    WIRE {
        w [1];
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        w = din;
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= w;
    }
@endmod

// Minimal module: only PORT and ASYNCHRONOUS (pure pass-through)
@module MinimalMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    ASYNCHRONOUS {
        data = din;
    }
@endmod

// Module without CONST: PORT + WIRE + ASYNCHRONOUS
@module NoConst
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    WIRE {
        w [1];
    }

    ASYNCHRONOUS {
        w = din;
        data = w;
    }
@endmod

// Module without REGISTER: pure combinational
@module NoRegister
    PORT {
        IN  [1] a;
        IN  [1] b;
        OUT [1] data;
    }

    ASYNCHRONOUS {
        data = a & b;
    }
@endmod

// Module without WIRE: ports and registers only
@module NoWire
    PORT {
        IN  [1] clk;
        IN  [1] din;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= din;
    }
@endmod

// Multiple SYNCHRONOUS blocks with different clocks
@module MultiSync
    PORT {
        IN  [1] clk_a;
        IN  [1] clk_b;
        IN  [1] din;
        OUT [1] data;
    }

    REGISTER {
        ra [1] = 1'b0;
        rb [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = ra ^ rb;
    }

    SYNCHRONOUS(CLK=clk_a) {
        ra <= din;
    }

    SYNCHRONOUS(CLK=clk_b) {
        rb <= din;
    }
@endmod

// SYNCHRONOUS header variants: EDGE, RESET, RESET_ACTIVE, RESET_TYPE
@module SyncVariants
    PORT {
        IN  [1] clk_a;
        IN  [1] clk_b;
        IN  [1] rst;
        IN  [1] din;
        OUT [1] data;
    }

    REGISTER {
        r1 [1] = 1'b0;
        r2 [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r1 ^ r2;
    }

    // Rising edge with reset
    SYNCHRONOUS(CLK=clk_a EDGE=Rising RESET=rst RESET_ACTIVE=Low RESET_TYPE=Immediate) {
        r1 <= din;
    }

    // Falling edge, different reset config
    SYNCHRONOUS(CLK=clk_b EDGE=Falling RESET=rst RESET_ACTIVE=High RESET_TYPE=Clocked) {
        r2 <= din;
    }
@endmod

// Top module: instantiates all helpers
@module TopMod
    PORT {
        IN  [1] clk_a;
        IN  [1] clk_b;
        IN  [1] rst;
        IN  [1] din;
        OUT [1] data;
    }

    @new inst_full FullCanonical {
        IN  [1] clk = clk_a;
        IN  [1] din = din;
        OUT [1] data = _;
    };

    @new inst_min MinimalMod {
        IN  [1] din = din;
        OUT [1] data = _;
    };

    @new inst_nc NoConst {
        IN  [1] din = din;
        OUT [1] data = _;
    };

    @new inst_nr NoRegister {
        IN  [1] a = din;
        IN  [1] b = din;
        OUT [1] data = _;
    };

    @new inst_nw NoWire {
        IN  [1] clk = clk_a;
        IN  [1] din = din;
        OUT [1] data = _;
    };

    @new inst_ms MultiSync {
        IN  [1] clk_a = clk_a;
        IN  [1] clk_b = clk_b;
        IN  [1] din = din;
        OUT [1] data = _;
    };

    @new inst_sv SyncVariants {
        IN  [1] clk_a = clk_a;
        IN  [1] clk_b = clk_b;
        IN  [1] rst = rst;
        IN  [1] din = din;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk_a) {
        r <= din;
    }
@endmod
