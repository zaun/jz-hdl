// CLOCK_GEN_PARAM_OUT_OF_RANGE: CLOCK_GEN CONFIG parameter outside valid chip-defined range.
// Tests PLL parameters exceeding their valid ranges.
// Valid parameters included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_PARAM_OUT_OF_RANGE_param_range
    CLOCKS {
        ref_clk = { period=10 };
        bad_out;
        valid_out;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        // Trigger: IDIV=100 exceeds range 0-63
        PLL {
            IN REF_CLK ref_clk;
            OUT BASE bad_out;

            CONFIG {
                IDIV = 100;
                FBDIV = 3;
                ODIV = 2;
            };
        };

        // Valid: all params in range (no trigger)
        PLL {
            IN REF_CLK ref_clk;
            OUT BASE valid_out;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
