// CLOCK_GEN_PARAM_OUT_OF_RANGE: CLOCK_GEN CONFIG parameter value outside valid chip-defined range.
// Tests a PLL CONFIG parameter (IDIV) exceeding the chip's valid range.
// Valid parameter values included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_PARAM_OUT_OF_RANGE_param_range
    CLOCKS {
        ref_clk = { period=10 };
        gen_out;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        PLL {
            IN REF_CLK ref_clk;
            OUT BASE gen_out;

            CONFIG {
                // Trigger: IDIV=100 exceeds valid range 0-63
                IDIV = 100;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
