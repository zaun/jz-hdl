// REG_MULTI_DIMENSIONAL: Register declared with multi-dimensional syntax.
// Trigger in helper module — compiler halts after first diagnostic so
// helper and top module triggers are split into separate files.
// Valid single-dimensional register included for no false positives.

@project REG_MULTI_DIMENSIONAL_multi_dim_helper
    @top TopMod {
        IN  [1] clk = _;
        OUT [8] dout = _;
    }
@endproj

// Helper module: multi-dimensional register
@module HelperMod
    PORT {
        IN  [1] clk;
        OUT [8] data_out;
    }

    REGISTER {
        // Trigger 1: multi-dimensional register in helper module
        r_bad [8] [4];
        // Valid: single-dimensional register
        r_ok [8] = 8'h00;
    }

    ASYNCHRONOUS {
        data_out = r_ok;
    }

    SYNCHRONOUS(CLK=clk) {
        r_ok <= ~r_ok;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [8] dout;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        OUT [8] data_out = dout;
    };

    REGISTER {
        r_ok [8] = 8'hAA;
    }

    ASYNCHRONOUS {
        dout = r_ok;
    }

    SYNCHRONOUS(CLK=clk) {
        r_ok <= ~r_ok;
    }
@endmod
