// CLOCK_GEN_CLKDIV2: Validate CLKDIV2 generator type is accepted in CLOCK_GEN.
// Verified

@project CLOCK_GEN_CLKDIV2_TEST
  CLOCKS {
    serial_clk = { period=4.0 };
    pixel_clk;
  }

  IN_PINS {
    serial_clk = { standard=LVCMOS33 };
    btn = { standard=LVCMOS33 };
  }

  OUT_PINS {
    led = { standard=LVCMOS33, drive=8 };
  }

  CLOCK_GEN {
    CLKDIV2 {
      IN REF_CLK serial_clk;
      OUT BASE pixel_clk;
    };
  }

  MAP {
    serial_clk = 1;
    btn = 2;
    led = 3;
  }

  @top top {
    IN  [1] a = btn;
    OUT [1] out = led;
  }
@endproj

@module top
  PORT {
    IN  [1] a;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = a;
  }
@endmod
