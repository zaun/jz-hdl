// HAPPY_PATH: Valid @check semantics — true conditions produce no diagnostics.
// Exercises true @check with nonzero literals, CONST-based expressions,
// CONFIG references, and nonzero values other than 1.

@project HAPPY_PATH_check_semantics_ok
    CONFIG {
        WIDTH = 8;
        DEPTH = 256;
    }

    // Valid: CONFIG equality at project scope
    @check (CONFIG.WIDTH == 8, "Width must be 8");

    // Valid: CONFIG comparison at project scope
    @check (CONFIG.DEPTH > 0, "Depth must be positive");

    // Valid: nonzero value other than 1 passes (42 is truthy)
    @check (CONFIG.WIDTH * 5 + 2, "nonzero is truthy");

    // Valid: clog2 of CONFIG
    @check (clog2(CONFIG.DEPTH) == 8, "clog2 correct");

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module HelperMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    CONST { LOCAL_W = 4; }

    // Valid: CONST-based @check in helper module
    @check (LOCAL_W > 0, "local width ok");

    // Valid: CONST arithmetic producing nonzero (not 1)
    @check (LOCAL_W * 2, "double width is nonzero");

    ASYNCHRONOUS {
        data = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    CONST { SIZE = 16; }
    CONST { ADDR_W = 4; }

    // Valid: CONST equality
    @check (SIZE == 16, "size ok");

    // Valid: clog2 match
    @check (ADDR_W == clog2(SIZE), "address width ok");

    // Valid: literal nonzero
    @check (1, "literal one ok");

    // Valid: large nonzero value
    @check (999, "large nonzero ok");

    @new inst_a HelperMod {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
