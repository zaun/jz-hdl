// MEM_WARN_PARTIAL_INIT: @file payload smaller than MEM depth * word_width.
// Verfied

@project MEM_INIT_FILE_PARTIAL_PROJECT
  @top MEM_INIT_FILE_PARTIAL_EXAMPLE {
    OUT [8] data = _;
  }
@endproj

@module MEM_INIT_FILE_PARTIAL_EXAMPLE
  PORT {
    OUT [8] data;
  }

  MEM {
    // Capacity: depth=8, word_width=8 -> 64 bits.
    // The test harness should provide 'mem_small.bin' with fewer than 8 bytes.
    rom_small [8] [8] = @file("mem_small.bin") {
      OUT rd ASYNC;
    };
  }

  ASYNCHRONOUS {
    data <= rom_small.rd[1];
  }
@endmod