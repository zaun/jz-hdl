// CLOCK_GEN_WIRE_IS_CLOCK: CLOCK_GEN WIRE used for clock output; use OUT instead.
// Tests using WIRE keyword for a PLL BASE output (is_clock=true).
// Valid WIRE for non-clock output included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_WIRE_IS_CLOCK_wire_for_clock
    CLOCKS {
        ref_clk = { period=10 };
        valid_out;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        PLL {
            IN REF_CLK ref_clk;
            // Valid: OUT for clock output (no trigger)
            OUT BASE valid_out;
            // Trigger 1: WIRE for a clock output (PHASE is_clock=true)
            WIRE PHASE phase_sig;
            // Valid: WIRE for non-clock output (no trigger)
            WIRE LOCK lock_sig;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
