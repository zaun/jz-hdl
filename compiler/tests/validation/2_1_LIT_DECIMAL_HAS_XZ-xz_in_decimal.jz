// LIT_DECIMAL_HAS_XZ: Decimal literal with x or z digits.
// Tests x and z in decimal literals in async RHS and sync RHS across modules.
// Valid decimal and binary literals included to verify no false positives.

@project LIT_DECIMAL_HAS_XZ_xz_in_decimal
    @top TopMod {
        IN  [1] clk = _;
        OUT [8] data = _;
    }
@endproj

// Helper: decimal with x in async, decimal with z in sync
@module HelperA
    PORT {
        IN  [1] clk;
        OUT [8] data;
    }
    REGISTER {
        r [8] = 8'h00;
    }
    ASYNCHRONOUS {
        // Trigger 1: decimal with x digit
        data = 8'd10x;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: decimal with z digit
        r <= 8'd1z0;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [8] data;
    }
    WIRE {
        helper_data [8];
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        OUT [8] data = helper_data;
    };

    REGISTER {
        r [8] = 8'h00;
    }
    ASYNCHRONOUS {
        // Valid: decimal without x/z (no false positive)
        data = helper_data;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 3: decimal with x in sync
        r <= 8'd2x;
    }
@endmod
