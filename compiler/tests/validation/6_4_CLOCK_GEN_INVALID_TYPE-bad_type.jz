// CLOCK_GEN_INVALID_TYPE: CLOCK_GEN generator must be PLL, DLL, CLKDIV, OSC, or BUF.
// Tests invalid generator type names.
// Valid generator types included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_INVALID_TYPE_bad_type
    CLOCKS {
        ref_clk = { period=10 };
        valid_out;
        bad_out;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        // Trigger 1: invalid generator type "RING"
        RING {
            IN REF_CLK ref_clk;
            OUT BASE bad_out;

            CONFIG {
                FREQ = 100;
            };
        };

        // Valid: PLL is a valid type (no trigger)
        PLL {
            IN REF_CLK ref_clk;
            OUT BASE valid_out;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
