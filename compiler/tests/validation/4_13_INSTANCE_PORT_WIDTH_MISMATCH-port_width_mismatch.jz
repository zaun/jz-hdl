// INSTANCE_PORT_WIDTH_MISMATCH: Port width in @new does not match child module port width.
// Tests width mismatches on IN and OUT ports using literal child port widths.
// Valid width-matching bindings are included for negative testing.

@project INSTANCE_PORT_WIDTH_MISMATCH_port_width_mismatch
    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Child module with literal port widths
@module ChildMod
    PORT {
        IN  [8] din;
        OUT [8] data;
    }
    ASYNCHRONOUS {
        data = din;
    }
@endmod

// Module that mismatches port widths
@module MidMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    // Trigger 1: IN port width mismatch (declared 4, child expects 8)
    @new inst_a ChildMod {
        IN  [4] din = _;
        OUT [8] data = _;
    };

    // Trigger 2: OUT port width mismatch (declared 4, child expects 8)
    @new inst_b ChildMod {
        IN  [8] din = _;
        OUT [4] data = _;
    };

    // Valid: correct widths (no trigger)
    @new inst_c ChildMod {
        IN  [8] din = _;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    // Trigger 3: IN width too wide in top module
    @new inst_d ChildMod {
        IN  [16] din = _;
        OUT [8] data = _;
    };

    @new inst_e MidMod {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
