// OBS_X_TO_OBSERVABLE_SINK: x-dependent expression may not drive registers or OUT/INOUT ports.
// Verified

@project OBS_X_TO_OBSERVABLE_SINK_PROJECT
  @top OBS_X_TO_OBSERVABLE_SINK_TOP {
    IN  [1] clk = _;
    OUT [4] x   = _;
    OUT [4] y   = _;
  }
@endproj

@module OBS_X_TO_OBSERVABLE_SINK_TOP
  PORT {
    IN  [1] clk;
    OUT [4] x;
    OUT [4] y;
  }

  REGISTER {
    r [4] = 4'h0;
  }

  ASYNCHRONOUS {
    // x in RHS feeding OUT port y: not allowed.
    y <= 4'b10x1;
    x = r;
  }

  SYNCHRONOUS(CLK=clk) {
    // x in RHS feeding register r: not allowed.
    r <= 4'b00x1;
  }
@endmod
