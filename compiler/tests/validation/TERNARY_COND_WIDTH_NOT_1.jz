// TERNARY_COND_WIDTH_NOT_1: ternary condition expression not width-1.
// Verified

@project TERNARY_COND_WIDTH_NOT_1_PROJECT
  @top TERNARY_COND_WIDTH_NOT_1_EXAMPLE {
    IN  [2] cond = _;
    IN  [8] a = _;
    IN  [8] b = _;
    OUT [8] outa = _;
    OUT [8] outb = _;
  }
@endproj

@module TERNARY_COND_WIDTH_NOT_1_EXAMPLE
  PORT {
    IN  [2] cond;
    IN  [8] a;
    IN  [8] b;
    OUT [8] outa;
    OUT [8] outb;
  }

  ASYNCHRONOUS {
    outa <= cond ? a : b;
    outb <= cond == 2'b01 ? a : b;
  }
@endmod
