// TEMPLATE_FORBIDDEN_BLOCK_HEADER: ASYNCHRONOUS block header in module-scoped template.
// Realistic syntax with full block body. Parser does not recover after the error,
// producing cascading PARSE000.

@project TEMPLATE_FORBIDDEN_BLOCK_HEADER_async_mod_scoped
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    // Trigger: ASYNCHRONOUS block header inside module-scoped template
    @template async_mod_tmpl(a, b)
        ASYNCHRONOUS {
            a = b;
        }
    @endtemplate

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
