// TRISTATE_TRANSFORM_OE_EXTRACT_FAIL: OE extraction failure on INOUT port.
// Trigger: DriverB uses concatenated z literal {4'bzzzz, 4'bzzzz} which the
// OE extractor cannot parse (it only handles scalar z literals at IR level).
// DriverA uses standard ternary z pattern — OE extracts fine.
// Both share the same parent wire through INOUT ports.
// Context: INOUT multi-driver with ambiguous OE condition.

@project OE_EXTRACT_FAIL_inout_oe_fail
    @top TopMod {
        IN  [1] en = _;
        IN  [8] din = _;
        OUT [8] result = _;
    }
@endproj

// DriverA: standard ternary z pattern — OE extracts fine
@module DriverA
    PORT {
        IN    [1] en;
        IN    [8] din;
        INOUT [8] data;
    }

    ASYNCHRONOUS {
        data <= (en == 1'b1) ? din : 8'bzzzz_zzzz;
    }
@endmod

// DriverB: concatenated z literal — confuses OE extractor
@module DriverB
    PORT {
        IN    [1] en;
        IN    [8] din;
        INOUT [8] data;
    }

    ASYNCHRONOUS {
        data <= (en == 1'b0) ? din : {4'bzzzz, 4'bzzzz};
    }
@endmod

// Top module: connects both drivers to shared wire via INOUT ports
@module TopMod
    PORT {
        IN  [1] en;
        IN  [8] din;
        OUT [8] result;
    }

    WIRE {
        bus [8];
    }

    @new inst_a DriverA {
        IN    [1] en = en;
        IN    [8] din = din;
        INOUT [8] data = bus;
    };

    @new inst_b DriverB {
        IN    [1] en = en;
        IN    [8] din = din;
        INOUT [8] data = bus;
    };

    ASYNCHRONOUS {
        result <= bus;
    }
@endmod
