// LIT_OVERFLOW: Literal intrinsic bit-width exceeds declared width.
// Tests overflow in binary, decimal, and hex literals in sync RHS across modules.
// Valid non-overflowing literals included to verify no false positives.

@project LIT_OVERFLOW_intrinsic_exceeds_declared
    @top TopMod {
        IN  [1] clk = _;
        OUT [4] data = _;
    }
@endproj

// Helper: binary and decimal overflow in sync context
@module HelperA
    PORT {
        IN  [1] clk;
        OUT [4] data;
    }
    REGISTER {
        r [4] = 4'h0;
        s [4] = 4'h0;
    }
    ASYNCHRONOUS {
        data = r ^ s;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 1: binary overflow — intrinsic 5 bits > declared 4
        r <= 4'b10101;
        // Trigger 2: decimal overflow — 16 needs 5 bits > declared 4
        s <= 4'd16;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [4] data;
    }
    WIRE {
        helper_data [4];
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        OUT [4] data = helper_data;
    };

    REGISTER {
        r [4] = 4'h0;
    }
    ASYNCHRONOUS {
        data = helper_data ^ r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Valid: 4'd15 fits exactly in 4 bits (no false positive)
        // Trigger 3: hex overflow — 0x1F needs 5 bits > declared 4
        r <= 4'h1F;
    }
@endmod
