// MULTI_CLK_ASSIGN: same register assigned in SYNCHRONOUS blocks driven by
// different clocks.
// Verified

@project MULTI_CLK_ASSIGN_PROJECT
  @top MULTI_CLK_ASSIGN_EXAMPLE {
    IN  [1] clk_a = _;
    IN  [1] clk_b = _;
    OUT [1] data = _;
  }
@endproj

@module MULTI_CLK_ASSIGN_EXAMPLE
  PORT {
    IN  [1] clk_a;
    IN  [1] clk_b;
    OUT [1] data;
  }

  REGISTER {
    r [1] = 1'b0;
  }

  ASYNCHRONOUS {
    data = r;
  }

  SYNCHRONOUS(CLK=clk_a) {
    r <= 1'b1;
  }

  SYNCHRONOUS(CLK=clk_b) {
    r <= 1'b0;
  }
@endmod
