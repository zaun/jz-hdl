// NET_FLOATING_WITH_SINK: internal net has sinks but no drivers.
// Verified

@project NET_FLOATING_WITH_SINK_PROJECT
  @top NET_FLOATING_WITH_SINK_EXAMPLE {
    OUT [1] out_sig = _;
  }
@endproj

@module NET_FLOATING_WITH_SINK_EXAMPLE
  PORT {
    OUT [1] out_sig;
  }

  WIRE {
    floating_net [1];
  }

  ASYNCHRONOUS {
    // floating_net is read but never driven inside the design.
    out_sig = floating_net;
  }
@endmod
