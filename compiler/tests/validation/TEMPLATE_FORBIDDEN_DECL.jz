// TEMPLATE_FORBIDDEN_DECL: WIRE inside template body.
// Expect ERR> TEMPLATE_FORBIDDEN_DECL

@project TEMPLATE_FORBIDDEN_DECL_PROJECT
  @top TEMPLATE_FORBIDDEN_DECL_MOD {
    IN  [8] in_a = _;
    OUT [8] out_a = _;
  }
@endproj

@template BAD(a, b)
  WIRE { t[8]; }
  b <= a;
@endtemplate

@module TEMPLATE_FORBIDDEN_DECL_MOD
  PORT {
    IN  [8] in_a;
    OUT [8] out_a;
  }

  ASYNCHRONOUS {
    @apply BAD(in_a, out_a);
  }
@endmod
