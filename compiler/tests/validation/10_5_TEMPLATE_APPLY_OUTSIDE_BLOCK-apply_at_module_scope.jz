// TEMPLATE_APPLY_OUTSIDE_BLOCK: @apply may only appear inside ASYNCHRONOUS or SYNCHRONOUS blocks.
// Trigger 1: @apply at module scope (between declaration blocks).
// Valid @apply in ASYNC included for negative testing.

@project TEMPLATE_APPLY_OUTSIDE_BLOCK_apply_at_module_scope
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@template simple(a, b)
    a <= b;
@endtemplate

@module HelperMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    WIRE {
        w1 [1];
    }

    // Trigger 1: @apply at module scope in HelperMod
    @apply simple(w1, din);

    ASYNCHRONOUS {
        // Valid: @apply inside ASYNC (no error)
        @apply simple(w1, din);
        data = w1;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    @new inst_a HelperMod {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    WIRE {
        w1 [1];
    }

    // Trigger 2: @apply at module scope in TopMod
    @apply simple(w1, r);

    ASYNCHRONOUS {
        // Valid: @apply inside ASYNC (no error)
        @apply simple(w1, r);
        data = w1;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
