// TOP_OUT_LITERAL_BINDING: OUT port bound to literal value in @top.
// Tests multiple OUT ports bound to different literal forms.
// Valid: IN port bound to literal (tie-off allowed), OUT bound to no-connect.

@project TOP_OUT_LITERAL_BINDING_literal_on_out
    @top TopMod {
        IN  [1] clk = _;
        // Valid: IN port bound to literal (allowed for tie-off)
        IN  [1] tie_high = 1'b1;
        // Trigger 1: OUT port bound to binary literal
        OUT [1] data = 1'b0;
        // Trigger 2: OUT port bound to hex literal
        OUT [8] wide_out = 8'hFF;
        // Valid: OUT port bound to no-connect
        OUT [1] other = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] tie_high;
        OUT [1] data;
        OUT [8] wide_out;
        OUT [1] other;
    }
    REGISTER {
        r [1] = 1'b0;
        w [8] = 8'b0000_0000;
    }
    ASYNCHRONOUS {
        data = r;
        wide_out = w;
        other = tie_high;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
        w <= 8'b0000_0000;
    }
@endmod
