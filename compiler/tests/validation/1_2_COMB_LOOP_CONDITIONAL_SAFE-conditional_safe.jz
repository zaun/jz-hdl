// COMB_LOOP_CONDITIONAL_SAFE: Cycles only within mutually exclusive branches.
// Two-variable cross-branch cycle — considered safe (warning, not error).

@project COMB_LOOP_CONDITIONAL_SAFE_conditional_safe
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] sel = _;
        IN  [1] in_a = _;
        OUT [1] out_a = _;
        OUT [1] out_b = _;
        OUT [1] out_c = _;
        OUT [1] out_d = _;
    }
@endproj

// Trigger 1: conditional safe loop in helper module
@module HelperA
    PORT {
        IN  [1] sel;
        IN  [1] in_a;
        OUT [1] out_a;
        OUT [1] out_b;
    }

    WIRE {
        a [1];
        b [1];
    }

    ASYNCHRONOUS {
        // Trigger 1: cycle only across mutually exclusive branches
        IF (sel) {
            a <= in_a;
            b <= a;
        } ELSE {
            b <= in_a;
            a <= b;
        }
        out_a = a;
        out_b = b;
    }
@endmod

// Top module with its own conditional safe loop
@module TopMod
    PORT {
        IN  [1] sel;
        IN  [1] in_a;
        OUT [1] out_a;
        OUT [1] out_b;
        OUT [1] out_c;
        OUT [1] out_d;
    }

    WIRE {
        x [1];
        y [1];
    }

    @new inst_a HelperA {
        IN  [1] sel = sel;
        IN  [1] in_a = in_a;
        OUT [1] out_a = out_a;
        OUT [1] out_b = out_b;
    };

    ASYNCHRONOUS {
        // Trigger 2: cycle only across mutually exclusive branches in top
        IF (sel) {
            x <= in_a;
            y <= x;
        } ELSE {
            y <= in_a;
            x <= y;
        }
        out_c = x;
        out_d = y;
    }
@endmod
