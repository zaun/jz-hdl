// GLOBAL_ASSIGN_FORBIDDEN: assignment to GLOBAL constant is forbidden.
// Verified

@global GLB
  G_VAL = 8'hAA;
@endglob

@project GLOBAL_ASSIGN_FORBIDDEN_PROJECT
  @top GLOBAL_ASSIGN_FORBIDDEN_EXAMPLE {
    IN  [8] a = _;
    OUT [8] out = _;
  }
@endproj

@module GLOBAL_ASSIGN_FORBIDDEN_EXAMPLE
  PORT {
    IN  [8] a;
    OUT [8] out;
  }

  ASYNCHRONOUS {
    out <= a;
    GLB.G_VAL <= a;
  }
@endmod
