// CHECK_INVALID_EXPR_TYPE: @check with runtime signals and bit-slices.
// S9.7 consolidates all @check error conditions. This test exercises
// CHECK_INVALID_EXPR_TYPE with ports, registers, wires, and their slices
// in @check expressions across helper and top modules. Valid uses of CONST,
// CONFIG, and literals included for negative testing.

@project CHECK_INVALID_EXPR_TYPE_runtime_signals
    CONFIG {
        WIDTH = 8;
    }

    // Valid: CONFIG reference at project scope (no error)
    @check (CONFIG.WIDTH == 8, "config check");

    @top TopMod {
        IN  [1] clk = _;
        IN  [8] din = _;
        OUT [8] data = _;
    }
@endproj

// Helper module — triggers with port and register in @check
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] din;
        OUT [8] data;
    }

    CONST { DEPTH = 16; }

    REGISTER {
        r [8] = 8'h00;
    }

    // Valid: CONST in @check (no error)
    @check (DEPTH > 0, "depth ok");

    // Trigger 1: bare port in @check (helper module)
    @check (din == 8'h00, "port in helper");

    // Trigger 2: bare register in @check (helper module)
    @check (r == 8'h00, "reg in helper");

    // Trigger 3: port bit-slice in @check (helper module)
    @check (din[3:0] == 4'h0, "port slice in helper");

    // Trigger 4: register bit-slice in @check (helper module)
    @check (r[7:4] == 4'h0, "reg slice in helper");

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] din;
        OUT [8] data;
    }

    CONST { SIZE = 8; }

    WIRE {
        w [8];
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Valid: CONST in @check (no error)
    @check (SIZE == 8, "size ok");

    // Valid: CONFIG in @check (no error)
    @check (CONFIG.WIDTH == 8, "config ok");

    // Valid: literal in @check (no error)
    @check (1, "literal ok");

    // Valid: clog2 of CONST (no error)
    @check (clog2(SIZE) == 3, "clog2 ok");

    // Trigger 5: bare port in @check (top module)
    @check (din == 8'hFF, "port in top");

    // Trigger 6: bare register in @check (top module)
    @check (r == 8'h00, "reg in top");

    // Trigger 7: bare wire in @check (top module)
    @check (w == 8'h00, "wire in top");

    // Trigger 8: port bit-slice in @check (top module)
    @check (din[7:4] == 4'hF, "port slice in top");

    // Trigger 9: register bit-slice in @check (top module)
    @check (r[0] == 1'b0, "reg bit in top");

    // Trigger 10: wire bit-slice in @check (top module)
    @check (w[3:0] == 4'h0, "wire slice in top");

    @new inst_a HelperMod {
        IN  [1] clk = clk;
        IN  [8] din = din;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        w = din;
        data = w | r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= din;
    }
@endmod
