// IF_COND_MISSING_PARENS: IF/ELIF condition must be written with parentheses.
// verified

@project IF_COND_MISSING_PARENS_PROJECT
  @top IF_COND_MISSING_PARENS_EXAMPLE {
    IN  [1] clk = _;
    IN  [1] state = _;
    OUT [8] out = _;
  }
@endproj

@module IF_COND_MISSING_PARENS_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [1] state;
    OUT [8] out;
  }

  ASYNCHRONOUS {
    // Missing parentheses around condition: should trigger parse-level rule.
    IF state {
      out = 8'h01;
    }
  }
@endmod