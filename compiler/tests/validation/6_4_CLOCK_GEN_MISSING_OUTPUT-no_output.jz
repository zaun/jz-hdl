// CLOCK_GEN_MISSING_OUTPUT: CLOCK_GEN unit must have at least one OUT clock declaration.
// Tests PLL without any OUT declaration.
// Valid PLL with OUT included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_MISSING_OUTPUT_no_output
    CLOCKS {
        ref_clk = { period=10 };
        valid_out;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        // Trigger 1: PLL without OUT declaration
        PLL {
            IN REF_CLK ref_clk;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };

        // Valid: PLL with OUT (no trigger)
        PLL {
            IN REF_CLK ref_clk;
            OUT BASE valid_out;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
