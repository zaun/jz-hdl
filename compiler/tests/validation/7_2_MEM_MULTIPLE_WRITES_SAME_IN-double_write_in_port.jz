// MEM_MULTIPLE_WRITES_SAME_IN: Multiple writes to same IN port in one SYNC block.
// Single writes to different IN ports included for no false positives.

@project MEM_MULTIPLE_WRITES_SAME_IN_double_write_in_port
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: double write to same IN port in helper
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        data = mem_a.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        // Trigger 1: first write
        mem_a.wr[addr] <= wdata;
        // Trigger 1: second write to same port
        mem_a.wr[addr] <= 8'hFF;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
            IN  wr2;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_b.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        // Valid: single write to each of two different IN ports
        mem_b.wr[addr] <= wdata;
        mem_b.wr2[addr] <= wdata;
        // Trigger 2: second write to same port wr
        mem_b.wr[addr] <= 8'hAA;
    }
@endmod
