// SPECIAL_DRIVER_SLICED: VCC/GND may not be sliced or indexed.
// Tests slicing VCC and GND in async RHS and sync RHS across modules.
// Valid uses of VCC/GND without slicing included to verify no false positives.

@project SPECIAL_DRIVER_SLICED_vcc_gnd_sliced
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] out_a = _;
        OUT [1] out_b = _;
        OUT [1] out_c = _;
    }
@endproj

// Helper: VCC and GND sliced in async RHS and sync RHS
@module HelperA
    PORT {
        IN  [1] clk;
        OUT [1] out_a;
        OUT [1] out_b;
        OUT [1] out_c;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        // Trigger 1: VCC sliced in async RHS
        out_a = VCC[0:0];
        // Trigger 2: GND sliced in async RHS
        out_b = GND[0:0];
        // Valid: unsliced VCC (no false positive)
        out_c = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 3: VCC sliced in sync RHS
        r <= VCC[0:0];
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] out_a;
        OUT [1] out_b;
        OUT [1] out_c;
    }
    WIRE {
        ha_out_a [1];
        ha_out_b [1];
        ha_out_c [1];
    }
    REGISTER {
        r [1] = 1'b0;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        OUT [1] out_a = ha_out_a;
        OUT [1] out_b = ha_out_b;
        OUT [1] out_c = ha_out_c;
    };

    ASYNCHRONOUS {
        // Valid: VCC without slice (no false positive)
        out_a = ha_out_a;
        out_b = ha_out_b;
        out_c = r;
    }

    SYNCHRONOUS(CLK=clk) {
        // Trigger 4: GND sliced in sync RHS
        r <= GND[0:0];
    }
@endmod
