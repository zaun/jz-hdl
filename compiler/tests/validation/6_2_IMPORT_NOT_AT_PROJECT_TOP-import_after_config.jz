// IMPORT_NOT_AT_PROJECT_TOP: @import appears after CONFIG/CLOCKS/PIN blocks.
// Tests @import placed after CONFIG block inside @project.
// Parser aborts after this error, so only one trigger is possible per file.

@project IMPORT_NOT_AT_PROJECT_TOP_import_after_config

    CONFIG {
        WIDTH = 8;
    }

    // Trigger 1: @import after CONFIG block (must come before CONFIG)
    @import "6_2_IMPORT_NOT_AT_PROJECT_TOP-import_after_config_lib.jz";

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        data = r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
