// NET_FLOATING_WITH_SINK: Wire declared but never driven, then read.
// Each trigger is commented. Valid driven wires verify no false positives.

@project NET_FLOATING_WITH_SINK_floating_net_read
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [8] din = _;
        OUT [8] dout_a = _;
        OUT [8] dout_b = _;
    }
@endproj

// Trigger 1: floating wire read in helper module
@module HelperA
    PORT {
        IN  [8] din;
        OUT [8] dout;
    }

    WIRE {
        undriven [8];
        driven [8];
    }

    ASYNCHRONOUS {
        driven <= din;
        // Trigger 1: undriven wire read in expression
        dout <= undriven;
    }
@endmod

// Top module with its own floating wire trigger
@module TopMod
    PORT {
        IN  [8] din;
        OUT [8] dout_a;
        OUT [8] dout_b;
    }

    WIRE {
        floating [8];
        valid_w [8];
    }

    @new inst_a HelperA {
        IN  [8] din = din;
        OUT [8] dout = dout_a;
    };

    ASYNCHRONOUS {
        valid_w <= din;
        // Trigger 2: floating wire read in top module
        dout_b <= floating;
    }
@endmod
