// REG_INIT_CONTAINS_X: Register initialization literal contains x bits.
// Tests x bits in register init across multiple modules and widths.
// Valid register inits (no x) are included to verify no false positives.

@project REG_INIT_CONTAINS_X_x_in_register_init
    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Helper module with x in register init
@module HelperA
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }
    REGISTER {
        // Trigger 1: x bits in binary register init (single bit)
        r_bad [1] = 1'bx;
        // Valid: no x bits
        r_ok [1] = 1'b0;
    }
    ASYNCHRONOUS {
        data = r_ok;
    }
    SYNCHRONOUS(CLK=clk) {
        r_bad <= ~r_bad;
        r_ok <= ~r_ok;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        OUT [1] data = _;
    };

    REGISTER {
        // Trigger 2: x bits in 8-bit binary register init
        r_xbits [8] = 8'bxxxx_xxxx;
        // Trigger 3: partial x bits in binary register init
        r_xpartial [8] = 8'bxxxx_0000;
        // Trigger 4: mixed x bits (some x, some valid)
        r_mixed [4] = 4'b1x0x;
        // Valid: all-zero init
        r_valid [8] = 8'b0000_0000;
    }

    ASYNCHRONOUS {
        data = r_valid[0:0];
    }

    SYNCHRONOUS(CLK=clk) {
        r_xbits <= ~r_xbits;
        r_xpartial <= ~r_xpartial;
        r_mixed <= ~r_mixed;
        r_valid <= ~r_valid;
    }
@endmod
