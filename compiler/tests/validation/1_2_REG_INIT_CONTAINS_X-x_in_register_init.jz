// REG_INIT_CONTAINS_X: Register initialization literal must not contain x bits.
// Each trigger is commented. Valid register inits included for no false positives.

@project REG_INIT_CONTAINS_X_x_in_register_init
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [8] din = _;
        OUT [8] dout_a = _;
        OUT [8] dout_b = _;
        OUT [8] dout_c = _;
        OUT [4] dout_d = _;
        OUT [8] dout_e = _;
    }
@endproj

// Trigger 1: x in register init in helper module
@module HelperA
    PORT {
        IN  [1] clk;
        IN  [8] din;
        OUT [8] dout;
        OUT [8] dout_ok;
    }

    REGISTER {
        // Trigger 1: x bit in 8-bit register init
        r_bad [8] = 8'bxxxx_xxxx;
        // Valid: no x bits
        r_ok [8] = 8'h00;
    }

    ASYNCHRONOUS {
        dout <= r_bad;
        dout_ok <= r_ok;
    }

    SYNCHRONOUS(CLK=clk) {
        r_bad <= din;
        r_ok <= din;
    }
@endmod

// Top module with multiple x-bit init patterns
@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] din;
        OUT [8] dout_a;
        OUT [8] dout_b;
        OUT [8] dout_c;
        OUT [4] dout_d;
        OUT [8] dout_e;
    }

    REGISTER {
        // Trigger 2: all x bits in 8-bit register init
        r_all_x [8] = 8'bxxxx_xxxx;
        // Trigger 3: mixed x and valid bits
        r_mixed [8] = 8'bxxxx_0000;
        // Trigger 4: x in 4-bit register
        r_4bit [4] = 4'b1x0x;
        // Valid: no x bits
        r_valid [8] = 8'hFF;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        IN  [8] din = din;
        OUT [8] dout = dout_a;
        OUT [8] dout_ok = _;
    };

    ASYNCHRONOUS {
        dout_b <= r_all_x;
        dout_c <= r_mixed;
        dout_d <= r_4bit;
        dout_e <= r_valid;
    }

    SYNCHRONOUS(CLK=clk) {
        r_all_x <= din;
        r_mixed <= din;
        r_4bit <= din[3:0];
        r_valid <= din;
    }
@endmod
