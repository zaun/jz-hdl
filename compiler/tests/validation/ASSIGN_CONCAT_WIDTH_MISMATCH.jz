// ASSIGN_CONCAT_WIDTH_MISMATCH: concatenation LHS width does not match RHS.
// Expect ERR> ASSIGN_CONCAT_WIDTH_MISMATCH on the assignment to '{hi, lo}'.
// Verified correct

@project ASSIGN_CONCAT_WIDTH_MISMATCH_PROJECT
  @top ASSIGN_CONCAT_WIDTH_MISMATCH_EXAMPLE {
    IN  [4]  in_a = _;
    IN  [4]  in_b = _;
    OUT [16] out_a = _;
    OUT [8]  out_b = _;
    OUT [8]  out_c = _;
    OUT [8]  out_d = _;
    OUT [16] out_e = _;
    OUT [8] out_f = _;
  }
@endproj

@module ASSIGN_CONCAT_WIDTH_MISMATCH_EXAMPLE
  PORT {
    IN  [4]  in_a;
    IN  [4]  in_b; 
    OUT [16] out_a;
    OUT [8]  out_b;
    OUT [8]  out_c;
    OUT [8]  out_d;
    OUT [16] out_e;
    OUT [8]  out_f;
  }

  ASYNCHRONOUS {
    // Expecting 24 bits, got 4
    {out_a, out_b} = in_a;

    // Expecting 24 bits, got 8
    {out_c, out_d} = {in_a, in_b};

    // Expecting 16bits, got 8
    out_e = {in_a, in_b};

    // Expecting 8bits, got 8
    out_f = {in_a, in_b};
  }
@endmod
