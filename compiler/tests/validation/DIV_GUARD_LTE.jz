// DIV_GUARD_LTE: IF (b <= N) ELSE proves b nonzero (ELSE: b > N → always nonzero unsigned).
// Verified

@project DIV_GUARD_LTE_PROJECT
  @top DIV_GUARD_LTE_EXAMPLE {
    IN  [8] a = _;
    IN  [8] b = _;
    OUT [8] out_a = _;
    OUT [8] out_b = _;
  }
@endproj

@module DIV_GUARD_LTE_EXAMPLE
  PORT {
    IN  [8] a;
    IN  [8] b;
    OUT [8] out_a;
    OUT [8] out_b;
  }

  ASYNCHRONOUS {
    // IF (b <= 0) ELSE: b > 0 → nonzero — should NOT warn
    IF (b <= 8'd0) {
      out_a <= 8'd0;
    } ELSE {
      out_a <= a / b;
    }

    // IF (b <= 10) ELSE: b > 10 → nonzero — should NOT warn
    IF (b <= 8'd10) {
      out_b <= 8'd0;
    } ELSE {
      out_b <= a % b;
    }
  }
@endmod
