// WIDTH_NONPOSITIVE_OR_NONINT: Declared width <= 0 or not an integer.
// Tests zero-width declarations in PORT, WIRE, and REGISTER blocks
// across two modules connected via @new.
// Valid positive-width declarations included to verify no false positives.

@project WIDTH_NONPOSITIVE_OR_NONINT_zero_width
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] data_in = _;
        OUT [8] data_out = _;
    }
@endproj

// Helper module: zero-width in WIRE and REGISTER
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] a;
        OUT [8] data;
    }
    WIRE {
        // Trigger 1: zero-width wire in helper
        bad_w [0];
    }
    REGISTER {
        r [8] = 8'h00;
        // Trigger 2: zero-width register in helper
        bad_r [0] = 1'b0;
    }
    ASYNCHRONOUS {
        data = r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= a;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] data_in;
        OUT [8] data_out;
    }
    WIRE {
        h_data [8];
        // Trigger 3: zero-width wire in top module
        bad_w2 [0];
    }
    REGISTER {
        r [8] = 8'h00;
        // Trigger 4: zero-width register in top module
        bad_r2 [0] = 1'b0;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [8] a = data_in;
        OUT [8] data = h_data;
    };

    ASYNCHRONOUS {
        data_out = h_data;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= r;
    }
@endmod
