// HAPPY_PATH: Valid @check evaluation order — CONST and CONFIG resolution
// work correctly. No diagnostics expected.

@project HAPPY_PATH_check_evaluation_order_ok
    CONFIG {
        WIDTH = 8;
        DEPTH = 256;
    }

    // Valid: CONFIG reference at project scope
    @check (CONFIG.WIDTH >= 8, "width ok");

    // Valid: CONFIG arithmetic at project scope
    @check (CONFIG.DEPTH > CONFIG.WIDTH, "depth exceeds width");

    // Valid: clog2 of CONFIG at project scope
    @check (clog2(CONFIG.DEPTH) == 8, "clog2 depth ok");

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module HelperMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    CONST { LOCAL_W = 4; }

    // Valid: @check with CONST in helper
    @check (LOCAL_W > 0, "local width ok");

    // Valid: @check with CONFIG from project in helper
    @check (CONFIG.WIDTH > 0, "config in helper ok");

    // Valid: @check with CONST arithmetic
    @check (LOCAL_W * 2, "double width is nonzero");

    ASYNCHRONOUS {
        data = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    CONST { SIZE = 16; }

    // Valid: @check with CONST
    @check (SIZE > 0, "size ok");

    // Valid: @check with clog2 of CONST
    @check (clog2(SIZE) == 4, "clog2 size ok");

    // Valid: @check with CONFIG
    @check (CONFIG.WIDTH == 8, "config in top ok");

    // Valid: @check with CONFIG arithmetic
    @check (CONFIG.WIDTH + CONFIG.DEPTH > 0, "config arith ok");

    // Valid: literal
    @check (1, "literal ok");

    @new inst_a HelperMod {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
