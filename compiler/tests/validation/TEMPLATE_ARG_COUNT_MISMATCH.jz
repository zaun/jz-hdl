// TEMPLATE_ARG_COUNT_MISMATCH: @apply with wrong argument count.
// Expect ERR> TEMPLATE_ARG_COUNT_MISMATCH

@project TEMPLATE_ARG_COUNT_PROJECT
  @top TEMPLATE_ARG_COUNT_MOD {
    IN  [8] in_a = _;
    OUT [8] out_a = _;
  }
@endproj

@template ADD_ONE(a, out)
  out <= a;
@endtemplate

@module TEMPLATE_ARG_COUNT_MOD
  PORT {
    IN  [8] in_a;
    OUT [8] out_a;
  }

  ASYNCHRONOUS {
    @apply ADD_ONE(in_a);
  }
@endmod
