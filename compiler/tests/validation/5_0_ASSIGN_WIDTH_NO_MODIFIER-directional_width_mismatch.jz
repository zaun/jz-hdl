// ASSIGN_WIDTH_NO_MODIFIER: Directional operators (<=, =>) with mismatched widths
// and no modifier. Tests that bare <= and => require matching widths; <=z/<=s or
// =>z/=>s needed for width mismatch. Valid same-width and extended assignments
// included as negative tests.

@project ASSIGN_WIDTH_NO_MODIFIER_directional_width_mismatch
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1]  clk = _;
        IN  [8]  din = _;
        IN  [4]  narrow = _;
        OUT [8]  dout_a = _;
        OUT [8]  dout_b = _;
        OUT [16] dout_c = _;
    }
@endproj

// Helper module: directional width mismatch in ASYNC and SYNC
@module HelperMod
    PORT {
        IN  [1]  clk;
        IN  [8]  wide_in;
        IN  [4]  narrow_in;
        OUT [16] wide_out;
        OUT [8]  dout;
    }

    REGISTER {
        r_wide [8] = 8'h00;
    }

    ASYNCHRONOUS {
        // Trigger 1: <= receive wider RHS into narrower LHS (8 <= 16, ASYNC helper)
        narrow_in <= wide_in;
        // Trigger 2: => drive narrower into wider (4 => 16, no modifier, ASYNC helper)
        narrow_in => wide_out;
        // Valid: same-width receive (no error)
        dout <= r_wide;
    }

    SYNCHRONOUS(CLK=clk) {
        // Trigger 3: <= receive with mismatch in SYNC (8 <= 4, SYNC helper)
        r_wide <= narrow_in;
    }
@endmod

@module TopMod
    PORT {
        IN  [1]  clk;
        IN  [8]  din;
        IN  [4]  narrow;
        OUT [8]  dout_a;
        OUT [8]  dout_b;
        OUT [16] dout_c;
    }

    REGISTER {
        r_narrow [4] = 4'h0;
    }

    @new inst_h HelperMod {
        IN  [1]  clk = clk;
        IN  [8]  wide_in = din;
        IN  [4]  narrow_in = narrow;
        OUT [16] wide_out = dout_c;
        OUT [8]  dout = dout_a;
    };

    ASYNCHRONOUS {
        // Trigger 4: => drive wider source into narrower sink (8 => 4, ASYNC top)
        din => narrow;
        // Valid: same-width receive and extended register read (no error)
        dout_b <=z r_narrow;
    }

    SYNCHRONOUS(CLK=clk) {
        // Trigger 5: <= receive with mismatch in SYNC (4 <= 8, SYNC top)
        r_narrow <= din;
    }
@endmod
