// LIT_VALUE_OVERFLOW: lit() value exceeds declared width.
// Tests lit(4, 20) where 20 > 2^4 - 1 = 15.
// Valid lit(8, 42) included to verify no false positives.

@project LIT_VALUE_OVERFLOW_value_exceeds_width
    @top TopMod {
        IN  [1] clk = _;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
    }
@endproj

// Helper module: lit() with overflowing value
@module HelperMod
    PORT {
        IN  [1] clk;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    REGISTER {
        r [8] = 8'd0;
    }
    ASYNCHRONOUS {
        // Trigger 1: lit(4, 20) in helper ASYNC — 20 > 15
        out_a <=z lit(4, 20);
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: lit(8, 256) in helper SYNC — 256 > 255
        r <=z lit(8, 256);
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    WIRE {
        ha_a [8];
        ha_b [8];
    }
    REGISTER {
        r [8] = 8'd0;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        OUT [8] out_a = ha_a;
        OUT [8] out_b = ha_b;
    };

    ASYNCHRONOUS {
        // Trigger 3: lit(4, 20) in top ASYNC
        out_a <=z lit(4, 20);
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 4: lit(8, 256) in top SYNC
        r <=z lit(8, 256);
    }
@endmod
