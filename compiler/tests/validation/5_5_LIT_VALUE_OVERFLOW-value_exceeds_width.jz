// LIT_VALUE_OVERFLOW: lit() value exceeds declared width.
// Tests lit() where value does not fit in the specified width across modules.
// e.g., lit(4, 20) — 20 requires 5 bits but only 4 declared.
// Valid lit(8, 255) included to verify no false positives.

@project LIT_VALUE_OVERFLOW_value_exceeds_width
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] data_in = _;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
    }
@endproj

// Helper module: lit() value overflow in async and sync
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] val;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    REGISTER {
        r [8] = 8'd0;
    }
    ASYNCHRONOUS {
        // Trigger 1: lit(8, 256) in helper async — 256 > max 8-bit value (255)
        out_a <= lit(8, 256);
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: lit(8, 300) in helper sync — 300 > max 8-bit value (255)
        r <= val | lit(8, 300);
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] data_in;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    WIRE {
        ha_a [8];
        ha_b [8];
    }
    REGISTER {
        r [8] = 8'd0;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [8] val = data_in;
        OUT [8] out_a = ha_a;
        OUT [8] out_b = ha_b;
    };

    ASYNCHRONOUS {
        // Trigger 3: lit(8, 1000) in top async — 1000 > max 8-bit value (255)
        out_a <= lit(8, 1000);
        // Valid: lit(8, 255) — 255 fits in 8 bits (no false positive)
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 4: lit(8, 512) in top sync — 512 > max 8-bit value (255)
        r <= data_in | lit(8, 512);
    }
@endmod
