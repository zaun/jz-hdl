// SIM_PROJECT_MIXED: A file contains both @project and @simulation directives.
// These cannot coexist in the same file.

@module mix_mod
    PORT {
        IN [1] clk;
        OUT [1] out;
    }
    ASYNCHRONOUS {
        out = 1'b0;
    }
@endmod

@project MixedProject
    @top mix_mod {
        IN  [1] clk = _;
        OUT [1] out = _;
    }
@endproj

@simulation mix_mod
    CLOCK {
        clk = { period=10.0 };
    }
    WIRE {
        out [1];
    }
    @new dut mix_mod {
        clk [1] = clk;
        out [1] = out;
    }
    @run(ns=100)
@endsim
