// MAP_PIN_MAPPED_NOT_DECLARED: MAP entry references a pin not declared in any PIN block.
// Tests undeclared scalar pin and undeclared bus pin in MAP.
// Valid declared+mapped pins included to verify no false positives.

@project MAP_PIN_MAPPED_NOT_DECLARED_undeclared_map_entry
    OUT_PINS {
        valid_out = { standard=LVCMOS33, drive=8 };
    }

    MAP {
        valid_out = 1;
        // Trigger 1: scalar pin not declared in any PIN block
        ghost_pin = 2;
        // Trigger 2: bus bit of undeclared pin
        ghost_bus[0] = 3;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
