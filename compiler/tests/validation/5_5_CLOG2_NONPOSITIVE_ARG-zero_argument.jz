// CLOG2_NONPOSITIVE_ARG: clog2() argument must be positive (> 0).
// Tests clog2(0) in CONST blocks across modules.
// Valid clog2(256) included to verify no false positives.

@project CLOG2_NONPOSITIVE_ARG_zero_argument
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] data_in = _;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
    }
@endproj

// Helper module: clog2(0) in CONST block
@module HelperMod
    CONST {
        // Trigger 1: clog2(0) in helper CONST
        BAD_A = clog2(0);
        // Trigger 2: second clog2(0) in helper CONST
        BAD_B = clog2(0);
        // Valid: clog2(256) = 8 (no false positive)
        GOOD = clog2(256);
    }
    PORT {
        IN  [1] clk;
        IN  [8] val;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    REGISTER {
        r [GOOD] = 8'd0;
    }
    ASYNCHRONOUS {
        out_a = val;
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= val;
    }
@endmod

@module TopMod
    CONST {
        // Trigger 3: clog2(0) in top CONST
        BAD_C = clog2(0);
        // Trigger 4: clog2(0) in top CONST
        BAD_D = clog2(0);
        // Valid: clog2(16) = 4 (no false positive)
        OK = clog2(16);
    }
    PORT {
        IN  [1] clk;
        IN  [8] data_in;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    WIRE {
        ha_a [8];
        ha_b [8];
    }
    REGISTER {
        r [OK] = 4'd0;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [8] val = data_in;
        OUT [8] out_a = ha_a;
        OUT [8] out_b = ha_b;
    };

    ASYNCHRONOUS {
        out_a = ha_a;
        out_b <=z r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= data_in[3:0];
    }
@endmod
