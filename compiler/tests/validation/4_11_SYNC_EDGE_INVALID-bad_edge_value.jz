// SYNC_EDGE_INVALID: SYNCHRONOUS block EDGE must be Rising, Falling, or Both.
// Tests invalid EDGE parameter values in multiple modules.
// Valid EDGE values included to verify no false positives.

@project SYNC_EDGE_INVALID_bad_edge_value
    @top TopMod {
        IN  [1] clk_a = _;
        IN  [1] clk_b = _;
        IN  [1] clk_c = _;
        OUT [1] data = _;
    }
@endproj

// Helper module: invalid EDGE value
@module HelperA
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        data = r;
    }
    // Trigger 1: invalid EDGE value "Positive"
    SYNCHRONOUS(CLK=clk EDGE=Positive) {
        r <= ~r;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk_a;
        IN  [1] clk_b;
        IN  [1] clk_c;
        OUT [1] data;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk_a;
        OUT [1] data = _;
    };

    REGISTER {
        r_ok [1] = 1'b0;
        r_bad [1] = 1'b0;
        r_ok2 [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r_ok;
    }

    // Valid: EDGE=Rising — should NOT trigger
    SYNCHRONOUS(CLK=clk_a EDGE=Rising) {
        r_ok <= ~r_ok;
    }

    // Trigger 2: invalid EDGE value "Negative"
    SYNCHRONOUS(CLK=clk_b EDGE=Negative) {
        r_bad <= ~r_bad;
    }

    // Valid: EDGE=Falling — should NOT trigger
    SYNCHRONOUS(CLK=clk_c EDGE=Falling) {
        r_ok2 <= ~r_ok2;
    }
@endmod
