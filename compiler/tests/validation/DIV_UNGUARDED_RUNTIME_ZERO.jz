// DIV_UNGUARDED_RUNTIME_ZERO: unguarded runtime division produces warning;
// guarded division (IF d != 0) is suppressed.
// Verified

@project DIV_UNGUARDED_RUNTIME_ZERO_PROJECT
  @top DIV_UNGUARDED_RUNTIME_ZERO_EXAMPLE {
    IN  [8] a = _;
    IN  [8] b = _;
    OUT [8] out_a = _;
    OUT [8] out_b = _;
    OUT [8] out_c = _;
    OUT [8] out_d = _;
  }
@endproj

@module DIV_UNGUARDED_RUNTIME_ZERO_EXAMPLE
  PORT {
    IN  [8] a;
    IN  [8] b;
    OUT [8] out_a;
    OUT [8] out_b;
    OUT [8] out_c;
    OUT [8] out_d;
  }

  ASYNCHRONOUS {
    // Unguarded division — should warn
    out_a <= a / b;

    // Unguarded modulus — should warn
    out_b <= a % b;

    // Guarded division — should NOT warn
    IF (b != 8'd0) {
      out_c <= a / b;
    } ELSE {
      out_c <= 8'd0;
    }

    // Guarded modulus via ELSE of == 0 — should NOT warn
    IF (b == 8'd0) {
      out_d <= 8'd0;
    } ELSE {
      out_d <= a % b;
    }
  }
@endmod
