// MEM_MULTIPLE_WDATA_ASSIGNS: Multiple .wdata assignments on INOUT port.
// Single .wdata assignment included for no false positives.

@project MEM_MULTIPLE_WDATA_ASSIGNS_inout_multi_wdata
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: multiple .wdata in helper
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    ASYNCHRONOUS {
        data = mem_a.rw.data;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_a.rw.addr <= addr;
        // First .wdata assignment
        mem_a.rw.wdata <= wdata;
        // Trigger 1: second .wdata assignment
        mem_a.rw.wdata <= 8'hFF;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_b.rw.data;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_b.rw.addr <= addr;
        // First .wdata assignment
        mem_b.rw.wdata <= wdata;
        // Trigger 2: second .wdata in top module
        mem_b.rw.wdata <= 8'hFF;
    }
@endmod
