// DUPLICATE_BLOCK: more than one SYNCHRONOUS block declared for the same
// clock signal in a module.
// Verified

@project DUPLICATE_BLOCK_PROJECT
  @top DUPLICATE_BLOCK_EXAMPLE {
    IN  [1] clk = _;
    OUT [1] out = _;
  }
@endproj

@module DUPLICATE_BLOCK_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [1] out;
  }

  REGISTER {
    r [1] = 1'b0;
  }

  ASYNCHRONOUS {
    out = r;
  }

  SYNCHRONOUS(CLK=clk) {
    r <= 1'b1;
  }

  SYNCHRONOUS(CLK=clk) {
    r <= 1'b0;
  }
@endmod
