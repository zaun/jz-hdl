// ASYNC_ALIAS_IN_CONDITIONAL: Alias = inside IF/SELECT is forbidden in ASYNC.
// Tests alias (=), zero-extend alias (=z), sign-extend alias (=s) inside
// IF, ELSE, and SELECT/CASE blocks across multiple modules. Valid directional
// assignments (<=, =>) in conditionals verify no false positives.

@project ASYNC_ALIAS_IN_CONDITIONAL_alias_in_conditional
    @top TopMod {
        IN  [1] sel = _;
        IN  [8] din_a = _;
        IN  [8] din_b = _;
        OUT [8] dout_a = _;
        OUT [8] dout_b = _;
        OUT [8] dout_c = _;
    }
@endproj

// Helper module: alias in IF body
@module HelperMod
    PORT {
        IN  [1] sel;
        IN  [8] din_a;
        IN  [8] din_b;
        OUT [8] dout;
    }

    ASYNCHRONOUS {
        // Trigger 1: alias = in IF body (helper module)
        IF (sel) {
            dout = din_a;
        } ELSE {
            // Valid: receive-assign in ELSE (no error)
            dout <= din_b;
        }
    }
@endmod

// Second helper: alias in ELSE body
@module HelperMod2
    PORT {
        IN  [1] sel;
        IN  [8] din_a;
        IN  [8] din_b;
        OUT [8] dout;
    }

    ASYNCHRONOUS {
        // Trigger 2: alias = in ELSE body (second helper)
        IF (sel) {
            dout <= din_a;
        } ELSE {
            dout = din_b;
        }
    }
@endmod

@module TopMod
    PORT {
        IN  [1] sel;
        IN  [8] din_a;
        IN  [8] din_b;
        OUT [8] dout_a;
        OUT [8] dout_b;
        OUT [8] dout_c;
    }

    @new inst_h HelperMod {
        IN  [1] sel = sel;
        IN  [8] din_a = din_a;
        IN  [8] din_b = din_b;
        OUT [8] dout = dout_a;
    };

    @new inst_h2 HelperMod2 {
        IN  [1] sel = sel;
        IN  [8] din_a = din_a;
        IN  [8] din_b = din_b;
        OUT [8] dout = dout_b;
    };

    ASYNCHRONOUS {
        // Trigger 3: alias = in SELECT/CASE body (top module)
        SELECT (sel) {
            CASE (1'b0) {
                dout_c = din_a;
            }
            DEFAULT {
                // Valid: receive-assign in DEFAULT (no error)
                dout_c <= din_b;
            }
        }
    }
@endmod
