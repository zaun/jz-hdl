// ASYNC_ALIAS_IN_CONDITIONAL: Alias = inside IF/SELECT is forbidden in ASYNC.
// Tests alias (=), zero-extend alias (=z), sign-extend alias (=s) inside
// IF, ELSE, ELIF, SELECT/CASE, DEFAULT, and nested IF blocks across
// multiple modules. Valid directional assignments (<=, =>) in conditionals
// verify no false positives.

@project ASYNC_ALIAS_IN_CONDITIONAL_alias_in_conditional
    @top TopMod {
        IN  [1] sel = _;
        IN  [1] sel2 = _;
        IN  [8] din_a = _;
        IN  [8] din_b = _;
        OUT [8] dout_a = _;
        OUT [8] dout_b = _;
        OUT [8] dout_c = _;
        OUT [8] dout_d = _;
    }
@endproj

// Helper module: alias in IF body
@module HelperMod
    PORT {
        IN  [1] sel;
        IN  [8] din_a;
        IN  [8] din_b;
        OUT [8] dout;
    }

    ASYNCHRONOUS {
        // Trigger 1: alias = in IF body (helper module)
        IF (sel) {
            dout = din_a;
        } ELSE {
            // Valid: receive-assign in ELSE (no error)
            dout <= din_b;
        }
    }
@endmod

// Second helper: alias =z in ELSE body
@module HelperMod2
    PORT {
        IN  [1] sel;
        IN  [1] narrow;
        IN  [8] din_a;
        OUT [8] dout;
    }

    ASYNCHRONOUS {
        IF (sel) {
            // Valid: receive-assign in IF (no error)
            dout <= din_a;
        } ELSE {
            // Trigger 2: alias =z in ELSE body (second helper)
            dout =z narrow;
        }
    }
@endmod

// Third helper: alias =s in ELIF body
@module HelperMod3
    PORT {
        IN  [1] sel;
        IN  [1] sel2;
        IN  [1] narrow;
        IN  [8] din_b;
        OUT [8] dout;
    }

    ASYNCHRONOUS {
        IF (sel) {
            // Valid: drive-assign in IF (no error)
            din_b => dout;
        } ELIF (sel2) {
            // Trigger 3: alias =s in ELIF body (third helper)
            dout =s narrow;
        } ELSE {
            dout <= din_b;
        }
    }
@endmod

@module TopMod
    PORT {
        IN  [1] sel;
        IN  [1] sel2;
        IN  [8] din_a;
        IN  [8] din_b;
        OUT [8] dout_a;
        OUT [8] dout_b;
        OUT [8] dout_c;
        OUT [8] dout_d;
    }

    @new inst_h HelperMod {
        IN  [1] sel = sel;
        IN  [8] din_a = din_a;
        IN  [8] din_b = din_b;
        OUT [8] dout = dout_a;
    };

    @new inst_h2 HelperMod2 {
        IN  [1] sel = sel;
        IN  [1] narrow = sel2;
        IN  [8] din_a = din_a;
        OUT [8] dout = dout_b;
    };

    @new inst_h3 HelperMod3 {
        IN  [1] sel = sel;
        IN  [1] sel2 = sel2;
        IN  [1] narrow = sel;
        IN  [8] din_b = din_b;
        OUT [8] dout = dout_c;
    };

    ASYNCHRONOUS {
        // Trigger 4: alias = in SELECT/CASE body (top module)
        SELECT (sel) {
            CASE (1'b0) {
                dout_d = din_a;
            }
            DEFAULT {
                // Trigger 5: alias = in DEFAULT body (top module)
                dout_d = din_b;
            }
        }
    }
@endmod
