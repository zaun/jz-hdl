// SSLICE_INDEX_OUT_OF_RANGE: sslice() index exceeds source width.
// Verified

@project SSLICE_INDEX_OUT_OF_RANGE_PROJECT
  @top SSLICE_INDEX_OUT_OF_RANGE_EXAMPLE {
    IN  [8] a = _;
    IN  [2] v = _;
    OUT [8] out = _;
  }
@endproj

@module SSLICE_INDEX_OUT_OF_RANGE_EXAMPLE
  PORT {
    IN  [8] a;
    IN  [2] v;
    OUT [8] out;
  }

  ASYNCHRONOUS {
    out <= sslice(a, 20, 2, v);
  }
@endmod
