// PIN_BUS_WIDTH_INVALID: Bus pin width non-integer or <= 0.
// Tests zero and negative bus widths in IN_PINS, OUT_PINS, and INOUT_PINS.
// Valid bus widths included to verify no false positives.

@project PIN_BUS_WIDTH_INVALID_bad_bus_width
    CLOCKS {
        sys_clk = { period=10 };
    }

    IN_PINS {
        sys_clk = { standard=LVCMOS33 };
        // Valid: width 1 scalar (no trigger)
        valid_in = { standard=LVCMOS33 };
        // Valid: bus width 4 (no trigger)
        valid_bus[4] = { standard=LVCMOS33 };
        // Trigger 1: zero width in IN_PINS
        bad_in[0] = { standard=LVCMOS33 };
        // Trigger 2: negative width in IN_PINS
        neg_in[-1] = { standard=LVCMOS33 };
    }

    OUT_PINS {
        // Valid: bus width 2 (no trigger)
        valid_out[2] = { standard=LVCMOS33, drive=8 };
        // Trigger 3: zero width in OUT_PINS
        bad_out[0] = { standard=LVCMOS33, drive=8 };
    }

    INOUT_PINS {
        // Valid: bus width 8 (no trigger)
        valid_io[8] = { standard=LVCMOS33, drive=4 };
        // Trigger 4: zero width in INOUT_PINS
        bad_io[0] = { standard=LVCMOS33, drive=4 };
    }

    MAP {
        sys_clk = 1;
        valid_in = 2;
        valid_bus[0] = 3;
        valid_bus[1] = 4;
        valid_bus[2] = 5;
        valid_bus[3] = 6;
        bad_in = 7;
        neg_in = 8;
        valid_out[0] = 9;
        valid_out[1] = 10;
        bad_out = 11;
        valid_io[0] = 12;
        valid_io[1] = 13;
        valid_io[2] = 14;
        valid_io[3] = 15;
        valid_io[4] = 16;
        valid_io[5] = 17;
        valid_io[6] = 18;
        valid_io[7] = 19;
        bad_io = 20;
    }

    @top TopMod {
        IN  [1] clk = sys_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
