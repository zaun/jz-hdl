// TEMPLATE_FORBIDDEN_DIRECTIVE: @feature directive in file-scoped template.
// Realistic syntax with feature guard body. Parser does not recover after
// the error, producing cascading PARSE000.

@project TEMPLATE_FORBIDDEN_DIRECTIVE_feature_in_template
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Trigger: @feature directive inside file-scoped template
@template feat_tmpl(a, b)
    @feature DEBUG {
        a <= b;
    }
@endtemplate

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
