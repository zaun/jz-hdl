// MUX_NAME_DUPLICATE: MUX identifier duplicates another identifier in the module.
// Verified

@project MUX_NAME_DUPLICATE_PROJECT
  @top MUX_NAME_DUPLICATE_EXAMPLE {
    IN  [8] data = _;
    IN  [8] sel = _;
    OUT [4] dout = _;
  }
@endproj

@module MUX_NAME_DUPLICATE_EXAMPLE
  PORT {
    IN  [8] data;
    IN  [8] sel;
    OUT [4] dout;
  }

  MUX {
    data = data; // MUX id 'data' conflicts with wire 'data'
  }

  ASYNCHRONOUS {
    dout = data[sel];
  }
@endmod
