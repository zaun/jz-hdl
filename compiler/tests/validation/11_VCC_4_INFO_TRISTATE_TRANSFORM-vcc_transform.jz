// INFO_TRISTATE_TRANSFORM: Tri-state nets transformed with --tristate-default=VCC.
// Verifies INFO_TRISTATE_TRANSFORM fires for each module containing internal
// tri-state wires when --tristate-default=VCC is active.
// Contexts: helper module with tri-state wire, top module with tri-state wire.
// Valid: INOUT port z is preserved (not transformed).

@project INFO_TRISTATE_TRANSFORM_vcc_transform
    @top TopMod {
        IN    [1] clk = _;
        IN    [1] en = _;
        OUT   [8] data = _;
        INOUT [8] bidir = _;
    }
@endproj

// Trigger 1: helper module with single-driver tri-state wire
@module HelperMod
    PORT {
        IN  [1] en;
        IN  [8] din;
        OUT [8] data;
    }

    WIRE {
        w_internal [8];
    }

    ASYNCHRONOUS {
        IF (en) {
            w_internal <= din;
        } ELSE {
            w_internal <= 8'bzzzz_zzzz;
        }
        data <= w_internal;
    }
@endmod

// Trigger 2: top module with tri-state wire and valid INOUT z usage
@module TopMod
    PORT {
        IN    [1] clk;
        IN    [1] en;
        OUT   [8] data;
        INOUT [8] bidir;
    }

    REGISTER {
        r [8] = 8'b0000_0000;
    }

    @new inst_h HelperMod {
        IN  [1] en = en;
        IN  [8] din = r;
        OUT [8] data = _;
    };

    WIRE {
        w_top [8];
    }

    ASYNCHRONOUS {
        // Trigger: tri-state wire in top module
        IF (en) {
            w_top <= r;
        } ELSE {
            w_top <= 8'bzzzz_zzzz;
        }

        // Valid: INOUT port z is preserved, not transformed
        IF (en) {
            bidir <= r;
        } ELSE {
            bidir <= 8'bzzzz_zzzz;
        }

        data <= w_top;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
