// CLOCK_EXTERNAL_NO_PERIOD: External clock (IN_PINS) must have period declared in CLOCKS block.

@project(CHIP="GW1NR-9-QN88-C6-I5") CLOCK_EXTERNAL_NO_PERIOD_TEST
  CLOCKS {
    sys_clk;
  }

  IN_PINS {
    sys_clk = { standard=LVCMOS33 };
    btn = { standard=LVCMOS33 };
  }

  OUT_PINS {
    led = { standard=LVCMOS33, drive=8 };
  }

  MAP {
    sys_clk = 4;
    btn = 10;
    led = 11;
  }

  @top top {
    IN  [1] a = btn;
    OUT [1] out = led;
  }
@endproj

@module top
  PORT {
    IN  [1] a;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = a;
  }
@endmod
