// TEMPLATE_APPLY_OUTSIDE_BLOCK: @apply may only appear inside ASYNCHRONOUS or SYNCHRONOUS blocks.
// Trigger: @apply at file scope (outside any module).
// Valid @apply inside ASYNC included for negative testing.

@project TEMPLATE_APPLY_OUTSIDE_BLOCK_apply_at_file_scope
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@template simple(a, b)
    a <= b;
@endtemplate

// Trigger 1: @apply at file scope
@apply simple(x, y);

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    WIRE {
        w1 [1];
    }

    ASYNCHRONOUS {
        // Valid: @apply inside ASYNC (no error)
        @apply simple(w1, r);
        data = w1;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
