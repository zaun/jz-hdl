// COMB_LOOP_UNCONDITIONAL: Cycle through instance port binding.
// Tests that a combinational loop through an instance's ports is detected:
// a wire drives the instance input, the instance output (which depends on
// the input combinationally) drives the same wire.
// Valid instance without feedback included to verify no false positives.

@project COMB_LOOP_UNCONDITIONAL_instance_port_cycle
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] in_a = _;
        OUT [1] out_a = _;
        OUT [1] out_b = _;
    }
@endproj

// Passthrough module: output depends combinationally on input
@module Passthrough
    PORT {
        IN  [1] din;
        OUT [1] dout;
    }

    ASYNCHRONOUS {
        dout = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] in_a;
        OUT [1] out_a;
        OUT [1] out_b;
    }

    WIRE {
        feedback [1];
    }

    // Trigger 1: cycle through instance — feedback -> inst.din -> inst.dout -> feedback
    @new inst_loop Passthrough {
        IN  [1] din = feedback;
        OUT [1] dout = feedback;
    };

    // Valid: no feedback loop — input drives instance, output goes elsewhere
    @new inst_ok Passthrough {
        IN  [1] din = in_a;
        OUT [1] dout = out_b;
    };

    ASYNCHRONOUS {
        out_a = feedback;
    }
@endmod
