// CLOG2_INVALID_CONTEXT: clog2() used outside compile-time constant context.
// Tests clog2() in ASYNC and SYNC blocks where it is forbidden.
// clog2() is compile-time only and must not appear in runtime expressions.
// Valid clog2() in CONST block included to verify no false positives.

@project CLOG2_INVALID_CONTEXT_runtime_expression
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] data_in = _;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
    }
@endproj

// Helper module: clog2() in async and sync blocks
@module HelperMod
    CONST {
        // Valid: clog2() in CONST block (no false positive)
        BITS = clog2(16);
    }
    PORT {
        IN  [1] clk;
        IN  [8] val;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    REGISTER {
        r [8] = 8'd0;
    }
    ASYNCHRONOUS {
        // Trigger 1: clog2() in helper async expression
        out_a <= clog2(256);
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: clog2() in helper sync expression
        r <= val | clog2(16);
    }
@endmod

@module TopMod
    CONST {
        // Valid: clog2() in CONST block (no false positive)
        ADDR_W = clog2(64);
    }
    PORT {
        IN  [1] clk;
        IN  [8] data_in;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    WIRE {
        ha_a [8];
        ha_b [8];
    }
    REGISTER {
        r [8] = 8'd0;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [8] val = data_in;
        OUT [8] out_a = ha_a;
        OUT [8] out_b = ha_b;
    };

    ASYNCHRONOUS {
        // Trigger 3: clog2() in top async expression
        out_a <= clog2(32);
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 4: clog2() in top sync expression
        r <= data_in | clog2(8);
    }
@endmod
