// MEM_IN_PORT_FIELD_ACCESS: Using .addr or .data field on IN (write) port.
// IN ports require bracket syntax mem.port[addr] <= data.
// Valid bracket write included for no false positives.

@project MEM_IN_PORT_FIELD_ACCESS_write_port_dot_field
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Helper: .addr and .data on IN port
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        data = mem_a.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        // Valid: bracket write
        mem_a.wr[addr] <= wdata;
        // Trigger 1: .addr on IN port
        mem_a.wr.addr <= addr;
        // Trigger 2: .data on IN port
        mem_a.wr.data <= wdata;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_b.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_b.wr[addr] <= wdata;
        // Trigger 3: .addr on IN port in top
        mem_b.wr.addr <= addr;
        // Trigger 4: .data on IN port in top
        mem_b.wr.data <= wdata;
    }
@endmod
