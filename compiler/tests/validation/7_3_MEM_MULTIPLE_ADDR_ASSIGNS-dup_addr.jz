// MEM_MULTIPLE_ADDR_ASSIGNS: Multiple assignments to INOUT .addr within same
// execution path. Valid single .addr assignment included for no false positives.

@project MEM_MULTIPLE_ADDR_ASSIGNS_dup_addr
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [4] addr2 = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [4] addr2;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    ASYNCHRONOUS {
        data = mem_a.rw.data;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        // First assignment to .addr (valid)
        mem_a.rw.addr <= addr;
        mem_a.rw.wdata <= wdata;
        // Trigger: second assignment to same .addr
        mem_a.rw.addr <= addr2;
    }
@endmod
