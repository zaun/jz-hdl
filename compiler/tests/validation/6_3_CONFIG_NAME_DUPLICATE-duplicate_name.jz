// CONFIG_NAME_DUPLICATE: Duplicate config_id within CONFIG block.
// Tests multiple entries with the same name.
// Valid unique entries included to verify no false positives.

@project CONFIG_NAME_DUPLICATE_duplicate_name
    CONFIG {
        // Valid: unique names
        ALPHA = 8;
        BETA = 16;
        // Trigger 1: duplicate of ALPHA
        ALPHA = 32;
        // Trigger 2: duplicate of BETA
        BETA = 64;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        data = r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
