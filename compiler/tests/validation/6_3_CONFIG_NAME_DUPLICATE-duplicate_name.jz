// CONFIG_NAME_DUPLICATE: Duplicate config_id within CONFIG block.
// Tests multiple entries with the same name.
// Valid unique entries included to verify no false positives.

@project CONFIG_NAME_DUPLICATE_duplicate_name
    CONFIG {
        // Valid: unique names
        ALPHA = 8;
        BETA = 16;
        GAMMA = 32;
        // Trigger 1: duplicate of ALPHA
        ALPHA = 64;
        // Trigger 2: duplicate of BETA
        BETA = 128;
        // Trigger 3: duplicate of GAMMA
        GAMMA = 256;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module Helper
    PORT {
        IN  [1] din;
        OUT [1] dout;
    }
    ASYNCHRONOUS {
        dout = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    @new inst_h Helper {
        IN  [1] din = r;
        OUT [1] dout = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
