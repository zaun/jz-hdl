// TEMPLATE_IDX_SLICE_OUT_OF_RANGE: @apply with IDX-based slice expressions
// that exceed signal width after template expansion.
// With COUNT=4 and width 11 per element, IDX=3 produces [43:33] but the
// register is only 32 bits wide (indices 0..31).

@project TEMPLATE_IDX_SLICE_OUT_OF_RANGE_PROJECT
  @top TEMPLATE_IDX_SLICE_OUT_OF_RANGE_MOD {
    IN  [1] clk = _;
    OUT [32] out = _;
  }
@endproj

@template BAD_SLICE(dst, src)
  dst[IDX*11+10:IDX*11] <= src;
@endtemplate

@module TEMPLATE_IDX_SLICE_OUT_OF_RANGE_MOD
  PORT {
    IN  [1] clk;
    OUT [32] out;
  }

  REGISTER {
    data [32] = 32'd0;
  }

  SYNCHRONOUS(CLK=clk) {
    @apply [4] BAD_SLICE(data, 11'd0);
  }

  ASYNCHRONOUS {
    out = data;
  }
@endmod
