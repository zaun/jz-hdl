// HAPPY_PATH: Valid operator usage across all S3.2 operator definitions.
// Exercises parenthesized unary arithmetic, multiply 2N width, guarded division
// and modulus with multiple guard patterns (!=, >, >=, ==, nested), logical/arithmetic
// shift, ternary with valid condition and matching widths, concatenation MSB ordering,
// bitwise ops, logical ops on 1-bit, comparison operators, and edge cases.

@project HAPPY_PATH_operator_semantics_ok
    CONFIG {
        WIDTH = 8;
    }
    @top TopMod {
        IN  [1]  clk = _;
        IN  [8]  a = _;
        IN  [8]  b = _;
        IN  [3]  sh = _;
        IN  [1]  flag = _;
        IN  [1]  bit_b = _;
        IN  [4]  nibble = _;
        OUT [8]  out_unary = _;
        OUT [16] out_mul = _;
        OUT [8]  out_shift = _;
        OUT [8]  out_tern = _;
        OUT [12] out_cat = _;
        OUT [8]  out_div = _;
        OUT [1]  out_log = _;
        OUT [1]  out_cmp = _;
    }
@endproj

// Helper module: shift operations, unary arithmetic, bitwise ops
@module HelperOps
    PORT {
        IN  [1] clk;
        IN  [8] a;
        IN  [8] b;
        IN  [3] sh;
        OUT [8] out_unary;
        OUT [8] out_shift;
        OUT [1] out_cmp;
    }
    REGISTER {
        r_asr [8] = 8'h00;
        r_sh0 [8] = 8'h00;
    }
    ASYNCHRONOUS {
        // Parenthesized unary minus — valid
        out_unary = (-a);
        // Logical shift left — zero-fill from right
        // Logical shift right — zero-fill from left
        out_shift = (a << sh) | (a >> sh) | r_asr | r_sh0;
        // Comparison operators: all valid with equal-width operands
        out_cmp = (a == b) | (a != b) | (a < b) | (a > b) | (a <= b) | (a >= b);
    }
    SYNCHRONOUS(CLK=clk) {
        // Arithmetic shift right — MSB replicated
        r_asr <= a >>> sh;
        // Edge case: shift by zero — no change
        r_sh0 <= a << 3'd0;
    }
@endmod

@module TopMod
    PORT {
        IN  [1]  clk;
        IN  [8]  a;
        IN  [8]  b;
        IN  [3]  sh;
        IN  [1]  flag;
        IN  [1]  bit_b;
        IN  [4]  nibble;
        OUT [8]  out_unary;
        OUT [16] out_mul;
        OUT [8]  out_shift;
        OUT [8]  out_tern;
        OUT [12] out_cat;
        OUT [8]  out_div;
        OUT [1]  out_log;
        OUT [1]  out_cmp;
    }
    WIRE {
        h_unary [8];
        h_shift [8];
        h_cmp   [1];
    }
    REGISTER {
        r_div  [8] = 8'd0;
        r_mod  [8] = 8'd0;
        r_gt   [8] = 8'd0;
        r_ge   [8] = 8'd0;
        r_eq   [8] = 8'd0;
        r_nest [8] = 8'd0;
        r_else [8] = 8'd0;
    }

    @new inst_ops HelperOps {
        IN  [1] clk = clk;
        IN  [8] a = a;
        IN  [8] b = b;
        IN  [3] sh = sh;
        OUT [8] out_unary = h_unary;
        OUT [8] out_shift = h_shift;
        OUT [1] out_cmp = h_cmp;
    };

    ASYNCHRONOUS {
        // Parenthesized unary plus — valid
        out_unary = (+a) | h_unary;
        // Multiply 8-bit * 8-bit = 16-bit result (2N width)
        out_mul = a * b;
        // Shift operations from helper
        out_shift = h_shift;
        // Ternary with 1-bit condition and matching 8-bit branches — valid
        out_tern = flag ? a : b;
        // Concatenation: MSB ordering, 8+4 = 12 bits; single-element concat
        out_cat = {a, nibble};
        // Division results from registers
        out_div = r_div | r_mod | r_gt | r_ge | r_eq | r_nest | r_else;
        // Logical operators on 1-bit operands — valid
        out_log = (flag && bit_b) | (flag || bit_b) | (!flag);
        // Comparison from helper
        out_cmp = h_cmp;
    }
    SYNCHRONOUS(CLK=clk) {
        // Guarded division: != 0 pattern
        IF (b != 8'd0) {
            r_div <= a / b;
            r_mod <= a % b;
        } ELSE {
            r_div <= 8'd0;
            r_mod <= 8'd0;
        }
        // Guarded division: > 0 pattern
        IF (b > 8'd0) {
            r_gt <= a / b;
        } ELSE {
            r_gt <= 8'd0;
        }
        // Guarded division: >= 1 pattern
        IF (b >= 8'd1) {
            r_ge <= a / b;
        } ELSE {
            r_ge <= 8'd0;
        }
        // Guarded division: == nonzero constant pattern
        IF (b == 8'd5) {
            r_eq <= a / b;
        } ELSE {
            r_eq <= 8'd0;
        }
        // Nested guard: outer IF proves nonzero, inner uses division
        IF (b != 8'd0) {
            IF (a > 8'd10) {
                r_nest <= a / b;
            } ELSE {
                r_nest <= 8'd0;
            }
        } ELSE {
            r_nest <= 8'd0;
        }
        // Guard on ELSE branch: == 0 then ... else division
        IF (b == 8'd0) {
            r_else <= 8'd0;
        } ELSE {
            r_else <= a / b;
        }
    }
@endmod
