// MEM_MULTIPLE_WRITES_SAME_IN: Multiple writes to same IN port in one SYNC block.
// Valid single write included for no false positives.

@project MEM_MULTIPLE_WRITES_SAME_IN_double_write
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [4] addr2 = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Helper: multiple writes to same IN port
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [4] addr2;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        data = mem_a.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        // First write (valid)
        mem_a.wr[addr] <= wdata;
        // Trigger 1: second write to same IN port
        mem_a.wr[addr2] <= wdata;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [4] addr2;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [4] addr2 = addr2;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_b.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_b.wr[addr] <= wdata;
        // Trigger 2: second write to same IN port in top
        mem_b.wr[addr2] <= wdata;
    }
@endmod
