// SBIT_INDEX_OUT_OF_RANGE: sbit() index is out of range for source width.
// Tests sbit() with constant index >= source width in ASYNC and SYNC blocks.
// Valid sbit() with in-range index included to verify no false positives.

@project SBIT_INDEX_OUT_OF_RANGE_const_index_exceeds_width
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] data = _;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
    }
@endproj

// Helper module: sbit() with out-of-range constant index
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] src;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    REGISTER {
        r [8] = 8'd0;
    }
    ASYNCHRONOUS {
        // Trigger 1: sbit() index 8 on 8-bit source (max valid = 7) in helper ASYNC
        out_a <= sbit(src, 4'd8, 1'b1);
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: sbit() index 8 in helper SYNC
        r <= sbit(src, 4'd8, 1'b1);
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] data;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    WIRE {
        ha_a [8];
        ha_b [8];
    }
    REGISTER {
        r [8] = 8'd0;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [8] src = data;
        OUT [8] out_a = ha_a;
        OUT [8] out_b = ha_b;
    };

    ASYNCHRONOUS {
        // Trigger 3: sbit() index 8 in top ASYNC
        out_a <= sbit(data, 4'd8, 1'b1);
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 4: sbit() index 8 in top SYNC
        r <= sbit(data, 4'd8, 1'b1);
    }
@endmod
