// CHECK_FAILED: Consolidated test for @check with false (zero) expressions.
// S9.7 cross-references all @check error conditions. This test exercises
// CHECK_FAILED at project scope, top module scope, and helper module scope.
// Valid true @check assertions included for negative testing.

@project CHECK_FAILED_false_assertion
    CONFIG {
        WIDTH = 8;
    }

    // Valid: true @check at project scope (no error)
    @check (CONFIG.WIDTH == 8, "width is 8");

    // Trigger 1: false @check at project scope — CONFIG comparison fails
    @check (CONFIG.WIDTH == 16, "width must be 16");

    // Trigger 2: false @check at project scope — expression evaluates to zero
    @check (CONFIG.WIDTH - 8, "width minus 8 nonzero");

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Helper module — triggers CHECK_FAILED in module scope
@module HelperMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    CONST { SIZE = 4; }

    // Valid: true @check in helper (no error)
    @check (SIZE > 0, "size positive");

    // Trigger 3: false @check in helper — CONST comparison fails
    @check (SIZE == 8, "size must be 8");

    // Trigger 4: false @check in helper — literal zero
    @check (0, "literal zero");

    ASYNCHRONOUS {
        data = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    CONST { DEPTH = 16; }
    CONST { ADDR_W = 3; }

    // Valid: true @check in top module (no error)
    @check (DEPTH > 0, "depth positive");

    // Trigger 5: false @check in top — clog2 mismatch
    @check (ADDR_W == clog2(DEPTH), "addr width must match depth");

    // Trigger 6: false @check in top — logical AND evaluates to false
    @check (1 && 0, "logical and fails");

    @new inst_a HelperMod {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
