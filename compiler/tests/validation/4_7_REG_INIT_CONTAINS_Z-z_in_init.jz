// REG_INIT_CONTAINS_Z: Register initialization literal must not contain z bits.
// Each trigger tests z in register init in different formats and modules.
// Valid registers without z included for no false positives.

@project REG_INIT_CONTAINS_Z_z_in_init
    @top TopMod {
        IN  [1] clk = _;
        OUT [8] dout = _;
        OUT [8] dout_h = _;
    }
@endproj

// Helper module: register init with z bits
@module HelperMod
    PORT {
        IN  [1] clk;
        OUT [8] data_out;
    }

    REGISTER {
        // Trigger 1: binary literal with z bits in helper module
        r_zbin [8] = 8'bzzzz_0000;
        // Trigger 2: single z bit in binary
        r_zone [8] = 8'b0000_000z;
        // Valid: no z bits
        r_ok [8] = 8'h00;
    }

    ASYNCHRONOUS {
        data_out = r_ok;
    }

    SYNCHRONOUS(CLK=clk) {
        r_zbin <= ~r_zbin;
        r_zone <= ~r_zone;
        r_ok <= ~r_ok;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [8] dout;
        OUT [8] dout_h;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        OUT [8] data_out = dout_h;
    };

    REGISTER {
        // Trigger 3: all z bits in top module
        r_zall [8] = 8'bzzzz_zzzz;
        // Trigger 4: 1-bit z
        r_z1 [1] = 1'bz;
        // Valid: no z bits
        r_ok [8] = 8'hFF;
    }

    ASYNCHRONOUS {
        dout = r_ok;
    }

    SYNCHRONOUS(CLK=clk) {
        r_zall <= ~r_zall;
        r_z1 <= ~r_z1;
        r_ok <= ~r_ok;
    }
@endmod
