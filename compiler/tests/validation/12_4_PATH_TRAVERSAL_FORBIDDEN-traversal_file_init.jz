// PATH_TRAVERSAL_FORBIDDEN: Path with '..' traversal in @file() MEM init
// forbidden without --allow-traversal.

@project PATH_TRAVERSAL_FORBIDDEN_traversal_file_init
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        OUT [8] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 1: @file() with .. traversal in MEM init
    MEM {
        mem_trav [8] [16] = @file("../escape/init.bin") {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        data = mem_trav.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_trav.wr[addr] <= 8'h00;
    }
@endmod
