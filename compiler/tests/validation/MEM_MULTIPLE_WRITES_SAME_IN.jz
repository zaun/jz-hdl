// MEM_MULTIPLE_WRITES_SAME_IN: multiple writes to same MEM OUT port in one SYNCHRONOUS block.
// Verified

@project MEM_MULTIPLE_WRITES_SAME_IN_PROJECT
  @top MEM_MULTIPLE_WRITES_SAME_IN_EXAMPLE {
    IN  [1] clk = _;
    IN  [8] din = _;
    IN  [4] addr_a = _;
    IN  [4] addr_b = _;
    OUT [8] dout = _;
  }
@endproj

@module MEM_MULTIPLE_WRITES_SAME_IN_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [8] din;
    IN  [4] addr_a;
    IN  [4] addr_b;
    OUT [8] dout;
  }

  MEM {
    mem0 [8] [16] = 8'h00 {
      OUT rd ASYNC;
      IN  wr;
    };
  }

  ASYNCHRONOUS {
    dout = mem0.rd[addr_a];
  }

  SYNCHRONOUS(CLK=clk) {
    // Two writes to the same OUT port 'wr' in a single block are illegal,
    // even though they target different addresses.
    mem0.wr[addr_a] <= din;
    mem0.wr[addr_b] <= din;
  }
@endmod