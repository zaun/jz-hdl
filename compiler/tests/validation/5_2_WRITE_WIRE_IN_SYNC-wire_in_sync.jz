// WRITE_WIRE_IN_SYNC: Cannot assign to WIRE in SYNCHRONOUS block.
// Tests wire assignment in SYNC root, IF body, ELIF body, ELSE body,
// SELECT/CASE body, and DEFAULT body across multiple modules.
// Valid wire usage in ASYNCHRONOUS blocks included to verify no false positives.
// Note: WRITE_WIRE_IN_SYNC fires alongside ASSIGN_TO_NON_REGISTER_IN_SYNC
// but suppresses it due to higher priority (2 vs 1).

@project WRITE_WIRE_IN_SYNC_wire_in_sync
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] data = _;
        IN  [1] sel = _;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
    }
@endproj

// Helper module: trigger wire write in SYNC root
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] data;
        OUT [8] out_a;
    }
    WIRE {
        w_helper [8];
    }
    REGISTER {
        r [8] = 8'h00;
    }
    ASYNCHRONOUS {
        // Valid: wire driven in ASYNC
        w_helper <= data;
        out_a <= w_helper;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 1: wire assigned at SYNC root (helper module)
        w_helper <= r;
        r <= data;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] data;
        IN  [1] sel;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    WIRE {
        w_top [8];
        w_branch [8];
    }
    REGISTER {
        r [8] = 8'h00;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [8] data = data;
        OUT [8] out_a = _;
    };

    ASYNCHRONOUS {
        // Valid: wire driven in ASYNC
        w_top <= data;
        w_branch <= data;
        out_a <= w_top | w_branch;
        out_b <= r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: wire assigned at SYNC root (top module)
        w_top <= r;
        // Trigger 3: wire assigned inside IF body in SYNC
        IF (sel) {
            w_branch <= data;
        // Trigger 4: wire assigned inside ELIF body in SYNC
        } ELIF (data[0:0]) {
            w_branch <= r;
        // Trigger 5: wire assigned inside ELSE body in SYNC
        } ELSE {
            w_branch <= 8'h00;
        }
        // Trigger 6: wire assigned inside SELECT/CASE body in SYNC
        SELECT (data[1:0]) {
            CASE (2'b00) {
                w_top <= 8'h00;
            }
            // Trigger 7: wire assigned inside DEFAULT body in SYNC
            DEFAULT {
                w_top <= 8'hFF;
            }
        }
        r <= data;
    }
@endmod
