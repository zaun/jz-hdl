// TOP_PORT_SIGNAL_WIDTH_MISMATCH: binding width does not match pin width.
// Verified

@project TOP_PORT_SIGNAL_WIDTH_MISMATCH_EXAMPLE
  IN_PINS {
    btn[2] = { standard=LVCMOS33 };
  }

  OUT_PINS {
    led[3] = { standard=LVCMOS33, drive=8 };
  }

  CLOCKS {
    clk = { period=10 };
  }

  IN_PINS {
    clk = { standard=LVCMOS33 };
  }

  MAP {
    clk = 1;
    btn[0] = 2;
    btn[1] = 3;
    led[0] = 4;
    led[1] = 5;
    led[2] = 6;
  }

  @top top {
    IN  [1] clk  = clk;
    IN  [4] sw   = btn;
    OUT [6] leds = led;
  }
@endproj

@module top
  PORT {
    IN  [1] clk;
    IN  [4] sw;
    OUT [6] leds;
  }

  ASYNCHRONOUS {
    leds <= sw;
  }
@endmod
