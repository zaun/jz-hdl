// FUNC_RESULT_TRUNCATED_SILENTLY: builtin function result is wider than the
// destination and would be truncated without an explicit slice.
// Verified

@project FUNC_RESULT_TRUNCATED_SILENTLY_PROJECT
  @top FUNC_RESULT_TRUNCATED_SILENTLY_EXAMPLE {
    IN  [1] clk = _;
    IN  [8] a = _;
    IN  [8] b = _;
    OUT [8] out = _;
  }
@endproj

@module FUNC_RESULT_TRUNCATED_SILENTLY_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [8] a;
    IN  [8] b;
    OUT [8] out;
  }

  REGISTER {
    sum [8] = 8'h00;
  }

  ASYNCHRONOUS {
    out = sum;
  }

  SYNCHRONOUS(CLK=clk) {
    // uadd(a, b) produces 9 bits; assigning to 8-bit 'sum' truncates the MSB.
    sum <= uadd(a, b);
  }
@endmod
