// PROJECT_MISSING_TOP_MODULE: Project has no @top directive.
// Single trigger: project-level error, only one @project per file.

@project PROJECT_MISSING_TOP_MODULE_no_top_directive
    CONFIG {
        WIDTH = 8;
    }
@endproj

@module SomeModule
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        data = r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
