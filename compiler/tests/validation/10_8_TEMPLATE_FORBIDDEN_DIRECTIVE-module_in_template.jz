// TEMPLATE_FORBIDDEN_DIRECTIVE: Cross-reference test for S10.4 @module directive in template.
// Parser does not recover after the error, producing cascading PARSE000.
// Split from @new trigger for this reason.

@project TEMPLATE_FORBIDDEN_DIRECTIVE_module_in_template
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Trigger: @module directive inside file-scoped template
@template mod_tmpl(a, b)
    @module InnerMod
        PORT {
            IN  [1] din;
            OUT [1] data;
        }
        ASYNCHRONOUS {
            data = din;
        }
    @endmod
@endtemplate

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
