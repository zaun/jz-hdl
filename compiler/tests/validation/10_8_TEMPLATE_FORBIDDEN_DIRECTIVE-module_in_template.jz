// TEMPLATE_FORBIDDEN_DIRECTIVE: Cross-reference test for S10.4 @module directive in template.
// Tests @module inside file-scoped and module-scoped templates.
// Split from other directive triggers due to potential parser recovery issues.

@project TEMPLATE_FORBIDDEN_DIRECTIVE_module_in_template
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Trigger 1: @module directive inside file-scoped template
@template mod_tmpl(a, b)
    @module InnerMod
        PORT {
            IN  [1] din;
            OUT [1] data;
        }
        ASYNCHRONOUS {
            data = din;
        }
    @endmod
@endtemplate

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    // Trigger 2: @module directive inside module-scoped template
    @template mod_mod(a, b)
        @module InnerMod2
            PORT {
                IN  [1] din;
                OUT [1] data;
            }
            ASYNCHRONOUS {
                data = din;
            }
        @endmod
    @endtemplate

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
