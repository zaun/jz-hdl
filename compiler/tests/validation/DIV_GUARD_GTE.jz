// DIV_GUARD_GTE: IF (b >= N) proves b nonzero in THEN when N >= 1.
// Verified

@project DIV_GUARD_GTE_PROJECT
  @top DIV_GUARD_GTE_EXAMPLE {
    IN  [8] a = _;
    IN  [8] b = _;
    OUT [8] out_a = _;
    OUT [8] out_b = _;
  }
@endproj

@module DIV_GUARD_GTE_EXAMPLE
  PORT {
    IN  [8] a;
    IN  [8] b;
    OUT [8] out_a;
    OUT [8] out_b;
  }

  ASYNCHRONOUS {
    // IF (b >= 1) THEN: b >= 1 → nonzero — should NOT warn
    IF (b >= 8'd1) {
      out_a <= a / b;
    } ELSE {
      out_a <= 8'd0;
    }

    // IF (b >= 5) THEN: b >= 5 → nonzero — should NOT warn
    IF (b >= 8'd5) {
      out_b <= a / b;
    } ELSE {
      out_b <= 8'd0;
    }
  }
@endmod
