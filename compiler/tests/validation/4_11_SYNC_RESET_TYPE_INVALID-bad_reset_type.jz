// SYNC_RESET_TYPE_INVALID: SYNCHRONOUS block RESET_TYPE must be Clocked or Immediate.
// Tests invalid RESET_TYPE parameter values in multiple modules.
// Valid RESET_TYPE values included to verify no false positives.

@project SYNC_RESET_TYPE_INVALID_bad_reset_type
    @top TopMod {
        IN  [1] clk_a = _;
        IN  [1] clk_b = _;
        IN  [1] clk_c = _;
        IN  [1] rst = _;
        OUT [1] data = _;
    }
@endproj

// Helper module: invalid RESET_TYPE value
@module HelperA
    PORT {
        IN  [1] clk;
        IN  [1] rst;
        OUT [1] data;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        data = r;
    }
    // Trigger 1: invalid RESET_TYPE value "Async"
    SYNCHRONOUS(CLK=clk RESET=rst RESET_TYPE=Async) {
        r <= ~r;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk_a;
        IN  [1] clk_b;
        IN  [1] clk_c;
        IN  [1] rst;
        OUT [1] data;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk_a;
        IN  [1] rst = rst;
        OUT [1] data = _;
    };

    REGISTER {
        r_ok [1] = 1'b0;
        r_bad [1] = 1'b0;
        r_ok2 [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r_ok;
    }

    // Valid: RESET_TYPE=Clocked — should NOT trigger
    SYNCHRONOUS(CLK=clk_a RESET=rst RESET_TYPE=Clocked) {
        r_ok <= ~r_ok;
    }

    // Trigger 2: invalid RESET_TYPE value "Synchronous"
    SYNCHRONOUS(CLK=clk_b RESET=rst RESET_TYPE=Synchronous) {
        r_bad <= ~r_bad;
    }

    // Valid: RESET_TYPE=Immediate — should NOT trigger
    SYNCHRONOUS(CLK=clk_c RESET=rst RESET_TYPE=Immediate) {
        r_ok2 <= ~r_ok2;
    }
@endmod
