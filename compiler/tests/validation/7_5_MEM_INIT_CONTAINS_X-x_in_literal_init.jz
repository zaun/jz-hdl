// MEM_INIT_CONTAINS_X: Memory init literals containing x bits trigger error.
// Triggers: partial x in binary (helper), all-x binary (top).
// Valid init (no x) included for no false positives.

@project MEM_INIT_CONTAINS_X_x_in_literal_init
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: x in binary literal init in helper module
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'b1100_x100 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        data = mem_a.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_a.wr[addr] <= 8'h00;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 2: all-x binary literal init in top module
    MEM {
        mem_b [8] [16] = 8'bxxxx_xxxx {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    // Valid: no x in init (no error expected)
    MEM {
        mem_ok [8] [16] = 8'h00 {
            OUT rd_ok ASYNC;
            IN  wr_ok;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_b.rd[addr] ^ mem_ok.rd_ok[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_b.wr[addr] <= 8'h00;
        mem_ok.wr_ok[addr] <= 8'h00;
    }
@endmod
