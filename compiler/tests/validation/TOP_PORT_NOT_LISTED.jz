// TOP_PORT_NOT_LISTED: top module port omitted from project-level @new block.
// Verified

@project TOP_PORT_NOT_LISTED_PROJECT
  IN_PINS {
    clk   = { standard=LVCMOS33 };
    reset = { standard=LVCMOS33 };
  }

  MAP {
    clk = 10;
    reset = 11;
  }

  @top TOP_PORT_NOT_LISTED_EXAMPLE {
    IN [1] clk = clk;
    IN [1] reset = reset;
  }
@endproj

@module TOP_PORT_NOT_LISTED_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [1] reset;
    OUT [1] data;
  }

  REGISTER {
    r [1] = 1'b0;
  }

  ASYNCHRONOUS {
    data = r;
  }

  SYNCHRONOUS(CLK=clk RESET=reset) {
    r <= 1'b1;
  }
@endmod
