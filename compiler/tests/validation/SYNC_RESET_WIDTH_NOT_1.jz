// SYNC_RESET_WIDTH_NOT_1: SYNCHRONOUS block RESET signal must have width [1].
// Verified

@project SYNC_RESET_WIDTH_NOT_1_PROJECT
  @top SYNC_RESET_WIDTH_NOT_1_EXAMPLE {
    IN  [1] clk = _;
    IN  [4] rst4 = _;
    OUT [8] out = _;
  }
@endproj

@module SYNC_RESET_WIDTH_NOT_1_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [4] rst4;
    OUT [8] out;
  }

  REGISTER {
    r [8] = 8'h00;
  }

  ASYNCHRONOUS {
    out <= r;
  }

  SYNCHRONOUS(CLK=clk RESET=rst4) {
    r <= 8'h01;
  }
@endmod
