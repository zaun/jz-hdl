// SBIT_SET_WIDTH_NOT_1: sbit() third argument must be width-1.
// Verified

@project SBIT_SET_WIDTH_NOT_1_PROJECT
  @top SBIT_SET_WIDTH_NOT_1_EXAMPLE {
    IN  [8] a = _;
    OUT [8] out = _;
  }
@endproj

@module SBIT_SET_WIDTH_NOT_1_EXAMPLE
  PORT {
    IN  [8] a;
    OUT [8] out;
  }

  ASYNCHRONOUS {
    out <= sbit(a, 0, 2'b11);
  }
@endmod
