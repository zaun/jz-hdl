// ASSIGN_TRUNCATES: directional assignment with z/s modifier that would truncate RHS bits.
// Expect ERR> ASSIGN_TRUNCATES on the assignment to 'narrow'.
// Verified

@project ASSIGN_TRUNCATES_PROJECT
  @top ASSIGN_TRUNCATES_EXAMPLE {
    IN    [8] wide = _;
    INOUT [4] narrow_z = _;
    OUT   [4] narrow_s = _;
    OUT   [8] fits = _;
  }
@endproj

@module ASSIGN_TRUNCATES_EXAMPLE
  PORT {
    IN    [8] wide;
    INOUT [4] narrow_z;
    OUT   [4] narrow_s;
    OUT   [8] fits;
  }

  ASYNCHRONOUS {
    // LHS (driver) is 8 bits, RHS (sink) is 4 bits; even with =>z or =>s this would
    // truncate driver bits into a narrower sink.
    wide =>z narrow_z;
    wide =>s narrow_s;
    wide =>s fits;
  }
@endmod
