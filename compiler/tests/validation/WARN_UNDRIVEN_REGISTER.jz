// WARN_UNDRIVEN_REGISTER: register is read but never written.

@project WARN_UNDRIVEN_REGISTER_PROJECT
  @top WARN_UNDRIVEN_REGISTER_EXAMPLE {
    IN  [1] clk = _;
    OUT [8] data = _;
  }
@endproj

@module WARN_UNDRIVEN_REGISTER_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [8] data;
  }

  REGISTER {
    r [8] = 8'h00; // read but never written
  }

  ASYNCHRONOUS {
    data <= r;
  }

  SYNCHRONOUS(CLK=clk) {
    // Empty body; 'r' is never assigned.
  }
@endmod
