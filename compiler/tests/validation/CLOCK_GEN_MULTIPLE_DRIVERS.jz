// CLOCK_GEN_MULTIPLE_DRIVERS: Two CLOCK_GEN outputs drive the same clock name.

@project CLOCK_GEN_MULTIPLE_DRIVERS_TEST
  CLOCKS {
    sys_clk = { period=10 };
    fast_clk;
  }

  IN_PINS {
    sys_clk = { standard=LVCMOS33 };
    btn = { standard=LVCMOS33 };
  }

  OUT_PINS {
    led = { standard=LVCMOS33, drive=8 };
  }

  CLOCK_GEN {
    PLL {
      IN REF_CLK sys_clk;
      OUT BASE fast_clk;
      CONFIG {
        IDIV = 1;
      };
    };
    PLL {
      IN REF_CLK sys_clk;
      OUT BASE fast_clk;
      CONFIG {
        IDIV = 1;
      };
    };
  }

  MAP {
    sys_clk = 1;
    btn = 2;
    led = 3;
  }

  @top top {
    IN  [1] a = btn;
    OUT [1] out = led;
  }
@endproj

@module top
  PORT {
    IN  [1] a;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = a;
  }
@endmod
