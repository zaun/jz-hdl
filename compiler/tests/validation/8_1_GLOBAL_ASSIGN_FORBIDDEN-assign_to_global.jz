// GLOBAL_ASSIGN_FORBIDDEN: Assigning to a global constant is forbidden.
// Tests assignment to globals in ASYNCHRONOUS and SYNCHRONOUS blocks across multiple modules.
// Valid reads of globals are included to verify no false positives.

@global CMD
    READ  = 4'b0001;
    WRITE = 4'b0010;
    RESET = 4'b0100;
@endglob

@project GLOBAL_ASSIGN_FORBIDDEN_assign_to_global
    @top TopMod {
        IN  [1] clk = _;
        OUT [4] data = _;
    }
@endproj

// Helper module — triggers assignment to global in async block
@module HelperA
    PORT {
        IN  [1] clk;
        OUT [4] data;
    }
    REGISTER {
        r [4] = 4'b0000;
    }
    ASYNCHRONOUS {
        // Valid: reading global on RHS (should NOT trigger)
        data = CMD.READ;
        // Trigger 1: assign to global in ASYNCHRONOUS block
        CMD.WRITE = r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= CMD.RESET;
    }
@endmod

// Helper module — triggers assignment to global in sync block
@module HelperB
    PORT {
        IN  [1] clk;
        OUT [4] data;
    }
    REGISTER {
        r [4] = 4'b0000;
    }
    ASYNCHRONOUS {
        data = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Valid: reading global on RHS in sync (should NOT trigger)
        r <= CMD.READ;
        // Trigger 2: assign to global in SYNCHRONOUS block
        CMD.RESET <= r;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [4] data;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        OUT [4] data = _;
    };

    @new inst_b HelperB {
        IN  [1] clk = clk;
        OUT [4] data = _;
    };

    REGISTER {
        r [4] = 4'b0000;
    }

    ASYNCHRONOUS {
        // Trigger 3: assign to global in top module ASYNCHRONOUS block
        CMD.READ = r;
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        // Trigger 4: assign to global in top module SYNCHRONOUS block
        CMD.WRITE <= r;
        r <= CMD.RESET;
    }
@endmod
