// MEM_INOUT_WDATA_IN_ASYNC: Assign INOUT .wdata in ASYNCHRONOUS block.
// Valid .wdata assignment in SYNC block included for no false positives.

@project MEM_INOUT_WDATA_IN_ASYNC_wdata_in_async
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Helper: .wdata in ASYNC block
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM(type=BLOCK) {
        mem_a [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    ASYNCHRONOUS {
        data = mem_a.rw.data;
        // Trigger 1: .wdata in ASYNC block
        mem_a.rw.wdata = wdata;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_a.rw.addr <= addr;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM(type=BLOCK) {
        mem_b [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_b.rw.data;
        // Trigger 2: .wdata in ASYNC block in top module
        mem_b.rw.wdata = wdata;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_b.rw.addr <= addr;
    }
@endmod
