// ASSIGN_INDEPENDENT_IF_SELECT: Same identifier assigned in multiple independent IF/SELECT chains.
// Tests independent chain conflicts in ASYNCHRONOUS blocks across modules.
// Valid branch-exclusive assignments included to verify no false positives.

@project ASSIGN_INDEPENDENT_IF_SELECT_independent_chains
    @top TopMod {
        IN  [1] clk = _;
        IN  [1] sel_a = _;
        IN  [1] sel_b = _;
        OUT [1] out_a = _;
        OUT [1] out_b = _;
    }
@endproj

// Helper module: two independent IFs assigning same port
@module HelperA
    PORT {
        IN  [1] clk;
        IN  [1] sel_a;
        IN  [1] sel_b;
        OUT [1] out_a;
        OUT [1] out_b;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        // Trigger 1: two independent IFs assigning same port
        IF (sel_a) {
            out_a <= VCC;
        } ELSE {
            out_a <= GND;
        }
        IF (sel_b) {
            out_a <= r;
        } ELSE {
            out_a <= VCC;
        }
        // Valid: branch-exclusive assignment (no false positive)
        IF (sel_a) {
            out_b <= VCC;
        } ELSE {
            out_b <= GND;
        }
    }
    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] sel_a;
        IN  [1] sel_b;
        OUT [1] out_a;
        OUT [1] out_b;
    }
    WIRE {
        w [1];
        ha_a [1];
        ha_b [1];
    }
    REGISTER {
        r [1] = 1'b0;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        IN  [1] sel_a = sel_a;
        IN  [1] sel_b = sel_b;
        OUT [1] out_a = ha_a;
        OUT [1] out_b = ha_b;
    };

    ASYNCHRONOUS {
        // Trigger 2: two independent IFs assigning same wire
        IF (sel_a) {
            w <= VCC;
        } ELSE {
            w <= GND;
        }
        IF (sel_b) {
            w <= ha_a;
        } ELSE {
            w <= ha_b;
        }
        out_a = w;
        out_b = ha_b;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
