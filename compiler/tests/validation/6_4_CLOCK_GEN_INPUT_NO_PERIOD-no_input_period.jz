// CLOCK_GEN_INPUT_NO_PERIOD: CLOCK_GEN input clock must have a period in CLOCKS.
// Tests CLOCK_GEN with IN clock that has no period declared.
// Valid CLOCK_GEN with period-bearing input included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_INPUT_NO_PERIOD_no_input_period
    CLOCKS {
        ref_clk = { period=10 };
        // Trigger input: clock without period
        bare_clk;
        valid_out;
        bad_out;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        // Trigger 1: input clock has no period
        PLL {
            IN REF_CLK bare_clk;
            OUT BASE bad_out;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };

        // Valid: input clock has period (no trigger)
        PLL {
            IN REF_CLK ref_clk;
            OUT BASE valid_out;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
