// CLOCK_GEN_INPUT_NO_PERIOD: CLOCK_GEN input clock must have a period declared in CLOCKS.
// Tests a PLL whose IN references a clock declared in CLOCKS but without period.
// Valid PLL with input that has period included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_INPUT_NO_PERIOD_no_input_period
    CLOCKS {
        ref_clk = { period=10 };
        // bare_clk has no period
        bare_clk;
        gen_out_a;
        gen_out_b;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        // Trigger: bare_clk has no period in CLOCKS
        PLL {
            IN REF_CLK bare_clk;
            OUT BASE gen_out_a;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };

        // Valid: ref_clk has period=10 (no trigger)
        PLL {
            IN REF_CLK ref_clk;
            OUT BASE gen_out_b;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
