// HAPPY_PATH: Valid D-latch and SR-latch usage.
// Exercises D-latch guarded assignment, SR-latch assignment,
// latch reads in ASYNCHRONOUS and SYNCHRONOUS blocks,
// latch in conditional, and multi-module instantiation.
// No diagnostics expected.

@project HAPPY_PATH_latch_ok
    @top TopMod {
        IN  [1] clk = _;
        IN  [1] enable = _;
        IN  [8] din = _;
        IN  [1] set_sig = _;
        IN  [1] reset_sig = _;
        OUT [8] data = _;
        OUT [1] sr_out = _;
    }
@endproj

// Helper module: valid D-latch and SR-latch usage
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [1] enable;
        IN  [8] din;
        IN  [1] set_sig;
        IN  [1] reset_sig;
        OUT [8] data;
        OUT [1] sr_out;
    }

    LATCH {
        lat_d [8] D;
        lat_sr [1] SR;
    }

    REGISTER {
        r_sync [8] = 8'h00;
    }

    ASYNCHRONOUS {
        // Valid: D-latch guarded assignment
        lat_d <= enable : din;
        // Valid: SR-latch assignment
        lat_sr <= set_sig : reset_sig;
        // Valid: latch read in ASYNC
        data <= r_sync;
        sr_out <= lat_sr;
    }

    SYNCHRONOUS(CLK=clk) {
        // Valid: latch read in SYNC
        r_sync <= lat_d;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] enable;
        IN  [8] din;
        IN  [1] set_sig;
        IN  [1] reset_sig;
        OUT [8] data;
        OUT [1] sr_out;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [1] enable = enable;
        IN  [8] din = din;
        IN  [1] set_sig = set_sig;
        IN  [1] reset_sig = reset_sig;
        OUT [8] data = _;
        OUT [1] sr_out = _;
    };

    LATCH {
        lat_top_d [8] D;
        lat_top_sr [1] SR;
    }

    REGISTER {
        r_top [8] = 8'h00;
    }

    ASYNCHRONOUS {
        lat_top_d <= enable : din;
        lat_top_sr <= set_sig : reset_sig;
        data <= r_top;
        sr_out <= lat_top_sr;
    }

    SYNCHRONOUS(CLK=clk) {
        // Valid: latch read in SYNC, conditional usage
        IF (enable) {
            r_top <= lat_top_d;
        }
    }
@endmod
