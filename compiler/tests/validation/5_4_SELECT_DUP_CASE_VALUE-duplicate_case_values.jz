// SELECT_DUP_CASE_VALUE: Duplicate CASE values in SELECT statement.
// Tests duplicate detection with bare integers and sized literals
// in both ASYNC and SYNC blocks across multiple modules.
// Valid unique CASE values included to verify no false positives.

@project SELECT_DUP_CASE_VALUE_duplicate_case_values
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] sel = _;
        OUT [1] out_a = _;
        OUT [1] out_b = _;
    }
@endproj

@module HelperA
    PORT {
        IN  [4] sel;
        OUT [1] out_a;
    }
    ASYNCHRONOUS {
        // Trigger 1: duplicate bare integer CASE in ASYNC
        SELECT (sel) {
            CASE 0 {
                out_a <= VCC;
            }
            CASE 1 {
                out_a <= GND;
            }
            CASE 0 {
                out_a <= GND;
            }
            DEFAULT {
                out_a <= GND;
            }
        }
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] sel;
        OUT [1] out_a;
        OUT [1] out_b;
    }

    @new inst_a HelperA {
        IN  [4] sel = sel;
        OUT [1] out_a = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        // Trigger 2: duplicate sized literal CASE in ASYNC
        SELECT (sel) {
            CASE 4'h3 {
                out_a <= r;
            }
            CASE 4'hA {
                out_a <= VCC;
            }
            CASE 4'h3 {
                out_a <= GND;
            }
            DEFAULT {
                out_a <= GND;
            }
        }
        // Trigger 3: duplicate sized binary CASE in ASYNC
        SELECT (sel) {
            CASE 4'b0010 {
                out_b <= VCC;
            }
            CASE 4'b0011 {
                out_b <= GND;
            }
            CASE 4'b0010 {
                out_b <= r;
            }
            DEFAULT {
                out_b <= GND;
            }
        }
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 4: duplicate bare integer CASE in SYNC
        SELECT (sel) {
            CASE 2 {
                r <= VCC;
            }
            CASE 2 {
                r <= GND;
            }
            DEFAULT {
                r <= GND;
            }
        }
    }
@endmod
