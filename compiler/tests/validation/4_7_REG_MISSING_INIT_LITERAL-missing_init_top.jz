// REG_MISSING_INIT_LITERAL: Register declared without mandatory reset literal.
// Trigger in top module — compiler halts after first diagnostic so
// helper and top module triggers are split into separate files.
// Valid register with init literal included for no false positives.

@project REG_MISSING_INIT_LITERAL_missing_init_top
    @top TopMod {
        IN  [1] clk = _;
        OUT [8] dout = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [8] dout;
    }

    REGISTER {
        // Trigger 1: missing init literal in top module
        r_noinit [8];
        // Valid: register with proper init
        r_ok [8] = 8'hFF;
    }

    ASYNCHRONOUS {
        dout = r_ok;
    }

    SYNCHRONOUS(CLK=clk) {
        r_ok <= ~r_ok;
    }
@endmod
