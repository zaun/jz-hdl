// WIDTHOF_INVALID_TARGET: widthof() argument does not resolve to WIRE, REGISTER, PORT, or BUS.
// Tests widthof() on non-signal targets such as CONST names.
// Valid widthof() on a port included to verify no false positives.
// NOTE: Compiler bug — this rule is not implemented. See issues.md.

@project WIDTHOF_INVALID_TARGET_non_signal_target
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] data_in = _;
        OUT [8] out_a = _;
    }
@endproj

// Helper module: widthof() on CONST name
@module HelperMod
    CONST {
        MY_CONST = 42;
        // Trigger 1: widthof() on a CONST name in helper
        BAD_W = widthof(MY_CONST);
        // Valid: widthof() on a port (no false positive)
        GOOD_W = widthof(val);
    }
    PORT {
        IN  [1] clk;
        IN  [8] val;
        OUT [8] out_a;
    }
    REGISTER {
        r [GOOD_W] = 8'd0;
    }
    ASYNCHRONOUS {
        out_a = r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= val;
    }
@endmod

@module TopMod
    CONST {
        TOP_CONST = 10;
        // Trigger 2: widthof() on a CONST name in top
        BAD_W2 = widthof(TOP_CONST);
        // Valid: widthof() on a port (no false positive)
        DIN_W = widthof(data_in);
    }
    PORT {
        IN  [1] clk;
        IN  [8] data_in;
        OUT [8] out_a;
    }
    WIRE {
        ha_a [8];
    }
    REGISTER {
        r [DIN_W] = 8'd0;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [8] val = data_in;
        OUT [8] out_a = ha_a;
    };

    ASYNCHRONOUS {
        out_a = r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= data_in;
    }
@endmod
