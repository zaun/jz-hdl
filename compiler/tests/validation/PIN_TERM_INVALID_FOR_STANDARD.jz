// PIN_TERM_INVALID_FOR_STANDARD: term=ON on LVCMOS standard.
// Verified

@project PIN_TERM_INVALID_FOR_STANDARD_PROJECT
  IN_PINS {
    pin = { standard=LVCMOS33, term=ON };
  }

  MAP {
    pin = 10;
  }

  @top PIN_TERM_INVALID_FOR_STANDARD_EXAMPLE {
    IN  [1] in = _;
    OUT [1] out = _;
  }
@endproj

@module PIN_TERM_INVALID_FOR_STANDARD_EXAMPLE
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod
