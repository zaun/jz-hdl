// CLOCK_GEN_MISSING_INPUT: CLOCK_GEN unit must have an IN clock declaration.
// Tests PLL without any IN declaration.
// Valid PLL with IN included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_MISSING_INPUT_no_input
    CLOCKS {
        ref_clk = { period=10 };
        valid_out;
        bad_out;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        // Trigger 1: PLL without IN declaration
        PLL {
            OUT BASE bad_out;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };

        // Valid: PLL with IN (no trigger)
        PLL {
            IN REF_CLK ref_clk;
            OUT BASE valid_out;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
