// CLOCK_GEN_INPUT_FREQ_OUT_OF_RANGE: CLOCK_GEN input frequency outside chip range.
// Tests PLL with input frequency outside the 3-500 MHz ref_clk range.
// Valid input frequency included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_INPUT_FREQ_OUT_OF_RANGE_freq_range
    CLOCKS {
        // Trigger: period=0.5 ns = 2000 MHz, exceeds 500 MHz max
        fast_clk = { period=0.5 };
        valid_clk = { period=10 };
        bad_out;
        valid_out;
    }

    IN_PINS {
        fast_clk = { standard=LVCMOS33 };
        valid_clk = { standard=LVCMOS33 };
    }

    MAP {
        fast_clk = 1;
        valid_clk = 2;
    }

    CLOCK_GEN {
        // Trigger 1: input freq 2000 MHz > 500 MHz max
        PLL {
            IN REF_CLK fast_clk;
            OUT BASE bad_out;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };

        // Valid: input freq 100 MHz in range (no trigger)
        PLL {
            IN REF_CLK valid_clk;
            OUT BASE valid_out;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = valid_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
