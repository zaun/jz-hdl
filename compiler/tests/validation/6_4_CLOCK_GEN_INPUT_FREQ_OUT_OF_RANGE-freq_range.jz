// CLOCK_GEN_INPUT_FREQ_OUT_OF_RANGE: CLOCK_GEN input frequency outside chip's supported range.
// Tests a PLL whose input clock frequency exceeds the chip's reference clock range.
// Valid input frequency included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_INPUT_FREQ_OUT_OF_RANGE_freq_range
    CLOCKS {
        good_clk = { period=10 };
        // 0.5 ns = 2000 MHz, well above typical chip max (~500 MHz)
        fast_clk = { period=0.5 };
        gen_out_a;
        gen_out_b;
    }

    IN_PINS {
        good_clk = { standard=LVCMOS33 };
        fast_clk = { standard=LVCMOS33 };
    }

    MAP {
        good_clk = 1;
        fast_clk = 2;
    }

    CLOCK_GEN {
        // Trigger: input frequency 2000 MHz is out of range
        PLL {
            IN REF_CLK fast_clk;
            OUT BASE gen_out_a;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };

        // Valid: ref_clk at 100 MHz is in range (no trigger)
        PLL {
            IN REF_CLK good_clk;
            OUT BASE gen_out_b;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = good_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
