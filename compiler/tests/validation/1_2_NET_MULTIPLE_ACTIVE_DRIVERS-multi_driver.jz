// NET_MULTIPLE_ACTIVE_DRIVERS: Multiple active drivers on same signal.
// Two non-z module instance outputs driving the same wire (cross-instance conflict).
// Each trigger is commented. Valid single-driver wires for no false positives.

@project NET_MULTIPLE_ACTIVE_DRIVERS_multi_driver
    @top TopMod {
        IN  [1] en = _;
        OUT [8] dout_a = _;
        OUT [8] dout_b = _;
    }
@endproj

// Simple driver module that always drives its output
@module DriverMod
    PORT {
        IN  [1] en;
        OUT [8] data;
    }

    ASYNCHRONOUS {
        IF (en) {
            data <= 8'hAA;
        } ELSE {
            data <= 8'h55;
        }
    }
@endmod

// Another driver module with different values
@module DriverAlt
    PORT {
        IN  [1] en;
        OUT [8] data;
    }

    ASYNCHRONOUS {
        IF (en) {
            data <= 8'hF0;
        } ELSE {
            data <= 8'h0F;
        }
    }
@endmod

// Helper module: two instances drive same wire (Trigger 1)
@module HelperMod
    PORT {
        IN  [1] en;
        OUT [8] dout;
    }

    WIRE {
        // Trigger 1: two instances drive this wire
        h_shared [8];
        // Valid: only one instance drives this wire
        h_single [8];
    }

    @new h_inst_a DriverMod {
        IN  [1] en = en;
        OUT [8] data = h_shared;
    };

    @new h_inst_b DriverAlt {
        IN  [1] en = en;
        OUT [8] data = h_shared;
    };

    @new h_inst_c DriverMod {
        IN  [1] en = en;
        OUT [8] data = h_single;
    };

    ASYNCHRONOUS {
        dout <= h_shared | h_single;
    }
@endmod

// Top module: additional multi-driver conflict (Trigger 2)
@module TopMod
    PORT {
        IN  [1] en;
        OUT [8] dout_a;
        OUT [8] dout_b;
    }

    WIRE {
        // Trigger 2: two instances drive this wire in TopMod
        t_shared [8];
        // Valid: only one instance drives this wire
        t_single [8];
    }

    @new inst_a DriverMod {
        IN  [1] en = en;
        OUT [8] data = t_shared;
    };

    @new inst_b DriverAlt {
        IN  [1] en = en;
        OUT [8] data = t_shared;
    };

    @new inst_c DriverMod {
        IN  [1] en = en;
        OUT [8] data = t_single;
    };

    @new inst_h HelperMod {
        IN  [1] en = en;
        OUT [8] dout = _;
    };

    ASYNCHRONOUS {
        dout_a <= t_shared | t_single;
        dout_b <= inst_h.dout;
    }
@endmod
