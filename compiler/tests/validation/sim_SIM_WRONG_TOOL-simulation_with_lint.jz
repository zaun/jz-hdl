// SIM_WRONG_TOOL: File contains @simulation blocks but is run with --lint instead of --simulate.
// The compiler should detect the @simulation block and report an error directing
// the user to use --simulate.

@module sim_test_mod
    PORT {
        IN [1] clk;
        IN [1] data;
        OUT [1] out;
    }
    ASYNCHRONOUS {
        out => data;
    }
@endmod

@simulation sim_test_mod
    CLOCK {
        clk = { period=10.0 };
    }
    WIRE {
        data [1];
        out [1];
    }
    @new dut sim_test_mod {
        clk [1] = clk;
        data [1] = data;
        out [1] = out;
    }
    @setup {
        data <= 1'b0;
    }
    @run(ns=100)
@endsim
