// TEMPLATE_DUP_NAME: duplicate template name in same scope.
// Expect ERR> TEMPLATE_DUP_NAME

@project TEMPLATE_DUP_NAME_PROJECT
  @top TEMPLATE_DUP_NAME_MOD {
    IN  [8] in_a = _;
    OUT [8] out_a = _;
  }
@endproj

@template MYTEMPL(a, b)
  b <= a;
@endtemplate

@template MYTEMPL(a, b)
  b <= a;
@endtemplate

@module TEMPLATE_DUP_NAME_MOD
  PORT {
    IN  [8] in_a;
    OUT [8] out_a;
  }

  ASYNCHRONOUS {
    @apply MYTEMPL(in_a, out_a);
  }
@endmod
