// HAPPY_PATH: Valid @check syntax with constant expressions produces no diagnostics.
// Exercises @check with literals, CONST, CONFIG, clog2, and complex expressions
// at both project and module scope.

@project HAPPY_PATH_check_syntax_ok
    CONFIG {
        WIDTH = 8;
        DEPTH = 256;
    }

    // Valid: CONFIG equality check at project scope
    @check (CONFIG.WIDTH == 8, "Width must be 8");

    // Valid: CONFIG comparison at project scope
    @check (CONFIG.DEPTH > 0, "Depth must be positive");

    // Valid: clog2 of CONFIG at project scope
    @check (clog2(CONFIG.DEPTH) <= 16, "Too deep");

    // Valid: literal-only expression at project scope
    @check (1 == 1, "literal truth");

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Helper module — exercises @check with module-local CONST
@module HelperMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    CONST { LOCAL_W = 4; }

    // Valid: CONST in @check at helper module scope
    @check (LOCAL_W > 0, "local width ok");

    // Valid: CONST arithmetic in @check
    @check (LOCAL_W * 2 == 8, "double width ok");

    ASYNCHRONOUS {
        data = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    CONST {
        WIDTH = 8;
        ADDR_W = 3;
    }

    // Valid: CONST in @check at top module scope
    @check (WIDTH == 8, "width ok");

    // Valid: CONFIG reference in @check at module scope
    @check (CONFIG.WIDTH == 8, "config ok");

    // Valid: clog2 in @check
    @check (clog2(WIDTH) == ADDR_W, "address width ok");

    // Valid: complex nested expression
    @check (WIDTH > 0, "positive width");

    @new inst_a HelperMod {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
