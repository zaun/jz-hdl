// DOMAIN_CONFLICT: Register used in SYNCHRONOUS block whose CLK does not match home domain.
// Tests register assigned in wrong SYNCHRONOUS block across multiple modules.
// Correct domain usage included to verify no false positives.

@project DOMAIN_CONFLICT_register_wrong_domain
    @top TopMod {
        IN  [1] clk_a = _;
        IN  [1] clk_b = _;
        OUT [1] data = _;
    }
@endproj

// Helper module: register written in wrong domain
@module HelperA
    PORT {
        IN  [1] clk_a;
        IN  [1] clk_b;
        OUT [1] data;
    }
    REGISTER {
        // Home domain: clk_a (first SYNCHRONOUS block where it's assigned)
        r_a [1] = 1'b0;
        // Home domain: clk_b
        r_b [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r_a;
    }

    // Valid: r_a assigned in its home domain clk_a
    SYNCHRONOUS(CLK=clk_a) {
        r_a <= ~r_a;
    }

    SYNCHRONOUS(CLK=clk_b) {
        r_b <= ~r_b;
        // Trigger 1: r_a assigned in clk_b but home domain is clk_a
        r_a <= 1'b1;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk_a;
        IN  [1] clk_b;
        OUT [1] data;
    }

    @new inst_a HelperA {
        IN  [1] clk_a = clk_a;
        IN  [1] clk_b = clk_b;
        OUT [1] data = _;
    };

    REGISTER {
        r_top [1] = 1'b0;
        r_other [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r_top;
    }

    // Valid: r_top in its home domain
    SYNCHRONOUS(CLK=clk_a) {
        r_top <= ~r_top;
    }

    SYNCHRONOUS(CLK=clk_b) {
        r_other <= ~r_other;
        // Trigger 2: r_top assigned in clk_b but home domain is clk_a
        r_top <= 1'b0;
    }
@endmod
