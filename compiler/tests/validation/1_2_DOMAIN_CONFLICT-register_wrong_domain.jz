// DOMAIN_CONFLICT: Register used in SYNCHRONOUS block whose CLK does not
// match its home-domain clock.
// Each trigger is commented. Valid same-domain assignment for no false positives.

@project DOMAIN_CONFLICT_register_wrong_domain
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk_a = _;
        IN  [1] clk_b = _;
        IN  [8] din = _;
        OUT [8] dout_a = _;
        OUT [8] dout_b = _;
    }
@endproj

// Trigger 1: register assigned in wrong domain in helper module
@module HelperA
    PORT {
        IN  [1] clk_a;
        IN  [1] clk_b;
        IN  [8] din;
        OUT [8] dout;
    }

    REGISTER {
        r_a [8] = 8'h00;
    }

    ASYNCHRONOUS {
        dout <= r_a;
    }

    // Valid: home domain assignment
    SYNCHRONOUS(CLK=clk_a) {
        r_a <= din;
    }

    // Trigger 1: r_a's home domain is clk_a, but assigned in clk_b block
    SYNCHRONOUS(CLK=clk_b) {
        r_a <= din;
    }
@endmod

// Top module with its own domain conflict trigger
@module TopMod
    PORT {
        IN  [1] clk_a;
        IN  [1] clk_b;
        IN  [8] din;
        OUT [8] dout_a;
        OUT [8] dout_b;
    }

    REGISTER {
        r_top [8] = 8'h00;
    }

    @new inst_a HelperA {
        IN  [1] clk_a = clk_a;
        IN  [1] clk_b = clk_b;
        IN  [8] din = din;
        OUT [8] dout = dout_a;
    };

    ASYNCHRONOUS {
        dout_b <= r_top;
    }

    // Valid: home domain assignment
    SYNCHRONOUS(CLK=clk_a) {
        r_top <= din;
    }

    // Trigger 2: r_top's home domain is clk_a, but assigned in clk_b
    SYNCHRONOUS(CLK=clk_b) {
        r_top <= din;
    }
@endmod
