// PIN_DRIVE_MISSING_OR_INVALID: missing or nonpositive drive strength for OUT/INOUT pins.
// Verified

@project PIN_DRIVE_MISSING_OR_INVALID_PROJECT
  OUT_PINS {
    pin_a = { standard=LVCMOS33, drive=8 };
    pin_b = { standard=LVCMOS33, drive=A };
    pin_c = { standard=LVCMOS33 };
  }

  MAP {
    pin_a = 10;
    pin_b = 11;
    pin_c = 12;
  }

  @top PIN_DRIVE_MISSING_OR_INVALID_EXAMPLE {
    IN  [1] in = _;
    OUT [1] out = _;
  }
@endproj

@module PIN_DRIVE_MISSING_OR_INVALID_EXAMPLE
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod