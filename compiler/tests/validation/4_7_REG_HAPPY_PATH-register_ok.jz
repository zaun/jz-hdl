// REG_HAPPY_PATH: Valid register usage with no diagnostics.
// Tests standard register declaration, read in ASYNC, write in SYNC,
// GND/VCC reset, read-current/write-next, multiple registers in one block.

@project REG_HAPPY_PATH_register_ok
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] din = _;
        OUT [8] dout_a = _;
        OUT [8] dout_b = _;
        OUT [8] dout_cnt = _;
        OUT [1] dout_flg = _;
    }
@endproj

// Helper module: standard register usage
@module HelperMod
    PORT {
        IN  [1] clk;
        OUT [8] data_out;
        OUT [1] flag_out;
    }

    REGISTER {
        // Standard register with hex reset
        counter [8] = 8'h00;
        // 1-bit register
        flag [1] = 1'b0;
    }

    ASYNCHRONOUS {
        // Valid: read current value in ASYNC
        data_out = counter;
        flag_out = flag;
    }

    SYNCHRONOUS(CLK=clk) {
        // Valid: write next state in SYNC
        counter <= counter + 8'd1;
        // Valid: read current, write next in same SYNC block
        flag <= ~flag;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] din;
        OUT [8] dout_a;
        OUT [8] dout_b;
        OUT [8] dout_cnt;
        OUT [1] dout_flg;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        OUT [8] data_out = dout_cnt;
        OUT [1] flag_out = dout_flg;
    };

    REGISTER {
        // Multiple registers in one block
        r_a [8] = 8'hFF;
        r_b [8] = 8'h00;
    }

    ASYNCHRONOUS {
        dout_a = r_a;
        dout_b = r_b;
    }

    SYNCHRONOUS(CLK=clk) {
        r_a <= din;
        r_b <= r_a;
    }
@endmod
