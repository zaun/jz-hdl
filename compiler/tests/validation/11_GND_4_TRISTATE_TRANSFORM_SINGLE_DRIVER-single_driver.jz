// TRISTATE_TRANSFORM_SINGLE_DRIVER: Single-driver tri-state net transformed.
// Verifies TRISTATE_TRANSFORM_SINGLE_DRIVER warning fires for each wire that
// has only one driver with conditional z when --tristate-default is active.
// Contexts: helper module with single-driver tristate wire, top module with
// single-driver tristate wire, top module with two tristate wires.

@project TRISTATE_TRANSFORM_SINGLE_DRIVER_single_driver
    @top TopMod {
        IN  [1] en = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: helper module with single-driver tri-state wire
@module HelperMod
    PORT {
        IN  [1] en;
        IN  [8] din;
        OUT [8] data;
    }

    WIRE {
        w [8];
    }

    ASYNCHRONOUS {
        IF (en) {
            w <= din;
        } ELSE {
            w <= 8'bzzzz_zzzz;
        }
        data <= w;
    }
@endmod

// Trigger 2-3: top module with two single-driver tri-state wires
@module TopMod
    PORT {
        IN  [1] en;
        OUT [8] data;
    }

    WIRE {
        w_top [8];
        w_extra [8];
    }

    @new inst_h HelperMod {
        IN  [1] en = en;
        IN  [8] din = 8'hFF;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        IF (en) {
            w_top <= 8'hCC;
        } ELSE {
            w_top <= 8'bzzzz_zzzz;
        }
        IF (en) {
            w_extra <= 8'hDD;
        } ELSE {
            w_extra <= 8'bzzzz_zzzz;
        }
        data <= w_top | w_extra;
    }
@endmod
