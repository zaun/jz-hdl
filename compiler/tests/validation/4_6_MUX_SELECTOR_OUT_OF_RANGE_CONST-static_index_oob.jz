// MUX_SELECTOR_OUT_OF_RANGE_CONST: Constant selector statically provable outside valid index range.
// Tests out-of-range constant indices on aggregation and auto-slice MUX.
// Valid in-range constant indices included to verify no false positives.

@project MUX_SELECTOR_OUT_OF_RANGE_CONST_static_index_oob
    @top TopMod {
        IN  [8] a = _;
        IN  [8] b = _;
        IN  [16] wide = _;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
        OUT [8] out_c = _;
        OUT [8] out_d = _;
    }
@endproj

@module HelperMod
    PORT {
        IN  [8] a;
        IN  [8] b;
        OUT [8] data;
    }

    MUX {
        h_mux = a, b;
    }

    ASYNCHRONOUS {
        // Trigger 1: index 5 on 2-element mux (valid 0-1), bare integer selector
        data = h_mux[5];
    }
@endmod

@module TopMod
    PORT {
        IN  [8] a;
        IN  [8] b;
        IN  [16] wide;
        OUT [8] out_a;
        OUT [8] out_b;
        OUT [8] out_c;
        OUT [8] out_d;
    }

    MUX {
        // 3-element aggregation (valid indices 0-2)
        agg_mux = a, b, a;
        // 2-element auto-slice (valid indices 0-1)
        slice_mux [8] = wide;
    }

    @new inst_h HelperMod {
        IN  [8] a = a;
        IN  [8] b = b;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        // Valid: in-range constant index (no error expected)
        out_a = agg_mux[1];
        // Trigger 2: index 3 on 3-element agg mux (valid 0-2)
        out_b = agg_mux[3];
        // Trigger 3: index 2 on 2-element slice mux (valid 0-1)
        out_c = slice_mux[2];
        // Valid: in-range slice index (no error expected)
        out_d = slice_mux[0];
    }
@endmod
