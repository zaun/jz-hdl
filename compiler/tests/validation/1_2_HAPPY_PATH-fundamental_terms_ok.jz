// HAPPY_PATH: Valid usage of all Section 1.2 fundamental concepts.
// Signals, nets, deterministic nets, drivers, active drivers, sinks,
// observable sinks, execution paths, registers, latches, home domains.
// No diagnostics expected.

@project HAPPY_PATH_fundamental_terms_ok
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [1] sel = _;
        IN  [1] enable = _;
        IN  [8] din = _;
        OUT [8] dout_a = _;
        OUT [8] dout_b = _;
        OUT [8] dout_c = _;
        OUT [1] dout_d = _;
        OUT [8] dout_e = _;
    }
@endproj

// Helper module: register as driver, latch as driver, single-driver net
@module HelperA
    PORT {
        IN  [1] clk;
        IN  [1] enable;
        IN  [8] din;
        OUT [8] reg_out;
        OUT [8] latch_out;
    }

    WIRE {
        w [8];
    }

    REGISTER {
        r [8] = 8'h00;
    }

    LATCH {
        lat [8] D;
    }

    ASYNCHRONOUS {
        // Single-driver deterministic net
        w <= din;

        // Register current value as driver (readable in ASYNC)
        reg_out <= r;

        // Latch as driver: guarded assignment then read
        lat <= enable : din;
        latch_out <= lat;
    }

    // Register as sink (next-state assigned in home SYNCHRONOUS)
    SYNCHRONOUS(CLK=clk) {
        r <= w;
    }
@endmod

// Helper module: single-bit signal as driver
@module HelperB
    PORT {
        IN  [1] bit_in;
        OUT [1] bit_out;
    }

    ASYNCHRONOUS {
        // 1-bit wire driving 1-bit port
        bit_out = bit_in;
    }
@endmod

// Top module: observable sinks, execution path exclusivity, x masking
@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] sel;
        IN  [1] enable;
        IN  [8] din;
        OUT [8] dout_a;
        OUT [8] dout_b;
        OUT [8] dout_c;
        OUT [1] dout_d;
        OUT [8] dout_e;
    }

    WIRE {
        w_excl [8];
        w_masked [8];
    }

    REGISTER {
        r_top [8] = 8'h00;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        IN  [1] enable = enable;
        IN  [8] din = din;
        OUT [8] reg_out = dout_a;
        OUT [8] latch_out = dout_b;
    };

    @new inst_b HelperB {
        IN  [1] bit_in = sel;
        OUT [1] bit_out = dout_d;
    };

    ASYNCHRONOUS {
        // Execution path exclusivity: IF/ELSE branches assign same wire
        IF (sel) {
            w_excl <= din;
        } ELSE {
            w_excl <= 8'hFF;
        }

        // Port as observable sink driven by expression
        dout_c <= w_excl;

        // x-bit masked before observable sink (valid: AND masks x bits)
        w_masked <= 8'bxxxx_0000 & 8'h0F;
        dout_e <= r_top | w_masked;
    }

    SYNCHRONOUS(CLK=clk) {
        r_top <= din;
    }
@endmod
