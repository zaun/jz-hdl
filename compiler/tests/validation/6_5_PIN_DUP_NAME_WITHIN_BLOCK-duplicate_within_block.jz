// PIN_DUP_NAME_WITHIN_BLOCK: Duplicate pin names within same PIN block.
// Tests duplicate names in IN_PINS, OUT_PINS, and INOUT_PINS blocks.
// Valid unique pins included to verify no false positives.

@project PIN_DUP_NAME_WITHIN_BLOCK_duplicate_within_block
    CLOCKS {
        sys_clk = { period=10 };
    }

    IN_PINS {
        sys_clk = { standard=LVCMOS33 };
        valid_in = { standard=LVCMOS33 };
        // Trigger 1: duplicate in IN_PINS
        dup_in = { standard=LVCMOS33 };
        dup_in = { standard=LVCMOS18 };
    }

    OUT_PINS {
        valid_out = { standard=LVCMOS33, drive=8 };
        // Trigger 2: duplicate in OUT_PINS
        dup_out = { standard=LVCMOS33, drive=8 };
        dup_out = { standard=LVCMOS18, drive=4 };
    }

    INOUT_PINS {
        valid_io = { standard=LVCMOS33, drive=4 };
        // Trigger 3: duplicate in INOUT_PINS
        dup_io = { standard=LVCMOS33, drive=4 };
        dup_io = { standard=LVCMOS18, drive=8 };
    }

    MAP {
        sys_clk = 1;
        valid_in = 2;
        dup_in = 3;
        valid_out = 4;
        dup_out = 5;
        valid_io = 6;
        dup_io = 7;
    }

    @top TopMod {
        IN  [1] clk = sys_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
