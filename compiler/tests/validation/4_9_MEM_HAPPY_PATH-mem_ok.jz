// MEM_HAPPY_PATH: Valid MEM declarations produce no diagnostics.
// Tests BLOCK type, DISTRIBUTED type, and multiple MEMs in one module.

@project MEM_HAPPY_PATH_mem_ok
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] rdata_a = _;
        OUT [8] rdata_b = _;
        OUT [8] rdata_c = _;
    }
@endproj

// Helper module: single DISTRIBUTED MEM
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] rdata;
    }

    MEM(type=DISTRIBUTED) {
        mem_d [8] [16] = 8'h00 {
            OUT rd ASYNC;
        };
    }

    ASYNCHRONOUS {
        rdata = mem_d.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
    }
@endmod

// Top module: BLOCK type, multiple MEMs, and instantiation
@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] rdata_a;
        OUT [8] rdata_b;
        OUT [8] rdata_c;
    }

    // Valid: BLOCK type MEM
    MEM(type=BLOCK) {
        mem_blk [8] [16] = 8'h00 {
            OUT rd_blk SYNC;
            IN  wr_blk;
        };
    }

    // Valid: DISTRIBUTED type MEM (multiple MEMs in one module)
    MEM(type=DISTRIBUTED) {
        mem_dist [8] [16] = 8'h00 {
            OUT rd_dist ASYNC;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        OUT [8] rdata = rdata_c;
    };

    REGISTER {
        r_rdata_a [8] = 8'h00;
    }

    ASYNCHRONOUS {
        rdata_a = r_rdata_a;
        rdata_b = mem_dist.rd_dist[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        mem_blk.rd_blk.addr <= addr;
        r_rdata_a <= mem_blk.rd_blk.data;
        mem_blk.wr_blk[addr] <= wdata;
    }
@endmod
