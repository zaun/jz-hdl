// CONFIG_FORWARD_REF: CONFIG entry references later CONFIG.<name> (forward reference).
// Verified

@project CONFIG_FORWARD_REF_EXAMPLE
  CONFIG {
    A = CONFIG.B + 1;
    B = 2;
  }

  @top top {
    OUT [1] out = _;
  }
@endproj

@module top
  PORT {
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out <= 1'b1;
  }
@endmod

