// TEMPLATE_FORBIDDEN_BLOCK_HEADER: Cross-reference test for S10.4 SYNCHRONOUS header in template.
// Tests SYNCHRONOUS block header in file-scoped and module-scoped templates.
// Split from ASYNC trigger due to potential parser recovery issues.

@project TEMPLATE_FORBIDDEN_BLOCK_HEADER_sync_in_template
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Trigger 1: SYNCHRONOUS block header inside file-scoped template
@template sync_tmpl(a, b)
    SYNCHRONOUS(CLK=a) {
        b <= a;
    }
@endtemplate

@module HelperMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    // Trigger 2: SYNCHRONOUS block header inside module-scoped template
    @template mod_sync(a, b)
        SYNCHRONOUS(CLK=a) {
            b <= a;
        }
    @endtemplate

    ASYNCHRONOUS {
        data = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    @new inst_a HelperMod {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
