// TEMPLATE_FORBIDDEN_BLOCK_HEADER: Cross-reference test for S10.4 SYNCHRONOUS header in template.
// Parser does not recover after the error, producing cascading PARSE000.
// Split from ASYNC trigger for this reason.

@project TEMPLATE_FORBIDDEN_BLOCK_HEADER_sync_in_template
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Trigger: SYNCHRONOUS block header inside file-scoped template
@template sync_tmpl(a, b)
    SYNCHRONOUS(CLK=a) {
        b <= a;
    }
@endtemplate

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
