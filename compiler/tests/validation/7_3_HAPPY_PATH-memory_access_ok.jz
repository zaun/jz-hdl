// HAPPY_PATH: Valid memory access syntax produces no diagnostics.
// Exercises async read, sync read, sync write, INOUT access,
// edge-case addresses (0, depth-1), and cross-module instantiation.

@project HAPPY_PATH_memory_access_ok
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] rdata_async = _;
        OUT [8] rdata_sync = _;
        OUT [8] rdata_inout = _;
    }
@endproj

// Helper: async read and sync write
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] rdata;
    }

    MEM {
        rom [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    // Valid: async read with bracket indexing
    ASYNCHRONOUS {
        rdata = rom.rd[addr];
    }

    // Valid: sync write with bracket indexing
    SYNCHRONOUS(CLK=clk) {
        rom.wr[addr] <= wdata;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] rdata_async;
        OUT [8] rdata_sync;
        OUT [8] rdata_inout;
    }

    REGISTER {
        r_sync [8] = 8'h00;
    }

    // Async read memory
    MEM {
        mem_async [8] [16] = 8'h00 {
            OUT rd_a ASYNC;
        };
    }

    // Sync read/write memory with multiple IN ports for edge-case addresses
    MEM {
        mem_sync [8] [16] = 8'h00 {
            OUT rd_s SYNC;
            IN  wr_s;
            IN  wr_zero;
            IN  wr_last;
        };
    }

    // INOUT memory
    MEM(type=BLOCK) {
        mem_inout [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] rdata = _;
    };

    ASYNCHRONOUS {
        // Valid: async read with bracket indexing
        rdata_async = mem_async.rd_a[addr];
        // Valid: INOUT .data readable in ASYNC block
        rdata_inout = mem_inout.rw.data;
        rdata_sync = r_sync;
    }

    SYNCHRONOUS(CLK=clk) {
        // Valid: sync read .addr and .data
        mem_sync.rd_s.addr <= addr;
        r_sync <= mem_sync.rd_s.data;
        // Valid: sync write with bracket
        mem_sync.wr_s[addr] <= wdata;
        // Valid: INOUT .addr and .wdata in SYNC
        mem_inout.rw.addr <= addr;
        mem_inout.rw.wdata <= wdata;
        // Valid edge: constant addr 0 (first entry)
        mem_sync.wr_zero[0] <= 8'hAA;
        // Valid edge: constant addr 15 (depth-1 = last entry)
        mem_sync.wr_last[15] <= 8'hBB;
    }
@endmod
