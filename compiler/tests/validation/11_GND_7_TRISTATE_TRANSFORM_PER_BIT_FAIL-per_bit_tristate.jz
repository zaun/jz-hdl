// TRISTATE_TRANSFORM_PER_BIT_FAIL: Per-bit tri-state pattern detected.
// Verifies the error fires when individual bit slices of a wire have
// different z-assignment patterns (not full-width z).
// Contexts: per-bit tristate wire in helper module, per-bit tristate wire
// in top module, different slice widths.
// Valid: full-width z assignments are not flagged (tested in happy path).

@project TRISTATE_TRANSFORM_PER_BIT_FAIL_per_bit
    @top TopMod {
        IN  [1] en_a = _;
        IN  [1] en_b = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: helper module with per-bit tri-state (4-bit slices)
@module HelperMod
    PORT {
        IN  [1] en_a;
        IN  [1] en_b;
        OUT [8] data;
    }

    WIRE {
        w [8];
    }

    ASYNCHRONOUS {
        IF (en_a) {
            w[7:4] <= 4'hA;
        } ELSE {
            w[7:4] <= 4'bzzzz;
        }
        IF (en_b) {
            w[3:0] <= 4'hB;
        } ELSE {
            w[3:0] <= 4'bzzzz;
        }
        data <= w;
    }
@endmod

// Top module with per-bit tri-state pattern (different slice widths)
@module TopMod
    PORT {
        IN  [1] en_a;
        IN  [1] en_b;
        OUT [8] data;
    }

    WIRE {
        w_top [8];
    }

    @new inst_h HelperMod {
        IN  [1] en_a = en_a;
        IN  [1] en_b = en_b;
        OUT [8] data = _;
    };

    // Trigger 2: per-bit tri-state in top module (uneven slices: 6-bit + 2-bit)
    ASYNCHRONOUS {
        IF (en_a) {
            w_top[7:2] <= 6'b10_1010;
        } ELSE {
            w_top[7:2] <= 6'bzz_zzzz;
        }
        IF (en_b) {
            w_top[1:0] <= 2'b11;
        } ELSE {
            w_top[1:0] <= 2'bzz;
        }
        data <= w_top;
    }
@endmod
