// TRISTATE_TRANSFORM_OE_EXTRACT_FAIL: Ambiguous output-enable condition.
// DriverA uses standard ternary z pattern — OE extracts fine.
// DriverB uses concatenation in z literal — confuses OE extractor because
// the z is not a simple literal.
// Both share the same parent wire through INOUT ports.
// Context: INOUT multi-driver with ambiguous OE condition.

@project OE_EXTRACT_FAIL_ambiguous_oe
    @top TopMod {
        IN  [1] en = _;
        IN  [8] din = _;
        OUT [8] result = _;
    }
@endproj

// DriverA: standard ternary z pattern, OE extraction succeeds
@module DriverA
    PORT {
        IN    [1] en;
        IN    [8] din;
        INOUT [8] data;
    }

    ASYNCHRONOUS {
        data <= (en == 1'b1) ? din : 8'bzzzz_zzzz;
    }
@endmod

// DriverB: concatenation in z literal — confuses OE extractor
@module DriverB
    PORT {
        IN    [1] en;
        IN    [8] din;
        INOUT [8] data;
    }

    ASYNCHRONOUS {
        data <= (en == 1'b0) ? din : {4'bzzzz, 4'bzzzz};
    }
@endmod

// Top module: two drivers sharing INOUT wire
@module TopMod
    PORT {
        IN  [1] en;
        IN  [8] din;
        OUT [8] result;
    }

    WIRE {
        bus [8];
    }

    @new inst_a DriverA {
        IN    [1] en = en;
        IN    [8] din = din;
        INOUT [8] data = bus;
    };

    @new inst_b DriverB {
        IN    [1] en = en;
        IN    [8] din = din;
        INOUT [8] data = bus;
    };

    ASYNCHRONOUS {
        result <= bus;
    }
@endmod
