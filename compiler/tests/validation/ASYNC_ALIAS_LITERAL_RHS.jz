// ASYNC_ALIAS_LITERAL_RHS: alias operator may not use bare literal RHS in ASYNCHRONOUS blocks.
// Expect ERR> ASYNC_ALIAS_LITERAL_RHS on the assignment to 'data'.
// Verified

@project ASYNC_ALIAS_LITERAL_RHS_PROJECT
  @top ASYNC_ALIAS_LITERAL_RHS_EXAMPLE {
    OUT [1] data = _;
  }
@endproj

@module ASYNC_ALIAS_LITERAL_RHS_EXAMPLE
  PORT {
    OUT [1] data;
  }

  ASYNCHRONOUS {
    data = 1'b1;
  }
@endmod
