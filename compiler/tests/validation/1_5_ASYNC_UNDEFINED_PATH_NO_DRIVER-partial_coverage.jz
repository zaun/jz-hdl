// ASYNC_UNDEFINED_PATH_NO_DRIVER: Signal undriven on some ASYNCHRONOUS paths.
// Tests partial coverage where IF lacks ELSE or SELECT lacks DEFAULT.
// Covers: IF-no-ELSE on port (helper), IF-no-ELSE on wire (top), IF-no-ELSE on port (top),
// SELECT-no-DEFAULT on port (top). Valid patterns included to verify no false positives.

@project ASYNC_UNDEFINED_PATH_NO_DRIVER_partial_coverage
    @top TopMod {
        IN  [1] clk = _;
        IN  [1] sel = _;
        IN  [2] sel2 = _;
        OUT [1] out_a = _;
        OUT [1] out_b = _;
        OUT [1] out_c = _;
        OUT [1] out_d = _;
    }
@endproj

// Helper module: IF without ELSE leaves port undriven
@module HelperA
    PORT {
        IN  [1] clk;
        IN  [1] sel;
        OUT [1] out_a;
        OUT [1] out_b;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        // Trigger 1: IF without ELSE — out_a undriven when sel is false
        IF (sel) {
            out_a <= VCC;
        }
        // Valid: complete IF/ELSE coverage (no false positive)
        IF (sel) {
            out_b <= VCC;
        } ELSE {
            out_b <= GND;
        }
    }
    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] sel;
        IN  [2] sel2;
        OUT [1] out_a;
        OUT [1] out_b;
        OUT [1] out_c;
        OUT [1] out_d;
    }
    WIRE {
        w [1];
        ha_a [1];
        ha_b [1];
    }
    REGISTER {
        r [1] = 1'b0;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        IN  [1] sel = sel;
        OUT [1] out_a = ha_a;
        OUT [1] out_b = ha_b;
    };

    ASYNCHRONOUS {
        out_b = ha_b;
        // Trigger 2: IF without ELSE — wire undriven when sel is false
        IF (sel) {
            w <= VCC;
        }
        out_a = w;
        // Trigger 3: IF without ELSE — port undriven when sel is false
        IF (sel) {
            out_c <= ha_a;
        }
        // Trigger 4: SELECT without DEFAULT — port undriven for uncovered cases
        SELECT (sel2) {
            CASE 2'b00 { out_d <= VCC; }
            CASE 2'b01 { out_d <= GND; }
        }
    }
    SYNCHRONOUS(CLK=clk) {
        // Valid: register in sync with IF and no ELSE (clock gating, not an error)
        IF (sel) {
            r <= ~r;
        }
    }
@endmod
