// UNARY_ARITH_MISSING_PARENS: Unary arithmetic -/+ must be parenthesized.
// Tests unparenthesized unary minus and plus in async and sync blocks across modules.
// Valid parenthesized uses included to verify no false positives.

@project UNARY_ARITH_MISSING_PARENS_unparenthesized_unary
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] data_in = _;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
        OUT [8] out_c = _;
        OUT [8] out_d = _;
    }
@endproj

// Helper module with unary triggers in async and sync
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] val;
        OUT [8] out_a;
        OUT [8] out_b;
        OUT [8] out_c;
    }
    REGISTER {
        r [8] = 8'd0;
    }
    ASYNCHRONOUS {
        // Trigger 1: unparenthesized unary minus in async
        out_a = -val;
        // Valid: parenthesized unary minus (no false positive)
        out_b = (-val);
        out_c = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: unparenthesized unary plus in sync
        r <= +val;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] data_in;
        OUT [8] out_a;
        OUT [8] out_b;
        OUT [8] out_c;
        OUT [8] out_d;
    }
    WIRE {
        ha_a [8];
        ha_b [8];
        ha_c [8];
    }
    REGISTER {
        r [8] = 8'd0;
        s [8] = 8'd0;
    }

    @new inst_a HelperMod {
        IN  [1] clk = clk;
        IN  [8] val = data_in;
        OUT [8] out_a = ha_a;
        OUT [8] out_b = ha_b;
        OUT [8] out_c = ha_c;
    };

    ASYNCHRONOUS {
        // Trigger 3: unparenthesized unary plus in async
        out_a = +data_in;
        // Trigger 4: unparenthesized unary minus in async
        out_b = -data_in;
        out_c = r;
        out_d = s;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 5: unparenthesized unary minus in sync
        r <= -data_in;
        // Valid: parenthesized unary plus (no false positive)
        s <= (+data_in);
    }
@endmod
