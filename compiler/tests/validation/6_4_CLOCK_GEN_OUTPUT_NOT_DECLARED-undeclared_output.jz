// CLOCK_GEN_OUTPUT_NOT_DECLARED: CLOCK_GEN output clock not declared in CLOCKS block.
// Tests CLOCK_GEN with OUT referring to a clock not in the CLOCKS block.
// Valid CLOCK_GEN with declared output included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_OUTPUT_NOT_DECLARED_undeclared_output
    CLOCKS {
        ref_clk = { period=10 };
        valid_out;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        PLL {
            IN REF_CLK ref_clk;
            // Trigger 1: output "phantom_out" not in CLOCKS
            OUT BASE phantom_out;
            // Valid: output declared in CLOCKS (no trigger)
            OUT PHASE valid_out;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
