// WIDTH_NONPOSITIVE_OR_NONINT: declared width must be a positive integer.
// Verified

@project WIDTH_NONPOSITIVE_OR_NONINT_PROJECT
  @top WIDTH_NONPOSITIVE_OR_NONINT_EXAMPLE {
    OUT [8] p_ok = _;
    OUT [0] p_bad = _;
  }
@endproj

@module WIDTH_NONPOSITIVE_OR_NONINT_EXAMPLE
  PORT {
    OUT [8] p_ok;
    OUT [0] p_bad;  // width 0 is invalid
  }
  
  WIRE {
    w_ok   [8];
    w_bad  [0];  // width 0 is invalid
  }
  
  REGISTER {
    r_ok   [8] = 8'b0;
    r_bad  [0] = 8'b0;  // width 0 is invalid
  }

  ASYNCHRONOUS {
    p_ok = w_ok;
    w_ok = r_ok;

    p_bad = w_bad;
    w_bad = r_bad;
  }
@endmod
