// KEYWORD_AS_IDENTIFIER: Reserved identifier IDX used as a user-declared name.
// IDX is reserved for template index usage per the spec.
// Tests IDX in module name, port name, const name, register name, instance name,
// and @new port binding contexts across multiple modules.
// Valid identifiers are included alongside invalid ones to verify no false positives.

@project KEYWORD_AS_IDENTIFIER_reserved_identifier
    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Trigger 1: reserved identifier IDX used as module name
@module IDX
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        data = r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod

// Helper module with IDX as port name
@module HelperA
    PORT {
        IN  [1] clk;
        // Trigger 2: reserved identifier IDX used as port name
        OUT [1] IDX;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        IDX = r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod

// Helper module with IDX as instance name and @new port binding
@module HelperB
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    // Trigger 3: reserved identifier IDX used as instance name
    @new IDX HelperA {
        IN  [1] clk = clk;
        // Trigger 4: reserved identifier IDX used in @new port binding
        OUT [1] IDX = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        data = r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod

// Helper module with IDX as register name
@module HelperC
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }
    REGISTER {
        // Trigger 5: reserved identifier IDX used as register name
        IDX [1] = 1'b0;
    }
    ASYNCHRONOUS {
        data = IDX;
    }
    SYNCHRONOUS(CLK=clk) {
        IDX <= ~IDX;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    // Trigger 6: reserved identifier IDX used as const name
    CONST {
        IDX = 4;
    }

    @new inst_m IDX {
        IN  [1] clk = clk;
        OUT [1] data = _;
    };

    @new inst_b HelperB {
        IN  [1] clk = clk;
        OUT [1] data = _;
    };

    @new inst_c HelperC {
        IN  [1] clk = clk;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
