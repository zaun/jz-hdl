@project BUS_DEF_SIGNAL_DUP_NAME_EXAMPLE
  BUS FABRIC {
    IN  [8] data;
    OUT [1] valid;
    OUT [1] valid; // duplicate signal name
  }

  @top top {
    IN [1] clk = _;
  }
@endproj

@module top
  PORT {
    IN [1] clk;
  }

  ASYNCHRONOUS {
    // no logic needed
  }
@endmod
