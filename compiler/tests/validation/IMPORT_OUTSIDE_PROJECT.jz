// IMPORT_OUTSIDE_PROJECT: @import used outside any @project block.
// Verified

@import "import module.jz";

@project IMPORT_OUTSIDE_PROJECT_EXAMPLE
  CONFIG {
    X = 1;
  }

  @top IMPORT_DUP_MOD {
    IN  [1] a = _;
    OUT [1] out = _;
  }
@endproj

@module IMPORT_DUP_MOD
  PORT {
    IN  [1] a;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = a;
  }
@endmod
