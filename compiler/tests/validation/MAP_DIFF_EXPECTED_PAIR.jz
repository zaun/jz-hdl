// MAP_DIFF_EXPECTED_PAIR: differential pin mapped to scalar.
// Verified

@project MAP_DIFF_EXPECTED_PAIR_PROJECT
  OUT_PINS {
    tmds = { mode=DIFFERENTIAL, standard=LVDS25, drive=4 };
  }

  MAP {
    tmds = 10;
  }

  @top MAP_DIFF_EXPECTED_PAIR_EXAMPLE {
    IN  [1] in = _;
    OUT [1] out = _;
  }
@endproj

@module MAP_DIFF_EXPECTED_PAIR_EXAMPLE
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod
