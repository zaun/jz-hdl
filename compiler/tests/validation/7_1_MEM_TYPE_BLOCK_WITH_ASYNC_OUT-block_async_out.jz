// MEM_TYPE_BLOCK_WITH_ASYNC_OUT: BLOCK type MEM with ASYNC OUT port triggers error.
// Valid BLOCK with SYNC OUT included for no false positives.

@project MEM_TYPE_BLOCK_WITH_ASYNC_OUT_block_async_out
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: BLOCK with ASYNC OUT in helper module
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM(type=BLOCK) {
        mem_a [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= wdata;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 2: BLOCK with ASYNC OUT in top module
    MEM(type=BLOCK) {
        mem_b [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    // Valid: BLOCK with SYNC OUT (no error expected)
    MEM(type=BLOCK) {
        mem_ok [8] [16] = 8'h00 {
            OUT rd_ok SYNC;
            IN  wr_ok;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        mem_ok.rd_ok.addr <= addr;
        r <= mem_ok.rd_ok.data;
        mem_ok.wr_ok[addr] <= wdata;
    }
@endmod
