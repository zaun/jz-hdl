// PORT_HAPPY_PATH: Valid PORT declarations compile without errors.
// Tests IN read, OUT write, INOUT conditional, BUS SOURCE/TARGET, arrayed BUS,
// wildcard broadcast, and extension modifiers.

@project PORT_HAPPY_PATH_valid_ports_ok
    BUS SPI_BUS {
        OUT [1] mosi;
        IN  [1] miso;
        OUT [1] sck;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [1] ctrl = _;
        IN  [8] din = _;
        INOUT [8] bidir = _;
        OUT [8] dout_a = _;
        OUT [8] dout_b = _;
        OUT [8] dout_c = _;
        OUT [1] dout_d = _;
    }
@endproj

// Module with BUS SOURCE port
@module SourceMod
    PORT {
        IN  [1] clk;
        IN  [8] din;
        BUS SPI_BUS SOURCE spi;
        OUT [8] data_out;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    ASYNCHRONOUS {
        // Valid: write to writable BUS signal (mosi is OUT for SOURCE)
        spi.mosi <= din[0];
        spi.sck <= din[1];
        // Valid: read from readable BUS signal (miso is IN for SOURCE)
        data_out <= r;
    }

    SYNCHRONOUS(CLK=clk) {
        r[0] <= spi.miso;
        r[7:1] <= 7'b0;
    }
@endmod

// Module with arrayed BUS TARGET port
@module ArrayTargetMod
    PORT {
        IN  [1] clk;
        IN  [4] sel;
        BUS SPI_BUS TARGET [4] spi_arr;
        OUT [1] data_out;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        // Valid: read from readable signal on arrayed BUS (sck is OUT from def -> IN for TARGET)
        data_out <= spi_arr[0].sck;
        // Valid: wildcard broadcast (1-bit RHS to all elements)
        spi_arr[*].miso <= r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= sel[0];
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] ctrl;
        IN  [8] din;
        INOUT [8] bidir;
        OUT [8] dout_a;
        OUT [8] dout_b;
        OUT [8] dout_c;
        OUT [1] dout_d;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    @new inst_s SourceMod {
        IN  [1] clk = clk;
        IN  [8] din = din;
        BUS SPI_BUS SOURCE spi = _;
        OUT [8] data_out = dout_a;
    };

    @new inst_a ArrayTargetMod {
        IN  [1] clk = clk;
        IN  [4] sel = din[3:0];
        BUS SPI_BUS TARGET [4] spi_arr = _;
        OUT [1] data_out = dout_d;
    };

    ASYNCHRONOUS {
        // Valid: read IN port
        dout_b <= din;
        // Valid: write OUT port
        dout_c <= r;
        // Valid: INOUT read and write conditionally
        IF (ctrl) {
            bidir <= din;
        } ELSE {
            bidir <= 8'bz;
        }
    }

    SYNCHRONOUS(CLK=clk) {
        // Valid: read from IN port in SYNC
        r <= din;
    }
@endmod
