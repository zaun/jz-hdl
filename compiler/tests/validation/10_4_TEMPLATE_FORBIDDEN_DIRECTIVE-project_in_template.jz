// TEMPLATE_FORBIDDEN_DIRECTIVE: @project directive in file-scoped template.
// Realistic syntax with full project block. Parser does not recover after
// the error, producing cascading PARSE000.

@project TEMPLATE_FORBIDDEN_DIRECTIVE_project_in_template
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Trigger: @project directive inside file-scoped template
@template proj_tmpl(a, b)
    @project InnerProj
        CONFIG {
            WIDTH = 8;
        }
        @top TopMod {
            IN  [1] clk = _;
            OUT [1] data = _;
        }
    @endproj
@endtemplate

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
