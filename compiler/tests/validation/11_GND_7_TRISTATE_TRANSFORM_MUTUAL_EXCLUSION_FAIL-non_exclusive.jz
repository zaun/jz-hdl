// TRISTATE_TRANSFORM_MUTUAL_EXCLUSION_FAIL: Non-mutually-exclusive enable
// conditions on multiple tri-state drivers of the same signal.
// Contexts: two instances driving the same wire through INOUT ports with
// the same enable signal (non-exclusive enables).
// Valid: single-driver wires with IF/ELSE are not flagged.

@project TRISTATE_TRANSFORM_MUTUAL_EXCLUSION_FAIL_non_exclusive
    @top TopMod {
        IN  [1] en = _;
        IN  [8] din = _;
        OUT [8] result = _;
    }
@endproj

// Driver module with conditional tri-state INOUT output
@module DriverMod
    PORT {
        IN    [1] en;
        IN    [8] din;
        INOUT [8] data;
    }

    ASYNCHRONOUS {
        IF (en) {
            data <= din;
        } ELSE {
            data <= 8'bzzzz_zzzz;
        }
    }
@endmod

// Top module: two instances drive same wire with same enable (non-exclusive)
@module TopMod
    PORT {
        IN  [1] en;
        IN  [8] din;
        OUT [8] result;
    }

    WIRE {
        bus [8];
    }

    // Trigger: two instances share same INOUT wire with same enable
    @new inst_a DriverMod {
        IN    [1] en = en;
        IN    [8] din = din;
        INOUT [8] data = bus;
    };

    @new inst_b DriverMod {
        IN    [1] en = en;
        IN    [8] din = din;
        INOUT [8] data = bus;
    };

    ASYNCHRONOUS {
        result <= bus;
    }
@endmod
