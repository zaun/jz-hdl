// TEMPLATE_NESTED_DEF: nested @template definitions.
// Expect ERR> TEMPLATE_NESTED_DEF

@project TEMPLATE_NESTED_DEF_PROJECT
  @top TEMPLATE_NESTED_DEF_MOD {
    IN  [8] in_a = _;
    OUT [8] out_a = _;
  }
@endproj

@template A(a, b)
  @template B(c, d)
    d <= c;
  @endtemplate
  b <= a;
@endtemplate

@module TEMPLATE_NESTED_DEF_MOD
  PORT {
    IN  [8] in_a;
    OUT [8] out_a;
  }

  ASYNCHRONOUS {
    @apply A(in_a, out_a);
  }
@endmod
