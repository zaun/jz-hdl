// LATCH_AS_CLOCK_OR_CDC: LATCH may not be used as a clock signal.
// Verified

@project LATCH_AS_CLOCK_OR_CDC_PROJECT
  @top LATCH_AS_CLOCK_OR_CDC_EXAMPLE {
    IN  [1] en = _;
    IN  [1] d = _;
    OUT [8] out = _;
  }
@endproj

@module LATCH_AS_CLOCK_OR_CDC_EXAMPLE
  PORT {
    IN  [1] en;
    IN  [1] d;
    OUT [8] out;
  }

  LATCH {
    l [1] D;
  }

  REGISTER {
    r [8] = 8'h00;
  }

  ASYNCHRONOUS {
    l <= en : d;
    out <= r;
  }

  SYNCHRONOUS(CLK=l) {
    r <= 8'h01;
  }
@endmod
