// SYNC_MULTI_ASSIGN_SAME_REG_BITS: same register bits assigned more than once along a single path.
// Verified

@project SYNC_MULTI_ASSIGN_SAME_REG_BITS_PROJECT
  @top SYNC_MULTI_ASSIGN_SAME_REG_BITS_EXAMPLE_A {
    IN  [1] clk = _;
    OUT [4] data = _;
  }
@endproj

@module SYNC_MULTI_ASSIGN_SAME_REG_BITS_EXAMPLE_A
  PORT {
    IN  [1] clk;
    OUT [4] data;
  }

  REGISTER {
    r [4] = 4'b0000;
    s [4] = 4'b0000;
  }

  ASYNCHRONOUS {
    data <= r & s;
  }

  SYNCHRONOUS(CLK=clk) {
    // Root-level assignment followed by nested conditional assignment to same register.
    r <= 4'b0001;
    IF (clk) {
      r <= 4'b0010;
      s <= 4'b0010;
    } ELSE {
      s <= 4'b0011;
    }
  }
@endmod