// DIRECTIVE_INVALID_CONTEXT: @check inside SYNCHRONOUS block is forbidden.
// S9.7 consolidates all @check error conditions. @check may only appear at
// module or project scope, not inside blocks. Single trigger because parser
// recovery after @check in block causes cascading PARSE000 errors.
// Valid @check at module and project scope included for negative testing.

@project DIRECTIVE_INVALID_CONTEXT_check_in_sync
    CONFIG {
        WIDTH = 8;
    }

    // Valid: @check at project scope (no error)
    @check (CONFIG.WIDTH == 8, "width ok");

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module HelperMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    CONST { SIZE = 4; }

    // Valid: @check at module scope in helper (no error)
    @check (SIZE > 0, "size ok");

    ASYNCHRONOUS {
        data = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    CONST { DEPTH = 16; }

    // Valid: @check at module scope (no error)
    @check (DEPTH > 0, "depth ok");

    @new inst_a HelperMod {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        // Trigger 1: @check inside SYNCHRONOUS block
        @check (1, "sync check");
        r <= ~r;
    }
@endmod
