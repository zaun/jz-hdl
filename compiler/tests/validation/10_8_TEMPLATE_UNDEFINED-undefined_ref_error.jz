// TEMPLATE_UNDEFINED: Cross-reference test for S10.5 undefined template reference error.
// Tests undefined template in ASYNC and SYNC blocks across multiple modules.
// Valid @apply calls included for negative testing.

@project TEMPLATE_UNDEFINED_undefined_ref_error
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Valid file-scoped template
@template valid_tmpl(a, b)
    a <= b;
@endtemplate

@module HelperMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    WIRE {
        w1 [1];
    }

    ASYNCHRONOUS {
        // Valid: apply existing template (no error)
        @apply valid_tmpl(w1, din);
        // Trigger 1: undefined template in ASYNC
        @apply nonexistent(w1, din);
        data = w1;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    @new inst_a HelperMod {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        // Trigger 2: undefined template in TopMod ASYNC
        @apply missing_tmpl(data, r);
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        // Trigger 3: undefined template in SYNC
        @apply no_such_tmpl(r, clk);
        r <= ~r;
    }
@endmod
