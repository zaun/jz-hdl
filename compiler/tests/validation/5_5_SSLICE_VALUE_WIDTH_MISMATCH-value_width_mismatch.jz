// SSLICE_VALUE_WIDTH_MISMATCH: sslice() value argument width does not match width parameter.
// Tests sslice() with 8-bit value but width parameter of 4.
// Valid sslice() with matching widths included to verify no false positives.

@project SSLICE_VALUE_WIDTH_MISMATCH_value_width_mismatch
    @top TopMod {
        IN  [1]  clk = _;
        IN  [16] data = _;
        IN  [4]  idx = _;
        OUT [16] out_a = _;
        OUT [16] out_b = _;
    }
@endproj

// Helper module: sslice() with mismatched value width
@module HelperMod
    PORT {
        IN  [1]  clk;
        IN  [16] src;
        IN  [4]  idx;
        OUT [16] out_a;
        OUT [16] out_b;
    }
    REGISTER {
        r [16] = 16'd0;
    }
    ASYNCHRONOUS {
        // Trigger 1: sslice() value width (8) != width param (4) in helper ASYNC
        out_a <= sslice(src, idx, 4, src[7:0]);
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: sslice() value width mismatch in helper SYNC
        r <= sslice(src, idx, 4, src[7:0]);
    }
@endmod

@module TopMod
    PORT {
        IN  [1]  clk;
        IN  [16] data;
        IN  [4]  idx;
        OUT [16] out_a;
        OUT [16] out_b;
    }
    WIRE {
        ha_a [16];
        ha_b [16];
    }
    REGISTER {
        r [16] = 16'd0;
    }

    @new inst_h HelperMod {
        IN  [1]  clk = clk;
        IN  [16] src = data;
        IN  [4]  idx = idx;
        OUT [16] out_a = ha_a;
        OUT [16] out_b = ha_b;
    };

    ASYNCHRONOUS {
        // Trigger 3: sslice() value width mismatch in top ASYNC
        out_a <= sslice(data, idx, 4, data[7:0]);
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 4: sslice() value width mismatch in top SYNC
        r <= sslice(data, idx, 4, data[7:0]);
    }
@endmod
