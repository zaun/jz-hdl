// CLOCK_EDGE_INVALID: Invalid edge specifier in CLOCKS block.
// Tests edge values that are not Rising or Falling.
// Valid edge specifiers are included to verify no false positives.

@project CLOCK_EDGE_INVALID_invalid_edge
    CLOCKS {
        // Valid: Rising edge (no trigger)
        clk_a = { period=10, edge=Rising };
        // Valid: Falling edge (no trigger)
        clk_b = { period=10, edge=Falling };
        // Trigger 1: invalid edge "Both"
        clk_c = { period=10, edge=Both };
        // Trigger 2: invalid edge "Positive"
        clk_d = { period=10, edge=Positive };
    }

    IN_PINS {
        clk_a = { standard=LVCMOS33 };
        clk_b = { standard=LVCMOS33 };
        clk_c = { standard=LVCMOS33 };
        clk_d = { standard=LVCMOS33 };
    }

    MAP {
        clk_a = 1;
        clk_b = 2;
        clk_c = 3;
        clk_d = 4;
    }

    @top TopMod {
        IN  [1] clk = clk_a;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
