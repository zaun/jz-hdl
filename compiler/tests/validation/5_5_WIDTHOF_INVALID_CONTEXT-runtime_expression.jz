// WIDTHOF_INVALID_CONTEXT: widthof() used outside compile-time constant context.
// Tests widthof() in ASYNC and SYNC blocks where it is forbidden.
// widthof() is compile-time only and must not appear in runtime expressions.
// Valid widthof() in CONST block included to verify no false positives.

@project WIDTHOF_INVALID_CONTEXT_runtime_expression
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] data_in = _;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
    }
@endproj

// Helper module: widthof() in async and sync blocks
@module HelperMod
    CONST {
        // Valid: widthof() in CONST block (no false positive)
        VAL_W = widthof(val);
    }
    PORT {
        IN  [1] clk;
        IN  [8] val;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    REGISTER {
        r [VAL_W] = 8'd0;
    }
    ASYNCHRONOUS {
        // Trigger 1: widthof() in helper async expression
        out_a <= widthof(val);
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: widthof() in helper sync expression
        r <= widthof(val);
    }
@endmod

@module TopMod
    CONST {
        // Valid: widthof() in CONST block (no false positive)
        DATA_W = widthof(data_in);
    }
    PORT {
        IN  [1] clk;
        IN  [8] data_in;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    WIRE {
        ha_a [8];
        ha_b [8];
    }
    REGISTER {
        r [DATA_W] = 8'd0;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [8] val = data_in;
        OUT [8] out_a = ha_a;
        OUT [8] out_b = ha_b;
    };

    ASYNCHRONOUS {
        // Trigger 3: widthof() in top async expression
        out_a <= widthof(data_in);
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 4: widthof() in top sync expression
        r <= widthof(data_in);
    }
@endmod
