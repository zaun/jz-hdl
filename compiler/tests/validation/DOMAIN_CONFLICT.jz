// DOMAIN_CONFLICT: register used in SYNCHRONOUS block whose CLK does not
// match its home-domain clock.
// Verified

@project DOMAIN_CONFLICT_PROJECT
  @top DOMAIN_CONFLICT_EXAMPLE {
    IN  [1] clk_a = _;
    IN  [1] clk_b = _;
    OUT [4] data = _;
  }
@endproj

@module DOMAIN_CONFLICT_EXAMPLE
  PORT {
    IN  [1] clk_a;
    IN  [1] clk_b;
    OUT [4] data;
  }

  REGISTER {
    r_a [4] = 4'b0000;
    r_b [4] = 4'b0000;
  }

  ASYNCHRONOUS {
    data = r_a | r_b;
  }

  // Home domain: CLK=clk_a
  SYNCHRONOUS(CLK=clk_a) {
    r_a <= 4'b0001;
  }

  // Illegal use: read/write 'r_a' in different clock domain.
  SYNCHRONOUS(CLK=clk_b) {
    r_b <= r_a;
  }
@endmod
