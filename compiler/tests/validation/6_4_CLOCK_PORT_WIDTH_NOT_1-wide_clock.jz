// CLOCK_PORT_WIDTH_NOT_1: Clock pin width is not [1].
// Tests clock pins declared with width > 1 in IN_PINS.
// Valid [1] width clock included to verify no false positives.

@project CLOCK_PORT_WIDTH_NOT_1_wide_clock
    CLOCKS {
        good_clk = { period=10 };
        // Trigger 1: wide clock
        wide_clk = { period=20 };
    }

    IN_PINS {
        good_clk = { standard=LVCMOS33 };
        // Trigger 1: clock pin with width 2
        wide_clk[2] = { standard=LVCMOS33 };
    }

    MAP {
        good_clk = 1;
        wide_clk[0] = 2;
        wide_clk[1] = 3;
    }

    @top TopMod {
        IN  [1] clk = good_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
