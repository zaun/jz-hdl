// CLOCK_PORT_WIDTH_NOT_1: Clock pin width is not [1].
// Tests clock pins declared with width > 1 in IN_PINS.
// Valid [1]-width clock included to verify no false positives.

@project CLOCK_PORT_WIDTH_NOT_1_wide_clock
    CLOCKS {
        good_clk = { period=10 };
        // Trigger: wide_clk is [2] in IN_PINS
        wide_clk = { period=20 };
        // Trigger: very_wide_clk is [4] in IN_PINS
        very_wide_clk = { period=30 };
    }

    IN_PINS {
        good_clk = { standard=LVCMOS33 };
        wide_clk[2] = { standard=LVCMOS33 };
        very_wide_clk[4] = { standard=LVCMOS33 };
    }

    MAP {
        good_clk = 1;
        wide_clk[0] = 2;
        wide_clk[1] = 3;
        very_wide_clk[0] = 4;
        very_wide_clk[1] = 5;
        very_wide_clk[2] = 6;
        very_wide_clk[3] = 7;
    }

    @top TopMod {
        IN  [1] clk = good_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
