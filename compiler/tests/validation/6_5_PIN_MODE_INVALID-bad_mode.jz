// PIN_MODE_INVALID: Invalid pin mode value (must be SINGLE or DIFFERENTIAL).
// Tests invalid mode values in IN_PINS, OUT_PINS, and INOUT_PINS blocks.
// Valid modes included to verify no false positives.

@project PIN_MODE_INVALID_bad_mode
    CLOCKS {
        sys_clk = { period=10 };
    }

    IN_PINS {
        sys_clk = { standard=LVCMOS33 };
        // Valid: mode=SINGLE (no trigger)
        valid_in = { standard=LVCMOS33, mode=SINGLE };
        // Trigger 1: invalid mode in IN_PINS
        bad_in = { standard=LVCMOS33, mode=BIDIR };
    }

    OUT_PINS {
        // Valid: mode=SINGLE (no trigger)
        valid_out = { standard=LVCMOS33, drive=8, mode=SINGLE };
        // Trigger 2: invalid mode in OUT_PINS
        bad_out = { standard=LVCMOS33, drive=8, mode=TRISTATE };
    }

    INOUT_PINS {
        // Valid: mode=SINGLE (no trigger)
        valid_io = { standard=LVCMOS33, drive=4, mode=SINGLE };
        // Trigger 3: invalid mode in INOUT_PINS
        bad_io = { standard=LVCMOS33, drive=4, mode=HALFDUP };
    }

    MAP {
        sys_clk = 1;
        valid_in = 2;
        bad_in = 3;
        valid_out = 4;
        bad_out = 5;
        valid_io = 6;
        bad_io = 7;
    }

    @top TopMod {
        IN  [1] clk = sys_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
