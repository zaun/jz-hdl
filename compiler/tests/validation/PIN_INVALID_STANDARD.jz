// PIN_INVALID_STANDARD: invalid electrical standard in PIN declaration.
// Verified

@project PIN_INVALID_STANDARD_PROJECT
  IN_PINS {
    pin = { standard=FOO };
  }

  MAP {
    pin = 10;
  }

  @top PIN_INVALID_STANDARD_EXAMPLE {
    IN  [1] in = _;
    OUT [1] out = _;
  }
@endproj

@module PIN_INVALID_STANDARD_EXAMPLE
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod

