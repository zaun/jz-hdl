// PATH_ABSOLUTE_FORBIDDEN: Absolute paths forbidden without --allow-absolute-paths.
// Tests absolute path rejection in @import context.

@project PATH_ABSOLUTE_FORBIDDEN_absolute_import

    // Trigger 1: @import with absolute path
    @import "/absolute/path/to/lib.jz";

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
