// SELECT_CASE_WIDTH_MISMATCH: CASE value width does not match selector width.
// Verified

@project SELECT_CASE_WIDTH_MISMATCH_PROJECT
  @top SELECT_CASE_WIDTH_MISMATCH_EXAMPLE {
    IN  [2] sel = _;
    OUT [8] out = _;
  }
@endproj

@module SELECT_CASE_WIDTH_MISMATCH_EXAMPLE
  PORT {
    IN  [2] sel;
    OUT [8] out;
  }

  ASYNCHRONOUS {
    SELECT (sel) {
      CASE 4'b0000 {
        out <= 8'h00;
      }
      DEFAULT {
        out <= 8'hFF;
      }
    }
  }
@endmod
