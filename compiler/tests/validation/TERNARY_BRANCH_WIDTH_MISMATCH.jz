// TERNARY_BRANCH_WIDTH_MISMATCH: ternary true/false branches have mismatched widths.
// Verified

@project TERNARY_BRANCH_WIDTH_MISMATCH_PROJECT
  @top TERNARY_BRANCH_WIDTH_MISMATCH_EXAMPLE {
    IN  [1] cond = _;
    IN  [8] a = _;
    IN  [4] b = _;
    IN  [8] c = _;
    OUT [8] outa = _;
    OUT [8] outb = _;
    OUT [8] outc = _;
  }
@endproj

@module TERNARY_BRANCH_WIDTH_MISMATCH_EXAMPLE
  PORT {
    IN  [1] cond;
    IN  [8] a;
    IN  [4] b;
    IN  [8] c;
    OUT [8] outa;
    OUT [8] outb;
    OUT [8] outc;
  }

  ASYNCHRONOUS {
    outa <= cond ? a : b;
    outb <= cond ? b : a;
    outc <= cond ? a : c;
  }
@endmod
