// WIDTH_ASSIGN_MISMATCH_NO_EXT: bare assignment operator used with mismatched widths.
// Verified

@project WIDTH_ASSIGN_MISMATCH_NO_EXT_PROJECT
  @top WIDTH_ASSIGN_MISMATCH_NO_EXT_EXAMPLE {
    IN  [8] a = _;
    OUT [4] b = _;
    OUT [4] c = _;
    OUT [4] d = _;
  }
@endproj

@module WIDTH_ASSIGN_MISMATCH_NO_EXT_EXAMPLE
  PORT {
    IN  [8] a;
    OUT [4] b;
    OUT [4] c;
    OUT [4] d;
  }

  ASYNCHRONOUS {
    // Bare operators with different widths (8 vs 4) require explicit z/s modifier.
    a = b;
    a => c;
    d <= a;
  }
@endmod
