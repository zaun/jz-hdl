// FUNDAMENTAL_TERMS: Happy path test for Section 1.2 fundamental concepts.
// Exercises signals, nets, deterministic nets, drivers, sinks, observable sinks,
// execution paths, registers, latches, and home domains — all valid.

@project FUNDAMENTAL_TERMS_happy_path_ok
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [1] enable = _;
        IN  [1] din = _;
        OUT [1] data = _;
    }
@endproj

// Helper module: single-driver net, register as driver/sink, port as observable sink
@module HelperA
    PORT {
        IN  [1] clk;
        IN  [1] din;
        OUT [1] data;
    }

    // Register as sink (assigned in SYNCHRONOUS) and driver (read in ASYNCHRONOUS)
    REGISTER {
        r [1] = 1'b0;
    }

    // Single-driver deterministic net
    WIRE {
        w [1];
    }

    ASYNCHRONOUS {
        // Wire driven by one source — deterministic net
        w = din;
        // Port as observable sink driven by register (register as driver)
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        // Register as sink — assigned in its home-domain SYNCHRONOUS block
        r <= w;
    }
@endmod

// Helper module: latch as driver, execution path exclusivity
@module HelperB
    PORT {
        IN  [1] clk;
        IN  [1] enable;
        IN  [1] din;
        OUT [1] data;
    }

    // Latch — guarded assignment in ASYNCHRONOUS, read as driver
    LATCH {
        lat [1] D;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    WIRE {
        sel_out [1];
    }

    ASYNCHRONOUS {
        // Latch as driver: guarded assignment then read
        lat <= enable : din;
        data <= lat;

        // Execution path exclusivity: IF/ELSE assigns same wire (valid, mutually exclusive)
        IF (enable) {
            sel_out <= din;
        } ELSE {
            sel_out <= r;
        }
    }

    SYNCHRONOUS(CLK=clk) {
        r <= sel_out;
    }
@endmod

// Top module: instantiates helpers, exercises single-bit signal as driver
@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] enable;
        IN  [1] din;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        IN  [1] din = din;
        OUT [1] data = _;
    };

    @new inst_b HelperB {
        IN  [1] clk = clk;
        IN  [1] enable = enable;
        IN  [1] din = din;
        OUT [1] data = _;
    };

    WIRE {
        w_single [1];
    }

    ASYNCHRONOUS {
        // Single-bit signal as driver for 1-bit port
        w_single = r;
        data = w_single;
    }

    SYNCHRONOUS(CLK=clk) {
        // Register driven in home domain
        r <= din;
    }
@endmod
