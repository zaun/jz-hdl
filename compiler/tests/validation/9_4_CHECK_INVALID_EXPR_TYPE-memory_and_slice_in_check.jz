// CHECK_INVALID_EXPR_TYPE: @check with signal slices and memory port fields.
// S9.4 forbids signal slices, memory ports, and any runtime expression in @check.
// Valid uses of CONST, CONFIG, and clog2 included to verify no false positives.

@project CHECK_INVALID_EXPR_TYPE_memory_and_slice_in_check
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [8] din = _;
        OUT [8] data = _;
    }
@endproj

@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] din;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    CONST { DEPTH = 16; }

    // Valid: CONST in @check (no error)
    @check (DEPTH > 0, "depth ok");

    // Trigger 1: port bit-slice in @check (helper module)
    @check (din[3:0] == 4'h0, "port slice in helper");

    // Trigger 2: register slice in @check (helper module)
    @check (r[7:4] == 4'h0, "reg slice in helper");

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] din;
        OUT [8] data;
    }

    CONST { SIZE = 8; }

    WIRE {
        w [8];
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Valid: CONST in @check (no error)
    @check (SIZE == 8, "size ok");

    // Valid: CONFIG in @check (no error)
    @check (CONFIG.WIDTH == 8, "config ok");

    // Valid: clog2 of CONST (no error)
    @check (clog2(SIZE) == 3, "clog2 ok");

    // Trigger 3: port bit-slice in @check (top module)
    @check (din[7:4] == 4'hF, "port slice in top");

    // Trigger 4: register bit-slice in @check
    @check (r[0] == 1'b0, "reg bit in check");

    // Trigger 5: wire bit-slice in @check
    @check (w[3:0] == 4'h0, "wire slice in check");

    @new inst_a HelperMod {
        IN  [1] clk = clk;
        IN  [8] din = din;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        w = din;
        data = w | r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= din;
    }
@endmod
