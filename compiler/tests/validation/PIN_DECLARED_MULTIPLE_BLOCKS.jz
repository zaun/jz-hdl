// PIN_DECLARED_MULTIPLE_BLOCKS: same pin name appears in multiple PIN blocks.
// Verified

@project PIN_DECLARED_MULTIPLE_BLOCKS_PROJECT
  IN_PINS {
    pin_in = { standard=LVCMOS33 };
    pin = { standard=LVCMOS33 };
  }

  OUT_PINS {
    pin_out = { standard=LVCMOS33, drive=8 };
    pin = { standard=LVCMOS33, drive=8 };
  }

  MAP {
    pin_in = 9;
    pin_out = 10;
    pin = 11;
  }

  @top PIN_DECLARED_MULTIPLE_BLOCKS_EXAMPLE {
    IN  [1] in = _;
    OUT [1] out = _;
  }
@endproj

@module PIN_DECLARED_MULTIPLE_BLOCKS_EXAMPLE
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod