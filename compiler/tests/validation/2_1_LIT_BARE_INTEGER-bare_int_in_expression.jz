// LIT_BARE_INTEGER: Bare integer literal in runtime expression.
// Tests bare integers in sync RHS across modules. Bare integers whose intrinsic
// width matches the target are used to avoid cascading width mismatch errors.
// Valid sized literals and CONST bare integers included to verify no false positives.

@project LIT_BARE_INTEGER_bare_int_in_expression
    @top TopMod {
        IN  [1] clk = _;
        OUT [8] data = _;
    }
@endproj

// Helper: bare integer in sync expression
@module HelperA
    PORT {
        IN  [1] clk;
        OUT [8] data;
    }
    REGISTER {
        r [8] = 8'h00;
    }
    ASYNCHRONOUS {
        data = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 1: bare integer 200 in sync RHS (intrinsic 8 bits = register width)
        r <= 200;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [8] data;
    }

    // Valid: bare integer in CONST (not a runtime expression, should NOT trigger)
    CONST {
        WIDTH = 8;
    }

    WIRE {
        helper_data [8];
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        OUT [8] data = helper_data;
    };

    REGISTER {
        r [8] = 8'h00;
    }
    ASYNCHRONOUS {
        data = helper_data ^ r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: bare integer 255 in sync RHS (intrinsic 8 bits = register width)
        r <= 255;
    }
@endmod
