// CDC_BIT_WIDTH_NOT_1: BIT CDC source register must have width [1].
// Expect ERR> CDC_BIT_WIDTH_NOT_1 on REGISTER 'r'

@project CDC_BIT_WIDTH_NOT_1_PROJECT
  @top CDC_BIT_WIDTH_NOT_1_EXAMPLE {
    IN  [1] clk_a = _;
    IN  [1] clk_b = _;
    OUT [4] data = _;
  }
@endproj

@module CDC_BIT_WIDTH_NOT_1_EXAMPLE
  PORT {
    IN  [1] clk_a;
    IN  [1] clk_b;
    OUT [4] data;
  }

  REGISTER {
    r [4] = 4'b0000;
  }

  // Illegal: BIT CDC on a 4-bit register.
  CDC {
    BIT r (clk_a) => alias_r (clk_b);
  }

  ASYNCHRONOUS {
    data = alias_r;
  }

  SYNCHRONOUS(CLK=clk_a) {
    r <= 4'b0001;
  }
@endmod