// CONFIG_INVALID_EXPR_TYPE: CONFIG value not a nonnegative integer expression.
// Tests undefined bare names and expressions with undefined names inside CONFIG block.
// Valid entries (simple integers, bare refs, strings) verify no false positives.

@project CONFIG_INVALID_EXPR_TYPE_invalid_value
    CONFIG {
        // Valid: simple integer
        GOOD = 8;
        // Valid: bare backward reference
        GOOD2 = GOOD;
        // Valid: expression with bare names
        GOOD3 = GOOD + GOOD2;
        // Valid: string value
        STR = "hello";
        // Trigger 1: undefined bare name
        BAD1 = UNDEF_X;
        // Trigger 2: another undefined bare name
        BAD2 = UNDEF_Y;
        // Trigger 3: expression with undefined name
        BAD3 = GOOD + UNDEF_Z;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module Helper
    PORT {
        IN  [1] din;
        OUT [1] dout;
    }
    ASYNCHRONOUS {
        dout = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    @new inst_h Helper {
        IN  [1] din = r;
        OUT [1] dout = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
