// TRISTATE_TRANSFORM_UNUSED_DEFAULT: --tristate-default=GND with no internal
// tri-state nets. Verifies warning when the flag is specified but there are no
// tri-state nets to transform. All nets are single-driver with no z assignments.
// Contexts: helper module with conditional output, top module with register + wire.
// Valid: no z values anywhere, so no tristate identification occurs.

@project TRISTATE_TRANSFORM_UNUSED_DEFAULT_no_tristate_nets
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [1] sel = _;
        OUT [8] data = _;
    }
@endproj

// Helper module: single driver on output, conditional values — no tri-state
@module HelperMod
    PORT {
        IN  [1] en;
        OUT [8] data;
    }

    ASYNCHRONOUS {
        IF (en) {
            data <= 8'b1010_1010;
        } ELSE {
            data <= 8'b0101_0101;
        }
    }
@endmod

// Top module: no tri-state nets, all single-driver
@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] sel;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'b0000_0000;
    }

    WIRE {
        w [8];
    }

    @new inst_h HelperMod {
        IN  [1] en = sel;
        OUT [8] data = w;
    };

    ASYNCHRONOUS {
        IF (sel) {
            data <= w;
        } ELSE {
            data <= r;
        }
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
