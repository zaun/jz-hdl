// TRISTATE_TRANSFORM_UNUSED_DEFAULT: --tristate-default=GND specified but no
// internal tri-state nets exist in the design. All nets are single-driver
// with no z assignments.
// Contexts: project-level warning (emitted once for the whole design).
// Valid: conditional outputs with determinate values are not tri-state.

@project TRISTATE_TRANSFORM_UNUSED_DEFAULT_no_tristate_nets
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [1] sel = _;
        IN  [8] din = _;
        OUT [8] data = _;
    }
@endproj

// Helper module: conditional output with determinate values — no z
@module HelperMod
    PORT {
        IN  [1] en;
        IN  [8] din;
        OUT [8] data;
    }

    ASYNCHRONOUS {
        IF (en) {
            data <= din;
        } ELSE {
            data <= 8'b0000_0000;
        }
    }
@endmod

// Top module: register + wire, no z values anywhere
@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] sel;
        IN  [8] din;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'b0000_0000;
    }

    WIRE {
        w [8];
    }

    @new inst_h HelperMod {
        IN  [1] en = sel;
        IN  [8] din = din;
        OUT [8] data = w;
    };

    ASYNCHRONOUS {
        IF (sel) {
            data <= w;
        } ELSE {
            data <= r;
        }
    }

    SYNCHRONOUS(CLK=clk) {
        r <= din;
    }
@endmod
