// MEM_TYPE_INVALID: Invalid MEM storage type keyword.
// Tests various invalid type strings across multiple modules.
// Valid types (BLOCK, DISTRIBUTED) included to verify no false positives.

@project MEM_TYPE_INVALID_invalid_storage_type
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: invalid type "SRAM" in helper module
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM(type=SRAM) {
        mem_a [8] [16] = 8'h00 {
            OUT rd ASYNC;
        };
    }

    ASYNCHRONOUS {
        data = mem_a.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
    }
@endmod

// Top module — valid MEM types plus invalid, instantiates HelperMod
@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 2: invalid type "RAM" in top module
    MEM(type=RAM) {
        mem_b [8] [16] = 8'h00 {
            OUT rd_b ASYNC;
        };
    }

    // Trigger 3: invalid type "REGISTER" — another invalid string
    MEM(type=REGISTER) {
        mem_c [8] [16] = 8'h00 {
            OUT rd_c ASYNC;
        };
    }

    // Valid: type=DISTRIBUTED (no error expected)
    MEM(type=DISTRIBUTED) {
        mem_ok [8] [16] = 8'h00 {
            OUT rd_ok ASYNC;
        };
    }

    // Valid: type=BLOCK (no error expected)
    MEM(type=BLOCK) {
        mem_blk [8] [16] = 8'h00 {
            OUT rd_blk SYNC;
            IN  wr_blk;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_b.rd_b[addr] ^ mem_c.rd_c[addr] ^ mem_ok.rd_ok[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_blk.rd_blk.addr <= addr;
        mem_blk.wr_blk[addr] <= r;
    }
@endmod
