// PIN_WIDTH_REQUIRES_DIFFERENTIAL: width attribute is only valid when mode=DIFFERENTIAL.
// Tests that width= on single-ended pins produces an error.
// Valid usage on differential pin included to verify no false positives.

@project PIN_WIDTH_REQUIRES_DIFFERENTIAL_width_no_diff
    CLOCKS {
        sys_clk = { period=10 };
        fast_clk = { period=2 };
    }

    IN_PINS {
        sys_clk = { standard=LVCMOS33 };
        fast_clk = { standard=LVCMOS33 };
        // Valid: width on differential pin (no trigger)
        valid_diff = { standard=LVDS25, mode=DIFFERENTIAL, width=10 };
        // Trigger 1: width on single-ended IN_PIN
        bad_in = { standard=LVCMOS33, width=10 };
    }

    OUT_PINS {
        // Trigger 2: width on single-ended OUT_PIN
        bad_out = { standard=LVCMOS33, drive=8, width=10 };
        // Trigger 3: width on explicit mode=SINGLE
        bad_single = { standard=LVCMOS33, drive=8, mode=SINGLE, width=10 };
    }

    MAP {
        sys_clk = 1;
        fast_clk = 2;
        valid_diff = { P=3, N=4 };
        bad_in = 5;
        bad_out = 6;
        bad_single = 7;
    }

    @top TopMod {
        IN  [1] clk = sys_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
