// ASSIGN_CONCAT_WIDTH_MISMATCH: Concatenation width sum does not match paired expression width.
// Tests concat width mismatch in ASYNCHRONOUS and SYNCHRONOUS blocks across modules.
// Valid matching-width concatenations included to verify no false positives.

@project ASSIGN_CONCAT_WIDTH_MISMATCH_concat_width_mismatch
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] a = _;
        IN  [4] b = _;
        IN  [2] c = _;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
    }
@endproj

// Helper module: concat width mismatches in async block
@module HelperA
    PORT {
        IN  [1] clk;
        IN  [4] a;
        IN  [4] b;
        IN  [2] c;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    REGISTER {
        r [8] = 8'h00;
    }
    ASYNCHRONOUS {
        // Trigger 1: RHS concat too narrow (4+2=6 assigned to 8-bit port)
        out_a <= {a, c};
        // Valid: matching concat width (4+4=8 to 8-bit port, no false positive)
        out_b <= {a, b};
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: RHS concat too narrow in SYNC (4+2=6 to 8-bit register)
        // Also reads r to avoid unsinked warning
        r <= {r[3:0], c};
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] a;
        IN  [4] b;
        IN  [2] c;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    WIRE {
        w [8];
        ha_a [8];
        ha_b [8];
    }
    REGISTER {
        r [8] = 8'h00;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        IN  [4] a = a;
        IN  [4] b = b;
        IN  [2] c = c;
        OUT [8] out_a = ha_a;
        OUT [8] out_b = ha_b;
    };

    ASYNCHRONOUS {
        // Trigger 3: RHS concat too wide in top module async (4+4+2=10 to 8-bit wire)
        w <= {a, b, c};
        // Trigger 4: LHS concat width mismatch (4+2=6 from 8-bit source via drive)
        {a, c} => ha_a;
        out_a = ha_b;
        out_b = w;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 5: RHS concat width mismatch in top module sync (4+2=6 to 8-bit reg)
        // Also reads r to avoid unsinked warning
        r <= {r[3:0], c};
    }
@endmod
