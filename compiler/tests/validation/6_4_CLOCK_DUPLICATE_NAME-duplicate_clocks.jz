// CLOCK_DUPLICATE_NAME: Duplicate clock names in CLOCKS block.
// Tests multiple duplicate clock entries within the same CLOCKS block.
// Valid unique clocks are included to verify no false positives.

@project CLOCK_DUPLICATE_NAME_duplicate_clocks
    CLOCKS {
        sys_clk = { period=10 };
        fast_clk = { period=5 };
        // Trigger 1: duplicate of sys_clk
        sys_clk = { period=20 };
        // Trigger 2: duplicate of fast_clk
        fast_clk = { period=8 };
        // Valid: unique clock name (no trigger)
        unique_clk = { period=50 };
        // Trigger 3: third instance of sys_clk
        sys_clk = { period=15 };
    }

    IN_PINS {
        sys_clk = { standard=LVCMOS33 };
        fast_clk = { standard=LVCMOS33 };
        unique_clk = { standard=LVCMOS33 };
    }

    MAP {
        sys_clk = 1;
        fast_clk = 2;
        unique_clk = 3;
    }

    @top TopMod {
        IN  [1] clk = sys_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
