// SYNC_EDGE_INVALID: SYNCHRONOUS block EDGE must be Rising, Falling, or Both.
// Verified

@project SYNC_EDGE_INVALID_PROJECT
  @top SYNC_EDGE_INVALID_EXAMPLE {
    IN  [1] clk = _;
    OUT [8] out = _;
  }
@endproj

@module SYNC_EDGE_INVALID_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [8] out;
  }

  REGISTER {
    r [8] = 8'h00;
  }

  ASYNCHRONOUS {
    out <= r;
  }

  SYNCHRONOUS(CLK=clk EDGE=Invalid) {
    r <= 8'h01;
  }
@endmod
