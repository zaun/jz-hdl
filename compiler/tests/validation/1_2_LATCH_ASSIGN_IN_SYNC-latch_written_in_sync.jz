// LATCH_ASSIGN_IN_SYNC: LATCH may not be written in SYNCHRONOUS blocks.
// Each trigger is commented. Valid latch usage in ASYNCHRONOUS for no false positives.

@project LATCH_ASSIGN_IN_SYNC_latch_written_in_sync
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [1] enable = _;
        IN  [8] din = _;
        OUT [8] dout_a = _;
        OUT [8] dout_b = _;
    }
@endproj

// Trigger 1: latch written in SYNCHRONOUS in helper module
@module HelperA
    PORT {
        IN  [1] clk;
        IN  [1] enable;
        IN  [8] din;
        OUT [8] dout;
    }

    LATCH {
        lat [8] D;
    }

    ASYNCHRONOUS {
        // Valid: latch guarded assignment in ASYNC
        lat <= enable : din;
        dout <= lat;
    }

    // Trigger 1: latch written in SYNCHRONOUS block
    SYNCHRONOUS(CLK=clk) {
        lat <= din;
    }
@endmod

// Top module with its own latch-in-sync trigger
@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] enable;
        IN  [8] din;
        OUT [8] dout_a;
        OUT [8] dout_b;
    }

    LATCH {
        top_lat [8] D;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        IN  [1] enable = enable;
        IN  [8] din = din;
        OUT [8] dout = dout_a;
    };

    ASYNCHRONOUS {
        // Valid: latch guarded assignment in ASYNC
        top_lat <= enable : din;
        dout_b <= top_lat;
    }

    // Trigger 2: latch written in SYNCHRONOUS block in top module
    SYNCHRONOUS(CLK=clk) {
        top_lat <= din;
    }
@endmod
