// MEM_PORT_USED_AS_SIGNAL: Bare INOUT port reference used as a signal.
// INOUT ports must use .addr, .data, or .wdata pseudo-fields.
// Valid .data read included for no false positives.

@project MEM_PORT_USED_AS_SIGNAL_inout_bare_ref
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    ASYNCHRONOUS {
        // Trigger: bare INOUT port ref on RHS
        data = mem_a.rw;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_a.rw.addr <= addr;
        mem_a.rw.wdata <= wdata;
    }
@endmod
