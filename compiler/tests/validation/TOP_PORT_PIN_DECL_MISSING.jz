// TOP_PORT_PIN_DECL_MISSING: connected top port has no corresponding pin/clock declaration.
// Verified

@project TOP_PORT_PIN_DECL_MISSING_PROJECT
  // No IN_PINS or CLOCKS declare 'clk'.
  @top TOP_PORT_PIN_DECL_MISSING_EXAMPLE {
    IN  [1] clk = clk;
    OUT [1] data = _;
  }
@endproj

@module TOP_PORT_PIN_DECL_MISSING_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [1] data;
  }

  ASYNCHRONOUS {
    data = clk;
  }
@endmod
