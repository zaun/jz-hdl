// INSTANCE_ARRAY_PARENT_BIT_OVERLAP: constant OUT slice for an instance array.
// Since the slice does not depend on IDX, multiple instances drive the same bits.

@project INSTANCE_ARRAY_PARENT_BIT_OVERLAP_PROJECT
  @top Top {
    IN  [1] clk = _;
    OUT [8] bus = _;
  }
@endproj

@module Child
  PORT {
    IN  [1] clk;
    OUT [8] y;
  }

  ASYNCHRONOUS {
    y = 8'h0F;
  }
@endmod

@module Top
  PORT {
    IN  [1] clk;
    OUT [8] bus;
  }

  // Two instances, both drive bus[7:0] with a constant slice (no IDX).
  @new u[2] Child {
    IN  [1] clk = clk;
    OUT [8] y   = bus[7:0];
  }

  ASYNCHRONOUS {
    // no additional logic
  }
@endmod
