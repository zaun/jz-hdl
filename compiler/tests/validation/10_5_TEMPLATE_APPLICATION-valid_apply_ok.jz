// TEMPLATE_APPLICATION: Valid @apply usage — verifies no false positives.
// Tests: basic apply with matching args, count=0 no-op, count=1 single expansion,
// apply in ASYNC and SYNC blocks, file-scoped and module-scoped templates,
// multi-module interaction via @new.
// This is a happy-path test: no diagnostics expected.

@project TEMPLATE_APPLICATION_valid_apply_ok
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// File-scoped template: simple assignment
@template assign_tmpl(dst, src)
    dst <= src;
@endtemplate

// File-scoped template with scratch wire
@template invert_tmpl(dst, src)
    @scratch tmp [1];
    tmp <= ~src;
    dst <= tmp;
@endtemplate

@module HelperMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    // Module-scoped template
    @template local_assign(out, inp)
        out <= inp;
    @endtemplate

    WIRE {
        w1 [1];
    }

    ASYNCHRONOUS {
        // Basic apply: file-scoped template with matching args
        @apply assign_tmpl(w1, din);
        // Module-scoped template apply
        @apply local_assign(data, w1);
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    @new inst_a HelperMod {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    WIRE {
        w1 [1];
    }

    ASYNCHRONOUS {
        // Apply with count=0: no-op, no expansion
        @apply[0] assign_tmpl(w1, r);
        // Apply with count=1: single expansion
        @apply[1] assign_tmpl(w1, r);
        // Apply template with scratch wire
        @apply invert_tmpl(data, w1);
    }

    SYNCHRONOUS(CLK=clk) {
        // Apply in SYNCHRONOUS context
        @apply assign_tmpl(r, ~r);
    }
@endmod
