// MEM_SYNC_ADDR_IN_ASYNC_BLOCK: Assign sync port .addr in ASYNCHRONOUS block.
// Valid .addr assignment in SYNC block included for no false positives.

@project MEM_SYNC_ADDR_IN_ASYNC_BLOCK_sync_addr_in_async
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: .addr in ASYNC block in helper
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd SYNC;
        };
    }

    ASYNCHRONOUS {
        data = r;
        // Trigger 1: .addr in ASYNC block
        mem_a.rd.addr = addr;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= mem_a.rd.data;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd SYNC;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = r;
        // Trigger 2: .addr in ASYNC block in top module
        mem_b.rd.addr = addr;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= mem_b.rd.data;
    }
@endmod
