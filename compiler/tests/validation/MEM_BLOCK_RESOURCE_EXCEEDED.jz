@module leaf
  PORT {
    OUT [8] data;
  }

  MEM(TYPE=BLOCK) {
    r1 [8] [512] = 8'h00 { OUT rd; };
    r2 [8] [512] = 8'h00 { OUT rd; };
    r3 [8] [512] = 8'h00 { OUT rd; };
    r4 [8] [512] = 8'h00 { OUT rd; };
    r5 [8] [512] = 8'h00 { OUT rd; };
    r6 [8] [512] = 8'h00 { OUT rd; };
    r7 [8] [512] = 8'h00 { OUT rd; };
    r8 [8] [512] = 8'h00 { OUT rd; };
    r9 [8] [512] = 8'h00 { OUT rd; };
    r10 [8] [512] = 8'h00 { OUT rd; };
  }

  ASYNCHRONOUS {
    data <= r1.rd[0];
  }
@endmod

@module mid
  PORT {
    OUT [8] data;
  }

  @new a1 leaf {
    OUT [8] data = _;
  }

  @new a2 leaf {
    OUT [8] data = _;
  }

  @new a3 leaf {
    OUT [8] data = _;
  }

  @new a4 leaf {
    OUT [8] data = _;
  }

  @new a5 leaf {
    OUT [8] data = _;
  }

  ASYNCHRONOUS {
    data <= a1.data;
  }
@endmod

@module top
  PORT {
    OUT [8] data;
  }

  @new m mid {
    OUT [8] data = _;
  }

  ASYNCHRONOUS {
    data <= m.data;
  }
@endmod

@project(CHIP="GW2AR-18-QN88-C8-I7") demo
  @top top {
    OUT [8] data = _;
  }
@endproj
