// TEMPLATE_SCRATCH_WIDTH_INVALID: Cross-reference test for S10.3 @scratch width error.
// Tests @scratch with zero width and non-constant (parameter) width.
// NOTE: Known compiler bug — this rule is not enforced. See issues.md.
// Valid @scratch with literal and CONST widths included for negative testing.

@project TEMPLATE_SCRATCH_WIDTH_INVALID_invalid_width_error
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Valid: scratch with literal constant width (no error)
@template valid_lit(a, b)
    @scratch tmp [8];
    tmp <= a;
    b <= tmp;
@endtemplate

// Trigger 1: scratch with zero width
@template zero_w(a, b)
    @scratch bad [0];
    a <= b;
@endtemplate

// Trigger 2: scratch with parameter as width (not a constant)
@template param_w(a, b, w)
    @scratch bad [w];
    a <= b;
@endtemplate

@module HelperMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    // Trigger 3: scratch with zero width in module-scoped template
    @template mod_zero(a, b)
        @scratch bad [0];
        a <= b;
    @endtemplate

    ASYNCHRONOUS {
        data = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    @new inst_a HelperMod {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
