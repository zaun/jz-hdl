// IF_COND_MISSING_PARENS: IF condition missing required parentheses in SYNC.
// Parser aborts after first parse error, so only one trigger per file.
// Tests IF without parens in SYNCHRONOUS block.

@project IF_COND_MISSING_PARENS_sync_missing_parens
    @top TopMod {
        IN  [1] clk = _;
        IN  [1] sel = _;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] sel;
        OUT [1] data;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        data = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 1: IF missing parens in SYNC
        IF sel {
            r <= VCC;
        } ELSE {
            r <= GND;
        }
    }
@endmod
