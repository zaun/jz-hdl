// GSLICE_WIDTH_INVALID: gslice() width parameter must be a positive integer.
// Tests gslice() with zero width parameter in async and sync blocks.
// Valid gslice() with positive width included to verify no false positives.

@project GSLICE_WIDTH_INVALID_zero_width_param
    @top TopMod {
        IN  [1]  clk = _;
        IN  [16] data = _;
        OUT [4]  out_a = _;
        OUT [4]  out_b = _;
    }
@endproj

// Helper module with zero-width gslice
@module HelperMod
    PORT {
        IN  [1]  clk;
        IN  [16] data;
        OUT [4]  out_a;
        OUT [4]  out_b;
    }
    REGISTER {
        r [4] = 4'd0;
    }
    ASYNCHRONOUS {
        // Trigger 1: gslice with width=0 in async
        out_a <= gslice(data, 4'd0, 0);
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: gslice with width=0 in sync
        r <= gslice(data, 4'd2, 0);
    }
@endmod

@module TopMod
    PORT {
        IN  [1]  clk;
        IN  [16] data;
        OUT [4]  out_a;
        OUT [4]  out_b;
    }
    WIRE {
        h_a [4];
        h_b [4];
    }
    REGISTER {
        r [4] = 4'd0;
    }

    @new inst_h HelperMod {
        IN  [1]  clk = clk;
        IN  [16] data = data;
        OUT [4]  out_a = h_a;
        OUT [4]  out_b = h_b;
    };

    ASYNCHRONOUS {
        // Trigger 3: gslice with width=0 in top async
        out_a <= gslice(data, 4'd4, 0);
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 4: gslice with width=0 in top sync
        r <= gslice(data, 4'd6, 0);
    }
@endmod
