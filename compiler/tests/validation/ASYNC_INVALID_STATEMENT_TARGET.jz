// ASYNC_INVALID_STATEMENT_TARGET: LHS in ASYNCHRONOUS assignment is not an
// assignable signal (e.g., CONFIG.<name>).
// Verified

@project ASYNC_INVALID_STATEMENT_TARGET_PROJECT
  CONFIG {
    X = 1;
  }

  @top ASYNC_INVALID_STATEMENT_TARGET_EXAMPLE {
    OUT [1] out = _;
  };
@endproj

@module ASYNC_INVALID_STATEMENT_TARGET_EXAMPLE
  PORT {
    OUT [1] out;
  }

  ASYNCHRONOUS {
    CONFIG.X <= 1;
    out <= 1'b1;
  }
@endmod
