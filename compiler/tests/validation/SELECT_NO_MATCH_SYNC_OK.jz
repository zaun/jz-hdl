// SELECT_NO_MATCH_SYNC_OK: SYNCHRONOUS SELECT without DEFAULT simply holds registers.
// Expect WRN> SELECT_NO_MATCH_SYNC_OK on the SELECT in the SYNCHRONOUS block.

@project SELECT_NO_MATCH_SYNC_OK_PROJECT
  @top SELECT_NO_MATCH_SYNC_OK_EXAMPLE {
    IN  [1] clk = _;
    IN  [2] state = _;
    OUT [8] out = _;
  }
@endproj

@module SELECT_NO_MATCH_SYNC_OK_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [2] state;
    OUT [8] out;
  }

  REGISTER {
    counter [8] = 8'h00;
  }

  ASYNCHRONOUS {
    out = counter;
  }

  SYNCHRONOUS(CLK=clk) {
    SELECT (state) {
      CASE 0 {
        counter <= counter + 8'd1;
      }
      CASE 1 {
        counter <= 8'h00;
      }
      // No DEFAULT: when state is 2 or 3, counter holds its current value.
    }
  }
@endmod
