// TEMPLATE_COUNT_ZERO: @apply[0] should be a no-op (zero iterations).
// No template errors expected.

@project TEMPLATE_COUNT_ZERO_PROJECT
  @top TEMPLATE_COUNT_ZERO_MOD {
    IN  [8] in_a = _;
    OUT [8] out_a = _;
  }
@endproj

@template NOOP(src, dst)
  dst <= src;
@endtemplate

@module TEMPLATE_COUNT_ZERO_MOD
  PORT {
    IN  [8] in_a;
    OUT [8] out_a;
  }

  ASYNCHRONOUS {
    @apply[0] NOOP(in_a, out_a);
    out_a <= in_a;
  }
@endmod
