// TOP_PORT_NOT_LISTED: Module ports omitted from @top binding.
// Tests omission of IN and OUT ports from @top.
// Valid port bindings included for no false positives.

@project TOP_PORT_NOT_LISTED_port_omitted
    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
        // Trigger 1: IN port not listed in @top
        IN  [1] extra_in;
        // Trigger 2: OUT port not listed in @top
        OUT [1] extra_out;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        data = r;
        extra_out = extra_in;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
