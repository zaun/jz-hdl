// DIV_CONST_ZERO: division/modulus by compile-time constant zero.
// Verified

@project DIV_CONST_ZERO_PROJECT
  @top DIV_CONST_ZERO_EXAMPLE {
    IN  [8] a = _;
    OUT [8] out_a = _;
    OUT [8] out_b = _;
  }
@endproj

@module DIV_CONST_ZERO_EXAMPLE
  PORT {
    IN  [8] a;
    OUT [8] out_a;
    OUT [8] out_b;
  }

  ASYNCHRONOUS {
    out_a <= a / 8'd0;
    out_b <= a % 8'd0;
  }
@endmod
