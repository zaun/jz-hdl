// HAPPY_PATH: Valid MEM initialization — literal and @file, multi-module.
// Covers: sized literal, zero init, narrower literal (zero-extended),
// @file with string path, @file with CONST string path,
// single-entry memory.
// No diagnostics expected.

@project HAPPY_PATH_initialization_ok
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [2] addr = _;
        OUT [8] data = _;
    }
@endproj

// Helper module: literal init with exact width match
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [2] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Valid: sized literal matching word width
    MEM {
        mem_lit [8] [4] = 8'hAA {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        data = mem_lit.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_lit.wr[addr] <= 8'h00;
    }
@endmod

@module TopMod
    CONST {
        LUT_FILE = "mem_exact_4bytes.bin";
    }

    PORT {
        IN  [1] clk;
        IN  [2] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Valid: zero literal init
    MEM {
        mem_zero [8] [4] = 8'h00 {
            OUT rd_z ASYNC;
            IN  wr_z;
        };
    }

    // Valid: narrower literal (4-bit for 8-bit word, zero-extended)
    MEM {
        mem_narrow [8] [4] = 4'hF {
            OUT rd_n ASYNC;
            IN  wr_n;
        };
    }

    // Valid: @file with string literal path
    MEM {
        mem_file [8] [4] = @file("mem_exact_4bytes.bin") {
            OUT rd_f ASYNC;
            IN  wr_f;
        };
    }

    // Valid: @file with CONST string path
    MEM {
        mem_const [8] [4] = @file(LUT_FILE) {
            OUT rd_c ASYNC;
            IN  wr_c;
        };
    }

    // Valid: single-entry memory with literal
    MEM {
        mem_single [8] [1] = 8'hFF {
            OUT rd_s ASYNC;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [2] addr = addr;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_zero.rd_z[addr] ^ mem_narrow.rd_n[addr]
             ^ mem_file.rd_f[addr] ^ mem_const.rd_c[addr]
             ^ mem_single.rd_s[1'b0];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_zero.wr_z[addr] <= 8'h00;
        mem_narrow.wr_n[addr] <= 8'h00;
        mem_file.wr_f[addr] <= 8'h00;
        mem_const.wr_c[addr] <= 8'h00;
    }
@endmod
