// ASYNC_FLOATING_Z_READ: net has sinks but all drivers assign 'z'
// (tri-state bus fully released while read).
// Expect ERR> ASYNC_FLOATING_Z_READ on 'bus'.
// Verified

@project ASYNC_FLOATING_Z_READ_PROJECT
  @top ASYNC_FLOATING_Z_READ_EXAMPLE {
    INOUT [8] data = _;
    OUT   [8] out_a = _;
  }
@endproj

@module ASYNC_FLOATING_Z_READ_EXAMPLE
  PORT {
    INOUT [8] data;
    OUT   [8] out_a;
  }

  ASYNCHRONOUS {
    // Only driver for 'out_a' drives all 'z'.
    data <= 8'bzzzz_zzzz;
    out_a = data;
  }
@endmod
