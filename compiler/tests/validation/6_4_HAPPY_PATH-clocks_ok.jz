// HAPPY_PATH: Valid CLOCKS block with IN_PIN clocks, CLOCK_GEN (PLL, CLKDIV, OSC),
// falling edge, minimal clock declaration, and indexed clock pins.
// No diagnostics expected.

@project(CHIP="gw2ar-18-qn88-c8-i7") HAPPY_PATH_clocks_ok
    CLOCKS {
        sys_clk = { period=10 };
        slow_clk = { period=100, edge=Falling };
        pll_out;
        pll_phase;
        div_clk;
        osc_clk;
    }

    IN_PINS {
        sys_clk = { standard=LVCMOS33 };
        slow_clk = { standard=LVCMOS33 };
    }

    MAP {
        sys_clk = 1;
        slow_clk = 2;
    }

    CLOCK_GEN {
        PLL {
            IN REF_CLK sys_clk;
            OUT BASE pll_out;
            OUT PHASE pll_phase;
            WIRE LOCK pll_lock;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };

        CLKDIV {
            IN REF_CLK sys_clk;
            OUT BASE div_clk;

            CONFIG {
                DIV_MODE = 2;
            };
        };

        OSC {
            OUT BASE osc_clk;

            CONFIG {
                DIV = 10;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = sys_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
