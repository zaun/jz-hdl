// OVERRIDE_STRING_CONST_FORWARD: String CONST forwarded through OVERRIDE by
// identifier reference should preserve string type for @file() contexts.
// Expects MEM_INIT_FILE_NOT_FOUND (file doesn't exist) but NOT
// CONST_NUMERIC_IN_STRING_CONTEXT (string type must propagate correctly).

@project OVERRIDE_STRING_CONST_FORWARD_TEST
  @top top {
    OUT [8] data = _;
  }
@endproj

// Child module: uses string CONST for @file() path
@module rom_child
  CONST {
    ROM_FILE = "default.bin";
  }

  PORT {
    OUT [8] data;
  }

  MEM {
    rom [8] [256] = @file(ROM_FILE) {
      OUT rd ASYNC;
    };
  }

  ASYNCHRONOUS {
    data <= rom.rd[1];
  }
@endmod

// Parent module: overrides ROM_FILE with its own string CONST by reference
@module top
  CONST {
    MY_FILE = "custom_data.hex";
  }

  PORT {
    OUT [8] data;
  }

  @new rom0 rom_child {
    OVERRIDE {
      ROM_FILE = MY_FILE;
    }
    OUT [8] data = data;
  }

  ASYNCHRONOUS {
  }
@endmod
