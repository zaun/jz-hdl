// MEM_PORT_ADDR_READ: Try to read .addr which is a write-only input.
// Triggers on SYNC OUT .addr read in helper and top modules.
// Valid .data read included for no false positives.

@project MEM_PORT_ADDR_READ_read_addr_input
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        OUT [4] raddr = _;
    }
@endproj

// Helper: read SYNC .addr
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [4] raddr;
    }

    REGISTER {
        r [4] = 4'h0;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd SYNC;
        };
    }

    ASYNCHRONOUS {
        raddr = r;
    }

    SYNCHRONOUS(CLK=clk) {
        mem_a.rd.addr <= addr;
        // Trigger 1: read .addr (write-only input) on SYNC port
        r <= mem_a.rd.addr;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [4] raddr;
    }

    REGISTER {
        r [4] = 4'h0;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd SYNC;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        OUT [4] raddr = _;
    };

    ASYNCHRONOUS {
        raddr = r;
    }

    SYNCHRONOUS(CLK=clk) {
        mem_b.rd.addr <= addr;
        // Trigger 2: read .addr on SYNC port in top
        r <= mem_b.rd.addr;
    }
@endmod
