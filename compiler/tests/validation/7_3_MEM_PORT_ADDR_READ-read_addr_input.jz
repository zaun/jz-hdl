// MEM_PORT_ADDR_READ: Try to read .addr which is a write-only input.
// Triggers on SYNC OUT .addr and INOUT .addr read contexts.
// Valid .data read included for no false positives.

@project MEM_PORT_ADDR_READ_read_addr_input
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [4] raddr = _;
        OUT [8] data = _;
    }
@endproj

// Helper: read SYNC .addr
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [4] raddr;
    }

    REGISTER {
        r [4] = 4'h0;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd SYNC;
        };
    }

    ASYNCHRONOUS {
        raddr = r;
    }

    SYNCHRONOUS(CLK=clk) {
        mem_a.rd.addr <= addr;
        // Trigger 1: read .addr (write-only) on SYNC port
        r <= mem_a.rd.addr;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [4] raddr;
        OUT [8] data;
    }

    REGISTER {
        r [4] = 4'h0;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd SYNC;
        };
    }

    MEM(type=BLOCK) {
        mem_c [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        OUT [4] raddr = _;
    };

    ASYNCHRONOUS {
        raddr = r;
        data = mem_c.rw.data;
    }

    SYNCHRONOUS(CLK=clk) {
        mem_b.rd.addr <= addr;
        mem_c.rw.addr <= addr;
        mem_c.rw.wdata <= wdata;
        // Trigger 2: read .addr on SYNC port in top
        r <= mem_b.rd.addr;
        // Trigger 3: read .addr on INOUT port
        r <= mem_c.rw.addr;
    }
@endmod
