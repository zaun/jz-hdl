// UNDECLARED_IDENTIFIER: use of an identifier with no declaration in module scope.
// Verified

@project UNDECLARED_IDENTIFIER_PROJECT
  @top UNDECLARED_IDENTIFIER_EXAMPLE {
    IN  [1] clk = _;
    OUT [1] data = _;
  }
@endproj

@module UNDECLARED_IDENTIFIER_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [1] data;
  }

  REGISTER {
    r [1] = 1'b0;
  }

  ASYNCHRONOUS {
    data = r;
  }

  SYNCHRONOUS(CLK=clk) {
    r <= missing_signal;
  }
@endmod
