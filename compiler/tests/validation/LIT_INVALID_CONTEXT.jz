@project LIT_INVALID_CONTEXT_PROJECT
  @top LIT_INVALID_CONTEXT_EXAMPLE {
    OUT [1] data = _;
  }
@endproj

@module LIT_INVALID_CONTEXT_EXAMPLE
  CONST {
    X = lit(4, 3);
  }

  PORT {
    OUT [1] data;
  }

  ASYNCHRONOUS {
    data <= 1'b0;
  }
@endmod
