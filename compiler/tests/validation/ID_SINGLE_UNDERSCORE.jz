// ID_SINGLE_UNDERSCORE: single '_' used as a regular identifier.
// The lexer treats '_' as JZ_TOK_NO_CONNECT
// verified

@project ID_SINGLE_UNDERSCORE_EXAMPLES
    CONFIG {
        WIDTH = 8;
    }

    @top M2 {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// '_' as module name
@module _
    CONST {
        X = 1;
    }

    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b1;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod

// '_' as a CONST name
@module M2
    CONST {
        _ = 1;
    }

    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    @new inst_a _ {
        IN  [1] clk = _;
        OUT [1] data = _;
    };

    @new inst_b M3 {
        IN  [1] _ = _;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b1;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod

// '_' as a port name
@module M3
    PORT {
        IN [1] _;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b1;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=_) {
        r <= ~r;
    }
@endmod
