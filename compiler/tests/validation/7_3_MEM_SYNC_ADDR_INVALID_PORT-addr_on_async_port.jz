// MEM_SYNC_ADDR_INVALID_PORT: Using .addr field on ASYNC OUT port.
// .addr is only valid for SYNC OUT ports.
// Valid ASYNC bracket access included for no false positives.

@project MEM_SYNC_ADDR_INVALID_PORT_addr_on_async_port
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        OUT [8] data = _;
    }
@endproj

// Helper: .addr on ASYNC port
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd ASYNC;
        };
    }

    // Valid: bracket access on ASYNC port
    ASYNCHRONOUS {
        data = mem_a.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        // Trigger 1: .addr on ASYNC port
        mem_a.rd.addr <= addr;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd ASYNC;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_b.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        // Trigger 2: .addr on ASYNC port in top module
        mem_b.rd.addr <= addr;
    }
@endmod
