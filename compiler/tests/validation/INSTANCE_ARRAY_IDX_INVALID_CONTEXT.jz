// INSTANCE_ARRAY_IDX_INVALID_CONTEXT: IDX used where it is not allowed.
// 1) Scalar @new using IDX in binding.
// 2) OVERRIDE expression using IDX.

@project INSTANCE_ARRAY_IDX_INVALID_CONTEXT_PROJECT
  @top Top {
    IN  [1] clk = _;
    OUT [8] busA = _;
    OUT [8] busB = _;
  }
@endproj

@module Child
  PORT {
    IN  [1] clk;
    OUT [8] y;
  }

  ASYNCHRONOUS {
    y = 8'h55;
  }
@endmod

@module Top
  PORT {
    IN  [1] clk;
    OUT [8] busA;
    OUT [8] busB;
  }

  // Scalar instance incorrectly using IDX in RHS (simple [IDX] index).
  @new u_scalar Child {
    IN  [1] clk = clk;
    OUT [8] y   = busA[IDX];
  }

  // OVERRIDE expression using IDX is also invalid.
  @new u_arr[2] Child {
    OVERRIDE {
      WIDTH = IDX;
    }
    IN  [1] clk = clk;
    OUT [8] y   = busB;
  }

  ASYNCHRONOUS {
    // no additional logic
  }
@endmod
