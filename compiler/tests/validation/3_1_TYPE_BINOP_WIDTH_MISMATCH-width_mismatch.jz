// TYPE_BINOP_WIDTH_MISMATCH: Binary operators require equal operand widths.
// Tests width mismatch across arithmetic (+, -), bitwise (&, |, ^),
// comparison (==, !=, <), and multiplication operators in ASYNCHRONOUS
// and SYNCHRONOUS blocks across multiple modules.
// Valid same-width operations included to verify no false positives.

@project TYPE_BINOP_WIDTH_MISMATCH_width_mismatch
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] a = _;
        IN  [4] b = _;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
        OUT [1] out_c = _;
    }
@endproj

// Helper module: arithmetic, comparison, and bitwise width mismatches
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] a;
        IN  [4] b;
        OUT [8] out_a;
        OUT [1] out_b;
        OUT [1] out_c;
    }
    REGISTER {
        r [8] = 8'h00;
    }
    ASYNCHRONOUS {
        // Trigger 1: ADD width mismatch (8 vs 4) in ASYNC
        out_a = r + b;
        // Trigger 2: EQ comparison width mismatch (8 vs 4) in ASYNC
        out_b = (a == b);
        // Trigger 3: NOT-EQ comparison width mismatch (8 vs 4) in ASYNC
        out_c = (a != b);
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 4: SUB width mismatch in SYNC (8 vs 4)
        r <= a - b;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] a;
        IN  [4] b;
        OUT [8] out_a;
        OUT [8] out_b;
        OUT [1] out_c;
    }
    WIRE {
        w    [8];
        ha_a [8];
        ha_b [1];
        ha_c [1];
    }
    REGISTER {
        r [8] = 8'h00;
    }

    @new inst_a HelperMod {
        IN  [1] clk = clk;
        IN  [8] a = a;
        IN  [4] b = b;
        OUT [8] out_a = ha_a;
        OUT [1] out_b = ha_b;
        OUT [1] out_c = ha_c;
    };

    ASYNCHRONOUS {
        // Trigger 5: bitwise AND width mismatch (8 vs 4) in ASYNC
        w = a & b;
        // Trigger 6: bitwise XOR width mismatch (8 vs 4) in ASYNC
        out_a = a ^ b;
        // Trigger 7: less-than comparison width mismatch (8 vs 4) in ASYNC
        out_c = (a < b) | ha_b | ha_c;
        // Valid: same-width bitwise OR (no false positive); sinks w, r, ha_a
        out_b = ha_a | r | w;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 8: MUL width mismatch in SYNC (8 vs 4)
        r <= a * b;
    }
@endmod
