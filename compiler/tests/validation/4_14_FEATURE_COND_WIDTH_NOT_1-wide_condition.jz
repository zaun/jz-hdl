// FEATURE_COND_WIDTH_NOT_1: Feature guard condition with width != 1.
// Tests that the compiler rejects @feature conditions that are not 1-bit wide.
// Valid conditions (comparisons producing width 1) are included as negative tests.

@project FEATURE_COND_WIDTH_NOT_1_wide_condition
    CONFIG {
        DEBUG = 1;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [1] din = _;
        OUT [1] data_a = _;
        OUT [1] data_b = _;
    }
@endproj

// Helper module with wide-condition trigger in ASYNCHRONOUS block
@module HelperMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    CONST {
        CTRL = 1;
    }

    ASYNCHRONOUS {
        // Valid: comparison produces width-1 (should NOT trigger)
        @feature CTRL == 1
            data = din;
        @else
            data = ~din;
        @endfeat

        // Trigger 1: wide literal as condition in ASYNCHRONOUS block
        @feature 8'd255
            data = din;
        @else
            data = ~din;
        @endfeat
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] din;
        OUT [1] data_a;
        OUT [1] data_b;
    }

    CONST {
        MODE = 1;
    }

    @new inst_h HelperMod {
        IN  [1] din = din;
        OUT [1] data = data_b;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        // Valid: CONFIG comparison produces width-1 (should NOT trigger)
        @feature CONFIG.DEBUG == 1
            data_a = r;
        @else
            data_a = ~r;
        @endfeat
    }

    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: wide literal as condition in SYNCHRONOUS block
        @feature 4'd3
            r <= din;
        @endfeat
    }
@endmod
