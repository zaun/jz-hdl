// LIT_OVERFLOW: sized literal intrinsic width exceeds declared width.
// Verified

@project LIT_OVERFLOW_PROJECT
  @top LIT_OVERFLOW_EXAMPLE {
    OUT [4] a = _;
    OUT [4] b = _;
    OUT [4] c = _;
  }
@endproj

@module LIT_OVERFLOW_EXAMPLE
  PORT {
    OUT [4] a;
    OUT [4] b;
    OUT [4] c;
  }

  ASYNCHRONOUS {
    // 5-bit value into 4-bit literal width => overflow before extension.
    a <= 4'b10101;
    b <= 4'hFF;
    c <= 2'd10;
  }
@endmod
