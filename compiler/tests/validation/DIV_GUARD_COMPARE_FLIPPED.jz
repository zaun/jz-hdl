// DIV_GUARD_COMPARE_FLIPPED: literal on the left side of >, >=, <, <=.
// E.g., IF (0 < b) is equivalent to IF (b > 0).
// Verified

@project DIV_GUARD_COMPARE_FLIPPED_PROJECT
  @top DIV_GUARD_COMPARE_FLIPPED_EXAMPLE {
    IN  [8] a = _;
    IN  [8] b = _;
    OUT [8] out_a = _;
    OUT [8] out_b = _;
    OUT [8] out_c = _;
  }
@endproj

@module DIV_GUARD_COMPARE_FLIPPED_EXAMPLE
  PORT {
    IN  [8] a;
    IN  [8] b;
    OUT [8] out_a;
    OUT [8] out_b;
    OUT [8] out_c;
  }

  ASYNCHRONOUS {
    // IF (0 < b) → same as IF (b > 0) → THEN: nonzero — should NOT warn
    IF (8'd0 < b) {
      out_a <= a / b;
    } ELSE {
      out_a <= 8'd0;
    }

    // IF (1 <= b) → same as IF (b >= 1) → THEN: nonzero — should NOT warn
    IF (8'd1 <= b) {
      out_b <= a / b;
    } ELSE {
      out_b <= 8'd0;
    }

    // IF (5 > b) → same as IF (b < 5) → ELSE: b >= 5 → nonzero — should NOT warn
    IF (8'd5 > b) {
      out_c <= 8'd0;
    } ELSE {
      out_c <= a % b;
    }
  }
@endmod
