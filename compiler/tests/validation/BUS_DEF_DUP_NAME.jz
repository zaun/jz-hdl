// BUS_DEF_DUP_NAME: duplicate BUS definition name in project.
// Verified

@project BUS_DEF_DUP_NAME_EXAMPLE
  BUS SYSBUS {
    IN  [8] data_in;
    OUT [8] data_out;
  }

  // Duplicate BUS with same id SYSBUS
  BUS SYSBUS {
    IN  [8] ctrl;
  }

  @top top {
    IN  [1] clk = _;
  }
@endproj

@module top
  PORT {
    IN [1] clk;
  }

  ASYNCHRONOUS {
    // no logic needed
  }
@endmod
