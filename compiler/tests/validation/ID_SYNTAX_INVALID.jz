// ID_SYNTAX_INVALID: identifiers that violate length constraints.
// Verified

@project ID_SYNTAX_INVALID_EXAMPLES
  CONFIG {
    WIDTH = 8;
  }

  @top M2 {
    IN  [1] clk = _;
    OUT [1] data = _;
  }
@endproj

// Too-long module name
@module 
  CONST {
    OK = 1;
  }

  PORT {
    IN  [1] clk;
    OUT [1] data;
  }

    REGISTER {
        r [1] = 1'b1;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod

// Too-long CONST identifier
@module M2
  CONST {
     = 1;
  }

  PORT {
    IN  [1] clk;
    OUT [1] data;
  }

  @new m  {
    IN  [1] clk = _;
    OUT [1] data = _;
  }

    REGISTER {
        r [1] = 1'b1;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
