// PIN_MODE_STANDARD_MISMATCH: DIFFERENTIAL mode with single-ended standard.
// Tests mode=DIFFERENTIAL paired with single-ended standards in all PIN blocks.
// Valid differential standard with DIFFERENTIAL mode verifies no false positives.

@project PIN_MODE_STANDARD_MISMATCH_mode_standard_conflict
    CLOCKS {
        sys_clk = { period=10 };
        fast_clk = { period=2 };
    }

    IN_PINS {
        sys_clk = { standard=LVCMOS33 };
        fast_clk = { standard=LVCMOS33 };
        // Valid: differential standard with DIFFERENTIAL mode (no trigger)
        valid_diff = { standard=LVDS25, mode=DIFFERENTIAL };
        // Trigger 1: DIFFERENTIAL mode with single-ended standard in IN_PINS
        bad_diff_in = { standard=LVCMOS33, mode=DIFFERENTIAL };
    }

    OUT_PINS {
        // Valid: single-ended standard with SINGLE mode (no trigger)
        valid_out = { standard=LVCMOS33, drive=8, mode=SINGLE };
        // Trigger 2: DIFFERENTIAL mode with single-ended standard in OUT_PINS
        bad_diff_out = { standard=LVCMOS18, drive=8, mode=DIFFERENTIAL, fclk=fast_clk, pclk=sys_clk, reset=sys_clk };
    }

    INOUT_PINS {
        // Valid: no mode specified (defaults to SINGLE, no trigger)
        valid_io = { standard=LVCMOS33, drive=4 };
        // Trigger 3: DIFFERENTIAL mode with single-ended standard in INOUT_PINS
        bad_diff_io = { standard=LVCMOS25, drive=4, mode=DIFFERENTIAL };
    }

    MAP {
        sys_clk = 1;
        fast_clk = 2;
        valid_diff = { P=3, N=4 };
        bad_diff_in = { P=5, N=6 };
        valid_out = 7;
        bad_diff_out = { P=8, N=9 };
        valid_io = 10;
        bad_diff_io = { P=11, N=12 };
    }

    @top TopMod {
        IN  [1] clk = sys_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
