// ASSIGN_SLICE_WIDTH_MISMATCH: slice assignment where source/destination widths differ.
// Verified

@project ASSIGN_SLICE_WIDTH_MISMATCH_PROJECT
  @top ASSIGN_SLICE_WIDTH_MISMATCH_EXAMPLE {
    IN  [4] data = _;
    OUT [1] out = _;
  }
@endproj

@module ASSIGN_SLICE_WIDTH_MISMATCH_EXAMPLE
  PORT {
    IN  [4] data;
    OUT [1] out;
  }

  WIRE {
    bus   [16];
  }

  ASYNCHRONOUS {
    out <= 1'b0;

    // LHS slice is 8 bits wide, RHS expression is 4 bits.
    bus[7:0] = data;

    // LHS slice is 5 bits wide, RHS expression is 4 bits.
    bus[6:2] = data;

    // LHS slice is 4 bits wide, RHS expression is 4 bits.
    bus[11:8] = data;
  }
@endmod
