// SYNC_RESET_TYPE_INVALID: SYNCHRONOUS block RESET_TYPE must be Clocked or Immediate.
// Verified

@project SYNC_RESET_TYPE_INVALID_PROJECT
  @top SYNC_RESET_TYPE_INVALID_EXAMPLE {
    IN  [1] clk = _;
    IN  [1] rst = _;
    OUT [8] out = _;
  }
@endproj

@module SYNC_RESET_TYPE_INVALID_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [1] rst;
    OUT [8] out;
  }

  REGISTER {
    r [8] = 8'h00;
  }

  ASYNCHRONOUS {
    out <= r;
  }

  SYNCHRONOUS(CLK=clk RESET=rst RESET_TYPE=Never) {
    r <= 8'h01;
  }
@endmod
