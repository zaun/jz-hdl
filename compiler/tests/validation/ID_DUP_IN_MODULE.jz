// ID_DUP_IN_MODULE: duplicate identifiers within a single module.
// Verified

@project ID_DUP_IN_MODULE_EXAMPLES
  CONFIG {
    WIDTH = 8;
  }

  @top M {
    IN  [1] clk = _;
    IN  [1] a = _;
    OUT [1] c = _;
  }
@endproj

@module M
  CONST {
    c = 10;
  }

  PORT {
    IN  [1] clk;
    IN  [1] a;
    OUT [1] c;
  }

  REGISTER {
    b [32] = 32'h00;
  }

  WIRE {
    a [1];
    b [1];
  }

  ASYNCHRONOUS {
    c = b;
  }

  SYNCHRONOUS(CLK=clk) {
    b <=z a;
  }
@endmod
