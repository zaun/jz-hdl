// BUS_SIGNAL_WRITE_TO_READABLE: Write access to readable BUS signal.
// Tests writing to readable-only BUS signals in SOURCE and TARGET roles.
// Valid writes to writable signals included for no false positives.

@project BUS_SIGNAL_WRITE_TO_READABLE_write_readable_signal
    BUS MY_BUS {
        OUT [8] tx;
        IN  [8] rx;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [8] din = _;
        OUT [8] dout_a = _;
        OUT [8] dout_b = _;
    }
@endproj

// SOURCE role: IN signals are readable (not writable)
@module SourceMod
    PORT {
        IN  [1] clk;
        IN  [8] din;
        BUS MY_BUS SOURCE sbus;
        OUT [8] data_out;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    ASYNCHRONOUS {
        // Valid: write to writable (tx is OUT for SOURCE = writable)
        sbus.tx <= r;
        // Trigger 1: write to readable signal (rx is IN for SOURCE = readable, not writable)
        sbus.rx <= r;
        data_out <= sbus.rx;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= din;
    }
@endmod

// TARGET role: OUT signals are readable (not writable)
@module TargetMod
    PORT {
        IN  [1] clk;
        IN  [8] din;
        BUS MY_BUS TARGET tbus;
        OUT [8] data_out;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    ASYNCHRONOUS {
        // Valid: write to writable (rx is IN for TARGET = writable)
        tbus.rx <= r;
        // Trigger 2: write to readable signal (tx is OUT for TARGET = readable, not writable)
        tbus.tx <= r;
        data_out <= tbus.tx;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] din;
        OUT [8] dout_a;
        OUT [8] dout_b;
    }

    @new inst_s SourceMod {
        IN  [1] clk = clk;
        IN  [8] din = din;
        BUS MY_BUS SOURCE sbus = _;
        OUT [8] data_out = dout_a;
    };

    @new inst_t TargetMod {
        IN  [1] clk = clk;
        IN  [8] din = din;
        BUS MY_BUS TARGET tbus = _;
        OUT [8] data_out = dout_b;
    };

    ASYNCHRONOUS {
        // TopMod passes through instance outputs
    }
@endmod
