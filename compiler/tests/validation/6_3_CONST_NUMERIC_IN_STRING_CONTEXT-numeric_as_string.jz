// CONST_NUMERIC_IN_STRING_CONTEXT: Numeric CONFIG value used where string expected.
// Tests numeric CONFIG used in @file() path argument in MEM initialization.
// Valid string CONFIG @file use is not tested to avoid needing an actual file.

@project CONST_NUMERIC_IN_STRING_CONTEXT_numeric_as_string
    CONFIG {
        WIDTH = 8;
        DEPTH = 4;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [2] addr = _;
        OUT [8] data = _;
    }
@endproj

@module Helper
    PORT {
        IN  [1] clk;
        IN  [2] addr;
        OUT [8] dout;
    }

    // Trigger 1: numeric CONFIG used in @file() path
    MEM {
        mem_a [8] [CONFIG.DEPTH] = @file(CONFIG.WIDTH) {
            OUT rd ASYNC;
        };
    }

    ASYNCHRONOUS {
        dout = mem_a.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [2] addr;
        OUT [8] data;
    }

    @new inst_h Helper {
        IN  [1] clk = clk;
        IN  [2] addr = addr;
        OUT [8] dout = _;
    };

    // Trigger 2: numeric CONFIG used in @file() path (top module)
    MEM {
        mem_b [8] [CONFIG.DEPTH] = @file(CONFIG.DEPTH) {
            OUT rd ASYNC;
        };
    }

    REGISTER {
        r [8] = 8'h00;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= mem_b.rd[addr];
    }
@endmod
