// CLOCK_GEN_INPUT_IS_SELF_OUTPUT: CLOCK_GEN input clock is an output of the same block.
// Tests a PLL where an IN clock is also an OUT of the same CLOCK_GEN unit.
// Valid PLL with separate input/output included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_INPUT_IS_SELF_OUTPUT_self_reference
    CLOCKS {
        ref_clk = { period=10 };
        self_clk;
        good_out;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        // Trigger: IN and OUT both reference self_clk
        PLL {
            IN REF_CLK self_clk;
            OUT BASE self_clk;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };

        // Valid: separate input and output (no trigger)
        PLL {
            IN REF_CLK ref_clk;
            OUT BASE good_out;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
