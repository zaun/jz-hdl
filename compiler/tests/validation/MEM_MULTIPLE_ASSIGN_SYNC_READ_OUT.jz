// MEM_MULTIPLE_ASSIGN_SYNC_READ_OUT: multiple assignments to same synchronous read output
// within a single SYNCHRONOUS block.
// Verified

@project MEM_MULTIPLE_ASSIGN_SYNC_READ_OUT_PROJECT
  @top MEM_MULTIPLE_ASSIGN_SYNC_READ_OUT_EXAMPLE {
    IN  [1] clk = _;
    OUT [8] data = _;
  }
@endproj

@module MEM_MULTIPLE_ASSIGN_SYNC_READ_OUT_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [8] data;
  }

  REGISTER {
    ra [8] = 8'hFF;
    rb [8] = 8'hFF;
  }

  MEM {
    m [8] [4] = 8'h00 {
      OUT rd SYNC;
    };
  }

  ASYNCHRONOUS {
    data = ra ^ rb;
  }

  SYNCHRONOUS(clk=clk) {
    m.rd.addr <= 0;
    ra <= m.rd.data;
    m.rd.addr <= 1; // second read address on same port in single cycle
    rb <= m.rd.data;
  }
@endmod
