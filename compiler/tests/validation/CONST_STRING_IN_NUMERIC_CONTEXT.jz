// CONST_STRING_IN_NUMERIC_CONTEXT: String CONST/CONFIG used where a number is expected.

@project CONST_STRING_IN_NUMERIC_TEST
  CONFIG {
    STR_CFG = "hello.bin";
    NUM_CFG = 8;
  }

  @top top {
    OUT [1] outA = _;
    OUT [1] outB = _;
    OUT [1] outC = _;
  }
@endproj

@module top
  PORT {
    OUT [1] outA;
    OUT [1] outB;
    OUT [1] outC;
  }

  CONST {
    STR_CONST = "some/path.hex";
    STR_CONST_NUM = "99";
    NUM_CONST = 16;
  }

  WIRE {
    bad_wire [STR_CONST];       // string CONST used as width
    wire [8];
  }

  ASYNCHRONOUS {
    wire = 8'b1;
    outA <= STR_CONST_NUM;                        // string CONST used as litteral
    outB <= wire[STR_CONST_NUM:CONFIG.STR_CFG];   // string CONST used as slice
    outC <= lit(1, STR_CONST_NUM);                // string CONST used as litteral
  }
@endmod
