// IF_COND_MISSING_PARENS: IF condition missing required parentheses.
// Parser aborts after first parse error, so only one trigger per file is possible.
// Tests IF without parens in ASYNCHRONOUS block.

@project IF_COND_MISSING_PARENS_missing_parentheses
    @top TopMod {
        IN  [1] clk = _;
        IN  [1] sel = _;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] sel;
        OUT [1] data;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        // Trigger 1: IF missing parens in ASYNC
        IF sel {
            data <= r;
        } ELSE {
            data <= VCC;
        }
    }
    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
