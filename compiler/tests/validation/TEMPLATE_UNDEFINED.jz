// TEMPLATE_UNDEFINED: @apply references unknown template.
// Expect ERR> TEMPLATE_UNDEFINED

@project TEMPLATE_UNDEFINED_PROJECT
  @top TEMPLATE_UNDEFINED_MOD {
    IN  [8] in_a = _;
    OUT [8] out_a = _;
  }
@endproj

@module TEMPLATE_UNDEFINED_MOD
  PORT {
    IN  [8] in_a;
    OUT [8] out_a;
  }

  ASYNCHRONOUS {
    @apply NONEXISTENT(in_a, out_a);
  }
@endmod
