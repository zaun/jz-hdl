// CLOCK_GEN_PARAM_OUT_OF_RANGE: PLL CONFIG parameter and derived value out of range.
// Verified

@project(CHIP="GW2AR-18-QN88-C8-I7") CLOCK_GEN_PARAM_OUT_OF_RANGE_TEST
    CLOCKS {
        SCLK = { period=37.04 };
        CLK_SYS;
    }

    IN_PINS {
        SCLK = { standard=LVCMOS33 };
    }

    OUT_PINS {
        led = { standard=LVCMOS33, drive=8 };
    }

    MAP {
        SCLK = 4;
        led = 15;
    }

    CLOCK_GEN {
        PLL {
            IN REF_CLK SCLK;
            OUT BASE  CLK_SYS;

            CONFIG {
                IDIV = 200;
                FBDIV = 3;
                ODIV = 16;
            };
        };
    }

    @top top {
        IN  [1] clk = SCLK;
        OUT [1] led = led;
    }
@endproj

@module top
    PORT {
        IN  [1] clk;
        OUT [1] led;
    }

    ASYNCHRONOUS {
        led = clk;
    }
@endmod
