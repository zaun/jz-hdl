// MEM_PORT_ADDR_READ: Reading .addr on INOUT port is forbidden.
// .addr is a write-only input on INOUT ports.
// Valid .data read included for no false positives.

@project MEM_PORT_ADDR_READ_inout_addr_read
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [4] raddr = _;
        OUT [8] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [4] raddr;
        OUT [8] data;
    }

    REGISTER {
        r [4] = 4'h0;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    ASYNCHRONOUS {
        // Valid: reading .data on INOUT port
        data = mem_a.rw.data;
        raddr = r;
    }

    SYNCHRONOUS(CLK=clk) {
        mem_a.rw.addr <= addr;
        mem_a.rw.wdata <= wdata;
        // Trigger: read .addr on INOUT port (write-only input)
        r <= mem_a.rw.addr;
    }
@endmod
