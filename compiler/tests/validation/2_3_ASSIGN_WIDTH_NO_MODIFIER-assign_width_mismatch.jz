// ASSIGN_WIDTH_NO_MODIFIER: Width mismatch in assignment without extension modifier.
// Tests width mismatch in alias (=), receive (<=), and drive (=>) assignments
// in ASYNCHRONOUS and SYNCHRONOUS blocks across multiple modules.
// Valid same-width assignments included to verify no false positives.

@project ASSIGN_WIDTH_NO_MODIFIER_assign_width_mismatch
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] a = _;
        IN  [4] b = _;
        OUT [8] out_a = _;
        OUT [4] out_b = _;
    }
@endproj

// Helper module: width mismatches in alias and receive assignments
@module HelperA
    PORT {
        IN  [1] clk;
        IN  [8] a;
        IN  [4] b;
        OUT [8] out_a;
        OUT [4] out_b;
    }
    REGISTER {
        r [8] = 8'h00;
    }
    ASYNCHRONOUS {
        // Trigger 1: alias 4-bit to 8-bit port (narrower to wider)
        out_a = b;
        // Trigger 2: receive 8-bit to 4-bit port (wider to narrower)
        out_b <= a;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 3: receive 4-bit slice to 8-bit register in SYNC
        r <= r[3:0];
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] a;
        IN  [4] b;
        OUT [8] out_a;
        OUT [4] out_b;
    }
    WIRE {
        w8 [8];
        ha_a [8];
        ha_b [4];
    }
    REGISTER {
        r [8] = 8'h00;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        IN  [8] a = a;
        IN  [4] b = b;
        OUT [8] out_a = ha_a;
        OUT [4] out_b = ha_b;
    };

    ASYNCHRONOUS {
        // Trigger 4: alias 4-bit to 8-bit wire in top module
        w8 = b;
        // Trigger 5: receive 8-bit to 4-bit port in top module
        out_b <= a;
        // Valid: same-width alias (no false positive)
        out_a = w8;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 6: receive 4-bit slice to 8-bit register in top module sync
        r <= r[3:0];
    }
@endmod
