// CONST_CIRCULAR_DEP: Circular dependency in CONST definitions.
// Tests direct A=B; B=A; circular reference across modules.
// Note: The compiler does not emit CONST_CIRCULAR_DEP for module CONSTs.
// Instead, all CONST evaluation failures are mapped to CONST_NEGATIVE_OR_NONINT.
// This test captures the actual compiler behavior.
// Valid CONST chain included to verify no false positives.

@project CONST_CIRCULAR_DEP_circular_dependency
    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
        OUT [1] out_h = _;
    }
@endproj

// Helper module with circular CONST dependency
@module HelperMod
    CONST {
        // Trigger 1: circular dependency A -> B -> A
        CA = CB;
        CB = CA;
        GOOD = 1;
    }

    PORT {
        IN  [1] din;
        OUT [GOOD] data;
    }

    ASYNCHRONOUS {
        data = din;
    }
@endmod

@module TopMod
    CONST {
        // Trigger 2: circular dependency in top module
        X = Y;
        Y = X;
        OK = 1;
    }

    PORT {
        IN  [1] clk;
        OUT [OK] data;
        OUT [OK] out_h;
    }

    @new inst_h HelperMod {
        IN  [1] din = r;
        OUT [1] data = out_h;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
