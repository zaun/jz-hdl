// CONTROL_FLOW_OUTSIDE_BLOCK: IF used outside ASYNCHRONOUS or SYNCHRONOUS block.
// Parser may emit multiple errors for the IF and its branches.
// Tests IF at module scope (between block declarations).

@project CONTROL_FLOW_OUTSIDE_BLOCK_if_outside_block
    @top TopMod {
        IN  [1] clk = _;
        IN  [1] sel = _;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] sel;
        OUT [1] data;
    }
    REGISTER {
        r [1] = 1'b0;
    }

    // Trigger 1: IF at module scope — outside any ASYNC/SYNC block
    IF (sel) {
        data <= r;
    } ELSE {
        data <= VCC;
    }

    ASYNCHRONOUS {
        data = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Valid use of sel to avoid NET_DANGLING_UNUSED
        IF (sel) {
            r <= VCC;
        }
    }
@endmod
