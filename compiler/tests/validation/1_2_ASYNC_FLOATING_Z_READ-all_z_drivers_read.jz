// ASYNC_FLOATING_Z_READ: All drivers assign z but signal is read (floating tri-state).
// Tests wire where all assignments are z-valued but the wire is still read.
// Properly driven signals included to verify no false positives.

@project ASYNC_FLOATING_Z_READ_all_z_drivers_read
    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Helper module with all-z driven wire that is read
@module HelperA
    PORT {
        IN  [1] din;
        OUT [1] data;
    }
    WIRE {
        // Trigger 1: wire driven only with z, then read
        w_allz [1];
        // Valid: wire driven with actual value
        w_ok [1];
    }
    ASYNCHRONOUS {
        w_allz <= 1'bz;
        w_ok = din;
        data = w_allz;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    @new inst_a HelperA {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    WIRE {
        // Trigger 2: wire driven only with z in top module, then read
        top_z [1];
        // Valid: properly driven wire
        top_ok [1];
    }

    ASYNCHRONOUS {
        top_z <= 1'bz;
        top_ok = r;
        data = top_z;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
