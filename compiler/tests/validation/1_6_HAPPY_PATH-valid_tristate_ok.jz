// HAPPY_PATH: Valid z literal forms and tri-state patterns.
// Exercises: binary z literal, z extension, single-bit z, conditional tri-state
// on INOUT ports, INOUT read when released, and multi-module tri-state via @new.
// This is a happy-path test: no diagnostics expected.

@project HAPPY_PATH_valid_tristate_ok
    @top TopMod {
        IN    [1] clk = _;
        IN    [1] en = _;
        IN    [8] din = _;
        INOUT [8] bus = _;
        OUT   [8] data = _;
    }
@endproj

// Helper: conditionally drives INOUT, releases with z
@module DriverMod
    PORT {
        IN    [1] clk;
        IN    [1] en;
        IN    [8] din;
        INOUT [8] bus;
        OUT   [8] data;
    }

    REGISTER {
        captured [8] = 8'b0000_0000;
    }

    ASYNCHRONOUS {
        // Valid: conditional tri-state on INOUT with full-width z literal
        IF (en) {
            bus <= din;
        } ELSE {
            bus <= 8'bzzzz_zzzz;
        }
        data = captured;
    }

    SYNCHRONOUS(CLK=clk) {
        // Valid: read INOUT when released by this driver (S1.6.5, S1.6.8)
        IF (!en) {
            captured <= bus;
        } ELSE {
            captured <= captured;
        }
    }
@endmod

@module TopMod
    PORT {
        IN    [1] clk;
        IN    [1] en;
        IN    [8] din;
        INOUT [8] bus;
        OUT   [8] data;
    }

    REGISTER {
        r [8] = 8'b0000_0000;
    }

    @new inst_drv DriverMod {
        IN    [1] clk = clk;
        IN    [1] en = en;
        IN    [8] din = din;
        INOUT [8] bus = bus;
        OUT   [8] data = _;
    };

    ASYNCHRONOUS {
        // Valid: conditional tri-state on INOUT with z extension (S1.6.1)
        // 1-bit z literal extends to match 8-bit bus width
        IF (!en) {
            bus <= din;
        } ELSE {
            bus <= 8'bz;
        }
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        // Valid: read INOUT when this module is not driving
        IF (en) {
            r <= bus;
        } ELSE {
            r <= r;
        }
    }
@endmod
