// TRISTATE_TRANSFORM_MUTUAL_EXCLUSION_FAIL: Non-mutually-exclusive enable
// conditions on multiple tri-state drivers of the same signal.
// Verifies the compiler rejects multi-driver tri-state nets where enables
// are not provably mutually exclusive.
// Context: two instances drive the same wire via INOUT with the same enable.

@project TRISTATE_TRANSFORM_MUTUAL_EXCLUSION_FAIL_non_exclusive
    @top TopMod {
        IN  [1] en = _;
        OUT [8] data = _;
    }
@endproj

// Driver module with conditional tri-state output via INOUT
@module DriverMod
    PORT {
        IN    [1] en;
        INOUT [8] bus;
    }

    ASYNCHRONOUS {
        IF (en) {
            bus <= 8'hAA;
        } ELSE {
            bus <= 8'bzzzz_zzzz;
        }
    }
@endmod

// Top module: two instances drive same wire with same enable (non-exclusive)
@module TopMod
    PORT {
        IN  [1] en;
        OUT [8] data;
    }

    WIRE {
        shared [8];
    }

    @new inst_a DriverMod {
        IN    [1] en = en;
        INOUT [8] bus = shared;
    };

    @new inst_b DriverMod {
        IN    [1] en = en;
        INOUT [8] bus = shared;
    };

    ASYNCHRONOUS {
        data <= shared;
    }
@endmod
