// CLOCK_GEN_OUTPUT_IS_INPUT_PIN: CLOCK_GEN output clock must not be declared as IN_PINS.
// Verified

@project CLOCK_GEN_OUTPUT_IS_INPUT_PIN_TEST
  CLOCKS {
    sys_clk = { period=10 };
    fast_clk;
  }

  IN_PINS {
    sys_clk = { standard=LVCMOS33 };
    fast_clk = { standard=LVCMOS33 };
    btn = { standard=LVCMOS33 };
  }

  OUT_PINS {
    led = { standard=LVCMOS33, drive=8 };
  }

  CLOCK_GEN {
    PLL {
      IN REF_CLK sys_clk;
      OUT BASE fast_clk;
      CONFIG {
        IDIV = 1;
      };
    };
  }

  MAP {
    sys_clk = 1;
    fast_clk = 2;
    btn = 3;
    led = 4;
  }

  @top top {
    IN  [1] a = btn;
    OUT [1] out = led;
  }
@endproj

@module top
  PORT {
    IN  [1] a;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = a;
  }
@endmod
