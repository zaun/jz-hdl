// CLOCK_SOURCE_AMBIGUOUS: Clock has period in CLOCKS but is also a CLOCK_GEN output.

@project(CHIP="GW1NR-9-QN88-C6-I5") CLOCK_SOURCE_AMBIGUOUS_TEST
  CLOCKS {
    sys_clk = { period=37.04 };
    fast_clk = { period=10 };
  }

  IN_PINS {
    sys_clk = { standard=LVCMOS33 };
    btn = { standard=LVCMOS33 };
  }

  OUT_PINS {
    led = { standard=LVCMOS33, drive=8 };
  }

  CLOCK_GEN {
    PLL {
      IN REF_CLK sys_clk;
      OUT BASE fast_clk;
      CONFIG {
        IDIV = 0;
        FBDIV = 3;
        ODIV = 8;
      };
    };
  }

  MAP {
    sys_clk = 4;
    btn = 10;
    led = 11;
  }

  @top top {
    IN  [1] a = btn;
    OUT [1] out = led;
  }
@endproj

@module top
  PORT {
    IN  [1] a;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = a;
  }
@endmod
