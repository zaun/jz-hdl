// MEM_IN_PORT_FIELD_ACCESS: IN (write) port requires bracket syntax.
// Using .addr/.data field syntax on an IN port is invalid.
// Verified

@project MEM_IN_PORT_FIELD_ACCESS_PROJECT
  @top MEM_IN_PORT_FIELD_ACCESS_EXAMPLE {
    IN  [1] clk = _;
    IN  [4] addr = _;
    IN  [8] din = _;
    OUT [8] dout = _;
  }
@endproj

@module MEM_IN_PORT_FIELD_ACCESS_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [4] addr;
    IN  [8] din;
    OUT [8] dout;
  }

  REGISTER {
    r [8] = 8'h00;
  }

  MEM {
    mem0 [8] [16] = 8'h00 {
      OUT rd SYNC;
      IN wr;
    };
  }

  ASYNCHRONOUS {
    dout = r;
  }

  SYNCHRONOUS(CLK=clk) {
    mem0.wr.addr <= addr;  // Illegal: IN port requires bracket syntax
    mem0.wr.data <= din;   // Illegal: IN port requires bracket syntax
    mem0.rd.addr <= addr;
    r <= mem0.rd.data;
  }
@endmod
