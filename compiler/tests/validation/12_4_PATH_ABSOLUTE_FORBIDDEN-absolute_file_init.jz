// PATH_ABSOLUTE_FORBIDDEN: Absolute paths in @file() MEM init forbidden
// without --allow-absolute-paths.
// Tests absolute path rejection in @file() context.

@project PATH_ABSOLUTE_FORBIDDEN_absolute_file_init
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        OUT [8] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 1: @file() with absolute path in MEM init
    MEM {
        rom [8] [16] = @file("/absolute/path/init.bin") {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        data = rom.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        rom.wr[addr] <= 8'h00;
    }
@endmod
