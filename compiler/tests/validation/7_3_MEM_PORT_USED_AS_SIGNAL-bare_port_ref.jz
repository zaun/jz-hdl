// MEM_PORT_USED_AS_SIGNAL: Reference MEM port without .field or [index].
// Triggers on ASYNC port and SYNC port.
// Valid field/index access included for no false positives.

@project MEM_PORT_USED_AS_SIGNAL_bare_port_ref
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Helper: bare port ref on ASYNC port
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        // Valid: bracket write uses addr
        mem_a.wr[addr] <= wdata;
        // Trigger 1: bare ASYNC port ref used as signal
        r <= mem_a.rd;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd SYNC;
            IN  wr;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        mem_b.rd.addr <= addr;
        mem_b.wr[addr] <= wdata;
        // Trigger 2: bare SYNC port ref
        r <= mem_b.rd;
    }
@endmod
