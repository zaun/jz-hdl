// INSTANCE_PORT_WIDTH_MISMATCH: instantiated port width does not match child module port width.
// Verified

@project INSTANCE_PORT_WIDTH_MISMATCH_PROJECT
  @top ParentWidth4 {
    OUT [4] a = _;
  }
@endproj

@module ChildWidth8
  PORT {
    OUT [8] a;
  }

  ASYNCHRONOUS {
    a <= 8'h0;
  }
@endmod

@module ParentWidth4
  PORT {
    OUT [4] a;
  }

  // Child port 'a' is 8 bits wide but we instantiate it as 4 bits here.
  @new u ChildWidth8 {
    OUT [4] a = a;
  }
@endmod
