// SPECIAL_DRIVER_IN_INDEX: GND/VCC may not appear in slice/index expressions.
// The parser currently rejects GND/VCC in index position with PARSE000 before
// the semantic rule SPECIAL_DRIVER_IN_INDEX can fire. This test documents
// the parser behavior. See issues.md for details.

@project SPECIAL_DRIVER_IN_INDEX_gnd_vcc_in_index
    @top TopMod {
        IN  [1] clk = _;
        OUT [1] out_a = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] out_a;
    }
    REGISTER {
        r [8] = 8'h00;
    }
    ASYNCHRONOUS {
        // Trigger 1: GND as bit-select index — parser rejects as PARSE000
        out_a = r[GND];
    }
    SYNCHRONOUS(CLK=clk) {
        r <= r;
    }
@endmod
