// OPERATOR_EXAMPLES: Happy path verifying canonical operator examples from S3.4.
// Exercises: parenthesized unary negation, multi-bit negation via subtraction,
// logical vs arithmetic right shift, overflow prevention via concatenation,
// ternary with concatenation, and tri-state driver pattern on INOUT port.
// No diagnostics expected.

@project OPERATOR_EXAMPLES_spec_examples_ok
    CONFIG {
        WIDTH = 8;
    }
    @top TopMod {
        IN    [1]  clk = _;
        IN    [1]  sel = _;
        IN    [1]  en = _;
        IN    [8]  a = _;
        IN    [8]  b = _;
        IN    [8]  c = _;
        IN    [8]  d = _;
        INOUT [8]  bus = _;
        OUT   [8]  out_neg = _;
        OUT   [8]  out_sub = _;
        OUT   [8]  out_lsr = _;
        OUT   [8]  out_asr = _;
        OUT   [9]  out_carry = _;
        OUT   [16] out_tern = _;
        OUT   [8]  out_data = _;
    }
@endproj

// Helper: shift operations and unary negation
@module ShiftOps
    PORT {
        IN  [1] clk;
        IN  [8] val;
        OUT [8] out_neg;
        OUT [8] out_sub;
        OUT [8] out_lsr;
        OUT [8] out_asr;
    }
    REGISTER {
        r_asr [8] = 8'h00;
    }
    ASYNCHRONOUS {
        // S3.4 Unary negation: parentheses required
        out_neg = (-val);
        // S3.4 Multi-bit negation via subtraction
        out_sub <= 8'h00 - val;
        // S3.4 Logical right shift: zero-filled from left
        out_lsr <= val >> 1'b1;
        // Arithmetic right shift from register
        out_asr = r_asr;
    }
    SYNCHRONOUS(CLK=clk) {
        // S3.4 Arithmetic right shift: MSB replicated
        r_asr <= val >>> 1'b1;
    }
@endmod

@module TopMod
    PORT {
        IN    [1]  clk;
        IN    [1]  sel;
        IN    [1]  en;
        IN    [8]  a;
        IN    [8]  b;
        IN    [8]  c;
        IN    [8]  d;
        INOUT [8]  bus;
        OUT   [8]  out_neg;
        OUT   [8]  out_sub;
        OUT   [8]  out_lsr;
        OUT   [8]  out_asr;
        OUT   [9]  out_carry;
        OUT   [16] out_tern;
        OUT   [8]  out_data;
    }
    WIRE {
        h_neg [8];
        h_sub [8];
        h_lsr [8];
        h_asr [8];
    }
    REGISTER {
        r_data [8] = 8'h00;
    }

    @new inst_shift ShiftOps {
        IN  [1] clk = clk;
        IN  [8] val = a;
        OUT [8] out_neg = h_neg;
        OUT [8] out_sub = h_sub;
        OUT [8] out_lsr = h_lsr;
        OUT [8] out_asr = h_asr;
    };

    ASYNCHRONOUS {
        out_neg = h_neg;
        out_sub = h_sub;
        out_lsr = h_lsr;
        out_asr = h_asr;
        // S3.4 Overflow prevention: 9-bit result captures carry
        out_carry <= {1'b0, a} + {1'b0, b};
        // S3.4 Ternary with concatenation: matching branch widths
        out_tern = sel ? {a, b} : {c, d};
        // S3.4 Tri-state driver on INOUT port: drive or release
        IF (en) {
            bus <= a;
        } ELSE {
            bus <= 8'bzzzz_zzzz;
        }
        out_data = r_data;
    }
    SYNCHRONOUS(CLK=clk) {
        // Read INOUT when not driving
        IF (!en) {
            r_data <= bus;
        } ELSE {
            r_data <= r_data;
        }
    }
@endmod
