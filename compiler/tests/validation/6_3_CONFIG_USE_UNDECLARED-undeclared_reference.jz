// CONFIG_USE_UNDECLARED: Use of CONFIG.<name> not declared in project CONFIG.
// Tests undeclared CONFIG references in multiple contexts across modules.
// Valid CONFIG references included to verify no false positives.

@project CONFIG_USE_UNDECLARED_undeclared_reference
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [CONFIG.WIDTH] data = _;
    }
@endproj

@module Helper
    PORT {
        // Trigger 1: undeclared CONFIG in port width
        IN  [CONFIG.MISSING_A] din;
        OUT [1] dout;
    }
    ASYNCHRONOUS {
        dout = din[0];
    }
@endmod

@module TopMod
    CONST {
        // Trigger 2: undeclared CONFIG in CONST initializer
        LOCAL = CONFIG.MISSING_B;
    }

    PORT {
        IN  [1] clk;
        // Trigger 3: undeclared CONFIG in port width (different module)
        OUT [CONFIG.MISSING_C] data;
    }

    @new inst_h Helper {
        IN  [1] din = 1'b0;
        OUT [1] dout = _;
    };

    REGISTER {
        // Trigger 4: undeclared CONFIG in register width
        r [CONFIG.MISSING_D] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
