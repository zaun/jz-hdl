// MEM_TYPE_BLOCK_WITH_ASYNC_OUT: strict mode MEM(TYPE=BLOCK) has IN port declared ASYNC.
// Verified

@project MEM_TYPE_BLOCK_WITH_ASYNC_OUT_PROJECT
  @top MEM_TYPE_BLOCK_WITH_ASYNC_OUT_EXAMPLE {
    IN  [1] clk = _;
    IN  [4] addr = _;
    OUT [8] read_data = _;
  }
@endproj

@module MEM_TYPE_BLOCK_WITH_ASYNC_OUT_EXAMPLE
  PORT {
    IN  [4] addr;
    OUT [8] read_data;
  }

  MEM(TYPE=BLOCK) {
    mem0 [8] [16] = 8'h00 {
      OUT rd ASYNC;   // ASYNC read not allowed when TYPE=BLOCK.
    };
  }

  ASYNCHRONOUS {
    read_data = mem0.rd[addr];
  }
@endmod
