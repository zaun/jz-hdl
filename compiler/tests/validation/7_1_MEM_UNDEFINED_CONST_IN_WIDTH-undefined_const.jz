// MEM_UNDEFINED_CONST_IN_WIDTH: Undefined CONST in MEM width or depth triggers error.
// Valid CONST-based MEM included for no false positives.

@project MEM_UNDEFINED_CONST_IN_WIDTH_undefined_const
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: undefined CONST in width position in helper module
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        bad_mem [UNDEF_W] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= wdata;
    }
@endmod

@module TopMod
    CONST {
        VALID_WIDTH = 8;
    }

    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 2: undefined CONST in depth position in top module
    MEM {
        bad_mem [8] [UNDEF_D] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    // Valid: declared CONST used in width (no error expected)
    MEM {
        ok_mem [VALID_WIDTH] [16] = 8'h00 {
            OUT rd_ok ASYNC;
            IN  wr_ok;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = ok_mem.rd_ok[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        ok_mem.wr_ok[addr] <= wdata;
    }
@endmod
