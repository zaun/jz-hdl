// PIN_IO_STANDARDS: valid usage of new I/O standards (no errors expected).
// Verified

@project PIN_IO_STANDARDS_PROJECT
  IN_PINS {
    clk = { standard=LVCMOS33 };
    ddr_in = { standard=SSTL15, term=ON };
  }

  OUT_PINS {
    tmds_clk = { mode=DIFFERENTIAL, standard=LVDS25, drive=4 };
    led = { standard=LVCMOS18, drive=4 };
    ddr_out = { standard=SSTL25_I, drive=8, term=ON };
  }

  INOUT_PINS {
    sda = { standard=LVCMOS33, drive=4, pull=UP };
  }

  MAP {
    clk = 4;
    ddr_in = 20;
    tmds_clk = { P=33, N=34 };
    led = 15;
    ddr_out = 21;
    sda = 52;
  }

  @top PIN_IO_STANDARDS_EXAMPLE {
    IN  [1] in = _;
    OUT [1] out = _;
  }
@endproj

@module PIN_IO_STANDARDS_EXAMPLE
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod
