// CDC_RAW_STAGES_FORBIDDEN: RAW CDC type does not accept a stages parameter.
// Verified

@project CDC_RAW_STAGES_FORBIDDEN_PROJECT
  @top CDC_RAW_STAGES_FORBIDDEN_EXAMPLE {
    IN  [1] clk_a = _;
    IN  [1] clk_b = _;
    OUT [1] data = _;
  }
@endproj

@module CDC_RAW_STAGES_FORBIDDEN_EXAMPLE
  PORT {
    IN  [1] clk_a;
    IN  [1] clk_b;
    OUT [1] data;
  }

  REGISTER {
    r [1] = 1'b0;
  }

  CDC {
    RAW[2] r (clk_a) => alias_r (clk_b);
  }

  ASYNCHRONOUS {
    data = alias_r;
  }

  SYNCHRONOUS(CLK=clk_a) {
    r <= 1'b1;
  }
@endmod
