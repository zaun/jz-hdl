// BLACKBOX_BODY_DISALLOWED: Blackbox with CONST block triggers forbidden body error.
// CONST is the only block the parser allows inside @blackbox but semantics rejects.
// ASYNCHRONOUS/SYNCHRONOUS/WIRE/REGISTER/MEM are rejected by the parser (PARSE000)
// before semantic analysis runs. See issues.md for parser inconsistency.
// Tests: CONST before PORT, CONST after PORT, multiple CONST entries.
// Valid blackbox (PORT only) included as negative test.

@project BLACKBOX_BODY_DISALLOWED_const_in_blackbox
    CONFIG {
        WIDTH = 8;
    }

    // Trigger 1: CONST block before PORT
    @blackbox bb_const_before {
        CONST { VAL = 42; }
        PORT {
            IN  [1] din;
            OUT [1] dout;
        }
    }

    // Trigger 2: CONST block after PORT
    @blackbox bb_const_after {
        PORT {
            IN  [1] din;
            OUT [1] dout;
        }
        CONST { MODE = 1; }
    }

    // Trigger 3: CONST block with multiple entries
    @blackbox bb_multi_const {
        CONST {
            WIDTH = 8;
            DEPTH = 16;
        }
        PORT {
            IN  [1] din;
            OUT [1] dout;
        }
    }

    // Valid: blackbox with PORT only (no error)
    @blackbox bb_valid {
        PORT {
            IN  [1] din;
            OUT [1] dout;
        }
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    @new inst_ok bb_valid {
        IN  [1] din = r;
        OUT [1] dout = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
