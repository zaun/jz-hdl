// NET_DANGLING_UNUSED: Signal declared but never driven or read.
// Each trigger is commented. Valid used wires verify no false positives.

@project NET_DANGLING_UNUSED_unused_signal
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [8] din = _;
        OUT [8] dout_a = _;
        OUT [8] dout_b = _;
    }
@endproj

// Trigger 1: unused wire in helper module
@module HelperA
    PORT {
        IN  [8] din;
        OUT [8] dout;
    }

    WIRE {
        // Trigger 1: wire never driven or read
        dangling_a [8];
        // Valid: wire driven and read
        used_w [8];
    }

    ASYNCHRONOUS {
        used_w <= din;
        dout <= used_w;
    }
@endmod

// Top module with its own unused wire triggers
@module TopMod
    PORT {
        IN  [8] din;
        OUT [8] dout_a;
        OUT [8] dout_b;
    }

    WIRE {
        // Trigger 2: 1-bit unused wire
        dangling_b [1];
        // Trigger 3: 8-bit unused wire
        dangling_c [8];
        // Valid: wire driven and read
        valid_w [8];
    }

    @new inst_a HelperA {
        IN  [8] din = din;
        OUT [8] dout = dout_a;
    };

    ASYNCHRONOUS {
        valid_w <= din;
        dout_b <= valid_w;
    }
@endmod
