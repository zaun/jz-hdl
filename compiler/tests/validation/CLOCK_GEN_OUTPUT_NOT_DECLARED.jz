// CLOCK_GEN_OUTPUT_NOT_DECLARED: CLOCK_GEN output clock not declared in CLOCKS block.
// Verified

@project CLOCK_GEN_OUTPUT_NOT_DECLARED_TEST
  CLOCKS {
    sys_clk = { period=10 };
  }

  IN_PINS {
    sys_clk = { standard=LVCMOS33 };
    btn = { standard=LVCMOS33 };
  }

  OUT_PINS {
    led = { standard=LVCMOS33, drive=8 };
  }

  CLOCK_GEN {
    PLL {
      IN REF_CLK sys_clk;
      OUT BASE undeclared_fast_clk;
      CONFIG {
        IDIV = 1;
      };
    };
  }

  MAP {
    sys_clk = 1;
    btn = 2;
    led = 3;
  }

  @top top {
    IN  [1] a = btn;
    OUT [1] out = led;
  }
@endproj

@module top
  PORT {
    IN  [1] a;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = a;
  }
@endmod
