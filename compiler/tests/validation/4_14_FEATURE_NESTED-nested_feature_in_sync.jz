// FEATURE_NESTED: Nested @feature guard in SYNCHRONOUS block.
// Parser stops at first nested @feature; split by context for coverage.

@project FEATURE_NESTED_nested_feature_in_sync
    CONFIG {
        MODE = 1;
    }

    @top TopMod {
        IN  [1] clk = _;
        IN  [1] din = _;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] din;
        OUT [1] data;
    }

    CONST {
        FLAG = 1;
        LEVEL = 0;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        // Trigger 1: nested @feature inside SYNCHRONOUS block @feature body
        @feature FLAG == 1
            @feature LEVEL == 0
                r <= din;
            @endfeat
        @endfeat
    }
@endmod
