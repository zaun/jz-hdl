// ASSIGN_WIDTH_NO_MODIFIER: bare assignment operator used with mismatched widths.
// Expect ERR> ASSIGN_WIDTH_NO_MODIFIER on the assignment to 'a'.
// Verified

@project ASSIGN_WIDTH_NO_MODIFIER_PROJECT
  @top ASSIGN_WIDTH_NO_MODIFIER_EXAMPLE {
    IN  [8] a = _;
    OUT [4] b = _;
    OUT [4] c = _;
    OUT [4] d = _;
  }
@endproj

@module ASSIGN_WIDTH_NO_MODIFIER_EXAMPLE
  PORT {
    IN  [8] a;
    OUT [4] b;
    OUT [4] c;
    OUT [4] d;
  }

  ASYNCHRONOUS {
    // Bare '=' with different widths (8 vs 4) requires explicit z/s modifier.
    b = a;
    a => c;
    d <= a;
  }
@endmod
