// TRISTATE_TRANSFORM_PER_BIT_FAIL: Per-bit tri-state pattern detected.
// Verifies that the compiler rejects tri-state patterns where individual bit
// slices of the same signal have different driver sets.
// Contexts: helper module with per-bit tristate wire, top module with per-bit
// tristate wire. Valid full-width z included as negative test.

@project TRISTATE_TRANSFORM_PER_BIT_FAIL_per_bit
    @top TopMod {
        IN  [1] en_a = _;
        IN  [1] en_b = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: helper module with per-bit tri-state (different enables per slice)
@module HelperMod
    PORT {
        IN  [1] en_a;
        IN  [1] en_b;
        OUT [8] data;
    }

    WIRE {
        w [8];
    }

    ASYNCHRONOUS {
        IF (en_a) {
            w[7:4] <= 4'hA;
        } ELSE {
            w[7:4] <= 4'bzzzz;
        }
        IF (en_b) {
            w[3:0] <= 4'hB;
        } ELSE {
            w[3:0] <= 4'bzzzz;
        }
        data <= w;
    }
@endmod

// Trigger 2: top module with per-bit tri-state pattern
@module TopMod
    PORT {
        IN  [1] en_a;
        IN  [1] en_b;
        OUT [8] data;
    }

    WIRE {
        w_top [8];
    }

    @new inst_h HelperMod {
        IN  [1] en_a = en_a;
        IN  [1] en_b = en_b;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        IF (en_a) {
            w_top[7:4] <= 4'hC;
        } ELSE {
            w_top[7:4] <= 4'bzzzz;
        }
        IF (en_b) {
            w_top[3:0] <= 4'hD;
        } ELSE {
            w_top[3:0] <= 4'bzzzz;
        }
        data <= w_top;
    }
@endmod
