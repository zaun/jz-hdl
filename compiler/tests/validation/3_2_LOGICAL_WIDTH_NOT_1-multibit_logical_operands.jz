// LOGICAL_WIDTH_NOT_1: Logical &&, ||, ! require 1-bit operands.
// Tests all three logical operators with multi-bit operands in async and sync
// blocks across two modules. Valid 1-bit operands included for no false positives.

@project LOGICAL_WIDTH_NOT_1_multibit_logical_operands
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] wide_a = _;
        IN  [8] wide_b = _;
        IN  [1] bit_a = _;
        IN  [1] bit_b = _;
        OUT [1] out_a = _;
        OUT [1] out_b = _;
        OUT [1] out_c = _;
        OUT [1] out_d = _;
    }
@endproj

// Helper module with logical operators on multi-bit operands
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] wide_a;
        IN  [8] wide_b;
        IN  [1] bit_a;
        OUT [1] out_a;
        OUT [1] out_b;
        OUT [1] out_c;
    }
    REGISTER {
        r1 [1] = 1'b0;
        r2 [1] = 1'b0;
    }
    ASYNCHRONOUS {
        // Trigger 1: logical AND with 8-bit operands in async
        out_a = wide_a && wide_b;
        // Trigger 2: logical NOT with 8-bit operand in async
        out_b = !wide_a;
        // Valid: logical AND with 1-bit operands (no false positive)
        out_c = bit_a && r1 && r2;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 3: logical OR with 8-bit operands in sync
        r1 <= wide_a || wide_b;
        // Valid: 1-bit logical NOT (no false positive)
        r2 <= !bit_a;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] wide_a;
        IN  [8] wide_b;
        IN  [1] bit_a;
        IN  [1] bit_b;
        OUT [1] out_a;
        OUT [1] out_b;
        OUT [1] out_c;
        OUT [1] out_d;
    }
    WIRE {
        ha_a [1];
        ha_b [1];
        ha_c [1];
    }
    REGISTER {
        r1 [1] = 1'b0;
        r2 [1] = 1'b0;
    }

    @new inst_a HelperMod {
        IN  [1] clk = clk;
        IN  [8] wide_a = wide_a;
        IN  [8] wide_b = wide_b;
        IN  [1] bit_a = bit_a;
        OUT [1] out_a = ha_a;
        OUT [1] out_b = ha_b;
        OUT [1] out_c = ha_c;
    };

    ASYNCHRONOUS {
        // Trigger 4: logical OR with 8-bit operands in top async
        out_a = wide_a || wide_b;
        // Trigger 5: logical NOT with 8-bit operand in top async
        out_b = !wide_b;
        // Valid: logical OR with 1-bit operands (no false positive)
        out_c = bit_a || bit_b;
        out_d = r1 | r2;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 6: logical AND with 8-bit operands in top sync
        r1 <= wide_a && wide_b;
        // Trigger 7: logical NOT with 8-bit operand in top sync
        r2 <= !wide_a;
    }
@endmod
