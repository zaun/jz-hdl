// LOGICAL_WIDTH_NOT_1: Logical &&, ||, ! require 1-bit operands.
// Tests multi-bit operands with all three logical operators in async/sync across modules.
// Valid 1-bit operands included to verify no false positives.

@project LOGICAL_WIDTH_NOT_1_multibit_logical_operands
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] wide_a = _;
        IN  [8] wide_b = _;
        IN  [1] bit_a = _;
        IN  [1] bit_b = _;
        OUT [1] out_a = _;
        OUT [1] out_b = _;
        OUT [1] out_c = _;
        OUT [1] out_d = _;
    }
@endproj

// Helper module with logical operators on multi-bit operands
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] wide_a;
        IN  [8] wide_b;
        IN  [1] bit_a;
        OUT [1] out_a;
        OUT [1] out_b;
        OUT [1] out_c;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        // Trigger 1: logical AND with 8-bit operands in async
        out_a = wide_a && wide_b;
        // Valid: logical AND with 1-bit operands (no false positive)
        out_b = bit_a && bit_a;
        out_c = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: logical OR with 8-bit operands in sync
        r <= wide_a || wide_b;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] wide_a;
        IN  [8] wide_b;
        IN  [1] bit_a;
        IN  [1] bit_b;
        OUT [1] out_a;
        OUT [1] out_b;
        OUT [1] out_c;
        OUT [1] out_d;
    }
    WIRE {
        ha_a [1];
        ha_b [1];
        ha_c [1];
    }
    REGISTER {
        r [1] = 1'b0;
        s [1] = 1'b0;
    }

    @new inst_a HelperMod {
        IN  [1] clk = clk;
        IN  [8] wide_a = wide_a;
        IN  [8] wide_b = wide_b;
        IN  [1] bit_a = bit_a;
        OUT [1] out_a = ha_a;
        OUT [1] out_b = ha_b;
        OUT [1] out_c = ha_c;
    };

    ASYNCHRONOUS {
        // Trigger 3: logical NOT with 8-bit operand in top async
        out_a = !wide_a;
        // Valid: logical NOT with 1-bit operand (no false positive)
        out_b = !bit_b;
        out_c = r;
        out_d = s;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 4: logical AND with 8-bit operands in top sync
        r <= wide_a && wide_b;
        // Valid: logical OR with 1-bit operands (no false positive)
        s <= bit_a || bit_b;
    }
@endmod
