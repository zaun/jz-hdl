// MEM_PORT_FIELD_UNDEFINED: Invalid field name on MEM port.
// Expected fields are .addr, .data, or .wdata.
// Triggers on SYNC OUT and INOUT ports. Valid field access included.

@project MEM_PORT_FIELD_UNDEFINED_invalid_field_name
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Helper: invalid field on SYNC port
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd SYNC;
        };
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        mem_a.rd.addr <= addr;
        r <= mem_a.rd.data;
        // Trigger 1: invalid field .foo on SYNC OUT port
        mem_a.rd.foo <= addr;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd SYNC;
        };
    }

    MEM(type=BLOCK) {
        mem_c [8] [16] = 8'h00 {
            INOUT rw;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        mem_b.rd.addr <= addr;
        r <= mem_b.rd.data;
        mem_c.rw.addr <= addr;
        mem_c.rw.wdata <= wdata;
        // Trigger 2: invalid field .bar on SYNC OUT port in top
        mem_b.rd.bar <= addr;
        // Trigger 3: invalid field .xyz on INOUT port
        mem_c.rw.xyz <= wdata;
    }
@endmod
