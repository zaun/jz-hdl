// MEM_PORT_FIELD_UNDEFINED: Invalid field name on MEM port.
// Expected fields are .addr, .data, or .wdata.
// Valid field accesses included for no false positives.

@project MEM_PORT_FIELD_UNDEFINED_invalid_field_name
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: .foo on SYNC port in helper
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd SYNC;
        };
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        mem_a.rd.addr <= addr;
        r <= mem_a.rd.data;
        // Trigger 1: invalid field .foo
        r <= mem_a.rd.foo;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd SYNC;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        mem_b.rd.addr <= addr;
        r <= mem_b.rd.data;
        // Trigger 2: invalid field .bar in top module
        r <= mem_b.rd.bar;
    }
@endmod
