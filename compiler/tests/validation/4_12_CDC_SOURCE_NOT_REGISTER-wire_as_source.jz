// CDC_SOURCE_NOT_REGISTER: CDC source must be a REGISTER declared in the module.
// Tests wire, port, and undeclared identifiers as CDC source in multiple modules.
// Valid register source included to verify no false positives.

@project CDC_SOURCE_NOT_REGISTER_wire_as_source
    @top TopMod {
        IN  [1] clk_a = _;
        IN  [1] clk_b = _;
        OUT [1] data = _;
    }
@endproj

// Helper module with wire as CDC source
@module HelperMod
    PORT {
        IN  [1] clk_a;
        IN  [1] clk_b;
        IN  [1] din;
        OUT [1] data;
    }

    WIRE {
        w [1];
    }

    REGISTER {
        ok_reg [1] = 1'b0;
    }

    CDC {
        // Trigger 1: wire used as CDC source
        BIT w (clk_a) => w_sync (clk_b);
        // Valid: register as source
        BIT ok_reg (clk_a) => ok_sync (clk_b);
    }

    ASYNCHRONOUS {
        w = din;
        data = ok_sync;
    }

    SYNCHRONOUS(CLK=clk_a) {
        ok_reg <= din;
    }

    SYNCHRONOUS(CLK=clk_b) {
        IF (w_sync) {
            // reading alias
        }
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk_a;
        IN  [1] clk_b;
        OUT [1] data;
    }

    REGISTER {
        top_ok [1] = 1'b0;
    }

    CDC {
        // Trigger 2: port used as CDC source
        BIT clk_a (clk_a) => port_sync (clk_b);
        // Valid: register as source
        BIT top_ok (clk_a) => top_sync (clk_b);
    }

    @new inst_h HelperMod {
        IN  [1] clk_a = clk_a;
        IN  [1] clk_b = clk_b;
        IN  [1] din = top_ok;
        OUT [1] data = _;
    };

    ASYNCHRONOUS {
        data = top_sync;
    }

    SYNCHRONOUS(CLK=clk_a) {
        top_ok <= ~top_ok;
    }

    SYNCHRONOUS(CLK=clk_b) {
        IF (port_sync) {
            // reading alias
        }
    }
@endmod
