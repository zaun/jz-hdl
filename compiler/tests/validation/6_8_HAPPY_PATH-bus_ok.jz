// HAPPY_PATH: Valid BUS definitions and usage.
// Covers: BUS with IN/OUT/INOUT signals, SOURCE and TARGET ports,
// bulk BUS assignment (SOURCE-to-TARGET), CONFIG width references,
// BUS with single signal, multi-module instantiation with BUS bindings.

@project HAPPY_PATH_bus_ok

    CONFIG {
        DATA_W = 8;
    }

    // Valid: BUS with mixed signal directions and CONFIG width reference
    BUS SPI_BUS {
        OUT   [1] sclk;
        OUT   [1] mosi;
        IN    [1] miso;
        INOUT [CONFIG.DATA_W] data;
    }

    // Valid: minimal BUS with single signal
    BUS ENABLE_BUS {
        OUT [1] en;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] dout = _;
    }
@endproj

// Valid: module with BUS SOURCE port
@module SourceMod
    PORT {
        IN  [1] clk;
        BUS SPI_BUS SOURCE sbus;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        sbus.sclk = r;
        sbus.mosi = r;
        data = sbus.miso;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= sbus.miso;
    }
@endmod

// Valid: module with BUS TARGET port
@module TargetMod
    PORT {
        IN  [1] clk;
        BUS SPI_BUS TARGET tbus;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        tbus.miso = r;
        data = tbus.sclk;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= tbus.mosi;
    }
@endmod

// Valid: module with single-signal BUS
@module EnableMod
    PORT {
        IN  [1] clk;
        BUS ENABLE_BUS SOURCE ebus;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        ebus.en = r;
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod

// Top module: instantiates SOURCE and TARGET, performs bulk BUS assignment
@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] dout;
    }

    @new inst_s SourceMod {
        IN  [1] clk = clk;
        BUS SPI_BUS SOURCE sbus = _;
        OUT [1] data = dout;
    };

    @new inst_t TargetMod {
        IN  [1] clk = clk;
        BUS SPI_BUS TARGET tbus = _;
        OUT [1] data = _;
    };

    @new inst_e EnableMod {
        IN  [1] clk = clk;
        BUS ENABLE_BUS SOURCE ebus = _;
        OUT [1] data = _;
    };

    // Valid: bulk BUS assignment between complementary roles
    ASYNCHRONOUS {
        inst_s.sbus = inst_t.tbus;
    }
@endmod
