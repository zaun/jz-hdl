// REG_MISSING_INIT_LITERAL: Register declared without mandatory reset literal.
// Trigger in helper module — compiler halts after first diagnostic so
// helper and top module triggers are split into separate files.
// Valid register with init literal included for no false positives.

@project REG_MISSING_INIT_LITERAL_missing_init_helper
    @top TopMod {
        IN  [1] clk = _;
        OUT [8] dout = _;
    }
@endproj

// Helper module: register missing init literal
@module HelperMod
    PORT {
        IN  [1] clk;
        OUT [8] data_out;
    }

    REGISTER {
        // Trigger 1: missing init literal in helper module
        r_noinit [8];
        // Valid: register with proper init
        r_ok [8] = 8'h00;
    }

    ASYNCHRONOUS {
        data_out = r_ok;
    }

    SYNCHRONOUS(CLK=clk) {
        r_ok <= ~r_ok;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [8] dout;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        OUT [8] data_out = dout;
    };

    REGISTER {
        r_ok [8] = 8'hFF;
    }

    ASYNCHRONOUS {
        dout = r_ok;
    }

    SYNCHRONOUS(CLK=clk) {
        r_ok <= ~r_ok;
    }
@endmod
