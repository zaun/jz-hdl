// SYNC_NO_ALIAS: Aliasing `=` is forbidden in SYNCHRONOUS blocks.
// Tests alias operator in multiple syntactic forms within SYNC blocks.
// Valid `<=` assignments included to verify no false positives.

@project SYNC_NO_ALIAS_alias_in_sync_block
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] data_in = _;
        IN  [4] narrow_in = _;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
        OUT [8] out_c = _;
    }
@endproj

// Helper module: alias in SYNC block
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] data_in;
        IN  [4] narrow_in;
        OUT [8] out_a;
        OUT [8] out_b;
        OUT [8] out_c;
    }
    REGISTER {
        r_a [8] = 8'h00;
        r_b [8] = 8'h00;
        r_c [8] = 8'h00;
    }
    ASYNCHRONOUS {
        out_a = r_a;
        out_b = r_b;
        out_c = r_c;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 1: simple alias at root of SYNC
        r_a = data_in;
        // Trigger 2: alias with =z modifier in SYNC
        r_b =z narrow_in;
        // Trigger 3: alias with =s modifier in SYNC
        r_c =s narrow_in;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] data_in;
        IN  [4] narrow_in;
        OUT [8] out_a;
        OUT [8] out_b;
        OUT [8] out_c;
    }
    REGISTER {
        r_x [8] = 8'h00;
        r_y [8] = 8'h00;
        r_z [8] = 8'h00;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [8] data_in = data_in;
        IN  [4] narrow_in = narrow_in;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
        OUT [8] out_c = _;
    };

    ASYNCHRONOUS {
        out_a = r_x;
        out_b = r_y;
        out_c = r_z;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 4: alias inside IF branch in SYNC
        IF (clk) {
            r_x = data_in;
        }
        // Valid: normal receive assignment (should NOT trigger)
        r_y <= data_in;
        // Trigger 5: alias at root in top module SYNC
        r_z = data_in;
    }
@endmod
