// COMB_LOOP_CONDITIONAL_SAFE: Cycles only within mutually exclusive branches.
// Tests that the compiler produces a warning (not error) when cycles exist
// only across IF/ELSE branches. Valid linear paths included for no false positives.

@project COMB_LOOP_CONDITIONAL_SAFE_mutually_exclusive_cycle
    @top TopMod {
        IN  [1] sel = _;
        IN  [1] in_a = _;
        OUT [1] out_a = _;
        OUT [1] out_b = _;
    }
@endproj

// Helper: conditional cycle across IF/ELSE
@module HelperA
    PORT {
        IN  [1] sel;
        IN  [1] in_a;
        OUT [1] out_a;
        OUT [1] out_b;
    }

    WIRE {
        a [1];
        b [1];
    }

    ASYNCHRONOUS {
        // Trigger 1: cycle only across mutually exclusive branches
        IF (sel) {
            a <= in_a;
            b <= a;
        } ELSE {
            b <= in_a;
            a <= b;
        }
        out_a = a;
        out_b = b;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] sel;
        IN  [1] in_a;
        OUT [1] out_a;
        OUT [1] out_b;
    }

    WIRE {
        x [1];
        y [1];
    }

    @new inst_a HelperA {
        IN  [1] sel = sel;
        IN  [1] in_a = in_a;
        OUT [1] out_a = _;
        OUT [1] out_b = _;
    };

    ASYNCHRONOUS {
        // Trigger 2: cycle only across mutually exclusive branches
        IF (sel) {
            x <= in_a;
            y <= x;
        } ELSE {
            y <= in_a;
            x <= y;
        }
        out_a = x;
        out_b = y;
    }
@endmod
