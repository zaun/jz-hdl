// PIN_DRIVE_MISSING_OR_INVALID: Missing or nonpositive drive for OUT/INOUT pins.
// Tests missing drive in OUT_PINS, missing drive in INOUT_PINS,
// zero drive, and negative drive values.
// Valid drive values and IN_PINS (no drive needed) verify no false positives.

@project PIN_DRIVE_MISSING_OR_INVALID_drive_problems
    CLOCKS {
        sys_clk = { period=10 };
    }

    IN_PINS {
        sys_clk = { standard=LVCMOS33 };
        // Valid: IN_PINS never needs drive (no trigger)
        valid_in = { standard=LVCMOS33 };
    }

    OUT_PINS {
        // Valid: positive drive (no trigger)
        valid_out = { standard=LVCMOS33, drive=8 };
        // Trigger 1: OUT_PIN missing drive
        no_drive_out = { standard=LVCMOS33 };
        // Trigger 2: OUT_PIN with zero drive
        zero_drive_out = { standard=LVCMOS33, drive=0 };
        // Trigger 3: OUT_PIN with negative drive
        neg_drive_out = { standard=LVCMOS33, drive=-4 };
    }

    INOUT_PINS {
        // Valid: positive drive (no trigger)
        valid_io = { standard=LVCMOS33, drive=4 };
        // Trigger 4: INOUT_PIN missing drive
        no_drive_io = { standard=LVCMOS33 };
        // Trigger 5: INOUT_PIN with zero drive
        zero_drive_io = { standard=LVCMOS33, drive=0 };
    }

    MAP {
        sys_clk = 1;
        valid_in = 2;
        valid_out = 3;
        no_drive_out = 4;
        zero_drive_out = 5;
        neg_drive_out = 6;
        valid_io = 7;
        no_drive_io = 8;
        zero_drive_io = 9;
    }

    @top TopMod {
        IN  [1] clk = sys_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
