// MEM_MISSING_INIT: MEM declared without initialization triggers error.
// Valid MEM with initialization included for no false positives.

@project MEM_MISSING_INIT_missing_init
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: missing init in helper module
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        bad_mem [8] [16] {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= wdata;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 2: missing init in top module
    MEM {
        bad_mem [8] [16] {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    // Valid: MEM with init (no error expected)
    MEM {
        ok_mem [8] [16] = 8'h00 {
            OUT rd_ok ASYNC;
            IN  wr_ok;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = ok_mem.rd_ok[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        ok_mem.wr_ok[addr] <= wdata;
    }
@endmod
