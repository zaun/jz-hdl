// TRISTATE_TRANSFORM_SINGLE_DRIVER: Single-driver tri-state net transformed.
// Verifies the warning fires for every wire that has only one driver with
// conditional z when --tristate-default is active.
// Contexts: single-driver tristate wire in helper module, two single-driver
// tristate wires in top module, INOUT port with single-driver tristate.
// Valid: wires without z are not flagged.

@project TRISTATE_TRANSFORM_SINGLE_DRIVER_single_driver
    @top TopMod {
        IN  [1] en = _;
        IN  [8] din = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: helper module with single-driver tri-state wire
@module HelperMod
    PORT {
        IN    [1] en;
        IN    [8] din;
        INOUT [8] bus;
        OUT   [8] data;
    }

    WIRE {
        w [8];
    }

    // Trigger 2: INOUT port with single-driver tri-state
    ASYNCHRONOUS {
        IF (en) {
            w <= din;
        } ELSE {
            w <= 8'bzzzz_zzzz;
        }
        IF (en) {
            bus <= din;
        } ELSE {
            bus <= 8'bzzzz_zzzz;
        }
        data <= w;
    }
@endmod

// Top module: two single-driver tri-state wires
@module TopMod
    PORT {
        IN  [1] en;
        IN  [8] din;
        OUT [8] data;
    }

    WIRE {
        w_top [8];
        w_extra [8];
        w_bus [8];
    }

    @new inst_h HelperMod {
        IN    [1] en = en;
        IN    [8] din = din;
        INOUT [8] bus = w_bus;
        OUT   [8] data = _;
    };

    // Trigger 3: single-driver tri-state wire w_top in top module
    // Trigger 4: single-driver tri-state wire w_extra in top module
    ASYNCHRONOUS {
        IF (en) {
            w_top <= 8'hCC;
        } ELSE {
            w_top <= 8'bzzzz_zzzz;
        }
        IF (en) {
            w_extra <= 8'hDD;
        } ELSE {
            w_extra <= 8'bzzzz_zzzz;
        }
        data <= w_top | w_extra | w_bus;
    }
@endmod
