// INSTANCE_PORT_NOT_ACCESSIBLE: Accessing a submodule instance's output port
// via dot notation (inst.port) is not allowed in synthesizable code.
// The output must be wired through the @new port binding instead.

@project INSTANCE_PORT_NOT_ACCESSIBLE_inst_port_access
    @top TopMod {
        IN  [1] clk = _;
        OUT [8] dout = _;
    }
@endproj

@module ChildMod
    PORT {
        IN  [1] clk;
        OUT [8] data;
    }
    REGISTER {
        counter [8] = 8'h00;
    }
    ASYNCHRONOUS {
        data = counter;
    }
    SYNCHRONOUS(CLK=clk) {
        counter <= counter + 8'b1;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [8] dout;
    }

    REGISTER {
        captured [8] = 8'h00;
    }

    @new inst ChildMod {
        IN  [1] clk  = clk;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        // Trigger: accessing instance output port in synthesizable code
        dout = inst.data;
    }

    SYNCHRONOUS(CLK=clk) {
        // Trigger: accessing instance output port in synchronous block
        captured <= inst.data;
    }
@endmod
