// TEMPLATE_DEFINITION: Valid template definitions in all supported contexts.
// Covers: module-scoped templates, file-scoped templates, zero-parameter templates,
// multiple distinct templates in same scope, same template name in different module
// scopes, and template name matching wire/register names.
// No diagnostics expected.

@project TEMPLATE_DEFINITION_valid_definitions_ok
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// File-scoped template with parameters
@template file_tmpl_a(dst, src)
    dst <= src;
@endtemplate

// File-scoped template with zero parameters (valid per S10.2)
@template file_tmpl_zero()
@endtemplate

// Multiple distinct file-scoped templates in same scope
@template file_tmpl_b(a, b)
    a <= b;
@endtemplate

@module HelperMod
    PORT {
        IN  [1] din;
        OUT [1] data;
    }

    // Module-scoped template with parameters
    @template mod_tmpl(a, b)
        a <= b;
    @endtemplate

    // Same name as TopMod's template — valid (different module scopes)
    @template shared_name(a, b)
        a <= b;
    @endtemplate

    // Template name matches a wire name — valid (different namespaces)
    @template w1(a, b)
        a <= b;
    @endtemplate

    WIRE {
        w1 [1];
    }

    ASYNCHRONOUS {
        @apply mod_tmpl(w1, din);
        @apply file_tmpl_a(data, w1);
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    // Module-scoped template in TopMod
    @template inner_tmpl(a, b)
        a <= b;
    @endtemplate

    // Same name as HelperMod's template — valid (different module scopes)
    @template shared_name(a, b)
        a <= b;
    @endtemplate

    // Template name matches a register name — valid (different namespaces)
    @template r(a, b)
        a <= b;
    @endtemplate

    // Multiple distinct templates in same module scope
    @template another_tmpl(a, b)
        a <= b;
    @endtemplate

    @new inst_a HelperMod {
        IN  [1] din = r;
        OUT [1] data = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        @apply inner_tmpl(r, ~r);
    }
@endmod
