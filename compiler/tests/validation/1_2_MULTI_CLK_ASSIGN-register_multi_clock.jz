// MULTI_CLK_ASSIGN: Same register assigned in SYNCHRONOUS blocks driven by
// different clocks.
// Each trigger is commented. Valid single-clock assignment for no false positives.

@project MULTI_CLK_ASSIGN_register_multi_clock
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk_a = _;
        IN  [1] clk_b = _;
        IN  [8] din = _;
        OUT [8] dout_a = _;
        OUT [8] dout_b = _;
    }
@endproj

// Trigger 1: register assigned under two different clocks in helper
@module HelperA
    PORT {
        IN  [1] clk_a;
        IN  [1] clk_b;
        IN  [8] din;
        OUT [8] dout;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    ASYNCHRONOUS {
        dout <= r;
    }

    // First clock domain (home domain)
    SYNCHRONOUS(CLK=clk_a) {
        r <= din;
    }

    // Trigger 1: same register under second clock domain
    SYNCHRONOUS(CLK=clk_b) {
        r <= din;
    }
@endmod

// Top module with its own multi-clock trigger
@module TopMod
    PORT {
        IN  [1] clk_a;
        IN  [1] clk_b;
        IN  [8] din;
        OUT [8] dout_a;
        OUT [8] dout_b;
    }

    REGISTER {
        r_multi [8] = 8'h00;
    }

    @new inst_a HelperA {
        IN  [1] clk_a = clk_a;
        IN  [1] clk_b = clk_b;
        IN  [8] din = din;
        OUT [8] dout = dout_a;
    };

    ASYNCHRONOUS {
        dout_b <= r_multi;
    }

    // First clock domain (home domain)
    SYNCHRONOUS(CLK=clk_a) {
        r_multi <= din;
    }

    // Trigger 2: same register under second clock domain in top module
    SYNCHRONOUS(CLK=clk_b) {
        r_multi <= din;
    }
@endmod
