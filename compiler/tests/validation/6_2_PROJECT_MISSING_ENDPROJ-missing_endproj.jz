// PROJECT_MISSING_ENDPROJ: @project block missing @endproj terminator.
// Tests that a @project block without @endproj produces an error.

@project PROJECT_MISSING_ENDPROJ_missing_endproj
    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        data = r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
