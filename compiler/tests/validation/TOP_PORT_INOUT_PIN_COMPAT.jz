// TOP_PORT_INOUT_PIN_COMPAT: INOUT_PINS may connect to IN, OUT, or INOUT module ports.
// Verified

@project TOP_PORT_INOUT_PIN_COMPAT_PROJECT
  INOUT_PINS {
    bidir_a = { standard=LVCMOS33, drive=8 };
    bidir_b = { standard=LVCMOS33, drive=8 };
    bidir_c = { standard=LVCMOS33, drive=8 };
  }
  MAP {
    bidir_a = 10;
    bidir_b = 11;
    bidir_c = 12;
  }

  @top TOP_PORT_INOUT_PIN_COMPAT_EXAMPLE {
    IN    [1] in_port    = bidir_a;
    OUT   [1] out_port   = bidir_b;
    INOUT [1] inout_port = bidir_c;
  }
@endproj

@module TOP_PORT_INOUT_PIN_COMPAT_EXAMPLE
  PORT {
    IN    [1] in_port;
    OUT   [1] out_port;
    INOUT [1] inout_port;
  }

  ASYNCHRONOUS {
    out_port <= in_port;
    inout_port <= in_port ? 1'b1 : 1'bz;
  }
@endmod
