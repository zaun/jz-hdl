// MEM_INOUT_MIXED_WITH_IN_OUT: INOUT ports mixed with IN/OUT ports triggers error.
// Tests INOUT + OUT, INOUT + IN combinations. Pure INOUT for no false positives.

@project MEM_INOUT_MIXED_WITH_IN_OUT_mixed_inout
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: INOUT mixed with OUT in helper module
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM(type=BLOCK) {
        mem_a [8] [16] = 8'h00 {
            INOUT rw;
            OUT rd SYNC;
        };
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= wdata;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 2: INOUT mixed with IN in top module
    MEM(type=BLOCK) {
        mem_b [8] [16] = 8'h00 {
            INOUT rw;
            IN  wr;
        };
    }

    // Trigger 3: INOUT mixed with both IN and OUT
    MEM(type=BLOCK) {
        mem_c [8] [16] = 8'h00 {
            INOUT rw;
            OUT rd SYNC;
            IN  wr;
        };
    }

    // Valid: pure INOUT (no error expected)
    MEM(type=BLOCK) {
        mem_ok [8] [16] = 8'h00 {
            INOUT rw_ok;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        mem_ok.rw_ok.addr <= addr;
        r <= mem_ok.rw_ok.data;
        mem_ok.rw_ok.wdata <= wdata;
    }
@endmod
