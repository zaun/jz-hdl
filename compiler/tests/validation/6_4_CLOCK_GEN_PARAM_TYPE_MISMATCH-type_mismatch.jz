// CLOCK_GEN_PARAM_TYPE_MISMATCH: CLOCK_GEN CONFIG parameter type mismatch.
// Tests an integer parameter (IDIV) given a decimal value.
// Valid integer parameter values included to verify no false positives.

@project(CHIP="gw2ar-18-qn88-c8-i7") CLOCK_GEN_PARAM_TYPE_MISMATCH_type_mismatch
    CLOCKS {
        ref_clk = { period=10 };
        gen_out;
    }

    IN_PINS {
        ref_clk = { standard=LVCMOS33 };
    }

    MAP {
        ref_clk = 1;
    }

    CLOCK_GEN {
        PLL {
            IN REF_CLK ref_clk;
            OUT BASE gen_out;

            CONFIG {
                // Trigger: IDIV is integer type but given decimal value
                IDIV = 1.5;
                FBDIV = 3;
                ODIV = 2;
            };
        };
    }

    @top TopMod {
        IN  [1] clk = ref_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
