// MEM_INVALID_WRITE_MODE: Invalid WRITE_MODE value on IN and INOUT ports.
// Valid write modes (WRITE_FIRST, READ_FIRST, NO_CHANGE) included for no false positives.

@project MEM_INVALID_WRITE_MODE_bad_write_mode_value
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: invalid WRITE_MODE on IN port via attribute block in helper
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr { WRITE_MODE = INVALID; };
        };
    }

    ASYNCHRONOUS {
        data = mem_a.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_a.wr[addr] <= wdata;
    }
@endmod

// Top module — tests invalid WRITE_MODE on INOUT port
@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 2: invalid WRITE_MODE on INOUT port via attribute block
    MEM {
        mem_b [8] [16] = 8'h00 {
            INOUT rw { WRITE_MODE = BADMODE; };
        };
    }

    // Valid: IN port with WRITE_FIRST (no error expected)
    MEM {
        mem_ok [8] [16] = 8'h00 {
            OUT rd_ok ASYNC;
            IN  wr_ok WRITE_FIRST;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_ok.rd_ok[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_b.rw.addr <= addr;
        mem_b.rw.wdata <= wdata;
        mem_ok.wr_ok[addr] <= wdata;
    }
@endmod
