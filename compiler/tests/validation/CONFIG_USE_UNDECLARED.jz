// CONFIG_USE_UNDECLARED: reference to CONFIG.<name> that is not declared.
// Verified

@project CONFIG_USE_UNDECLARED_EXAMPLES
  CONFIG {
    WIDTH = 10;
  }

  @top top {
    OUT [CONFIG.WIDTH] out = _;
  }
@endproj

@module top
  CONST {
    WIDTH = CONFIG.WIDTH;
    TEST = CONFIG.UNDECLARED;
  }

  PORT {
    OUT [CONFIG.UNDECLARED] out;
  }

  ASYNCHRONOUS {
    out <= 1'b1;
  }
@endmod