// MEM_INVALID_PORT_TYPE: Invalid port type or qualifier triggers error.
// Tests ASYNC and SYNC qualifiers on IN (write) ports, which are always synchronous.
// Valid OUT ASYNC and OUT SYNC ports included for no false positives.

@project MEM_INVALID_PORT_TYPE_invalid_port_type
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: IN port with ASYNC qualifier in helper module
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr ASYNC;
        };
    }

    ASYNCHRONOUS {
        data = mem_a.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_a.wr[addr] <= wdata;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 2: IN port with SYNC qualifier in top module
    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr SYNC;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_b.rd[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_b.wr[addr] <= wdata;
    }
@endmod
