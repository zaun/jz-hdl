// CLOCK_GEN_INPUT_FREQ_OUT_OF_RANGE: CLOCK_GEN input frequency outside chip FCLKIN range.
// Per UG286: rPLL FCLKIN range is 3-500 MHz. A 2 MHz input (period=500ns) is below minimum.
// Verified

@project(CHIP="GW2AR-18-QN88-C8-I7") CLOCK_GEN_INPUT_FREQ_OUT_OF_RANGE_TEST
    CLOCKS {
        slow_clk = { period=500.0 };
        CLK_SYS;
    }

    IN_PINS {
        slow_clk = { standard=LVCMOS33 };
    }

    OUT_PINS {
        led = { standard=LVCMOS33, drive=8 };
    }

    MAP {
        slow_clk = 4;
        led = 15;
    }

    CLOCK_GEN {
        PLL {
            IN REF_CLK slow_clk;
            OUT BASE  CLK_SYS;

            CONFIG {
                IDIV = 0;
                FBDIV = 3;
                ODIV = 16;
            };
        };
    }

    @top top {
        IN  [1] clk = slow_clk;
        OUT [1] led = led;
    }
@endproj

@module top
    PORT {
        IN  [1] clk;
        OUT [1] led;
    }

    ASYNCHRONOUS {
        led = clk;
    }
@endmod
