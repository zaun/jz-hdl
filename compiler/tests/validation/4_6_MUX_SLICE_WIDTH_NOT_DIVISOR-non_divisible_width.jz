// MUX_SLICE_WIDTH_NOT_DIVISOR: Auto-slicing requires source width to be exact multiple of element width.
// Tests non-divisible auto-slicing across multiple modules.
// Valid divisible slicing included to verify no false positives.

@project MUX_SLICE_WIDTH_NOT_DIVISOR_non_divisible_width
    @top TopMod {
        IN  [8] a = _;
        IN  [16] b = _;
        IN  [2] sel = _;
        OUT [8] data = _;
    }
@endproj

@module HelperMod
    PORT {
        IN  [8] a;
        OUT [8] data;
    }

    MUX {
        // Trigger 1: 8 % 3 != 0 (not evenly divisible)
        h_mux [3] = a;
    }

    ASYNCHRONOUS {
        data = a;
    }
@endmod

@module TopMod
    PORT {
        IN  [8] a;
        IN  [16] b;
        IN  [2] sel;
        OUT [8] data;
    }

    MUX {
        // Valid: 16 % 8 == 0 (evenly divisible, no error expected)
        valid_mux [8] = b;
        // Trigger 2: 16 % 5 != 0 (not evenly divisible)
        t_mux [5] = b;
        // Trigger 3: 8 % 6 != 0 (not evenly divisible)
        t_mux2 [6] = a;
    }

    @new inst_h HelperMod {
        IN  [8] a = a;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = valid_mux[sel[0]];
    }
@endmod
