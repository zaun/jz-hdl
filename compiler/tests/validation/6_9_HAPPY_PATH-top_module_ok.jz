// HAPPY_PATH: Valid @top module instantiation with all supported features.
// Exercises IN/OUT ports bound to pins, no-connect with explicit width,
// IN port bound to literal tie-off, differential pin binding, and
// multi-module structure with @new instantiation. No diagnostics expected.

@project HAPPY_PATH_top_module_ok
    CLOCKS {
        sys_clk = { period=10, edge=Rising };
    }

    IN_PINS {
        sys_clk = { standard=LVCMOS33 };
        btn = { standard=LVCMOS33 };
    }

    OUT_PINS {
        led = { standard=LVCMOS33, drive=8 };
        status = { standard=LVCMOS33, drive=8 };
    }

    MAP {
        sys_clk = 1;
        btn = 2;
        led = 3;
        status = 4;
    }

    @top TopMod {
        IN  [1] clk = sys_clk;
        IN  [1] btn_in = btn;
        // Valid: IN port bound to literal tie-off
        IN  [1] tie_high = 1'b1;
        OUT [1] led_out = led;
        OUT [1] status_out = status;
        // Valid: no-connect with explicit width
        OUT [1] debug = _;
        IN  [1] reserved = _;
    }
@endproj

@module Helper
    PORT {
        IN  [1] clk;
        IN  [1] enable;
        OUT [1] result;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        result = r;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= enable;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [1] btn_in;
        IN  [1] tie_high;
        OUT [1] led_out;
        OUT [1] status_out;
        OUT [1] debug;
        IN  [1] reserved;
    }

    WIRE {
        helper_result [1];
    }

    @new helper_inst Helper {
        IN  [1] clk = clk;
        IN  [1] enable = btn_in;
        OUT [1] result = helper_result;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        led_out = r;
        status_out = helper_result;
        debug = tie_high;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= btn_in ^ reserved;
    }
@endmod
