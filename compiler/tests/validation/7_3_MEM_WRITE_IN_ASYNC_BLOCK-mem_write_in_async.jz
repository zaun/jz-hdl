// MEM_WRITE_IN_ASYNC_BLOCK: Write to MEM IN port inside ASYNCHRONOUS block.
// Valid writes in SYNC block included for no false positives.

@project MEM_WRITE_IN_ASYNC_BLOCK_mem_write_in_async
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: write to IN port in ASYNC block in helper
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        data = mem_a.rd[addr];
        // Trigger 1: write in ASYNC block
        mem_a.wr[addr] = wdata;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_b.rd[addr];
        // Trigger 2: write in ASYNC block in top module
        mem_b.wr[addr] = wdata;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
    }
@endmod
