// CONST_NUMERIC_IN_STRING_CONTEXT: Numeric CONST/CONFIG used in @file() path.
// Tests both direct use and OVERRIDE forwarding of numeric CONSTs.

@project CONST_NUMERIC_IN_STRING_TEST
  CONFIG {
    NUM_CFG = 1024;
  }

  @top top {
    OUT [8] data  = _;
    OUT [8] data2 = _;
  }
@endproj

// Child module with string CONST default that gets overridden with numeric
@module rom_child
  CONST {
    ROM_FILE = "default.bin";
  }

  PORT {
    OUT [8] data;
  }

  MEM {
    rom [8] [256] = @file(ROM_FILE) {
      OUT rd ASYNC;
    };
  }

  ASYNCHRONOUS {
    data <= rom.rd[1];
  }
@endmod

@module top
  PORT {
    OUT [8] data;
    OUT [8] data2;
  }

  CONST {
    NUM_CONST = 42;
  }

  // Direct: numeric CONST in @file() path
  MEM {
    rom [8] [256] = @file(NUM_CONST) {
      OUT rd ASYNC;
    };
  }

  // OVERRIDE: numeric CONST forwarded by identifier to child string context
  @new rom0 rom_child {
    OVERRIDE {
      ROM_FILE = NUM_CONST;
    }
    OUT [8] data = data2;
  }

  ASYNCHRONOUS {
    data <= rom.rd[1];
  }
@endmod
