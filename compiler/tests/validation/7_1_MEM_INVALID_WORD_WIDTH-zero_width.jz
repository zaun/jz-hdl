// MEM_INVALID_WORD_WIDTH: Word width <= 0 triggers error.
// Valid width included for no false positives.

@project MEM_INVALID_WORD_WIDTH_zero_width
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: width = 0 in helper module
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [0] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= wdata;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 2: width = 0 in top module
    MEM {
        mem_b [0] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    // Valid: width = 8 (no error expected)
    MEM {
        mem_ok [8] [16] = 8'h00 {
            OUT rd_ok ASYNC;
            IN  wr_ok;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_ok.rd_ok[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_ok.wr_ok[addr] <= wdata;
    }
@endmod
