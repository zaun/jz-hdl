// BUS_SIGNAL_READ_FROM_WRITABLE: read access to writable BUS signal.
// Verified

@project BUS_SIGNAL_READ_FROM_WRITABLE_EXAMPLE
  BUS SIMPLE {
    OUT [1] rx;
  }

  @top top {
    OUT [1] out = _;
    BUS SIMPLE SOURCE link = _;
  }
@endproj

@module top
  PORT {
    OUT [1] out;
    BUS SIMPLE SOURCE link;
  }

  ASYNCHRONOUS {
    out = link.rx; // rx is writable in SOURCE role (OUT)
  }
@endmod
