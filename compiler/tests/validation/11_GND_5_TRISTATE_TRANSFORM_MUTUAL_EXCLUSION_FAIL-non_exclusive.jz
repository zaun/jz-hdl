// TRISTATE_TRANSFORM_MUTUAL_EXCLUSION_FAIL: Non-mutually-exclusive enable
// conditions on multiple tri-state drivers of the same signal.
// Context: two instances drive the same INOUT wire with the same enable,
// so their enables are non-exclusive → compiler cannot build priority chain.

@project TRISTATE_TRANSFORM_MUTUAL_EXCLUSION_FAIL_non_exclusive
    @top TopMod {
        IN  [1] en = _;
        OUT [8] data = _;
    }
@endproj

// Driver module: conditional tri-state output via INOUT
@module DriverMod
    PORT {
        IN    [1] en;
        INOUT [8] data;
    }

    ASYNCHRONOUS {
        IF (en) {
            data <= 8'hAA;
        } ELSE {
            data <= 8'bzzzz_zzzz;
        }
    }
@endmod

// Trigger 1: two instances with same enable (non-exclusive) driving same wire
@module TopMod
    PORT {
        IN  [1] en;
        OUT [8] data;
    }

    WIRE {
        bus [8];
    }

    @new inst_a DriverMod {
        IN    [1] en = en;
        INOUT [8] data = bus;
    };

    @new inst_b DriverMod {
        IN    [1] en = en;
        INOUT [8] data = bus;
    };

    ASYNCHRONOUS {
        data <= bus;
    }
@endmod
