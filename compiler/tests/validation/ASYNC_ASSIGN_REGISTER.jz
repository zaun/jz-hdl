// ASYNC_ASSIGN_REGISTER: registers may not be written in ASYNCHRONOUS blocks.
// Verified

@project ASYNC_ASSIGN_REGISTER_PROJECT
  @top ASYNC_ASSIGN_REGISTER_EXAMPLE {
    IN  [1] clk = _;
    OUT [1] out = _;
  }
@endproj

@module ASYNC_ASSIGN_REGISTER_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [1] out;
  }

  REGISTER {
    r [1] = 1'b0;
  }

  ASYNCHRONOUS {
    out <= r;
    r <= 1'b1;
  }

  SYNCHRONOUS(CLK=clk) {
  }
@endmod
