// MEM_EMPTY_PORT_LIST: MEM declared with no ports triggers error.
// Valid MEM with ports included for no false positives.

@project MEM_EMPTY_PORT_LIST_no_ports
    @top TopMod {
        IN  [1] clk = _;
        IN  [4] addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: empty port list in helper module
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {};
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= wdata;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [4] addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    // Trigger 2: empty port list in top module
    MEM {
        mem_b [8] [16] = 8'h00 {};
    }

    // Valid: MEM with ports (no error expected)
    MEM {
        mem_ok [8] [16] = 8'h00 {
            OUT rd_ok ASYNC;
            IN  wr_ok;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [4] addr = addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = mem_ok.rd_ok[addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_ok.wr_ok[addr] <= wdata;
    }
@endmod
