// UNARY_ARITH_MISSING_PARENS: S3.4 example "flag = (-flag)" requires parens.
// Tests unparenthesized unary minus/plus in S3.4 operator example contexts
// across async and sync blocks in multiple modules.
// Valid parenthesized uses included to verify no false positives.

@project UNARY_ARITH_MISSING_PARENS_negate_without_parens
    CONFIG {
        WIDTH = 8;
    }
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] val = _;
        OUT [8] out_a = _;
        OUT [8] out_b = _;
        OUT [8] out_c = _;
        OUT [8] out_d = _;
    }
@endproj

// Helper module: unary minus without parens in async and sync
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] val;
        OUT [8] out_a;
        OUT [8] out_b;
    }
    REGISTER {
        r [8] = 8'd0;
    }
    ASYNCHRONOUS {
        // Trigger 1: unparenthesized unary minus in async (S3.4 negation pattern)
        out_a <= -val;
        // Valid: parenthesized negation (S3.4 correct form, no false positive)
        out_b = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 2: unparenthesized unary minus in sync
        r <= -val;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] val;
        OUT [8] out_a;
        OUT [8] out_b;
        OUT [8] out_c;
        OUT [8] out_d;
    }
    WIRE {
        ha [8];
        hb [8];
    }
    REGISTER {
        r [8] = 8'd0;
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [8] val = val;
        OUT [8] out_a = ha;
        OUT [8] out_b = hb;
    };

    ASYNCHRONOUS {
        // Trigger 3: unparenthesized unary minus in top async
        out_a <= -val;
        // Trigger 4: unparenthesized unary plus in top async
        out_b <= +val;
        // Valid: parenthesized forms (no false positive)
        out_c = (-val);
        out_d = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 5: unparenthesized unary minus in top sync
        r <= -val;
    }
@endmod
