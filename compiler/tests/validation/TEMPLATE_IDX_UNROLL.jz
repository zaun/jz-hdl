// TEMPLATE_IDX_UNROLL: @apply[2] with IDX for unrolling.
// No template-specific errors expected. Tests that IDX substitution works
// with simple expressions that the semantic analyzer can handle.

@project TEMPLATE_IDX_UNROLL_PROJECT
  @top TEMPLATE_IDX_UNROLL_MOD {
    IN  [8] in_a = _;
    IN  [8] in_b = _;
    OUT [8] out_a = _;
    OUT [8] out_b = _;
  }
@endproj

@template SET_BYTE(src, dst)
  dst <= src;
@endtemplate

@module TEMPLATE_IDX_UNROLL_MOD
  PORT {
    IN  [8] in_a;
    IN  [8] in_b;
    OUT [8] out_a;
    OUT [8] out_b;
  }

  WIRE {
    sel [1];
  }

  ASYNCHRONOUS {
    sel <= 1'b0;
    IF (sel == 1'b0) {
      @apply SET_BYTE(in_a, out_a);
      @apply SET_BYTE(in_b, out_b);
    } ELSE {
      @apply SET_BYTE(in_b, out_a);
      @apply SET_BYTE(in_a, out_b);
    }
  }
@endmod
