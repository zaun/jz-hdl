// CLOCK_GEN_DERIVED_OUT_OF_RANGE: CLOCK_GEN derived VCO frequency outside valid range (400-1200 MHz).
// With 27MHz input (period=37.04ns), IDIV=0, FBDIV=0, ODIV=2:
// FVCO = (1000/37.04) * (0+1) * 2 / (0+1) = 27.0 * 2 = 54 MHz (below 400 MHz minimum)

@project(CHIP="GW1NR-9-QN88-C6-I5") CLOCK_GEN_DERIVED_OUT_OF_RANGE_TEST
  CLOCKS {
    sys_clk = { period=37.04 };
    fast_clk;
  }

  IN_PINS {
    sys_clk = { standard=LVCMOS33 };
    btn = { standard=LVCMOS33 };
  }

  OUT_PINS {
    led = { standard=LVCMOS33, drive=8 };
  }

  CLOCK_GEN {
    PLL {
      IN REF_CLK sys_clk;
      OUT BASE fast_clk;
      CONFIG {
        IDIV = 0;
        FBDIV = 0;
        ODIV = 2;
      };
    };
  }

  MAP {
    sys_clk = 4;
    btn = 10;
    led = 11;
  }

  @top top {
    IN  [1] a = btn;
    OUT [1] out = led;
  }
@endproj

@module top
  PORT {
    IN  [1] a;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = a;
  }
@endmod
