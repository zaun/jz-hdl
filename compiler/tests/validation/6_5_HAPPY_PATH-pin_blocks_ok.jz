// HAPPY_PATH: Valid PIN block declarations covering all features.
// Exercises IN_PINS, OUT_PINS, INOUT_PINS with valid standards, drive,
// bus pins, differential mode, pull resistors, termination, and serializer.
// No diagnostics expected.

@project HAPPY_PATH_pin_blocks_ok
    CLOCKS {
        sys_clk = { period=10 };
        fast_clk = { period=2 };
    }

    IN_PINS {
        sys_clk = { standard=LVCMOS33 };
        fast_clk = { standard=LVCMOS33 };
        // Scalar input
        btn = { standard=LVCMOS33 };
        // Bus input
        sw[4] = { standard=LVCMOS33 };
        // Input with pull-up
        btn_pull = { standard=LVCMOS33, pull=UP };
        // Input with pull-down
        btn_down = { standard=LVCMOS33, pull=DOWN };
        // Input with pull=NONE
        btn_none = { standard=LVCMOS33, pull=NONE };
        // Input with termination on supported standard
        sstl_in = { standard=SSTL18_I, term=ON };
        // Differential input
        lvds_in = { standard=LVDS25, mode=DIFFERENTIAL };
        // Explicit single mode
        single_in = { standard=LVCMOS25, mode=SINGLE };
        // Explicit width=1 scalar
        explicit_w1[1] = { standard=LVCMOS33 };
        // Large bus
        wide_bus[32] = { standard=LVCMOS33 };
    }

    OUT_PINS {
        // Scalar output with drive
        led = { standard=LVCMOS18, drive=8 };
        // Bus output
        data_out[8] = { standard=LVCMOS33, drive=4 };
        // Differential output with all required serializer attributes
        lvds_out = { standard=LVDS25, drive=8, mode=DIFFERENTIAL, fclk=fast_clk, pclk=sys_clk, reset=sys_clk };
    }

    INOUT_PINS {
        // Bidirectional pin
        sda = { standard=LVCMOS33, drive=4 };
        // INOUT with pull-up
        io_pull = { standard=LVCMOS33, drive=4, pull=UP };
        // INOUT with pull-down
        io_down = { standard=LVCMOS33, drive=4, pull=DOWN };
        // INOUT with termination on supported standard
        sstl_io = { standard=SSTL18_I, drive=4, term=ON };
    }

    MAP {
        sys_clk = 1;
        fast_clk = 2;
        btn = 3;
        sw[0] = 4;
        sw[1] = 5;
        sw[2] = 6;
        sw[3] = 7;
        btn_pull = 8;
        btn_down = 9;
        btn_none = 10;
        sstl_in = 11;
        lvds_in = { P=12, N=13 };
        single_in = 14;
        explicit_w1[0] = 15;
        wide_bus[0] = 100;
        wide_bus[1] = 101;
        wide_bus[2] = 102;
        wide_bus[3] = 103;
        wide_bus[4] = 104;
        wide_bus[5] = 105;
        wide_bus[6] = 106;
        wide_bus[7] = 107;
        wide_bus[8] = 108;
        wide_bus[9] = 109;
        wide_bus[10] = 110;
        wide_bus[11] = 111;
        wide_bus[12] = 112;
        wide_bus[13] = 113;
        wide_bus[14] = 114;
        wide_bus[15] = 115;
        wide_bus[16] = 116;
        wide_bus[17] = 117;
        wide_bus[18] = 118;
        wide_bus[19] = 119;
        wide_bus[20] = 120;
        wide_bus[21] = 121;
        wide_bus[22] = 122;
        wide_bus[23] = 123;
        wide_bus[24] = 124;
        wide_bus[25] = 125;
        wide_bus[26] = 126;
        wide_bus[27] = 127;
        wide_bus[28] = 128;
        wide_bus[29] = 129;
        wide_bus[30] = 130;
        wide_bus[31] = 131;
        led = 16;
        data_out[0] = 17;
        data_out[1] = 18;
        data_out[2] = 19;
        data_out[3] = 20;
        data_out[4] = 21;
        data_out[5] = 22;
        data_out[6] = 23;
        data_out[7] = 24;
        lvds_out = { P=25, N=26 };
        sda = 27;
        io_pull = 28;
        io_down = 29;
        sstl_io = 30;
    }

    @top TopMod {
        IN  [1] clk = sys_clk;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
