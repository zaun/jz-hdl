// BLACKBOX_NAME_DUP_IN_PROJECT: Blackbox name conflicts with module or another blackbox.
// Trigger 1: duplicate blackbox name (bb-bb conflict)
// Trigger 2: blackbox name matches a module name (bb-module conflict)
// Valid unique blackbox included as negative test.

@project BLACKBOX_DUP_bb_name_conflicts
    // Valid: unique blackbox — no trigger
    @blackbox bb_ok {
        PORT {
            IN  [1] din;
            OUT [1] dout;
        }
    }

    // First definition of bb_dup
    @blackbox bb_dup {
        PORT {
            IN  [1] din;
            OUT [1] dout;
        }
    }

    // Trigger 1: duplicate blackbox name bb_dup
    @blackbox bb_dup {
        PORT {
            IN  [1] din;
            OUT [1] dout;
        }
    }

    // Trigger 2: blackbox name conflicts with module name ConflictMod
    @blackbox ConflictMod {
        PORT {
            IN  [1] din;
            OUT [1] dout;
        }
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

// Module named ConflictMod — blackbox above conflicts with this
@module ConflictMod
    PORT {
        IN  [1] din;
        OUT [1] dout;
    }
    ASYNCHRONOUS {
        dout = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    @new inst_bb bb_ok {
        IN  [1] din = r;
        OUT [1] dout = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
