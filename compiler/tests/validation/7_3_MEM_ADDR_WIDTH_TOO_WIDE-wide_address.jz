// MEM_ADDR_WIDTH_TOO_WIDE: Address signal wider than ceil(log2(depth)).
// mem [8] [16] needs ceil(log2(16))=4 bit address. Using 8-bit address.
// Valid 4-bit address included for no false positives.

@project MEM_ADDR_WIDTH_TOO_WIDE_wide_address
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] wide_addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Trigger 1: wide address in async read in helper
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] wide_addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    ASYNCHRONOUS {
        // Trigger 1: 8-bit addr for 16-deep mem (needs 4 bits)
        data = mem_a.rd[wide_addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        // Trigger 2: 8-bit addr for sync write
        mem_a.wr[wide_addr] <= wdata;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] wide_addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [8] wide_addr = wide_addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        // Trigger 3: 8-bit addr in async read in top module
        data = mem_b.rd[wide_addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        // Trigger 4: 8-bit addr in sync write in top module
        mem_b.wr[wide_addr] <= wdata;
    }
@endmod
