// MEM_ADDR_WIDTH_TOO_WIDE: Address signal wider than ceil(log2(depth)).
// mem [8] [16] needs ceil(log2(16))=4 bit address. Using 8-bit address.
// Triggers in async read, sync write, and sync .addr contexts.
// Valid 4-bit address included for no false positives.

@project MEM_ADDR_WIDTH_TOO_WIDE_wide_address
    @top TopMod {
        IN  [1] clk = _;
        IN  [8] wide_addr = _;
        IN  [4] ok_addr = _;
        IN  [8] wdata = _;
        OUT [8] data = _;
    }
@endproj

// Helper: wide address in async read and sync write
@module HelperMod
    PORT {
        IN  [1] clk;
        IN  [8] wide_addr;
        IN  [4] ok_addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_a [8] [16] = 8'h00 {
            OUT rd ASYNC;
            IN  wr_ok;
            IN  wr_wide;
        };
    }

    ASYNCHRONOUS {
        // Trigger 1: 8-bit addr for 16-deep mem (needs 4 bits) in async read
        data = mem_a.rd[wide_addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        // Valid: 4-bit address fits
        mem_a.wr_ok[ok_addr] <= wdata;
        // Trigger 2: 8-bit addr for sync write
        mem_a.wr_wide[wide_addr] <= wdata;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        IN  [8] wide_addr;
        IN  [4] ok_addr;
        IN  [8] wdata;
        OUT [8] data;
    }

    REGISTER {
        r [8] = 8'h00;
    }

    MEM {
        mem_b [8] [16] = 8'h00 {
            OUT rd_a ASYNC;
            OUT rd_s SYNC;
            IN  wr;
        };
    }

    @new inst_h HelperMod {
        IN  [1] clk = clk;
        IN  [8] wide_addr = wide_addr;
        IN  [4] ok_addr = ok_addr;
        IN  [8] wdata = wdata;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        // Trigger 3: 8-bit addr in async read in top
        data = mem_b.rd_a[wide_addr];
    }

    SYNCHRONOUS(CLK=clk) {
        r <= r;
        mem_b.wr[ok_addr] <= wdata;
        // Trigger 4: 8-bit addr in sync .addr on SYNC port
        mem_b.rd_s.addr <= wide_addr;
    }
@endmod
