// HAPPY_PATH: Valid project with unique module names, unique blackbox names,
// and no name collisions. Exercises project scope and uniqueness rules.

@project HAPPY_PATH_project_scope_ok
    @blackbox ExtIp {
        PORT {
            IN  [1] din;
            OUT [1] dout;
        }
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module Helper
    PORT {
        IN  [1] din;
        OUT [1] dout;
    }
    ASYNCHRONOUS {
        dout = din;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    @new inst_h Helper {
        IN  [1] din = r;
        OUT [1] dout = _;
    };

    @new inst_bb ExtIp {
        IN  [1] din = r;
        OUT [1] dout = _;
    };

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
