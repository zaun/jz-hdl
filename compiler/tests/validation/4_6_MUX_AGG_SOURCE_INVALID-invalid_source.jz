// MUX_AGG_SOURCE_INVALID: Aggregation source not a valid readable signal.
// Tests using literals and constants as MUX aggregation sources.
// Valid signal sources included to verify no false positives.

@project MUX_AGG_SOURCE_INVALID_invalid_source
    @top TopMod {
        IN  [8] a = _;
        IN  [8] b = _;
        IN  [1] sel = _;
        OUT [8] data = _;
    }
@endproj

@module HelperMod
    PORT {
        IN  [8] a;
        OUT [8] data;
    }

    MUX {
        // Trigger 1: literal as aggregation source
        h_mux = a, 8'd5;
    }

    ASYNCHRONOUS {
        data = a;
    }
@endmod

@module TopMod
    PORT {
        IN  [8] a;
        IN  [8] b;
        IN  [1] sel;
        OUT [8] data;
    }

    CONST {
        MY_CONST = 42;
    }

    MUX {
        // Valid: signal sources (no error expected)
        valid_mux = a, b;
        // Trigger 2: const as aggregation source
        t_mux = a, MY_CONST;
    }

    @new inst_h HelperMod {
        IN  [8] a = a;
        OUT [8] data = _;
    };

    ASYNCHRONOUS {
        data = valid_mux[sel];
    }
@endmod
