// RPT_COUNT_INVALID: @repeat with non-numeric count is invalid.
// Triggers RPT-001 because @repeat requires a positive integer count.
// The error is fatal — the repeat expander stops processing the file.

@project RPT_COUNT_INVALID_non_numeric_count
    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }
    REGISTER {
        r [1] = 1'b0;
    }
    ASYNCHRONOUS {
        data = r;
    }
    SYNCHRONOUS(CLK=clk) {
        // Trigger 1: @repeat abc — non-numeric argument
        @repeat abc
            r <= ~r;
        @end
    }
@endmod
