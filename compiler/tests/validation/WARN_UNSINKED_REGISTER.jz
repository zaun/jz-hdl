// WARN_UNSINKED_REGISTER: register is written but never read.

@project WARN_UNSINKED_REGISTER_PROJECT
  @top WARN_UNSINKED_REGISTER_EXAMPLE {
    IN  [1] clk = _;
    OUT [8] data = _;
  }
@endproj

@module WARN_UNSINKED_REGISTER_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [8] data;
  }

  REGISTER {
    r [8] = 8'h00; // written but never read
  }

  ASYNCHRONOUS {
    data <= 8'b1;
  }

  SYNCHRONOUS(CLK=clk) {
    r <= 8'hFF;
  }
@endmod
