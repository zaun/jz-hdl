// TEMPLATE_FORBIDDEN_BLOCK_HEADER: SYNCHRONOUS block header in module-scoped template.
// Realistic syntax with CLK parameter and block body. Parser does not recover after
// the error, producing cascading PARSE000.

@project TEMPLATE_FORBIDDEN_BLOCK_HEADER_sync_mod_scoped
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [1] data = _;
    }
@endproj

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [1] data;
    }

    // Trigger: SYNCHRONOUS block header inside module-scoped template
    @template sync_mod_tmpl(a, b)
        SYNCHRONOUS(CLK=a) {
            b <= a;
        }
    @endtemplate

    REGISTER {
        r [1] = 1'b0;
    }

    ASYNCHRONOUS {
        data = r;
    }

    SYNCHRONOUS(CLK=clk) {
        r <= ~r;
    }
@endmod
