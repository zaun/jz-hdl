// SPECIAL_DRIVER_HAPPY_PATH: Valid uses of GND and VCC as standalone drivers.
// Exercises polymorphic expansion, register reset, wire tie-off, sync assignment,
// IF/ELSE branches, and various widths. No diagnostics expected.

@project SPECIAL_DRIVER_HAPPY_PATH_valid_gnd_vcc
    CONFIG {
        WIDTH = 8;
    }

    @top TopMod {
        IN  [1] clk = _;
        OUT [8] out_a = _;
        OUT [1] out_b = _;
        OUT [8] out_c = _;
    }
@endproj

// Helper: GND/VCC in register reset and async tie-off
@module HelperA
    PORT {
        IN  [1] clk;
        OUT [8] out_a;
        OUT [1] out_b;
    }
    REGISTER {
        // GND as register reset (8-bit, expands to 8'b0000_0000)
        r [8] = GND;
        // VCC as register reset (1-bit, expands to 1'b1)
        s [1] = VCC;
    }
    ASYNCHRONOUS {
        out_a = r;
        out_b = s;
    }
    SYNCHRONOUS(CLK=clk) {
        // GND as standalone sync assignment
        r <= GND;
        // VCC as standalone sync assignment
        s <= VCC;
    }
@endmod

// Helper: GND/VCC in IF/ELSE branches and wire tie-off
@module HelperB
    PORT {
        IN  [1] clk;
        IN  [1] sel;
        OUT [8] out_c;
    }
    WIRE {
        w [8];
    }
    REGISTER {
        r [8] = 8'h00;
    }
    ASYNCHRONOUS {
        // GND/VCC in exclusive IF/ELSE paths
        IF (sel) {
            w <= VCC;
        } ELSE {
            w <= GND;
        }
        out_c = w;
    }
    SYNCHRONOUS(CLK=clk) {
        r <= r;
    }
@endmod

@module TopMod
    PORT {
        IN  [1] clk;
        OUT [8] out_a;
        OUT [1] out_b;
        OUT [8] out_c;
    }
    WIRE {
        ha_out_a [8];
        ha_out_b [1];
        hb_out_c [8];
    }
    REGISTER {
        // VCC as register reset (8-bit, expands to 8'b1111_1111)
        r [8] = VCC;
    }

    @new inst_a HelperA {
        IN  [1] clk = clk;
        OUT [8] out_a = ha_out_a;
        OUT [1] out_b = ha_out_b;
    };

    @new inst_b HelperB {
        IN  [1] clk = clk;
        IN  [1] sel = ha_out_b;
        OUT [8] out_c = hb_out_c;
    };

    ASYNCHRONOUS {
        out_a = ha_out_a ^ r;
        out_b = ha_out_b;
        out_c = hb_out_c;
    }
    SYNCHRONOUS(CLK=clk) {
        // VCC as standalone register assignment
        r <= VCC;
    }
@endmod
