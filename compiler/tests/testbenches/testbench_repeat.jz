// Test @repeat with IDX substitution in testbench context.

@module counter
    PORT {
        IN  [1] clk;
        IN  [1] rst_n;
        OUT [8] count;
    }

    REGISTER {
        cnt [8] = 8'h00;
    }

    ASYNCHRONOUS {
        count <= cnt;
    }

    SYNCHRONOUS(CLK=clk RESET=rst_n RESET_ACTIVE=Low) {
        cnt <= cnt + 8'h01;
    }
@endmod

@testbench counter
    CLOCK {
        clk;
    }

    WIRE {
        rst_n [1];
        count [8];
    }

    TEST "Repeat advances clock and checks" {
        @new dut counter {
            clk [1] = clk;
            rst_n [1] = rst_n;
            count [8] = count;
        }

        @setup {
            rst_n <= 1'b0;
        }

        // Release reset
        @clock(clk, cycle=1)
        @update {
            rst_n <= 1'b1;
        }

        // Use @repeat to advance 3 individual cycles and check each
        @repeat 3
        @clock(clk, cycle=1)
        @end

        // After 3 cycles, count should be 3
        @expect_equal(count, 8'h03)
    }
@endtb
