// Tristate testbench: verifies @expect_tristate directive

@module tri_driver
    PORT {
        IN  [1] clk;
        IN  [1] rst_n;
        IN  [1] enable;
        OUT [8] data_out;
    }

    REGISTER {
        data [8] = 8'h00;
    }

    ASYNCHRONOUS {
        data_out <= enable ? data : 8'bz;
    }

    SYNCHRONOUS(CLK=clk RESET=rst_n RESET_ACTIVE=Low) {
        data <= data + 8'h01;
    }
@endmod

@testbench tri_driver
    CLOCK {
        clk;
    }

    WIRE {
        rst_n [1];
        enable [1];
        data_out [8];
    }

    TEST "Output is tristate when disabled" {
        @new dut tri_driver {
            clk [1] = clk;
            rst_n [1] = rst_n;
            enable [1] = enable;
            data_out [8] = data_out;
        }

        @setup {
            rst_n <= 1'b0;
            enable <= 1'b0;
        }

        @clock(clk, cycle=1)
        @expect_tristate(data_out)
    }

    TEST "Output is driven when enabled" {
        @new dut tri_driver {
            clk [1] = clk;
            rst_n [1] = rst_n;
            enable [1] = enable;
            data_out [8] = data_out;
        }

        @setup {
            rst_n <= 1'b0;
            enable <= 1'b1;
        }

        @clock(clk, cycle=1)
        @expect_equal(data_out, 8'h00)

        @update {
            rst_n <= 1'b1;
        }

        @clock(clk, cycle=1)
        @expect_equal(data_out, 8'h01)
    }

    TEST "Transition from tristate to driven" {
        @new dut tri_driver {
            clk [1] = clk;
            rst_n [1] = rst_n;
            enable [1] = enable;
            data_out [8] = data_out;
        }

        @setup {
            rst_n <= 1'b0;
            enable <= 1'b0;
        }

        @clock(clk, cycle=1)
        @expect_tristate(data_out)

        @update {
            enable <= 1'b1;
        }

        @clock(clk, cycle=1)
        @expect_equal(data_out, 8'h00)
    }
@endtb
