// Basic testbench example for testing the parser.

@module counter
    PORT {
        IN  [1] clk;
        IN  [1] rst_n;
        OUT [8] count;
    }

    REGISTER {
        cnt [8] = 8'h00;
    }

    ASYNCHRONOUS {
        count <= cnt;
    }

    SYNCHRONOUS(CLK=clk RESET=rst_n RESET_ACTIVE=Low) {
        cnt <= cnt + 8'h01;
    }
@endmod

@testbench counter
    CLOCK {
        clk;
    }

    WIRE {
        rst_n [1];
        count [8];
    }

    TEST "Reset holds counter at zero" {
        @new dut counter {
            clk [1] = clk;
            rst_n [1] = rst_n;
            count [8] = count;
        }

        @setup {
            rst_n <= 1'b0;
        }

        @clock(clk, cycle=5)
        @expect_equal(count, 8'h00)

        @update {
            rst_n <= 1'b1;
        }

        @clock(clk, cycle=1)
        @expect_equal(count, 8'h01)
    }

    TEST "Counter increments after reset release" {
        @new dut counter {
            clk [1] = clk;
            rst_n [1] = rst_n;
            count [8] = count;
        }

        @setup {
            rst_n <= 1'b0;
        }

        @clock(clk, cycle=3)
        @expect_equal(count, 8'h00)

        @update {
            rst_n <= 1'b1;
        }

        @clock(clk, cycle=1)
        @expect_equal(count, 8'h01)

        @clock(clk, cycle=4)
        @expect_equal(count, 8'h05)
    }
@endtb
