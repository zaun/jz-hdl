// PIN_DUP_NAME_WITHIN_BLOCK: duplicate pin names inside the same PIN block.
// Verified

@project PIN_DUP_NAME_WITHIN_BLOCK_PROJECT
  IN_PINS {
    pin = { standard=LVCMOS33 };
    pin_in = { standard=LVCMOS33 };
    pin = { standard=LVCMOS33 };
  }

  MAP {
    pin = 10;
    pin_in = 11;
  }

  @top PIN_DUP_NAME_WITHIN_BLOCK_EXAMPLE {
    IN  [1] in = _;
    OUT [1] out = _;
  }
@endproj

@module PIN_DUP_NAME_WITHIN_BLOCK_EXAMPLE
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod
