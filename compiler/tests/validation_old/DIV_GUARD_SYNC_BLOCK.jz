// DIV_GUARD_SYNC_BLOCK: guard inside a SYNCHRONOUS block suppresses warning.
// Verified

@project DIV_GUARD_SYNC_BLOCK_PROJECT
  CLOCKS {
    sys_clk = { period=10.0, edge=Rising };
  }

  IN_PINS {
    sys_clk = { standard=LVCMOS33 };
    sys_rst = { standard=LVCMOS33 };
    a[8] = { standard=LVCMOS33 };
    b[8] = { standard=LVCMOS33 };
  }

  OUT_PINS {
    out_a[8] = { standard=LVCMOS18, drive=8 };
    out_b[8] = { standard=LVCMOS18, drive=8 };
  }

  MAP {
    sys_clk = 52;
    sys_rst = 53;
    a[0] = 1; a[1] = 2; a[2] = 3; a[3] = 4;
    a[4] = 5; a[5] = 6; a[6] = 7; a[7] = 8;
    b[0] = 10; b[1] = 11; b[2] = 12; b[3] = 13;
    b[4] = 14; b[5] = 15; b[6] = 16; b[7] = 17;
    out_a[0] = 20; out_a[1] = 21; out_a[2] = 22; out_a[3] = 23;
    out_a[4] = 24; out_a[5] = 25; out_a[6] = 26; out_a[7] = 27;
    out_b[0] = 30; out_b[1] = 31; out_b[2] = 32; out_b[3] = 33;
    out_b[4] = 34; out_b[5] = 35; out_b[6] = 36; out_b[7] = 37;
  }

  @top DIV_GUARD_SYNC_BLOCK_EXAMPLE {
    IN  [1] clk = sys_clk;
    IN  [1] rst = sys_rst;
    IN  [8] a = a;
    IN  [8] b = b;
    OUT [8] out_a = out_a;
    OUT [8] out_b = out_b;
  }
@endproj

@module DIV_GUARD_SYNC_BLOCK_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [1] rst;
    IN  [8] a;
    IN  [8] b;
    OUT [8] out_a;
    OUT [8] out_b;
  }

  REGISTER {
    result_a [8] = 8'd0;
    result_b [8] = 8'd0;
  }

  ASYNCHRONOUS {
    out_a = result_a;
    out_b = result_b;
  }

  SYNCHRONOUS(
    CLK=clk
    EDGE=Rising
    RESET=rst
    RESET_ACTIVE=High
    RESET_TYPE=Immediate
  ) {
    // Unguarded division in sync block — should warn
    result_a <= a / b;

    // Guarded division in sync block — should NOT warn
    IF (b != 8'd0) {
      result_b <= a / b;
    }
  }
@endmod
