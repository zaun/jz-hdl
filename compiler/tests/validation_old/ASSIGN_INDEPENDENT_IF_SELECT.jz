// ASSIGN_INDEPENDENT_IF_SELECT: same identifier assigned in multiple
// independent IF or SELECT chains at the same nesting level.
// Verified

@project ASSIGN_INDEPENDENT_IF_SELECT_PROJECT
  @top ASSIGN_INDEPENDENT_IF_SELECT_EXAMPLE {
    IN  [8] a = _;
    IN  [8] b = _;
    OUT [8] out = _;
  }
@endproj

@module ASSIGN_INDEPENDENT_IF_SELECT_EXAMPLE
  PORT {
    IN  [8] a;
    IN  [8] b;
    OUT [8] out;
  }

  ASYNCHRONOUS {
    // First IF chain assigning to out.
    IF (1'b1) {
      out <= a;
    }

    // Second, independent IF chain at the same nesting level assigning to out.
    IF (1'b1) {
      out <= b;
    }
  }
@endmod
