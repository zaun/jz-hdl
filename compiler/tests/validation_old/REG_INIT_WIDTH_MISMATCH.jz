// REG_INIT_WIDTH_MISMATCH: register initialization literal width must match declared width.
// Verified

@project REG_INIT_WIDTH_MISMATCH_PROJECT
  @top REG_INIT_WIDTH_MISMATCH_EXAMPLE {
    IN  [1] clk = _;
    IN  [1] rst = _;
    OUT [1] out = _;
  }
@endproj

@module REG_INIT_WIDTH_MISMATCH_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [1] rst;
    OUT [1] out;
  }

  REGISTER {
    a [1] = 3'b0;
    b [25] = 5'h000;
    c [8] = 8'hFF;
    d [4] = 4'b0000;
  }

  ASYNCHRONOUS {
    out <= a & b[1] & c[1] & d[1];
  }

  SYNCHRONOUS(CLK=clk RESET=rst) {
    a <= 1'b0;
    b <= 25'b0;
    c <= 8'h00;
    d <= 4'b0;
  }
@endmod
