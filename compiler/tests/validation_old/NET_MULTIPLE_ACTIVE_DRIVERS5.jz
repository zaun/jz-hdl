// NET_MULTIPLE_ACTIVE_DRIVERS2: selects are excluside, no error
// Verifies

@project NET_MULTIPLE_ACTIVE_DRIVERS_PROJECT
  @top NET_MULTIPLE_ACTIVE_DRIVERS_EXAMPLE {
    IN  [1] clk = _;
    OUT [4] data = _;
  }
@endproj

@module NET_MULTIPLE_ACTIVE_DRIVERS_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [4] data;
  }

  @new n0 NET_MULTIPLE_ACTIVE_DRIVERS_NODE_A {
    IN  [1] clk = clk;
    IN  [1] sel = 1'b0;
    OUT [4] data = data;
  }

  @new n1 NET_MULTIPLE_ACTIVE_DRIVERS_NODE_B {
    IN  [1] clk = clk;
    IN  [1] sel = 1'b1;
    OUT [4] data = data;
  }

@endmod

@module NET_MULTIPLE_ACTIVE_DRIVERS_NODE_A
  PORT {
    IN  [1] clk; 
    IN  [1] sel;
    OUT [4] data;
  }

  REGISTER {
    reg [2] = 2'b00;
  }

  ASYNCHRONOUS {
    data <= sel == reg[0] ? 4'b1 : 4'bz;
  }

  SYNCHRONOUS(CLK=clk) {
    reg <= reg + 2'b1;
  }
@endmod

@module NET_MULTIPLE_ACTIVE_DRIVERS_NODE_B
  PORT {
    IN  [1] clk;
    IN  [1] sel;
    OUT [4] data;
  }

  REGISTER {
    reg [2] = 2'b01;
  }

  ASYNCHRONOUS {
    data <= sel == reg[0] ? 4'b1 : 4'bz;
  }

  SYNCHRONOUS(CLK=clk) {
    reg <= reg + 2'b1;
  }
@endmod
