// CONFIG_CIRCULAR_DEP: circular dependency between CONFIG entries.
// Verified

@project CONFIG_CIRCULAR_DEP_EXAMPLE
  CONFIG {
    A = CONFIG.B + 1;
    B = CONFIG.A + 2;
  }

  @top top {
    OUT [1] out = _;
  }
@endproj

@module top
  PORT {
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out <= 1'b1;
  }
@endmod
