// DIV_GUARD_GT: IF (b > N) proves b nonzero in THEN branch for any N >= 0.
// IF (b <= N) proves b nonzero in ELSE branch (sig > N always nonzero unsigned).
// Verified

@project DIV_GUARD_GT_PROJECT
  @top DIV_GUARD_GT_EXAMPLE {
    IN  [8] a = _;
    IN  [8] b = _;
    OUT [8] out_a = _;
    OUT [8] out_b = _;
    OUT [8] out_c = _;
  }
@endproj

@module DIV_GUARD_GT_EXAMPLE
  PORT {
    IN  [8] a;
    IN  [8] b;
    OUT [8] out_a;
    OUT [8] out_b;
    OUT [8] out_c;
  }

  ASYNCHRONOUS {
    // IF (b > 0) THEN: b >= 1 → nonzero — should NOT warn
    IF (b > 8'd0) {
      out_a <= a / b;
    } ELSE {
      out_a <= 8'd0;
    }

    // IF (b > 5) THEN: b >= 6 → nonzero — should NOT warn
    IF (b > 8'd5) {
      out_b <= a / b;
    } ELSE {
      out_b <= 8'd0;
    }

    // IF (b <= 8'd3) ELSE: b > 3 → nonzero — should NOT warn
    IF (b <= 8'd3) {
      out_c <= 8'd0;
    } ELSE {
      out_c <= a % b;
    }
  }
@endmod
