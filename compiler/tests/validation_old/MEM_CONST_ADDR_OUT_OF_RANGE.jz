// MEM_CONST_ADDR_OUT_OF_RANGE: constant address index >= depth.
// Verified

@project MEM_CONST_ADDR_OUT_OF_RANGE_PROJECT
  @top MEM_CONST_ADDR_OUT_OF_RANGE_EXAMPLE {
    OUT [8] data_a = _;
    OUT [8] data_b = _;
    OUT [8] data_c = _;
  }
@endproj

@module MEM_CONST_ADDR_OUT_OF_RANGE_EXAMPLE
  CONST {
    index = 1;
    bad = 5;
  }

  PORT {
    OUT [8] data_a;
    OUT [8] data_b;
    OUT [8] data_c;
  }

  MEM {
    // depth = 4, valid indices are 0..3.
    mem0 [8] [4] = 8'h00 {
      OUT rd ASYNC;
    };
  }

  ASYNCHRONOUS {
    data_a = mem0.rd[4]; // Constant index 4 is out of range.
    data_b = mem0.rd[index]; // In-range index, not and error.
    data_c = mem0.rd[bad]; // out of range index, not and error.
  }
@endmod
