// ASYNC_ALIAS_IN_CONDITIONAL: alias operators (=, =z, =s) forbidden inside conditional control flow.
// Expect ERR> ASYNC_ALIAS_IN_CONDITIONAL on all alias assignments inside IF/ELIF/ELSE/SELECT/CASE.
// Verified

@project ASYNC_ALIAS_IN_CONDITIONAL_PROJECT
  @top ASYNC_ALIAS_IN_CONDITIONAL_EXAMPLE {
    IN  [1] sel = _;
    IN  [8] a = _;
    IN  [8] b = _;
    OUT [8] out = _;
  }
@endproj

@module ASYNC_ALIAS_IN_CONDITIONAL_EXAMPLE
  PORT {
    IN  [1] sel;
    IN  [8] a;
    IN  [8] b;
    OUT [8] out;
  }

  ASYNCHRONOUS {
    // ERROR: alias operator inside IF
    IF (sel) {
      out = a;
    } ELSE {
      out = b;
    }
  }
@endmod
