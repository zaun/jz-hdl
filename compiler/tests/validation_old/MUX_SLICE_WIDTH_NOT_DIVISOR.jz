// MUX_SLICE_WIDTH_NOT_DIVISOR: element_width does not divide wide source width exactly.
// Verified.

@project MUX_SLICE_WIDTH_NOT_DIVISOR_PROJECT
  @top MUX_SLICE_WIDTH_NOT_DIVISOR_EXAMPLE {
    IN  [9] data = _;
    OUT [4] dout = _;
  }
@endproj

@module MUX_SLICE_WIDTH_NOT_DIVISOR_EXAMPLE
  PORT {
    IN  [9] data;
    OUT [4] dout;
  }

  MUX {
    // 9-bit wide source with element_width 4 -> not an exact divisor.
    bad_slice_mux [4] = data;
  }

  ASYNCHRONOUS {
    dout = bad_slice_mux[0];
  }
@endmod
