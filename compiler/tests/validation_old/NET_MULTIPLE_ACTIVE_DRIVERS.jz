// NET_MULTIPLE_ACTIVE_DRIVERS: sel is not unique, 2 drivers at the same time
// Verifies

@project NET_MULTIPLE_ACTIVE_DRIVERS_PROJECT
  @top NET_MULTIPLE_ACTIVE_DRIVERS_EXAMPLE {
    IN  [1] sel = _;
    OUT [4] data = _;
  }
@endproj

@module NET_MULTIPLE_ACTIVE_DRIVERS_EXAMPLE
  PORT {
    IN  [1] sel;
    OUT [4] data;
  }

  @new n0 NET_MULTIPLE_ACTIVE_DRIVERS_NODE {
    IN  [1] addr = 1'b0;
    IN  [1] sel = sel;
    OUT [4] data = data;
  }

  @new n1 NET_MULTIPLE_ACTIVE_DRIVERS_NODE {
    IN  [1] addr = 1'b0;
    IN  [1] sel = sel;
    OUT [4] data = data;
  }

@endmod

@module NET_MULTIPLE_ACTIVE_DRIVERS_NODE
  PORT {
    IN  [1] addr;
    IN  [1] sel;
    OUT [4] data;
  }

  ASYNCHRONOUS {
    data <= sel == addr ? 4'b1 : 4'bz;
  }
@endmod
