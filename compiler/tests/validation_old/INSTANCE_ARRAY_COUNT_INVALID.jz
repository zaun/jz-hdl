// INSTANCE_ARRAY_COUNT_INVALID: count must be positive integer expression.
// Use undefined CONST in the count to trigger INSTANCE_ARRAY_COUNT_INVALID.

@project INSTANCE_ARRAY_COUNT_INVALID_PROJECT
  @top Top {
    IN  [1] clk = _;
    OUT [8] bus = _;
  }
@endproj

@module Child
  PORT {
    IN  [1] clk;
    OUT [8] y;
  }

  ASYNCHRONOUS {
    y = 8'hFF;
  }
@endmod

@module Top
  PORT {
    IN  [1] clk;
    OUT [8] bus;
  }

  // UNDEF_COUNT is not declared anywhere.
  @new u[UNDEF_COUNT] Child {
    IN  [1] clk = clk;
    OUT [8] y   = bus;
  }

  ASYNCHRONOUS {
    // no additional logic
  }
@endmod
