// BUS_WILDCARD_WIDTH_MISMATCH: wildcard RHS width must be 1 or array count.
// Verified

@project BUS_WILDCARD_WIDTH_MISMATCH_EXAMPLE
  BUS SIMPLE {
    INOUT [1] tkn;
  }

  @top top {
    OUT [1] out = _;
  }
@endproj

@module top
  PORT {
    OUT [1] out;
    BUS SIMPLE SOURCE [4] nodes;
  }

  WIRE {
    data [2];
  }

  ASYNCHRONOUS {
    data <= 2'b0;
    nodes[*].tkn = data; // width mismatch: 2 vs count 4
    out <= 1'b0;
  }
@endmod
