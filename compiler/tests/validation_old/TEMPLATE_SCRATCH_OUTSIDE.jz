// TEMPLATE_SCRATCH_OUTSIDE: @scratch outside template body.
// Expect ERR> TEMPLATE_SCRATCH_OUTSIDE

@project TEMPLATE_SCRATCH_OUTSIDE_PROJECT
  @top TEMPLATE_SCRATCH_OUTSIDE_MOD {
    IN  [8] in_a = _;
    OUT [8] out_a = _;
  }
@endproj

@module TEMPLATE_SCRATCH_OUTSIDE_MOD
  PORT {
    IN  [8] in_a;
    OUT [8] out_a;
  }

  ASYNCHRONOUS {
    @scratch t [8];
    out_a <= in_a;
  }
@endmod
