// MUX_AGG_SOURCE_WIDTH_MISMATCH: aggregation form sources must all have identical bit-width.
// Verified

@project MUX_AGG_SOURCES_PROJECT
  @top MUX_AGG_SOURCES_EXAMPLE {
    IN  [8] a = _;
    IN  [8] b = _;
    IN  [4] c = _;
    OUT [4] data = _;
  }
@endproj

@module MUX_AGG_SOURCES_EXAMPLE
  PORT {
    IN  [8] a;
    IN  [8] b;
    IN  [4] c;
    OUT [4] data;
  }

  MUX {
    // Mixed-width aggregation: a[8] and c[4].
    mixed_width_mux = a, c;

    valid_mux = a, b;
  }

  ASYNCHRONOUS {
    data = valid_mux[1];
  }
@endmod
