// MEM_INOUT_WDATA_IN_ASYNC: INOUT port .wdata may only be assigned in SYNCHRONOUS blocks.
// Verified

@project MEM_INOUT_WDATA_IN_ASYNC_PROJECT
  @top MEM_INOUT_WDATA_IN_ASYNC_EXAMPLE {
    IN  [8] write_data = _;
    OUT [1] data = _;
  }
@endproj

@module MEM_INOUT_WDATA_IN_ASYNC_EXAMPLE
  PORT {
    IN  [8] write_data;
    OUT [1] data;
  }

  MEM {
    single_port [8] [16] = 8'h00 {
      INOUT rw;
    };
  }

  ASYNCHRONOUS {
    // ERROR: .wdata can only be assigned in SYNCHRONOUS blocks
    single_port.rw.wdata <= write_data;
    data <= 1'b0;
  }
@endmod
