// MEM_WRITE_TO_READ_PORT: assignment writes to MEM IN (read) port; only OUT ports are writable.
// Verified

@project MEM_WRITE_TO_READ_PORT_PROJECT
  @top MEM_WRITE_TO_READ_PORT_EXAMPLE {
    IN  [1] clk = _;
    IN  [2] addr = _;
    IN  [8] data_in = _;
    OUT [8] data_out = _;
  }
@endproj

@module MEM_WRITE_TO_READ_PORT_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [2] addr;
    IN  [8] data_in;
    OUT [8] data_out;
  }

  MEM {
    // depth = 4 -> addr_width = ceil(log2(4)) = 2 bits.
    mem0 [8] [4] = 8'h00 {
      IN rd ASYNC;
    };
  }

  ASYNCHRONOUS {
    // Legal read from IN port.
    data_out = mem0.rd[addr];
  }

  SYNCHRONOUS(CLK=clk) {
    // Illegal: writing to IN (read) port.
    mem0.rd[addr] <= data_in;
  }
@endmod
