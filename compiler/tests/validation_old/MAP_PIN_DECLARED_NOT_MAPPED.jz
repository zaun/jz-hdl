// MAP_PIN_DECLARED_NOT_MAPPED: pin declared in PIN blocks but not fully mapped in MAP.
// Verified

@project MAP_PIN_DECLARED_NOT_MAPPED_PROJECT
  OUT_PINS {
    led[2] = { standard=LVCMOS33, drive=8 }; // led 0 and 1
    single = { standard=LVCMOS33, drive=8 };
  }

  MAP {
    // Only map bit 0 of led; bit 1 and single are unmapped.
    led[0] = 10;
  }

  @top MAP_PIN_DECLARED_NOT_MAPPED_EXAMPLE {
    OUT [1] data = _;
  }
@endproj

@module MAP_PIN_DECLARED_NOT_MAPPED_EXAMPLE
  PORT {
    OUT [1] data;
  }

  ASYNCHRONOUS {
    data <= 1'b1;
  }
@endmod
