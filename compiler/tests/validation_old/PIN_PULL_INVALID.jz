// PIN_PULL_INVALID: pull attribute with invalid value.
// Verified

@project PIN_PULL_INVALID_PROJECT
  IN_PINS {
    pin = { standard=LVCMOS33, pull=STRONG };
  }

  MAP {
    pin = 10;
  }

  @top PIN_PULL_INVALID_EXAMPLE {
    IN  [1] in = _;
    OUT [1] out = _;
  }
@endproj

@module PIN_PULL_INVALID_EXAMPLE
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod
