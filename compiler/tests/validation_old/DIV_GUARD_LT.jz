// DIV_GUARD_LT: IF (b < N) ELSE proves b nonzero when N >= 1 (ELSE: b >= N).
// Verified

@project DIV_GUARD_LT_PROJECT
  @top DIV_GUARD_LT_EXAMPLE {
    IN  [8] a = _;
    IN  [8] b = _;
    OUT [8] out_a = _;
    OUT [8] out_b = _;
  }
@endproj

@module DIV_GUARD_LT_EXAMPLE
  PORT {
    IN  [8] a;
    IN  [8] b;
    OUT [8] out_a;
    OUT [8] out_b;
  }

  ASYNCHRONOUS {
    // IF (b < 1) ELSE: b >= 1 → nonzero — should NOT warn
    IF (b < 8'd1) {
      out_a <= 8'd0;
    } ELSE {
      out_a <= a / b;
    }

    // IF (b < 5) ELSE: b >= 5 → nonzero — should NOT warn
    IF (b < 8'd5) {
      out_b <= 8'd0;
    } ELSE {
      out_b <= a % b;
    }
  }
@endmod
