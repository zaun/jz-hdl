// DIV_GUARD_NESTED_IF: guard in an outer IF protects inner nested division.
// Verified

@project DIV_GUARD_NESTED_IF_PROJECT
  @top DIV_GUARD_NESTED_IF_EXAMPLE {
    IN  [8] a = _;
    IN  [8] b = _;
    IN  [1] sel = _;
    OUT [8] out_a = _;
  }
@endproj

@module DIV_GUARD_NESTED_IF_EXAMPLE
  PORT {
    IN  [8] a;
    IN  [8] b;
    IN  [1] sel;
    OUT [8] out_a;
  }

  ASYNCHRONOUS {
    // Outer IF guards b, inner IF uses sel — division is safe
    IF (b != 8'd0) {
      IF (sel) {
        out_a <= a / b;
      } ELSE {
        out_a <= 8'd0;
      }
    } ELSE {
      out_a <= 8'd0;
    }
  }
@endmod
