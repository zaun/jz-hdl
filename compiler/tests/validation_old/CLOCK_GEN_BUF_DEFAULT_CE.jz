// CLOCK_GEN_BUF_DEFAULT_CE: Validate BUF generator without CE uses chip default (1'b1).
// The CE input is optional per chip JSON. Omitting it should not produce an error.

@project(CHIP="GW2AR-18-QN88-C8-I7") CLOCK_GEN_BUF_DEFAULT_CE_TEST
    CLOCKS {
        sys_clk = { period=37.04 };
        buffered_clk;
    }

    IN_PINS {
        sys_clk = { standard=LVCMOS33 };
    }

    OUT_PINS {
        led = { standard=LVCMOS33, drive=8 };
    }

    MAP {
        sys_clk = 4;
        led = 15;
    }

    CLOCK_GEN {
        BUF {
            IN REF_CLK sys_clk;
            OUT BASE buffered_clk;
        };
    }

    @top top {
        IN  [1] a = sys_clk;
        OUT [1] out = led;
    }
@endproj

@module top
    PORT {
        IN  [1] a;
        OUT [1] out;
    }

    ASYNCHRONOUS {
        out = a;
    }
@endmod
