// SYNC_EDGE_BOTH_WARNING: EDGE=Both warning for dual-edge clocking.
// Expect WRN> SYNC_EDGE_BOTH_WARNING

@project SYNC_EDGE_BOTH_WARNING_PROJECT
  @top SYNC_EDGE_BOTH_WARNING_EXAMPLE {
    IN  [1] clk = _;
    OUT [1] q = _;
  }
@endproj

@module SYNC_EDGE_BOTH_WARNING_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [1] q;
  }

  REGISTER {
    r [1] = 1'b0;
  }

  ASYNCHRONOUS {
    q = r;
  }

  SYNCHRONOUS(CLK=clk EDGE=Both) {
    r <= ~r;
  }
@endmod
