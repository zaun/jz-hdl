// MEM_WARN_PORT_NEVER_ACCESSED: MEM IN/OUT port declared but never used.
// Verified

@project MEM_WARN_PORT_NEVER_ACCESSED_PROJECT
  @top MEM_WARN_PORT_NEVER_ACCESSED_EXAMPLE {
    IN  [1] clk = _;
    OUT [8] out = _;
  }
@endproj

@module MEM_WARN_PORT_NEVER_ACCESSED_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [8] out;
  }

  MEM {
    m [8] [4] = 8'h00 {
      OUT rd ASYNC;
    };
  }

  ASYNCHRONOUS {
    out <= 8'b1;
  }

  SYNCHRONOUS(CLK=clk) {
  }
@endmod
