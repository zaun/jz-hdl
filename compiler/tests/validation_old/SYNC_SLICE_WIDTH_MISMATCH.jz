// SYNC_SLICE_WIDTH_MISMATCH: register slice assignment expression width not
// equal to slice width.
// Verified.

@project SYNC_SLICE_WIDTH_MISMATCH_PROJECT
  @top SYNC_SLICE_WIDTH_MISMATCH_EXAMPLE {
    IN  [1] clk = _;
    OUT [8] data = _;
  }
@endproj

@module SYNC_SLICE_WIDTH_MISMATCH_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [8] data;
  }

  REGISTER {
    r [8] = 8'h00;
  }

  ASYNCHRONOUS {
    data = r;
  }

  SYNCHRONOUS(CLK=clk) {
    // Slice width is 4, RHS width is 8.
    r[3:0] <= 8'hFF;
  }
@endmod
