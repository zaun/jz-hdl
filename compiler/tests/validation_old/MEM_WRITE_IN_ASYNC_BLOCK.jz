// MEM_WRITE_IN_ASYNC_BLOCK: OUT write port used in ASYNCHRONOUS block.
// Verified

@project MEM_WRITE_IN_ASYNC_BLOCK_PROJECT
  @top MEM_WRITE_IN_ASYNC_BLOCK_EXAMPLE {
    IN  [1] clk = _;
    IN  [4] addr = _;
    IN  [8] din = _;
    OUT [8] dout = _;
  }
@endproj

@module MEM_WRITE_IN_ASYNC_BLOCK_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [4] addr;
    IN  [8] din;
    OUT [8] dout;
  }

  REGISTER {
    r [8] = 8'h00;
  }

  MEM {
    mem0 [8] [16] = 8'h00 {
      OUT rd SYNC;
      IN wr;
    };
  }

  ASYNCHRONOUS {
    mem0.wr[addr] <= din; // Illegal: writes must be in SYNCHRONOUS block.
    dout = r;
  }

  SYNCHRONOUS(CLK=clk) {
    mem0.rd.addr <= addr;
    r <= mem0.rd.data;
  }
@endmod
