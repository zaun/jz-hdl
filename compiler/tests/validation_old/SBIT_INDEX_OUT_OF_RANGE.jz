// SBIT_INDEX_OUT_OF_RANGE: sbit() index exceeds source width.
// Verified

@project SBIT_INDEX_OUT_OF_RANGE_PROJECT
  @top SBIT_INDEX_OUT_OF_RANGE_EXAMPLE {
    IN  [4] a = _;
    OUT [4] out = _;
  }
@endproj

@module SBIT_INDEX_OUT_OF_RANGE_EXAMPLE
  PORT {
    IN  [4] a;
    OUT [4] out;
  }

  ASYNCHRONOUS {
    out <= sbit(a, 10, 1'b1);
  }
@endmod
