// MEM_MISSING_INIT: MEM declared without explicit init; tool may still zero-fill.
// Verified

@project MEM_MISSING_INIT_PROJECT
  @top MEM_MISSING_INIT_EXAMPLE {
    IN  [1] clk = _;
    IN  [4] addr = _;
    OUT [8] read_data = _;
  }
@endproj

@module MEM_MISSING_INIT_EXAMPLE
  PORT {
    IN  [4] addr;
    OUT [8] read_data;
  }

  MEM {
    mem0 [8] [16] {
      OUT rd ASYNC;
    };
  }

  ASYNCHRONOUS {
    read_data = mem0.rd[addr];
  }
@endmod
