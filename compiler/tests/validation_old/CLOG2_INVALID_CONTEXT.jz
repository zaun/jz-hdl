// CLOG2_INVALID_CONTEXT: clog2() used in a runtime expression context.
// Verified

@project CLOG2_INVALID_CONTEXT_PROJECT
  CLOCKS {
    clk = { period=10 };
  }

  IN_PINS {
    clk = { standard=LVCMOS33 };
  }

  MAP {
    clk = 4;
  }

  @top CLOG2_INVALID_CONTEXT_EXAMPLE {
    IN  [1] clk = clk;
    OUT [4] out = _;
  }
@endproj

@module CLOG2_INVALID_CONTEXT_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [4] out;
  }

  REGISTER {
    r [4] = 4'b0000;
  }

  ASYNCHRONOUS {
    out = r;
  }

  SYNCHRONOUS(CLK=clk) {
    r <= clog2(4);
  }
@endmod
