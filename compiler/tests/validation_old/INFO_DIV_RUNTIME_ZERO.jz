// INFO_DIV_RUNTIME_ZERO: divisor may be 0 at runtime (non-constant divisor).
// Verbose

@project INFO_DIV_RUNTIME_ZERO_PROJECT
  @top INFO_DIV_RUNTIME_ZERO_EXAMPLE  {
    IN  [8] a = _;
    IN  [8] b = _;
    OUT [8] out_a = _;
    OUT [8] out_b = _;
  }
@endproj

@module INFO_DIV_RUNTIME_ZERO_EXAMPLE
  PORT {
    IN  [8] a;
    IN  [8] b;
    OUT [8] out_a;
    OUT [8] out_b;
  }

  ASYNCHRONOUS {
    out_a = a / b;
    out_b = a % b;
  }
@endmod
