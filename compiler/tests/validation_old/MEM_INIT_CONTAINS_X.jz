// MEM_INIT_CONTAINS_X: memory initialization literal must not contain x bits.
// Verified

@project MEM_INIT_CONTAINS_X_PROJECT
  @top MEM_INIT_CONTAINS_X_EXAMPLE {
    IN  [2] addr = _;
    OUT [8] y = _;
  }
@endproj

@module MEM_INIT_CONTAINS_X_EXAMPLE
  PORT {
    IN  [2] addr;
    OUT [8] y;
  }

  MEM {
    m [8] [4] = 8'b10x1_0000 {
      OUT rd ASYNC;
    };
  }

  ASYNCHRONOUS {
    y = m.rd[addr];
  }
@endmod
