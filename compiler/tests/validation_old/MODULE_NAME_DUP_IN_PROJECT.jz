// MODULE_NAME_DUP_IN_PROJECT: duplicate module names in a single project.
// Verified

@project EXAMPLE_PROJECT
  @top NO_CONFLICT {
    IN  [1] clk = _;
    OUT [1] dout = _;
  }
@endproj

@module NO_CONFLICT
  PORT {
    IN  [1] clk;
    OUT [1] dout;
  }

  @new m CONFLICT {
    IN  [1] clk = clk;
    OUT [1] dout = dout;
  }
@endmod

@module CONFLICT
  PORT {
    IN  [1] clk;
    OUT [1] dout;
  }

  ASYNCHRONOUS {
    dout = clk;
  }
@endmod

@module CONFLICT
  PORT {
    IN  [1] clk;
    OUT [1] dout;
  }

  ASYNCHRONOUS {
    dout = clk;
  }
@endmod
