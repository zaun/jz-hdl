// FEATURE_DECL_BLOCKS: @feature guards in declaration blocks (WIRE, REGISTER).
// Declarations inside @feature guards should parse correctly and be visible
// to semantic analysis. Both branches are validated so all names must be valid.
// Verified

@project FEATURE_DECL_BLOCKS_PROJECT
  CONFIG {
    USE_WIDE = 1;
  }
  @top FEATURE_DECL_BLOCKS_TOP {
    IN  [1] clk = _;
    IN  [1] rst = _;
    IN  [8] a = _;
    OUT [8] out = _;
  }
@endproj

@module FEATURE_DECL_BLOCKS_TOP
  PORT {
    IN  [1] clk;
    IN  [1] rst;
    IN  [8] a;
    OUT [8] out;
  }

  WIRE {
    @feature CONFIG.USE_WIDE == 1
      wide_wire [8];
    @else
      narrow_wire [4];
    @endfeat
  }

  REGISTER {
    @feature CONFIG.USE_WIDE == 1
      wide_reg [8] = 8'h00;
    @else
      narrow_reg [4] = 4'h0;
    @endfeat
  }

  ASYNCHRONOUS {
    @feature CONFIG.USE_WIDE == 1
      wide_wire = a;
      out = wide_reg;
    @else
      narrow_wire = a[3:0];
      out = narrow_reg;
    @endfeat
  }

  SYNCHRONOUS(CLK=clk RESET=rst RESET_ACTIVE=Low) {
    @feature CONFIG.USE_WIDE == 1
      wide_reg <= wide_wire;
    @else
      narrow_reg <= narrow_wire;
    @endfeat
  }
@endmod
