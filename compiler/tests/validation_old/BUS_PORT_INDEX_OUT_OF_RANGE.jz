// BUS_PORT_INDEX_OUT_OF_RANGE: BUS array index outside valid range.
// Verified

@project BUS_PORT_INDEX_OUT_OF_RANGE_EXAMPLE
  BUS SIMPLE {
    IN [1] tx;
  }

  @top top {
    OUT [1] out = _;
    BUS SIMPLE SOURCE [2] link = _;
  }
@endproj

@module top
  PORT {
    OUT [1] out;
    BUS SIMPLE SOURCE [2] link;
  }

  ASYNCHRONOUS {
    out <= link[2].tx; // valid indices: 0..1
  }
@endmod
