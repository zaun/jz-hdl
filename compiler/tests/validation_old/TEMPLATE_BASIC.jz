// TEMPLATE_BASIC: Valid template definition and application.
// No template-specific errors expected.

@project TEMPLATE_BASIC_PROJECT
  @top TEMPLATE_BASIC_MOD {
    IN  [8] in_a = _;
    OUT [8] out_a = _;
  }
@endproj

@template PASS_THROUGH(src, dst)
  dst <= src;
@endtemplate

@module TEMPLATE_BASIC_MOD
  PORT {
    IN  [8] in_a;
    OUT [8] out_a;
  }

  ASYNCHRONOUS {
    @apply PASS_THROUGH(in_a, out_a);
  }
@endmod
