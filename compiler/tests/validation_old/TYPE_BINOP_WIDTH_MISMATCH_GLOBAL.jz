// TYPE_BINOP_WIDTH_MISMATCH_GLOBAL: comparison of signals with different widths
// via a global constant. rx_data is 3 bits but PROTO.MAGIC is 16 bits.
// Expect ERR> TYPE_BINOP_WIDTH_MISMATCH on the comparison.

@global PROTO
  MAGIC = 16'hA5A5;
@endglob

@project TYPE_BINOP_WIDTH_MISMATCH_GLOBAL_PROJECT
  @top TYPE_BINOP_WIDTH_MISMATCH_GLOBAL_MOD {
    IN  [3] rx = _;
    OUT [1] q  = _;
  }
@endproj

@module TYPE_BINOP_WIDTH_MISMATCH_GLOBAL_MOD
  PORT {
    IN  [3] rx;
    OUT [1] q;
  }

  ASYNCHRONOUS {
    q = (rx == PROTO.MAGIC);
  }
@endmod
