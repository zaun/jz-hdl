// GSLICE_INDEX_OUT_OF_RANGE: gslice() index exceeds source width.
// Verified

@project GSLICE_INDEX_OUT_OF_RANGE_PROJECT
  @top GSLICE_INDEX_OUT_OF_RANGE_EXAMPLE {
    IN  [8] a = _;
    OUT [8] out = _;
  }
@endproj

@module GSLICE_INDEX_OUT_OF_RANGE_EXAMPLE
  PORT {
    IN  [8] a;
    OUT [8] out;
  }

  ASYNCHRONOUS {
    out <= gslice(a, 20, 2);
  }
@endmod
