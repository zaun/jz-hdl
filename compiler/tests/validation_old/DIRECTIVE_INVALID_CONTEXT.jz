// DIRECTIVE_INVALID_CONTEXT: structural directives used in invalid locations.
// These examples are intentionally malformed and should eventually
// or early semantic passes.
// Verified

@project Test
    @top Top {
        OUT [1] out = _;
    };
@endproj

// 1. @project nested inside a module
@module Top
    CONST {
        X = 1;
    }

    PORT {
        OUT [1] out;
    }

    ASYNCHRONOUS {
        out <= 1'b0;
    }

    @new outer Outer {
        OUT [1] out = _;
    }

    @project NESTED_IN_MODULE
        CONFIG {
            WIDTH = 8;
        }
    @endproj
@endmod

// 2. @module nested inside another module body
@module Outer
    CONST {
        Y = 1;
    }

    PORT {
        OUT [1] out;
    }

    ASYNCHRONOUS {
        out <= 1'b0;
    }

    @module Inner
        CONST {
            Z = 1;
        }
    @endmod
@endmod

// 3. Extra @endmod with no matching @module
@endmod
