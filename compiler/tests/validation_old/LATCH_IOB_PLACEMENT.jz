@module iob_latch_mod
    PORT {
        IN  [1] enable;
        IN  [8] data_in;
        OUT [8] data_out;
    }

    LATCH {
        my_latch [8] D;
    }

    ASYNCHRONOUS {
        my_latch <= enable : data_in;
        data_out <= my_latch;
    }
@endmod

@project(CHIP="GW2AR-18-QN88-C8-I7") iob_test
    IN_PINS {
        EN  = { standard=LVCMOS33 };
        DIN[8] = { standard=LVCMOS33 };
    }

    OUT_PINS {
        DOUT[8] = { standard=LVCMOS33, drive=8 };
    }

    MAP {
        EN = 4;
        DIN[0] = 15;
        DIN[1] = 16;
        DIN[2] = 17;
        DIN[3] = 18;
        DIN[4] = 19;
        DIN[5] = 20;
        DIN[6] = 25;
        DIN[7] = 26;
        DOUT[0] = 27;
        DOUT[1] = 28;
        DOUT[2] = 29;
        DOUT[3] = 30;
        DOUT[4] = 31;
        DOUT[5] = 32;
        DOUT[6] = 33;
        DOUT[7] = 34;
    }

    @top iob_latch_mod {
        IN  [1] enable   = EN;
        IN  [8] data_in  = DIN;
        OUT [8] data_out = DOUT;
    }
@endproj
