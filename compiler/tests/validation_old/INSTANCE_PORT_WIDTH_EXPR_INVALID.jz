// INSTANCE_PORT_WIDTH_EXPR_INVALID: width expression in instance port list uses
// an undefined CONST/CONFIG or an otherwise invalid integer expression.
// Verified

@project INSTANCE_PORT_WIDTH_EXPR_INVALID_PROJECT
  CONFIG {
    GOOD_WIDTH = 4;
  }

  @top ParentExpr {
    OUT [1] data = _;
  }
@endproj

@module ChildForExpr
  PORT {
    OUT [4] a;
  }

  ASYNCHRONOUS {
    a <= 4'b1;
  }
@endmod

@module ParentExpr
  CONST {
    GOOD_WIDTH = 4;
  }

  PORT {
    OUT [1] data;
  }

  // BAD_WIDTH is neither a module CONST nor a project CONFIG entry.
  @new u ChildForExpr {
    OUT [BAD_WIDTH] a = _;
  }

  ASYNCHRONOUS {
    data <= 1'b1;
  }
@endmod
