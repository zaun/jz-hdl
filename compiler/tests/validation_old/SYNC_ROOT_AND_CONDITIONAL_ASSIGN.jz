// SYNC_ROOT_AND_CONDITIONAL_ASSIGN: root-level register assignment combined
// with nested conditional assignment to the same bits.
// Verified

@project SYNC_ROOT_AND_CONDITIONAL_ASSIGN_PROJECT
  @top SYNC_ROOT_AND_CONDITIONAL_ASSIGN_EXAMPLE {
    IN  [1] clk = _;
    OUT [4] data = _;
  }
@endproj

@module SYNC_ROOT_AND_CONDITIONAL_ASSIGN_EXAMPLE
  PORT {
    IN  [1] clk;
    OUT [4] data;
  }

  REGISTER {
    r [4] = 4'b0000;
  }

  ASYNCHRONOUS {
    data = r;
  }

  SYNCHRONOUS(CLK=clk) {
    r <= 4'b0001;
    IF (clk) {
      r <= 4'b0010;
    }
  }
@endmod
