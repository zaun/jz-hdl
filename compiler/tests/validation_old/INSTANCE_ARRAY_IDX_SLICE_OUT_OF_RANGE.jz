// INSTANCE_ARRAY_IDX_SLICE_OUT_OF_RANGE: IDX-dependent slice exceeds parent width.

@project INSTANCE_ARRAY_IDX_SLICE_OUT_OF_RANGE_PROJECT
  @top Top {
    IN  [1] clk = _;
    IN  [2] din = _;
    OUT [4] bus = _;
  }
@endproj

@module Child
  PORT {
    IN  [1] clk;
    IN  [2] d;
    OUT [2] y;
  }

  ASYNCHRONOUS {
    y <= d;
  }
@endmod

@module Top
  PORT {
    IN  [1] clk;
    IN  [2] din;
    OUT [4] bus;
  }

  // 4 instances, each maps 2 bits via IDX.
  // Worker 0 -> [1:0], Worker 1 -> [3:2], Worker 2 -> [5:4], Worker 3 -> [7:6]
  // But bus is only [4] wide, so Worker 2 (IDX=2) accesses bits 5:4 which is out of range.
  @new u[4] Child {
    IN  [1] clk = clk;
    IN  [2] d   = din;
    OUT [2] y   = bus[uadd(umul(IDX, 2), 1) : umul(IDX, 2)];
  }

  ASYNCHRONOUS {
    // no additional logic
  }
@endmod
