// FEATURE_NESTED: @feature guards may not be nested.
// The parser rejects this at parse time.
// Verified

@project FEATURE_NESTED_PROJECT
  CONFIG {
    ENABLE_A = 1;
    ENABLE_B = 1;
  }
  @top FEATURE_NESTED_EXAMPLE {
    IN  [8] a = _;
    OUT [8] out = _;
  }
@endproj

@module FEATURE_NESTED_EXAMPLE
  PORT {
    IN  [8] a;
    OUT [8] out;
  }

  ASYNCHRONOUS {
    @feature (CONFIG.ENABLE_A)
      @feature (CONFIG.ENABLE_B)
        out <= a;
      @endfeat
    @endfeat
  }
@endmod
