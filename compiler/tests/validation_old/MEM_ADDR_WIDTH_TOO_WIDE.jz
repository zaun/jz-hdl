// MEM_ADDR_WIDTH_TOO_WIDE: address expression width exceeds ceil(log2(depth)).
// Expect ERR> MEM_ADDR_WIDTH_TOO_WIDE on use of 'addr_wide'.

@project MEM_ADDR_WIDTH_TOO_WIDE_PROJECT
  @top MEM_ADDR_WIDTH_TOO_WIDE_EXAMPLE {
    IN  [1] clk = _;
    IN  [3] addr_wide = _;
    IN  [8] data_in = _;
    OUT [8] data_out = _;
  }
@endproj

@module MEM_ADDR_WIDTH_TOO_WIDE_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [3] addr_wide; // 3 bits
    IN  [8] data_in;
    OUT [8] data_out;
  }

  MEM {
    // depth = 4 -> addr_width = ceil(log2(4)) = 2 bits.
    mem0 [8] [4] = 8'h00 {
      OUT rd ASYNC;
      IN  wr;
    };
  }

  ASYNCHRONOUS {
    // addr_wide has width 3 > required 2.
    data_out = mem0.rd[addr_wide];
  }

  SYNCHRONOUS(CLK=clk) {
    mem0.wr[addr_wide] <= data_in;
  }
@endmod
