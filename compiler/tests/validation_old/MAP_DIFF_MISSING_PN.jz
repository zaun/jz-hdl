// MAP_DIFF_MISSING_PN: differential map with only P (no N).
// Verified

@project MAP_DIFF_MISSING_PN_PROJECT
  OUT_PINS {
    tmds = { mode=DIFFERENTIAL, standard=LVDS25, drive=4 };
  }

  MAP {
    tmds = { P=10 };
  }

  @top MAP_DIFF_MISSING_PN_EXAMPLE {
    IN  [1] in = _;
    OUT [1] out = _;
  }
@endproj

@module MAP_DIFF_MISSING_PN_EXAMPLE
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod
