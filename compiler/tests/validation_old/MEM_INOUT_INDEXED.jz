// MEM_INOUT_INDEXED: INOUT port may not be indexed; use .addr/.data/.wdata pseudo-fields.
// Verified

@project MEM_INOUT_INDEXED_PROJECT
  @top MEM_INOUT_INDEXED_EXAMPLE {
    IN  [1] clk = _;
    IN  [4] addr = _;
    OUT [8] data = _;
  }
@endproj

@module MEM_INOUT_INDEXED_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [4] addr;
    OUT [8] data;
  }

  MEM {
    // Single-port memory with INOUT
    single_port [8] [16] = 8'h00 {
      INOUT rw;
    };
  }

  SYNCHRONOUS(CLK=clk) {
    // ERROR: INOUT port cannot be indexed
    single_port.rw[addr] <= 8'hAA;
  }

  ASYNCHRONOUS {
    data <= 8'h00;
  }
@endmod
