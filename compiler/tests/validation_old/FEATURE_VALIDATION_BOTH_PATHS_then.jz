// FEATURE_VALIDATION_BOTH_PATHS: The THEN branch of a @feature guard
// must pass semantic validation even when the feature is disabled.
// Here the THEN branch references an undefined identifier.
// Verified

@project FEATURE_BOTH_PATHS_THEN_PROJECT
  CONFIG {
    ENABLE = 1;
  }
  @top FEATURE_BOTH_PATHS_THEN_EXAMPLE {
    IN  [8] a = _;
    OUT [8] out = _;
  }
@endproj

@module FEATURE_BOTH_PATHS_THEN_EXAMPLE
  PORT {
    IN  [8] a;
    OUT [8] out;
  }

  ASYNCHRONOUS {
    out <= a;
    @feature (CONFIG.ENABLE)
      out <= undefined_signal;
    @endfeat
  }
@endmod
