// BSWAP_WIDTH_NOT_BYTE_ALIGNED: bswap() source width must be a multiple of 8.
// Verified

@project BSWAP_WIDTH_NOT_BYTE_ALIGNED_PROJECT
  @top BSWAP_WIDTH_NOT_BYTE_ALIGNED_EXAMPLE {
    IN  [5] a = _;
    OUT [5] out = _;
  }
@endproj

@module BSWAP_WIDTH_NOT_BYTE_ALIGNED_EXAMPLE
  PORT {
    IN  [5] a;
    OUT [5] out;
  }

  ASYNCHRONOUS {
    out <= bswap(a);
  }
@endmod
