// CONFIG_IN_CONST_EXPR: CONFIG values flow through CONST intermediaries.
// Verified

@project CONFIG_IN_CONST_EXPR_PROJ
  CONFIG {
    DATA_WIDTH = 8;
    ADDR_WIDTH = 4;
  }

  @top top {
    OUT [CONFIG.DATA_WIDTH] data_out = _;
  }
@endproj

@module top
  CONST {
    WIDTH = CONFIG.DATA_WIDTH;
    HALF  = CONFIG.DATA_WIDTH / 2;
    TOTAL = CONFIG.DATA_WIDTH + CONFIG.ADDR_WIDTH;
  }

  PORT {
    OUT [WIDTH] data_out;
  }

  WIRE {
    half_data [HALF];
    combined  [TOTAL];
  }

  ASYNCHRONOUS {
    data_out  <= 8'h00;
    half_data <= 4'h0;
    combined  <= 12'h000;
  }
@endmod
