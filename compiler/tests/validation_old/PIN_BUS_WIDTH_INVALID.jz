// PIN_BUS_WIDTH_INVALID: bus pin width non-integer or <= 0.
// Verified

@project PIN_BUS_WIDTH_INVALID_PROJECT
  IN_PINS {
    btns[-1] = { standard=LVCMOS33 };
  }

  OUT_PINS {
    leds[0] = { standard=LVCMOS33, drive=8 };
  }

  MAP {
    leds[0] = 9;
    leds[1] = 10;
    btns[0] = 11;
    btns[1] = 12;
  }

  @top PIN_BUS_WIDTH_INVALID_EXAMPLE {
    IN  [1] in = _;
    OUT [1] out = _;
  }
@endproj

@module PIN_BUS_WIDTH_INVALID_EXAMPLE
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod
