// INSTANCE_NAME_CONFLICT: instance name clashes with another identifier in module.
// Verified

@project INSTANCE_NAME_CONFLICT_EXAMPLES
  CONFIG {
    WIDTH = 8;
  }

  @top Parent {
    IN  [1] in = _;
    OUT [1] out = _;
  }
@endproj

@module Child
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod

@module Parent
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  @new in Child {
    IN  [1] in = _;
    OUT [1] out = _;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod
