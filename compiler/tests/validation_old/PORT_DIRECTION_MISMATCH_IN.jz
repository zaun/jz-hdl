// PORT_DIRECTION_MISMATCH_IN: assigning to an IN port is forbidden.
// Verified

@project PORT_DIRECTION_MISMATCH_IN_PROJECT
  @top PORT_DIRECTION_MISMATCH_IN_EXAMPLE {
    IN  [1] in_a = _;
    IN  [1] in_b = _;
    OUT [1] out = _;
  }
@endproj

@module PORT_DIRECTION_MISMATCH_IN_EXAMPLE
  PORT {
    IN  [1] in_a;
    IN  [1] in_b;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out <= in_a;
    // Illegal: drive an IN-only port.
    in_a = in_b;
  }
@endmod
