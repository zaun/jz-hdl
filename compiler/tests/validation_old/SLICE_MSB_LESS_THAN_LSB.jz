// SLICE_MSB_LESS_THAN_LSB: slice uses MSB < LSB.
// Verifies

@project SLICE_MSB_LESS_THAN_LSB_PROJECT
  @top SLICE_MSB_LESS_THAN_LSB_EXAMPLE {
    IN  [8] bus = _;
    OUT [4] out = _;
  }
@endproj

@module SLICE_MSB_LESS_THAN_LSB_EXAMPLE
  PORT {
    IN  [8] bus;
    OUT [4] out;
  }

  ASYNCHRONOUS {
    out = bus[0:3];  // MSB (0) < LSB (3) -> invalid
  }
@endmod
