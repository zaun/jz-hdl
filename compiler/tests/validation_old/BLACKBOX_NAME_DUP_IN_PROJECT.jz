// BLACKBOX_NAME_DUP_IN_PROJECT: duplicate @blackbox names in a single project.
// Verified

@project BLACKBOX_NAME_DUP_IN_PROJECT_EXAMPLES
  @blackbox bb {
    PORT { OUT [1] b; }
  }

  @blackbox bb {
    PORT { OUT [1] b; }
  }

  @blackbox aa {
    PORT { OUT [1] a; }
  }

  @top top {
    IN  [1] in = _;
    OUT [1] out = _;
  }
@endproj

@module top
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  @new i_aa aa {
    OUT [1] a = _;
  }

  @new i_bb bb {
    OUT [1] b = _;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod

@module aa
  PORT {
    IN  [1] in;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = in;
  }
@endmod
