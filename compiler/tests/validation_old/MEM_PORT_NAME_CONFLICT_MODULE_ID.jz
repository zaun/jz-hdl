// MEM_PORT_NAME_CONFLICT_MODULE_ID: MEM port name conflicts with module-level identifier.
// Verified

@project MEM_PORT_NAME_CONFLICT_PROJECT
  @top MEM_PORT_NAME_CONFLICT_EXAMPLE {
    IN  [4] bus_addr = _;
    OUT [8] data = _;
  }
@endproj

@module MEM_PORT_NAME_CONFLICT_EXAMPLE
  PORT {
    IN  [4] bus_addr;
    OUT [8] data;
  }

  MEM {
    mem0 [8] [16] = 8'h00 {
      OUT rd ASYNC; // Conflicts with WIRE 'addr'.
      OUT bus_addr ASYNC; // Conflicts with WIRE 'bus_addr'.
    };
  }

  ASYNCHRONOUS {
    data = mem0.rd[bus_addr];
  }
@endmod
