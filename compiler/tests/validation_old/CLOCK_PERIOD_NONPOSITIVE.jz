// CLOCK_PERIOD_NONPOSITIVE: clock period <= 0 in CLOCKS block.
// Verified

@project CLOG2_INVALID_CONTEXT_PROJECT
  CLOCKS {
    clk_a = { period=0 };
    clk_b = { period=-1 };
  }

  IN_PINS {
    clk_a = { standard=LVCMOS33 };
    clk_b = { standard=LVCMOS33 };
  }

  MAP {
    clk_a = 4;
    clk_b = 5;
  }

  @top top {
    IN  [1] clk = clk_a;
    IN  [1] out = _;
  }
@endproj

@module top
  PORT {
    IN  [1] clk;
    OUT [1] out;
  }

  ASYNCHRONOUS {
    out = clk;
  }
@endmod
