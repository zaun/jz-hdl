// LATCH_INVALID_TYPE: LATCH type must be D or SR.
// The parser rejects invalid latch types at parse time.
// Verified

@project LATCH_INVALID_TYPE_PROJECT
  @top LATCH_INVALID_TYPE_EXAMPLE {
    IN  [1] a = _;
    OUT [1] out = _;
  }
@endproj

@module LATCH_INVALID_TYPE_EXAMPLE
  PORT {
    IN  [1] a;
    OUT [1] out;
  }

  LATCH {
    l [1] INVALID;
  }

  ASYNCHRONOUS {
    l <= a;
    out <= l;
  }
@endmod
