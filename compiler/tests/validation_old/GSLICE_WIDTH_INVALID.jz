// GSLICE_WIDTH_INVALID: gslice() width parameter is not a positive integer.
// Verified

@project GSLICE_WIDTH_INVALID_PROJECT
  @top GSLICE_WIDTH_INVALID_EXAMPLE {
    IN  [8] a = _;
    OUT [8] out = _;
  }
@endproj

@module GSLICE_WIDTH_INVALID_EXAMPLE
  PORT {
    IN  [8] a;
    OUT [8] out;
  }

  ASYNCHRONOUS {
    out <= gslice(a, 0, 0);
  }
@endmod
