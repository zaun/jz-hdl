// CONST_UNDEFINED_IN_WIDTH_OR_SLICE: width uses undefined CONST/CONFIG name.
// Verified

@project CONST_UNDEFINED_IN_WIDTH_OR_SLICE_PROJECT
  @top CONST_UNDEFINED_IN_WIDTH_OR_SLICE_EXAMPLE {
    OUT [1] data = _;
  }
@endproj

@module CONST_UNDEFINED_IN_WIDTH_OR_SLICE_EXAMPLE
  CONST {
    WIDTH=5;
  }

  PORT {
    OUT [UNDEFINED] data;
  }

  ASYNCHRONOUS {
    data <= 1'b1;
  }
@endmod
