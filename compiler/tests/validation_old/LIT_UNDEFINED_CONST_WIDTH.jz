// LIT_UNDEFINED_CONST_WIDTH: literal width uses undefined CONST/CONFIG name.
// Verified

@project LIT_UNDEFINED_CONST_WIDTH_EXAMPLE
  @top M_UNDEFINED_WIDTH {
    OUT [4] out = _;
  }
@endproj

@module M_UNDEFINED_WIDTH
  PORT {
    OUT [4] out;
  }

  ASYNCHRONOUS {
    // WIDTH is not declared as a CONST or CONFIG name anywhere
    out <= WIDTH'hFF;
  }
@endmod
