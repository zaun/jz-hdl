// MEM_INVALID_WRITE_MODE: WRITE_MODE not in [WRITE_FIRST|READ_FIRST|NO_CHANGE].
// Verfied

@project MEM_INVALID_WRITE_MODE_PROJECT
  @top MEM_INVALID_WRITE_MODE_EXAMPLE {
    IN  [1] clk = _;
    IN  [8] din = _;
    OUT [8] dout = _;
  }
@endproj

@module MEM_INVALID_WRITE_MODE_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [8] din;
    OUT [8] dout;
  }

  MEM {
    mem0 [8] [16] = 8'h00 {
      OUT rd SYNC;
      // Unknown WRITE_MODE value "FOO" should be rejected.
      IN  wr_bad {
        WRITE_MODE = FOO;
      };
    };
  }

  REGISTER {
    r [8] = 8'h00;
  }

  ASYNCHRONOUS {
    dout = r;
  }

  SYNCHRONOUS(CLK=clk) {
    mem0.rd.addr <= 4'd1;
    r <= mem0.rd.data;
    mem0.wr_bad[1] <= din;
  }
@endmod
