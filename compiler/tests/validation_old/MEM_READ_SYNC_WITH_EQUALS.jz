// MEM_READ_SYNC_WITH_EQUALS: synchronous read used with '=' instead of '<=' in SYNCHRONOUS block.
// Verified

@project MEM_READ_SYNC_WITH_EQUALS_PROJECT
  @top MEM_READ_SYNC_WITH_EQUALS_EXAMPLE {
    IN  [1] clk = _;
    IN  [4] addr = _;
    OUT [8] read_data = _;
  }
@endproj

@module MEM_READ_SYNC_WITH_EQUALS_EXAMPLE
  PORT {
    IN  [1] clk;
    IN  [4] addr;
    OUT [8] read_data;
  }

  MEM {
    mem0 [8] [16] = 8'h00 {
      OUT rd SYNC;
    };
  }

  SYNCHRONOUS(CLK=clk) {
    // SYNC read address must use '<=' but this uses '='.
    mem0.rd.addr = addr;
    read_data = mem0.rd.data;
  }
@endmod
