// BUS_PORT_INDEX_REQUIRED: arrayed BUS access requires index or wildcard.
// Verified

@project BUS_PORT_INDEX_REQUIRED_EXAMPLE
  BUS SIMPLE {
    IN [1] tx;
  }

  @top top {
    OUT [1] out = _;
    BUS SIMPLE SOURCE [2] link = _;
  }
@endproj

@module top
  PORT {
    OUT [1] out;
    BUS SIMPLE SOURCE [2] link;
  }

  ASYNCHRONOUS {
    out = link.tx; // missing [index]
  }
@endmod
