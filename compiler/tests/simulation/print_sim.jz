// Test @print and @print_if in simulation context.

@module counter
    PORT {
        IN  [1] clk;
        IN  [1] rst_n;
        OUT [8] count;
    }

    REGISTER {
        cnt [8] = 8'h00;
    }

    ASYNCHRONOUS {
        count <= cnt;
    }

    SYNCHRONOUS(CLK=clk RESET=rst_n RESET_ACTIVE=Low) {
        cnt <= cnt + 8'h01;
    }
@endmod

@simulation counter
    CLOCK {
        clk = { period=10.0 };
    }

    WIRE {
        rst_n [1];
        count [8];
    }

    @new dut counter {
        clk  [1] = clk;
        rst_n [1] = rst_n;
        count [8] = count;
    }

    @setup {
        rst_n <= 1'b0;
    }

    @print("Initial state: count=%h", count)

    @run(ns=20)

    @update {
        rst_n <= 1'b1;
    }

    @run(ns=100)

    @print("After 100ns: count=%d (hex=%h)", count, count)
    @print("Time: %ms ms, ticks: %tick")
    @print_if(count == 8'h00, "This should not print")
    @print_if(count != 8'h00, "Count is non-zero: %h", count)
@endsim
