// Basic simulation test: 8-bit counter with synchronous reset.
//
// Verifies:
//   - Clock auto-toggling at the declared period
//   - @setup sets initial wire values
//   - @run advances time with clock edges firing synchronous logic
//   - @update changes wire values mid-simulation
//   - VCD output is produced

@module counter
    PORT {
        IN  [1] clk;
        IN  [1] rst_n;
        OUT [8] count;
    }

    REGISTER {
        cnt [8] = 8'h00;
    }

    ASYNCHRONOUS {
        count <= cnt;
    }

    SYNCHRONOUS(CLK=clk RESET=rst_n RESET_ACTIVE=Low) {
        cnt <= cnt + 8'h01;
    }
@endmod

@simulation counter
    CLOCK {
        clk = { period=10.0 };
    }

    WIRE {
        rst_n [1];
        count [8];
    }

    @new dut counter {
        clk  [1] = clk;
        rst_n [1] = rst_n;
        count [8] = count;
    }

    // Hold reset low for 50 ns (5 clock cycles)
    @setup {
        rst_n <= 1'b0;
    }

    @run(ns=50)

    // Release reset
    @update {
        rst_n <= 1'b1;
    }

    // Run for 100 ns (10 clock cycles) — counter should increment
    @run(ns=100)
@endsim
