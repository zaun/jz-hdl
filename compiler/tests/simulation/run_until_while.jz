// Test @run_until and @run_while directives in simulation context.

@module counter
    PORT {
        IN  [1] clk;
        IN  [1] rst_n;
        OUT [8] count;
    }

    REGISTER {
        cnt [8] = 8'h00;
    }

    ASYNCHRONOUS {
        count <= cnt;
    }

    SYNCHRONOUS(CLK=clk RESET=rst_n RESET_ACTIVE=Low) {
        cnt <= cnt + 8'h01;
    }
@endmod

@simulation counter
    CLOCK {
        clk = { period=10.0 };
    }

    WIRE {
        rst_n [1];
        count [8];
    }

    @new dut counter {
        clk  [1] = clk;
        rst_n [1] = rst_n;
        count [8] = count;
    }

    @setup {
        rst_n <= 1'b0;
    }

    // Hold reset for 20ns
    @run(ns=20)

    // Release reset
    @update {
        rst_n <= 1'b1;
    }

    // Run until counter reaches 5
    @run_until(count == 8'h05, timeout=ns=1000)

    // Run while counter is not equal to 10
    @run_while(count != 8'h0A, timeout=ns=1000)
@endsim
