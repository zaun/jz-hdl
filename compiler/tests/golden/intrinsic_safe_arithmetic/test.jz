// ============================================================================
// TEST: INTRINSIC SAFE ARITHMETIC (usub, ssub, abs)
// VERIFIES: Sections 5.5.17–5.5.19
//   - usub/ssub: result width = max(w_a, w_b) + 1
//   - abs: result width = width(a) + 1
// ============================================================================

@project(CHIP="GW2AR-18-QN88-C8-I7") SafeArithTest
    CLOCKS {
        SCLK = { period=10.0 };
    }

    IN_PINS {
        SCLK    = { standard=LVCMOS33 };
        DONE    = { standard=LVCMOS33 };
        a[8]    = { standard=LVCMOS33 };
        b[8]    = { standard=LVCMOS33 };
    }

    OUT_PINS {
        udiff[9] = { standard=LVCMOS33, drive=8 };
        sdiff[9] = { standard=LVCMOS33, drive=8 };
        absv[9]  = { standard=LVCMOS33, drive=8 };
    }

    MAP {
        SCLK = 4;
        DONE = IOR32B;
        a[0] = 10; a[1] = 11; a[2] = 12; a[3] = 13;
        a[4] = 14; a[5] = 15; a[6] = 16; a[7] = 17;
        b[0] = 20; b[1] = 21; b[2] = 22; b[3] = 23;
        b[4] = 24; b[5] = 25; b[6] = 26; b[7] = 27;
        udiff[0] = 30; udiff[1] = 31; udiff[2] = 32; udiff[3] = 33;
        udiff[4] = 34; udiff[5] = 35; udiff[6] = 36; udiff[7] = 37;
        udiff[8] = 38;
        sdiff[0] = 39; sdiff[1] = 40; sdiff[2] = 41; sdiff[3] = 42;
        sdiff[4] = 43; sdiff[5] = 44; sdiff[6] = 45; sdiff[7] = 46;
        sdiff[8] = 47;
        absv[0] = 48; absv[1] = 49; absv[2] = 50; absv[3] = 51;
        absv[4] = 52; absv[5] = 53; absv[6] = 54; absv[7] = 55;
        absv[8] = 56;
    }

    @top SafeArithCore {
        IN  [1] clk   = SCLK;
        IN  [1] rst_n = DONE;
        IN  [8] a     = a;
        IN  [8] b     = b;
        OUT [9] udiff = udiff;
        OUT [9] sdiff = sdiff;
        OUT [9] absv  = absv;
    }
@endproj

@module SafeArithCore
    PORT {
        IN  [1] clk;
        IN  [1] rst_n;
        IN  [8] a;
        IN  [8] b;
        OUT [9] udiff;
        OUT [9] sdiff;
        OUT [9] absv;
    }

    ASYNCHRONOUS {
        udiff <= usub(a, b);
        sdiff <= ssub(a, b);
        absv  <= abs(a);
    }
@endmod
