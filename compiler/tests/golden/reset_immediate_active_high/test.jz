@project reset_immediate_active_high_test
  @top reset_imm_hi {
    IN  [1] clk = _;
    IN  [1] rst = _;
    IN  [1] en = _;
    IN  [8] d_in = _;
    OUT [8] q = _;
  }
@endproj

@module reset_imm_hi
  PORT {
    IN  [1] clk;
    IN  [1] rst;
    IN  [1] en;
    IN  [8] d_in;
    OUT [8] q;
  }

  REGISTER {
    reg_a [8] = 8'h00;
  }

  ASYNCHRONOUS {
    q = reg_a;
  }

  SYNCHRONOUS(
    CLK=clk
    EDGE=Rising
    RESET=rst
    RESET_ACTIVE=High
    RESET_TYPE=Immediate
  ) {
    IF (en) {
      reg_a <= d_in;
    }
  }
@endmod
