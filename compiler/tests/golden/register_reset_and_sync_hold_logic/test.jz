@project(CHIP=GW2AR-18) register_reset_hold_test
  CLOCKS {
    sys_clk = { period=10.0, edge=Rising };
  }

  IN_PINS {
    sys_clk = { standard=LVCMOS33 };
    sys_rst = { standard=LVCMOS33 };
    update_en = { standard=LVCMOS33 };
    data_in[8] = { standard=LVCMOS33 };
  }

  OUT_PINS {
    imm_out[8] = { standard=LVCMOS18, drive=8 };
    clk_out[8] = { standard=LVCMOS18, drive=8 };
  }

  MAP {
    sys_clk = 52;
    sys_rst = 53;
    update_en = 54;
    data_in[0] = 1;
    data_in[1] = 2;
    data_in[2] = 3;
    data_in[3] = 4;
    data_in[4] = 5;
    data_in[5] = 6;
    data_in[6] = 7;
    data_in[7] = 8;
    imm_out[0] = 10;
    imm_out[1] = 11;
    imm_out[2] = 12;
    imm_out[3] = 13;
    imm_out[4] = 14;
    imm_out[5] = 15;
    imm_out[6] = 16;
    imm_out[7] = 17;
    clk_out[0] = 20;
    clk_out[1] = 21;
    clk_out[2] = 22;
    clk_out[3] = 23;
    clk_out[4] = 24;
    clk_out[5] = 25;
    clk_out[6] = 26;
    clk_out[7] = 27;
  }

  @top register_test_module {
    IN  [1] clk1 = sys_clk;
    IN  [1] clk2 = sys_clk;
    IN  [1] clk3 = sys_clk;
    IN  [1] clk4 = sys_clk;
    IN  [1] rst = sys_rst;
    IN  [1] en  = update_en;
    IN  [8] d_in = data_in;
    OUT [8] q_imm = imm_out;
    OUT [8] q_clk = clk_out;
  }
@endproj

@module register_test_module
  PORT {
    IN  [1] clk1;
    IN  [1] clk2;
    IN  [1] clk3;
    IN  [1] clk4;
    IN  [1] rst;
    IN  [1] en;
    IN  [8] d_in;
    OUT [8] q_imm;
    OUT [8] q_clk;
  }

  REGISTER {
    // Both registers reset to 0
    reg_immediate [8] = 8'h00;
    reg_clocked   [8] = 8'h00;
    reg_low       [8] = 8'h00;
    reg_falling   [8] = 8'h00;
  }

  ASYNCHRONOUS {
    q_imm = reg_immediate;
    q_clk = reg_clocked;
  }

  // Test 1: Immediate Reset
  // Reset forces reg_immediate to 8'h00 combinationally
  SYNCHRONOUS(
    CLK=clk1
    EDGE=Rising
    RESET=rst
    RESET_ACTIVE=High
    RESET_TYPE=Immediate
  ) {
    IF (en) {
      reg_immediate <= d_in;
    }
    // No ELSE block: when en is low, reg_immediate holds its value.
    // Hold logic must coexist with Immediate reset priority.
  }

  // Test 2: Clocked Reset active High
  // Reset forces reg_clocked to 8'h00 only at the rising edge of clk
  SYNCHRONOUS(
    CLK=clk2
    EDGE=Rising
    RESET=rst
    RESET_ACTIVE=High
    RESET_TYPE=Clocked
  ) {
    IF (en) {
      reg_clocked <= d_in;
    } ELSE {
      // Explicitly checking that the register holds its value when not enabled
      // The compiler handles this implicitly, but having an empty ELSE or
      // omitting it is the primary way to test "Sync Hold".
    }
  }

  // Test 3: Clocked Reset active Low
  // Reset forces reg_low to 8'h00 only at the rising edge of clk
  SYNCHRONOUS(
    CLK=clk3
    EDGE=Rising
    RESET=rst
    RESET_ACTIVE=Low
    RESET_TYPE=Clocked
  ) {
    IF (en) {
      reg_low <= d_in;
    } ELSE {
      // Explicitly checking that the register holds its value when not enabled
      // The compiler handles this implicitly, but having an empty ELSE or
      // omitting it is the primary way to test "Sync Hold".
    }
  }

  // Test 3: Clocked Reset active Low Falling
  // Reset forces reg_falling to 8'h00 only at the falling edge of clk
  SYNCHRONOUS(
    CLK=clk4
    EDGE=Falling
    RESET=rst
    RESET_ACTIVE=Low
    RESET_TYPE=Clocked
  ) {
    IF (en) {
      reg_falling <= d_in;
    } ELSE {
      // Explicitly checking that the register holds its value when not enabled
      // The compiler handles this implicitly, but having an empty ELSE or
      // omitting it is the primary way to test "Sync Hold".
    }
  }
@endmod
