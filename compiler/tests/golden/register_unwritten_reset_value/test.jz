@project(CHIP=GW2AR-18) unwritten_reg_reset_test
  CLOCKS {
    sys_clk = { period=10.0, edge=Rising };
  }

  IN_PINS {
    sys_clk = { standard=LVCMOS33 };
    sys_rst = { standard=LVCMOS33 };
    data_in[8] = { standard=LVCMOS33 };
  }

  OUT_PINS {
    result[8] = { standard=LVCMOS18, drive=8 };
  }

  MAP {
    sys_clk = 52;
    sys_rst = 53;
    data_in[0] = 1;
    data_in[1] = 2;
    data_in[2] = 3;
    data_in[3] = 4;
    data_in[4] = 5;
    data_in[5] = 6;
    data_in[6] = 7;
    data_in[7] = 8;
    result[0] = 10;
    result[1] = 11;
    result[2] = 12;
    result[3] = 13;
    result[4] = 14;
    result[5] = 15;
    result[6] = 16;
    result[7] = 17;
  }

  @top unwritten_reg_test_module {
    IN  [1] clk = sys_clk;
    IN  [1] rst_n = sys_rst;
    IN  [8] d_in = data_in;
    OUT [8] q = result;
  }
@endproj

@module unwritten_reg_test_module
  PORT {
    IN  [1] clk;
    IN  [1] rst_n;
    IN  [8] d_in;
    OUT [8] q;
  }

  WIRE {
    scaled [16];
  }

  REGISTER {
    // Written register: normal case
    data [8] = 8'h00;

    // Unwritten register with non-zero reset value.
    // This register is only read (never assigned in SYNCHRONOUS)
    // but must still be reset to its declared value.
    factor [8] = 8'hAB;
  }

  ASYNCHRONOUS {
    scaled = d_in * factor;
    q = scaled[15:8];
  }

  SYNCHRONOUS(CLK=clk RESET=rst_n RESET_ACTIVE=Low) {
    data <= d_in;
  }
@endmod
