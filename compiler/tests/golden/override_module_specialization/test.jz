// =============================================================================
// TEST: OVERRIDE Block Specialization
// Purpose: Verify that OVERRIDE blocks correctly specialize child modules
//          using three patterns: literal values, parent CONST references,
//          and CONFIG references. Each produces a distinct specialization
//          with different widths in the generated Verilog.
// =============================================================================

@project(CHIP=GENERIC) override_specialization_test

    CONFIG {
        DATA_WIDTH = 12;
        MEM_DEPTH  = 6;
    }

    CLOCKS {
    }

    IN_PINS {
        d_in[16] = { standard=LVCMOS33 };
    }

    OUT_PINS {
        out_a[16] = { standard=LVCMOS33, drive=8 };
        out_b[10] = { standard=LVCMOS33, drive=8 };
        out_c[CONFIG.DATA_WIDTH] = { standard=LVCMOS33, drive=8 };
    }

    MAP {
        d_in[0] = 2; d_in[1] = 3; d_in[2] = 4; d_in[3] = 5;
        d_in[4] = 6; d_in[5] = 7; d_in[6] = 8; d_in[7] = 9;
        d_in[8] = 10; d_in[9] = 11; d_in[10] = 12; d_in[11] = 13;
        d_in[12] = 14; d_in[13] = 15; d_in[14] = 16; d_in[15] = 17;

        out_a[0] = 20; out_a[1] = 21; out_a[2] = 22; out_a[3] = 23;
        out_a[4] = 24; out_a[5] = 25; out_a[6] = 26; out_a[7] = 27;
        out_a[8] = 28; out_a[9] = 29; out_a[10] = 30; out_a[11] = 31;
        out_a[12] = 32; out_a[13] = 33; out_a[14] = 34; out_a[15] = 35;

        out_b[0] = 40; out_b[1] = 41; out_b[2] = 42; out_b[3] = 43;
        out_b[4] = 44; out_b[5] = 45; out_b[6] = 46; out_b[7] = 47;
        out_b[8] = 48; out_b[9] = 49;

        out_c[0] = 60; out_c[1] = 61; out_c[2] = 62; out_c[3] = 63;
        out_c[4] = 64; out_c[5] = 65; out_c[6] = 66; out_c[7] = 67;
        out_c[8] = 68; out_c[9] = 69; out_c[10] = 70; out_c[11] = 71;
    }

    @top override_test {
        IN  [16] d_in   = d_in;
        OUT [16] out_a  = out_a;
        OUT [10] out_b  = out_b;
        OUT [12] out_c  = out_c;
    }

@endproj

// =============================================================================
// Child module: configurable_unit
// Has default CONST values that can be overridden by the parent.
// =============================================================================
@module configurable_unit
    CONST {
        WIDTH = 8;
        DEPTH = 4;
    }

    PORT {
        IN  [WIDTH] data_in;
        OUT [WIDTH] data_out;
    }

    WIRE {
        masked [WIDTH];
    }

    ASYNCHRONOUS {
        masked <= data_in;
        data_out = masked;
    }
@endmod

// =============================================================================
// Parent module: override_test
// Instantiates configurable_unit three times with different OVERRIDE patterns.
// Each produces a distinct specialization with different widths.
// =============================================================================
@module override_test
    CONST {
        MY_WIDTH = 10;
        MY_DEPTH = 5;
    }

    PORT {
        IN  [16] d_in;
        OUT [16] out_a;
        OUT [10] out_b;
        OUT [12] out_c;
    }

    // Pattern 1: OVERRIDE with literal values (WIDTH=16)
    @new inst_literal configurable_unit {
        OVERRIDE {
            WIDTH = 16;
            DEPTH = 8;
        }
        IN  [16] data_in  = d_in;
        OUT [16] data_out = out_a;
    }

    // Pattern 2: OVERRIDE with parent CONST references (WIDTH=10)
    @new inst_const configurable_unit {
        OVERRIDE {
            WIDTH = MY_WIDTH;
            DEPTH = MY_DEPTH;
        }
        IN  [10] data_in  = d_in[9:0];
        OUT [10] data_out = out_b;
    }

    // Pattern 3: OVERRIDE with CONFIG references (WIDTH=12)
    @new inst_config configurable_unit {
        OVERRIDE {
            WIDTH = CONFIG.DATA_WIDTH;
            DEPTH = CONFIG.MEM_DEPTH;
        }
        IN  [12] data_in  = d_in[11:0];
        OUT [12] data_out = out_c;
    }

    ASYNCHRONOUS {
    }
@endmod
