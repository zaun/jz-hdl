// ============================================================================
// TEST: INTRINSICS WITH CONCATENATION SOURCE EXPRESSIONS
// VERIFIES: Verilog emission uses shift-and-mask (not bit-select) so that
//           intrinsics applied to concatenation expressions produce valid
//           Verilog (bit-select on concatenations is a syntax error).
// ============================================================================

@project(CHIP="GW2AR-18-QN88-C8-I7") IntrinsicConcatTest
    CLOCKS {
        SCLK = { period=10.0 };
    }

    IN_PINS {
        SCLK     = { standard=LVCMOS33 };
        DONE     = { standard=LVCMOS33 };
        a[4]     = { standard=LVCMOS33 };
        b[4]     = { standard=LVCMOS33 };
        c[8]     = { standard=LVCMOS33 };
        d[8]     = { standard=LVCMOS33 };
    }

    OUT_PINS {
        pop_out[4]    = { standard=LVCMOS33, drive=8 };
        rev_out[8]    = { standard=LVCMOS33, drive=8 };
        swap_out[16]  = { standard=LVCMOS33, drive=8 };
        prienc_out[3] = { standard=LVCMOS33, drive=8 };
        lzc_out[4]    = { standard=LVCMOS33, drive=8 };
        abs_out[9]    = { standard=LVCMOS33, drive=8 };
        rand_out[1]   = { standard=LVCMOS33, drive=8 };
        ror_out[1]    = { standard=LVCMOS33, drive=8 };
        rxor_out[1]   = { standard=LVCMOS33, drive=8 };
        oh2b_out[3]   = { standard=LVCMOS33, drive=8 };
        b2oh_out[8]   = { standard=LVCMOS33, drive=8 };
        gbit_out[1]   = { standard=LVCMOS33, drive=8 };
        gslice_out[4] = { standard=LVCMOS33, drive=8 };
    }

    MAP {
        SCLK = 4;
        DONE = IOR32B;
        a[0] = 10; a[1] = 11; a[2] = 12; a[3] = 13;
        b[0] = 14; b[1] = 15; b[2] = 16; b[3] = 17;
        c[0] = 25; c[1] = 26; c[2] = 27; c[3] = 28;
        c[4] = 29; c[5] = 30; c[6] = 31; c[7] = 32;
        d[0] = 33; d[1] = 34; d[2] = 35; d[3] = 36;
        d[4] = 37; d[5] = 38; d[6] = 39; d[7] = 40;
        pop_out[0] = 41; pop_out[1] = 42; pop_out[2] = 43; pop_out[3] = 44;
        rev_out[0] = 45; rev_out[1] = 46; rev_out[2] = 47; rev_out[3] = 48;
        rev_out[4] = 49; rev_out[5] = 50; rev_out[6] = 51; rev_out[7] = 52;
        swap_out[0] = 53; swap_out[1] = 54; swap_out[2] = 55; swap_out[3] = 56;
        swap_out[4] = 57; swap_out[5] = 58; swap_out[6] = 59; swap_out[7] = 60;
        swap_out[8] = 61; swap_out[9] = 62; swap_out[10] = 63; swap_out[11] = 64;
        swap_out[12] = 65; swap_out[13] = 66; swap_out[14] = 67; swap_out[15] = 68;
        prienc_out[0] = 69; prienc_out[1] = 70; prienc_out[2] = 71;
        lzc_out[0] = 72; lzc_out[1] = 73; lzc_out[2] = 74; lzc_out[3] = 75;
        abs_out[0] = 76; abs_out[1] = 77; abs_out[2] = 78; abs_out[3] = 79;
        abs_out[4] = 80; abs_out[5] = 81; abs_out[6] = 82; abs_out[7] = 83;
        abs_out[8] = 84;
        rand_out = 85;
        ror_out = 86;
        rxor_out = 18;
        oh2b_out[0] = 19; oh2b_out[1] = 20; oh2b_out[2] = 21;
        b2oh_out[0] = 22; b2oh_out[1] = 23; b2oh_out[2] = 24;
        b2oh_out[3] = IOL7A; b2oh_out[4] = IOL14A; b2oh_out[5] = IOL14B;
        b2oh_out[6] = IOR30A; b2oh_out[7] = IOR30B;
        gbit_out = IOR29A;
        gslice_out[0] = IOR29B; gslice_out[1] = IOR28A;
        gslice_out[2] = IOR28B; gslice_out[3] = IOR27A;
    }

    @top IntrinsicConcatCore {
        IN  [1]  clk        = SCLK;
        IN  [1]  rst_n      = DONE;
        IN  [4]  a          = a;
        IN  [4]  b          = b;
        IN  [8]  c          = c;
        IN  [8]  d          = d;
        OUT [4]  pop_out    = pop_out;
        OUT [8]  rev_out    = rev_out;
        OUT [16] swap_out   = swap_out;
        OUT [3]  prienc_out = prienc_out;
        OUT [4]  lzc_out    = lzc_out;
        OUT [9]  abs_out    = abs_out;
        OUT [1]  rand_out   = rand_out;
        OUT [1]  ror_out    = ror_out;
        OUT [1]  rxor_out   = rxor_out;
        OUT [3]  oh2b_out   = oh2b_out;
        OUT [8]  b2oh_out   = b2oh_out;
        OUT [1]  gbit_out   = gbit_out;
        OUT [4]  gslice_out = gslice_out;
    }
@endproj

@module IntrinsicConcatCore
    PORT {
        IN  [1]  clk;
        IN  [1]  rst_n;
        IN  [4]  a;
        IN  [4]  b;
        IN  [8]  c;
        IN  [8]  d;
        OUT [4]  pop_out;
        OUT [8]  rev_out;
        OUT [16] swap_out;
        OUT [3]  prienc_out;
        OUT [4]  lzc_out;
        OUT [9]  abs_out;
        OUT [1]  rand_out;
        OUT [1]  ror_out;
        OUT [1]  rxor_out;
        OUT [3]  oh2b_out;
        OUT [8]  b2oh_out;
        OUT [1]  gbit_out;
        OUT [4]  gslice_out;
    }

    ASYNCHRONOUS {
        // All intrinsics applied to concatenation expressions {a, b} or {c, d}
        pop_out    <= popcount({a, b});
        rev_out    <= reverse({a, b});
        swap_out   <= bswap({c, d});
        prienc_out <= prienc({a, b});
        lzc_out    <= lzc({a, b});
        abs_out    <= abs({a, b});
        rand_out   <= reduce_and({a, b});
        ror_out    <= reduce_or({a, b});
        rxor_out   <= reduce_xor({a, b});
        oh2b_out   <= oh2b({a, b});
        b2oh_out   <= b2oh(a);
        gbit_out   <= gbit({a, b}, a);
        gslice_out <= gslice({c, d}, a);
    }
@endmod
